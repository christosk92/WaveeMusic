# Proprietary/Licensed code - cannot be open sourced
Wavee/Core/Crypto/AudioDecryptStream.cs

# PlayPlay native dependencies — third-party binaries we MUST NOT commit.
# Spotify.dll is Spotify's IP (copyright); unicorn.dll is GPLv2-licensed and
# is built per-machine via scripts/build-unicorn.ps1. Devs drop their own
# copy of each at the documented paths; see Wavee.PlayPlay/README.md for
# the exact pinned Spotify version (v1.2.88.483 x86_64).
Wavee.PlayPlay.Host/native/Spotify.dll
Wavee.PlayPlay.Host/native/win-x64/unicorn.dll
.unicorn-build/

