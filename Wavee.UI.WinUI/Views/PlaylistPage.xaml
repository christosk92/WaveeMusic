<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.PlaylistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tdg="using:Wavee.UI.WinUI.Controls.TrackDataGrid"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:controls1="using:Wavee.UI.WinUI.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">
    <Grid x:Name="RootGrid" SizeChanged="RootGrid_SizeChanged">
        <!-- Responsive: driven by SizeChanged in code-behind. Loading is bound to
             IsLoading (metadata) for the left panel; the TrackListView has its own
             IsLoadingTracks-driven shimmer because playlist tracks lazy-load
             independently of the metadata. -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState"/>
                <VisualState x:Name="NarrowState">
                    <VisualState.Setters>
                        <!-- NarrowPlaylistHeader.Visibility setters removed: no element
                             with that x:Name exists in this page anymore, so the setter
                             threw XamlUnhandledException on every SizeChanged that flipped
                             between Wide/Narrow. If a narrow-mode header is reintroduced
                             later, re-add matching setters referencing the real name. -->
                        <Setter Target="WidePlaylistPanel.Visibility" Value="Collapsed"/>
                        <Setter Target="ShimmerContainer.Visibility" Value="Collapsed"/>
                        <Setter Target="PlaylistSplitter.Visibility" Value="Collapsed"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Hero backdrop for editorial / radio playlists: the composition visual
             is attached in code-behind. Image is left-anchored and fades out to the
             right so the regular content (cover, metadata, track grid) layers on top
             without competing. A theme-aware scrim sprite is layered above the image
             in the same composition tree — see PlaylistPage.xaml.cs. Hit-test-invisible
             so it doesn't eat pointer events.
             VerticalAlignment="Top" + Height="440" constrain the backdrop to sit
             behind the title/metadata band only — without them, the Border stretches
             to the full page height and the image tint bleeds down into the track
             rows area on the left column. Height is a bit taller than the hard-cutoff
             value (was 360) because the composition mask now also fades vertically:
             the bottom ~30-40% of the host is mostly transparent, so a 440 px host
             gives roughly 280-300 px of actually-visible hero before it dissolves.
             The composition visuals automatically track this host's ActualSize. -->
        <Border x:Name="HeaderBackgroundHost"
                VerticalAlignment="Top"
                Height="440"
                IsHitTestVisible="False"/>

        <Grid x:Name="TwoColumnGrid"
              Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="200" MinWidth="200" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Shimmer skeleton for left panel (visible while metadata loads) -->
            <StackPanel x:Name="ShimmerContainer" Grid.Column="0" Spacing="14"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Padding="16,24"
                        MaxWidth="280"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:Shimmer Width="120" Height="16" HorizontalAlignment="Center"/>
                <controls:Shimmer Width="240" Height="240" CornerRadius="8"/>
                <controls:Shimmer Width="180" Height="20" HorizontalAlignment="Center"/>
                <controls:Shimmer Width="150" Height="20" HorizontalAlignment="Center"/>
                <controls:Shimmer Width="110" Height="14" HorizontalAlignment="Center"/>
                <controls:Shimmer Width="130" Height="14" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <controls:Shimmer Width="48" Height="48" CornerRadius="24"/>
                    <controls:Shimmer Width="40" Height="40" CornerRadius="20"/>
                </StackPanel>
            </StackPanel>

            <!-- Wide left panel: shown once metadata has arrived -->
            <StackPanel x:Name="WidePlaylistPanel" Grid.Column="0"
                        Padding="16,24" Spacing="14" HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">

                <Grid MinHeight="20" HorizontalAlignment="Center">
                    <HyperlinkButton Content="{x:Bind ViewModel.OwnerName, Mode=OneWay}"
                                     Padding="0"
                                     HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                     Visibility="{x:Bind ViewModel.OwnerName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <controls:Shimmer Width="120" Height="16" HorizontalAlignment="Center"
                                      Visibility="{x:Bind ViewModel.OwnerName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                </Grid>

                <!--
                    Square cover art. Hidden when the playlist carries a header image —
                    that image composes behind the whole page as a left-anchored backdrop
                    (see HeaderBackgroundHost on RootGrid + PlaylistPage.xaml.cs) and the
                    cover would just duplicate / compete with it.
                -->
                <Border x:Name="PlaylistArtContainer" CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        SizeChanged="PlaylistArtContainer_SizeChanged"
                        Visibility="{x:Bind ViewModel.HeaderImageUrl, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid>
                        <!-- Full-container shimmer BEHIND the Image. One visual
                             state while PlaylistImageUrl is null (or mosaic
                             compose is in flight), then FadeInOnLoad animates
                             the Image from opacity 0→1 over the shimmer. No
                             jump from small-glyph to bare-background to image
                             — same rectangle size throughout. -->
                        <controls:Shimmer HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Visibility="{x:Bind ViewModel.PlaylistImageUrl, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                        <Image Source="{x:Bind ViewModel.PlaylistImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='280'}"
                               Stretch="UniformToFill"
                               Visibility="{x:Bind ViewModel.PlaylistImageUrl, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                               behaviors:ImageFallbackBehavior.HideOnError="True"
                               behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                               behaviors:ImageFallbackBehavior.DecodePixelWidth="280"/>
                    </Grid>
                </Border>

                <Grid MinHeight="24" HorizontalAlignment="Stretch">
                    <TextBlock Text="{x:Bind ViewModel.PlaylistName, Mode=OneWay}"
                               FontSize="20" FontWeight="Bold" TextAlignment="Center"
                               TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Visibility="{x:Bind ViewModel.PlaylistName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <controls:Shimmer Width="180" Height="22" HorizontalAlignment="Center"
                                      Visibility="{x:Bind ViewModel.PlaylistName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                </Grid>

                <!-- Description card: RichTextBlock renders HTML-decoded description
                     with embedded <a href="spotify:..."> links surfaced as real
                     accent-styled Hyperlinks (see PlaylistPage.xaml.cs
                     RebuildDescriptionInlines). MaxLines is 3 by default; the
                     More/Less toggle below flips it to 0 (unlimited) and back.
                     The Border's Visibility drives the whole card so empty-
                     description playlists don't show blank card chrome. -->
                <Border CornerRadius="{ThemeResource OverlayCornerRadius}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Padding="14,10"
                        Margin="0,4,0,0"
                        Visibility="{x:Bind ViewModel.PlaylistDescription, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel Spacing="4">
                        <RichTextBlock x:Name="DescriptionRichText"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextAlignment="Center"
                                       MaxLines="3"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="Wrap"
                                       IsTextTrimmedChanged="DescriptionRichText_IsTextTrimmedChanged"/>

                        <HyperlinkButton x:Name="DescriptionMoreButton"
                                         HorizontalAlignment="Center"
                                         Padding="4,2"
                                         FontSize="12"
                                         Visibility="Collapsed"
                                         Click="DescriptionMoreButton_Click">
                            <TextBlock x:Name="DescriptionMoreLabel" Text="More..."/>
                        </HyperlinkButton>
                    </StackPanel>
                </Border>

                <!-- Metadata pills: each metric ("X songs", "Y hr Z min") gets its own
                     fully-rounded WinUI pill (CornerRadius=14 on a ~28 px-tall Border
                     gives stadium ends). The bullet separator is dropped — the pills
                     ARE the separator. ControlFillColor*Brush + ControlStrokeColor*
                     give clearly-bounded chip chrome (the secondary card tint blended
                     too softly into the page background). -->
                <Grid MinHeight="28" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="6"
                                Visibility="{x:Bind ViewModel.IsLoadingTracks, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Border CornerRadius="14"
                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Padding="10,3">
                            <!-- Two Runs with no x:Uid: the leading space in " songs"
                                 was being stripped by the localization resource, producing
                                 "50songs". xml:space="preserve" on the TextBlock keeps any
                                 future literal whitespace inside the Runs intact too. -->
                            <TextBlock xml:space="preserve"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"><Run Text="{x:Bind ViewModel.TotalTracks, Mode=OneWay}"/><Run Text=" songs"/></TextBlock>
                        </Border>
                        <Border CornerRadius="14"
                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Padding="10,3"
                                Visibility="{x:Bind ViewModel.TotalDuration, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{x:Bind ViewModel.TotalDuration, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Border>
                    </StackPanel>
                    <controls:Shimmer Width="140" Height="20" HorizontalAlignment="Center"
                                      Visibility="{x:Bind ViewModel.IsLoadingTracks, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>

                <TextBlock Text="{x:Bind ViewModel.FollowerCountFormatted, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center"
                           Visibility="{x:Bind ViewModel.FollowerCountFormatted, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>

                <StackPanel Orientation="Horizontal" Spacing="12"
                            HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.PlayAllCommand}" Padding="20,10" CornerRadius="20">
                        <FontIcon Glyph="&#xE768;" FontSize="18"/>
                    </Button>
                    <Button Command="{x:Bind ViewModel.ShuffleCommand}"
                            Padding="10,8" Background="Transparent" BorderThickness="1">
                        <FontIcon Glyph="&#xE8B1;" FontSize="16"/>
                    </Button>
                </StackPanel>
            </StackPanel>

            <controls1:GridSplitter
                x:Name="PlaylistSplitter"
                Grid.Column="1"
                Width="12"
                ResizeCompleted="PlaylistSplitter_ResizeCompleted"/>

            <!-- Track grid in column 2. IsLoading is driven by IsLoadingTracks because
                 playlist tracks lazy-load independently of metadata. Rewrite swapped
                 TrackListView for TrackDataGrid — filter/sort/columns live inside the
                 grid's toolbar now; the page-level hero + narrow-mode header that used
                 to nest inside TrackListView.HeaderContent still render above the grid. -->
            <tdg:TrackDataGrid
                x:Name="TrackGrid"
                Grid.Column="2"
                VerticalAlignment="Stretch"
                Margin="0,0,0,0"
                PageKey="playlist"
                ItemsSource="{x:Bind ViewModel.FilteredTracks, Mode=OneWay}"
                PlayCommand="{x:Bind ViewModel.PlayTrackCommand}" />

        </Grid>

        <!-- Error overlay: shown when detail fetch or track fetch fails.
             Retry re-invalidates the PlaylistStore and resets track-load state. -->
        <controls1:ErrorStateView
            Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            RetryCommand="{x:Bind ViewModel.RetryCommand}"/>
    </Grid>
</Page>
