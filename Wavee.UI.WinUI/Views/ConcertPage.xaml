<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.ConcertPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:appControls="using:Wavee.UI.WinUI.Controls"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True"/>
    </Page.Resources>

    <Grid>
        <!-- Shimmer (visible while loading) -->
        <StackPanel x:Name="ShimmerContainer" Spacing="24" Padding="32"
                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <controls:Shimmer Width="400" Height="32" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <controls:Shimmer Width="160" Height="20"/>
                <controls:Shimmer Width="100" Height="20"/>
            </StackPanel>
            <controls:Shimmer Width="250" Height="16"/>
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
                <controls:Shimmer Width="80" Height="80" CornerRadius="40"/>
                <controls:Shimmer Width="80" Height="80" CornerRadius="40"/>
            </StackPanel>
            <controls:Shimmer Width="200" Height="20" Margin="0,16,0,0"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <controls:Shimmer Width="140" Height="44" CornerRadius="8"/>
                <controls:Shimmer Width="140" Height="44" CornerRadius="8"/>
            </StackPanel>
        </StackPanel>

        <!-- Full-page background: diagonal artist images (Composition visuals injected in code-behind) -->
        <Border x:Name="HeroImageContainer"/>

        <!-- Full-page gradient overlay for text readability (theme-aware) -->
        <Border x:Name="GradientOverlay" IsHitTestVisible="False"/>

        <!-- Content (fades in after loading) -->
        <ScrollView x:Name="ContentContainer" Opacity="0">
            <StackPanel Spacing="24" Padding="32,40,32,32">

                <!-- Concert info (was in hero, now top of scrollable content) -->
                <StackPanel Spacing="10">
                        <!-- Date pill -->
                        <Border CornerRadius="4" Padding="10,5" Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{x:Bind ViewModel.DateFormatted, Mode=OneWay}"
                                       FontSize="13" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Border>

                        <!-- Title -->
                        <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                                   FontSize="40" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   TextWrapping="Wrap" MaxLines="2"/>

                        <!-- Venue · City · Time -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE81D;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.Venue, Mode=OneWay}"/>
                                <Run Text=" · "/>
                                <Run Text="{x:Bind ViewModel.City, Mode=OneWay}"/>
                                <Run Text=" · "/>
                                <Run Text="{x:Bind ViewModel.ShowTime, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Genre pills -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Genres, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.HasGenres, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="6"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border CornerRadius="10" Padding="10,4" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <TextBlock Text="{x:Bind}" FontSize="11" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- Action buttons: Get Tickets + Save -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Offers, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="8"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ConcertOfferVm">
                                        <Button Click="Offer_Click" Tag="{x:Bind Url}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Padding="16,8" CornerRadius="20">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                                                <TextBlock Text="{x:Bind ProviderName}" FontWeight="SemiBold" FontSize="13"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                            <Button Padding="12,8" CornerRadius="20"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderThickness="0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xEB51;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Save" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                </StackPanel>

                <!-- Lineup -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Lineup" FontWeight="Bold" FontSize="20"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Artists, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="20"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ConcertArtistVm">
                                <StackPanel Spacing="8">
                                    <!-- Artist name + on tour -->
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <cards:ContentCard
                                            Width="140"
                                            ImageUrl="{x:Bind AvatarUrl}"
                                            Title="{x:Bind Name}"
                                            Subtitle="Artist"
                                            IsCircularImage="True"
                                            CenterText="True"
                                            NavigationUri="{x:Bind Uri}"/>
                                    </StackPanel>

                                    <!-- Popular albums — wrapping grid -->
                                    <ItemsRepeater ItemsSource="{x:Bind PopularAlbums}">
                                        <ItemsRepeater.Layout>
                                            <UniformGridLayout MinItemWidth="130" MinItemHeight="190"
                                                               MinColumnSpacing="8" MinRowSpacing="8"
                                                               ItemsStretch="Fill"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ConcertAlbumVm">
                                                <cards:ContentCard
                                                    ImageUrl="{x:Bind CoverArtUrl}"
                                                    Title="{x:Bind Name}"
                                                    Subtitle="{x:Bind ArtistName}"
                                                    NavigationUri="{x:Bind Uri}"/>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>

                                    <!-- On tour link -->
                                    <TextBlock FontSize="12" Opacity="0.6" Margin="0,4,0,0">
                                        <Run Text="On tour · View all upcoming concerts ("/>
                                        <Run Text="{x:Bind UpcomingConcertCount}"/>
                                        <Run Text=")"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Venue card -->
                <Border CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Venue" FontWeight="Bold" FontSize="16"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE81D;" FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.Venue, Mode=OneWay}"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock FontSize="13" Opacity="0.7">
                                    <Run Text="{x:Bind ViewModel.City, Mode=OneWay}"/>
                                    <Run Text=", "/>
                                    <Run Text="{x:Bind ViewModel.Country, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                            <FontIcon Glyph="&#xE823;" FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock FontSize="13" Opacity="0.7">
                                <Run Text="Show at "/>
                                <Run Text="{x:Bind ViewModel.ShowTime, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Related Concerts + Location -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.HasRelatedConcerts, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="More Concerts Nearby" FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                        <appControls:LocationButton
                            LocationName="{x:Bind ViewModel.UserLocationName, Mode=TwoWay}"
                            LocationChanged="LocationButton_LocationChanged"/>
                    </StackPanel>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.RelatedConcerts, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ConcertRelatedVm">
                                <Button Click="RelatedConcert_Click" Tag="{x:Bind Uri}"
                                        Padding="16,12" Width="200" CornerRadius="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" HorizontalContentAlignment="Left">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Bind DateFormatted}" FontWeight="Bold" FontSize="14"
                                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="{x:Bind Venue}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                        <TextBlock Text="{x:Bind City}" FontSize="12" Opacity="0.6"/>
                                        <TextBlock Text="{x:Bind ArtistName}" FontSize="11" Opacity="0.5"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
