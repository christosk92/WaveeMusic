<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sidebar="using:Wavee.UI.WinUI.Controls.Sidebar"
    xmlns:tabbar="using:Wavee.UI.WinUI.Controls.TabBar"
    xmlns:navtoolbar="using:Wavee.UI.WinUI.Controls.NavigationToolbar"
    xmlns:playerbar="using:Wavee.UI.WinUI.Controls.PlayerBar"
    xmlns:sidebarplayer="using:Wavee.UI.WinUI.Controls.SidebarPlayer"
    xmlns:rightpanel="using:Wavee.UI.WinUI.Controls.RightPanel"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    xmlns:toolkit="using:CommunityToolkit.WinUI"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
        <converters:PlayerLocationToVisibilityConverter x:Key="PlayerLocationBottomConverter" TargetLocation="Bottom" />
        <converters:PlayerLocationToVisibilityConverter x:Key="PlayerLocationSidebarConverter" TargetLocation="Sidebar" />
    </Page.Resources>

    <!-- F12 debug shortcut removed — use Settings > Diagnostics instead -->

    <!-- Keyboard shortcuts handled in ProcessKeyboardAccelerators to avoid tooltip flyouts -->

    <controls:ZoomContentControl x:Name="ZoomControl">
    <Grid x:Name="RootLayoutGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: TitleBar with TabBar (full width) -->
        <Grid Grid.Row="0" x:Name="TitleBarGrid">
            <tabbar:TabBar
                x:Name="TabControl"
                TabInstances="{x:Bind ViewModel.Tabs}"
                SelectedIndex="{x:Bind ViewModel.SelectedTabIndex, Mode=TwoWay}"
                TabCloseRequested="TabControl_TabCloseRequested"
                TabSleepToggleRequested="TabControl_TabSleepToggleRequested"
                AddTabRequested="TabControl_AddTabRequested"/>
        </Grid>

        <!-- Row 1: Navigation Toolbar (full width, below tabs) -->
        <navtoolbar:NavigationToolbar
            x:Name="NavToolbar"
            Grid.Row="1"
            CanGoBack="{x:Bind ViewModel.CanGoBack, Mode=OneWay}"
            CanGoForward="{x:Bind ViewModel.CanGoForward, Mode=OneWay}"
            IsOnHomePage="{x:Bind ViewModel.IsOnHomePage, Mode=OneWay}"
            IsOnProfilePage="{x:Bind ViewModel.IsOnProfilePage, Mode=OneWay}"
            SearchSuggestionsLoading="{x:Bind ViewModel.IsSearchSuggestionsLoading, Mode=OneWay}"
            SearchSuggestionsErrorMessage="{x:Bind ViewModel.SearchSuggestionErrorMessage, Mode=OneWay}"
            BackRequested="NavToolbar_BackRequested"
            ForwardRequested="NavToolbar_ForwardRequested"
            HomeRequested="NavToolbar_HomeRequested"
            SearchQuerySubmitted="NavToolbar_SearchQuerySubmitted"
            SearchTextChanged="NavToolbar_SearchTextChanged"
            SearchSuggestionChosen="NavToolbar_SearchSuggestionChosen"
            SearchRetryRequested="NavToolbar_SearchRetryRequested"
            SearchActionButtonClicked="NavToolbar_SearchActionButtonClicked"
            SearchSuggestions="{x:Bind ViewModel.SearchSuggestions, Mode=OneWay}"
            SignInRequested="NavToolbar_SignInRequested"/>

        <!-- Shell-level notification bars -->
        <StackPanel Grid.Row="2" Canvas.ZIndex="1">
            <InfoBar
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                IsOpen="{x:Bind ViewModel.IsNotificationOpen, Mode=TwoWay}"
                Message="{x:Bind ViewModel.NotificationMessage, Mode=OneWay}"
                Severity="{x:Bind ViewModel.NotificationSeverity, Mode=OneWay}"
                IsClosable="True">
                <InfoBar.ActionButton>
                    <Button Content="{x:Bind ViewModel.NotificationActionLabel, Mode=OneWay}"
                            Click="NotificationAction_Click"
                            IsEnabled="{x:Bind ViewModel.IsNotificationActionEnabled, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.HasNotificationAction, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </InfoBar.ActionButton>
            </InfoBar>
            <InfoBar x:Uid="Views_ShellPage__InfoBar_1"
                x:Name="ConnectionErrorBar"
                Title="Connection failed"
                Severity="Error"
                IsOpen="False"
                IsClosable="True">
                <InfoBar.ActionButton>
                    <Button x:Uid="Views_ShellPage__Button_2" Content="Retry" Click="RetryConnection_Click"/>
                </InfoBar.ActionButton>
            </InfoBar>
        </StackPanel>

        <!-- Connection overlay — blocks interaction while disconnected -->
        <Border
            x:Name="ConnectionOverlay"
            Grid.Row="2"
            Canvas.ZIndex="2"
            Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
            Opacity="0.85"
            IsHitTestVisible="True"
            Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressRing x:Name="ReconnectingRing" IsActive="True" Width="36" Height="36"/>
                <TextBlock x:Uid="Views_ShellPage__TextBlock_3" x:Name="ConnectionOverlayText"
                           Text="Reconnecting to Spotify..."
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Row 2: Main content area with sidebar -->
        <sidebar:SidebarView
            x:Name="SidebarControl"
            Grid.Row="2"
            DisplayMode="{x:Bind ViewModel.SidebarDisplayMode, Mode=TwoWay}"
            IsPaneOpen="{x:Bind ViewModel.IsSidebarPaneOpen, Mode=TwoWay}"
            OpenPaneLength="{x:Bind ViewModel.SidebarWidth, Mode=TwoWay}"
            MenuItemsSource="{x:Bind ViewModel.SidebarItems}"
            SelectedItem="{x:Bind ViewModel.SelectedSidebarItem, Mode=TwoWay}"
            ItemInvoked="SidebarControl_ItemInvoked">

            <!-- Main Content + Right Panel (each with independent shadow) -->
            <sidebar:SidebarView.InnerContent>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Main content card (Files-style: subtle rounded corners + soft shadow) -->
                    <Border Grid.Column="0">
                        <toolkit:Effects.Shadow>
                            <media:AttachedCardShadow BlurRadius="16" Offset="0,2"
                                                      Opacity="0.12" Color="Black" CornerRadius="8"/>
                        </toolkit:Effects.Shadow>
                        <Border Background="{ThemeResource App.Theme.FileArea.BackgroundBrush}"
                                CornerRadius="8">
                            <ContentPresenter
                                x:Name="TabContentPresenter"
                                Content="{x:Bind ViewModel.SelectedTabItem.ContentFrame, Mode=OneWay}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                                <ContentPresenter.ContentTransitions>
                                    <TransitionCollection>
                                        <EntranceThemeTransition/>
                                    </TransitionCollection>
                                </ContentPresenter.ContentTransitions>
                            </ContentPresenter>
                        </Border>
                    </Border>

                    <!-- Right panel card -->
                    <Border Grid.Column="1"
                            Visibility="{x:Bind ViewModel.IsRightPanelOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <toolkit:Effects.Shadow>
                            <media:AttachedCardShadow BlurRadius="32" Offset="4,-2"
                                                      Opacity="0.3" Color="Black" CornerRadius="8"/>
                        </toolkit:Effects.Shadow>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8">
                            <rightpanel:RightPanelView
                                x:Name="RightPanelControl"
                                PanelWidth="{x:Bind ViewModel.RightPanelWidth, Mode=TwoWay}"
                                IsOpen="{x:Bind ViewModel.IsRightPanelOpen, Mode=TwoWay}"
                                SelectedMode="{x:Bind ViewModel.RightPanelMode, Mode=TwoWay}"/>
                        </Border>
                    </Border>
                </Grid>
            </sidebar:SidebarView.InnerContent>

            <!-- Sidebar Header — sidebar player widget mount point. Visible only when
                 PlayerLocation == Sidebar. The widget itself only renders when a
                 track is loaded (HasTrack gate inside the control). -->
            <sidebar:SidebarView.Header>
                <sidebarplayer:SidebarPlayerWidget
                    x:Name="SidebarPlayerControl"
                    Visibility="{x:Bind ViewModel.PlayerLocation, Mode=OneWay, Converter={StaticResource PlayerLocationSidebarConverter}}" />
            </sidebar:SidebarView.Header>

            <!-- Sidebar Footer (settings) -->
            <sidebar:SidebarView.Footer>
                <StackPanel>
                    <!-- Expandable Album Art -->
                    <Border
                        x:Name="ExpandedAlbumArtContainer"
                        Margin="0,0,0,0"
                        CornerRadius="0"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        Tapped="ExpandedAlbumArt_Tapped"
                        Visibility="{x:Bind PlayerBarControl.ViewModel.IsAlbumArtExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <animations:Implicit.ShowAnimations>
                            <animations:OpacityAnimation Duration="0:0:0.3" From="0" To="1" />
                            <animations:TranslationAnimation Duration="0:0:0.3" From="0,50,0" To="0" />
                        </animations:Implicit.ShowAnimations>
                        <animations:Implicit.HideAnimations>
                            <animations:OpacityAnimation Duration="0:0:0.2" From="1" To="0" />
                            <animations:TranslationAnimation Duration="0:0:0.2" From="0" To="0,50,0" />
                        </animations:Implicit.HideAnimations>
                        <Image
                            Stretch="UniformToFill"
                            Source="{x:Bind PlayerBarControl.ViewModel.AlbumArtLarge, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=300}"
                            behaviors:ImageFallbackBehavior.HideOnError="True"
                            behaviors:ImageFallbackBehavior.FadeInOnLoad="True" />
                    </Border>
                </StackPanel>
            </sidebar:SidebarView.Footer>
        </sidebar:SidebarView>

        <!-- Player bar (docked at bottom) — collapsed when player is hosted in the sidebar instead. -->
        <playerbar:PlayerBar
            x:Name="PlayerBarControl"
            Grid.Row="3"
            HorizontalAlignment="Stretch"
            Visibility="{x:Bind ViewModel.PlayerLocation, Mode=OneWay, Converter={StaticResource PlayerLocationBottomConverter}}"/>

    </Grid>
    </controls:ZoomContentControl>
</Page>
