<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:eq="using:Wavee.UI.WinUI.Controls.Equalizer"
    xmlns:services="using:Wavee.UI.WinUI.Services"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:diag="using:Wavee.UI.WinUI.Controls.Diagnostics"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="32,24,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,8"/>

        <NavigationView Grid.Row="1"
                         PaneDisplayMode="Top"
                         IsBackButtonVisible="Collapsed"
                         IsSettingsVisible="False"
                         Background="Transparent"
                         SelectionChanged="Nav_SelectionChanged">
            <NavigationView.Resources>
                <!-- Remove the NavigationView content area background -->
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
            </NavigationView.Resources>
            <NavigationView.MenuItems>
                <NavigationViewItem Content="General" Tag="general">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE771;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Playback" Tag="playback">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE768;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Audio" Tag="audio">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE995;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Storage &amp; Network" Tag="storage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Diagnostics" Tag="diagnostics">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="About" Tag="about">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>
                <!-- ═══════════════════ General ═══════════════════ -->
                <ScrollViewer x:Name="GeneralContent">
                    <StackPanel Spacing="4" Padding="0,16,0,24">
                        <TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>
                        <controls:SettingsCard Header="Theme"
                                               Description="Choose light, dark, or match your system">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE790;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
                                      MinWidth="140">
                                <ComboBoxItem Content="Light"/>
                                <ComboBoxItem Content="Dark"/>
                                <ComboBoxItem Content="System"/>
                            </ComboBox>
                        </controls:SettingsCard>

                        <!-- ── Display scaling ── -->
                        <TextBlock Text="Display" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8"/>

                        <!-- Layout density previews -->
                        <Grid ColumnSpacing="12" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Compact preview -->
                            <Border Grid.Column="0" CornerRadius="8" Padding="16,12" Height="88"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <StackPanel Spacing="2">
                                        <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1" Height="2" HorizontalAlignment="Left" Width="56"/>
                                        <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1" Height="2" HorizontalAlignment="Left" Width="44"/>
                                        <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1" Height="2" HorizontalAlignment="Left" Width="52"/>
                                        <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1" Height="2" HorizontalAlignment="Left" Width="36"/>
                                    </StackPanel>
                                    <TextBlock Text="Compact" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Default preview -->
                            <Border Grid.Column="1" CornerRadius="8" Padding="16,12" Height="88"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <StackPanel Spacing="4">
                                        <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1.5" Height="3" HorizontalAlignment="Left" Width="56"/>
                                        <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1.5" Height="3" HorizontalAlignment="Left" Width="44"/>
                                        <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1.5" Height="3" HorizontalAlignment="Left" Width="52"/>
                                    </StackPanel>
                                    <TextBlock Text="Default" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Spacious preview -->
                            <Border Grid.Column="2" CornerRadius="8" Padding="16,12" Height="88"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <StackPanel Spacing="6">
                                        <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="2" Height="4" HorizontalAlignment="Left" Width="56"/>
                                        <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="2" Height="4" HorizontalAlignment="Left" Width="44"/>
                                    </StackPanel>
                                    <TextBlock Text="Spacious" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Zoom level card -->
                        <controls:SettingsCard Header="Zoom level"
                                               Description="{x:Bind ViewModel.ZoomPreviewLabel, Mode=OneWay}">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8A3;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.ZoomLevelDisplay, Mode=OneWay}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="36"/>
                                <Button Content="Reset" Command="{x:Bind ViewModel.ResetZoomCommand}"/>
                            </StackPanel>
                        </controls:SettingsCard>

                        <!-- Zoom slider -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16,4,16,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="A" FontSize="11" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <Slider Grid.Column="1"
                                        Value="{x:Bind ViewModel.ZoomLevelIndex, Mode=TwoWay}"
                                        Minimum="0" Maximum="6" StepFrequency="1" SnapsTo="StepValues"
                                        Margin="12,0"/>
                                <TextBlock Grid.Column="2" Text="A" FontSize="18" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ═══════════════════ Playback ═══════════════════ -->
                <ScrollViewer x:Name="PlaybackContent" Visibility="Collapsed">
                    <StackPanel Spacing="4" Padding="0,16,0,24">

                        <TextBlock Text="Interaction" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>
                        <controls:SettingsCard Header="Track click behavior"
                                               Description="How clicking a track starts playback">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8B0;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.TrackClickIndex, Mode=TwoWay}"
                                      MinWidth="140">
                                <ComboBoxItem Content="Single tap"/>
                                <ComboBoxItem Content="Double tap"/>
                            </ComboBox>
                        </controls:SettingsCard>

                        <TextBlock Text="Queue" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8"/>
                        <controls:SettingsCard Header="Default play action"
                                               Description="What happens when you start a track">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8FD;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.DefaultPlayActionIndex, Mode=TwoWay}"
                                      MinWidth="180">
                                <ComboBoxItem Content="Play and clear queue"/>
                                <ComboBoxItem Content="Play next"/>
                                <ComboBoxItem Content="Play later"/>
                            </ComboBox>
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Ask before playing"
                                               Description="Show a prompt before replacing the current queue">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE9CE;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AskPlayAction, Mode=TwoWay}"
                                          OnContent="" OffContent=""/>
                        </controls:SettingsCard>

                        <TextBlock Text="Audio" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8"/>
                        <controls:SettingsCard Header="Streaming quality"
                                               Description="Higher quality uses more bandwidth and storage">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8D6;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.AudioQualityIndex, Mode=TwoWay}"
                                      MinWidth="160">
                                <ComboBoxItem Content="Normal (96 kbps)"/>
                                <ComboBoxItem Content="High (160 kbps)"/>
                                <ComboBoxItem Content="Very High (320 kbps)"/>
                            </ComboBox>
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Normalize volume"
                                               Description="Adjust volume levels so all tracks play at a similar loudness">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE767;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.NormalizationEnabled, Mode=TwoWay}"
                                          OnContent="" OffContent=""/>
                        </controls:SettingsCard>

                        <TextBlock Text="Lyrics sources" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,4"/>
                        <TextBlock Text="Drag to reorder by preference. Higher position = stronger weight when multiple sources match."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,8"/>
                        <ListView ItemsSource="{x:Bind ViewModel.LyricsSources}"
                                  CanReorderItems="True"
                                  AllowDrop="True"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:LyricsSourceItem">
                                    <Grid Padding="0,4" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                            <TextBlock Text="{x:Bind Description}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1"
                                                      IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                                      OnContent="" OffContent=""
                                                      VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>

                <!-- ═══════════════════ Audio (Equalizer) ═══════════════════ -->
                <Grid x:Name="AudioContent" Visibility="Collapsed" Padding="0,16,0,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header controls -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" Header="Preset"
                                  SelectedIndex="{x:Bind ViewModel.SelectedEqPresetIndex, Mode=TwoWay}"
                                  MinWidth="160">
                            <ComboBoxItem Content="Flat"/>
                            <ComboBoxItem Content="Bass Boost"/>
                            <ComboBoxItem Content="Treble Boost"/>
                            <ComboBoxItem Content="Vocal"/>
                            <ComboBoxItem Content="Radio"/>
                        </ComboBox>

                        <ToggleSwitch Grid.Column="2" Header="Equalizer"
                                      IsOn="{x:Bind ViewModel.IsEqualizerEnabled, Mode=TwoWay}"
                                      OnContent="On" OffContent="Off"
                                      Margin="0,0,16,0"/>

                        <Button Grid.Column="3" Content="Reset" VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.ResetEqCommand}"/>
                    </Grid>

                    <!-- Preset description -->
                    <TextBlock Grid.Row="1"
                               Text="{x:Bind ViewModel.EqPresetDescription, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,12"/>

                    <!-- Equalizer curve -->
                    <eq:EqualizerCurveControl Grid.Row="2"
                                              Bands="{x:Bind ViewModel.EqBands, Mode=OneWay}"
                                              MinHeight="250" MaxHeight="400"/>
                </Grid>

                <!-- ═══════════════════ Storage & Network ═══════════════════ -->
                <ScrollViewer x:Name="StorageContent" Visibility="Collapsed">
                    <StackPanel Spacing="4" Padding="0,16,0,24">

                        <TextBlock Text="Audio Cache" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                                 Message="Cache and connection changes take effect after restarting the app."
                                 Margin="0,0,0,8"/>

                        <controls:SettingsCard Header="Enable cache"
                                               Description="Cache audio files locally for faster playback">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE74E;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.CacheEnabled, Mode=TwoWay}"
                                          OnContent="" OffContent=""/>
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Cache size limit"
                                               Description="Oldest tracks are automatically removed when the limit is reached">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xEDA2;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.CacheSizeLimitIndex, Mode=TwoWay}"
                                      MinWidth="140">
                                <ComboBoxItem Content="500 MB"/>
                                <ComboBoxItem Content="1 GB"/>
                                <ComboBoxItem Content="2 GB"/>
                                <ComboBoxItem Content="5 GB"/>
                            </ComboBox>
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Cache location"
                                               Description="{x:Bind ViewModel.CacheLocationDisplay}">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8B7;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <TextBlock Text="{x:Bind ViewModel.CacheSizeDisplay}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Clear cache"
                                               Description="Delete all cached audio files">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE74D;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <Button Content="Clear Cache" Command="{x:Bind ViewModel.ClearCacheCommand}"/>
                        </controls:SettingsCard>

                        <TextBlock Text="Connection" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8"/>
                        <controls:SettingsCard Header="Auto-reconnect"
                                               Description="Automatically reconnect when the connection is lost">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE703;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <ToggleSwitch IsOn="{x:Bind ViewModel.AutoReconnect, Mode=TwoWay}"
                                          OnContent="" OffContent=""/>
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="Connection timeout"
                                               Description="Maximum time to wait when connecting">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE916;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <ComboBox SelectedIndex="{x:Bind ViewModel.ConnectionTimeoutIndex, Mode=TwoWay}"
                                      MinWidth="140">
                                <ComboBoxItem Content="10 seconds"/>
                                <ComboBoxItem Content="30 seconds"/>
                                <ComboBoxItem Content="60 seconds"/>
                            </ComboBox>
                        </controls:SettingsCard>
                    </StackPanel>
                </ScrollViewer>

                <!-- ═══════════════════ Diagnostics ═══════════════════ -->
                <ScrollViewer x:Name="DiagnosticsContent" Visibility="Collapsed" Padding="0,16,0,0">
                    <StackPanel Spacing="0">
                        <!-- Audio Pipeline Health -->
                        <controls:SettingsExpander Margin="0,0,0,12"
                                               Header="Audio Pipeline"
                                               Description="{x:Bind ViewModel.AudioPipelineMode, Mode=OneWay}">
                            <controls:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xE767;"/>
                            </controls:SettingsExpander.HeaderIcon>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind ViewModel.AudioPipelineStatus, Mode=OneWay}"/>
                            </StackPanel>
                            <controls:SettingsExpander.Items>
                                <controls:SettingsCard Header="Process ID"
                                                   Description="PID of the audio engine process (0 = in-process)">
                                    <controls:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE943;"/>
                                    </controls:SettingsCard.HeaderIcon>
                                    <TextBlock Text="{x:Bind ViewModel.AudioPipelinePid, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </controls:SettingsCard>
                                <controls:SettingsCard Header="Restart Count"
                                                   Description="Number of auto-restarts this session">
                                    <controls:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE72C;"/>
                                    </controls:SettingsCard.HeaderIcon>
                                    <TextBlock Text="{x:Bind ViewModel.AudioRestartCount, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </controls:SettingsCard>
                                <controls:SettingsCard Header="Audio Underruns"
                                                   Description="PortAudio buffer underflows (causes audible glitches)">
                                    <controls:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE7BA;"/>
                                    </controls:SettingsCard.HeaderIcon>
                                    <TextBlock Text="{x:Bind ViewModel.AudioUnderrunCount, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </controls:SettingsCard>
                                <controls:SettingsCard Header="GC Collections"
                                                   Description="Garbage collection counts (Gen2 causes audio freezes)">
                                    <controls:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE74D;"/>
                                    </controls:SettingsCard.HeaderIcon>
                                    <TextBlock Text="{x:Bind ViewModel.AudioGcStats, Mode=OneWay}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </controls:SettingsCard>
                                <controls:SettingsCard Header="Slowest UI Operations"
                                                   Description="Profiled operations that block the UI thread">
                                    <controls:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE916;"/>
                                    </controls:SettingsCard.HeaderIcon>
                                    <TextBlock Text="{x:Bind ViewModel.AudioProfilerTop, Mode=OneWay}"
                                           FontFamily="Consolas" FontSize="11"
                                           MaxWidth="300" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </controls:SettingsCard>
                                <controls:SettingsCard Header="IPC Throughput"
                                                   Description="Messages sent/received over the Named Pipe">
                                    <controls:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE8AB;"/>
                                    </controls:SettingsCard.HeaderIcon>
                                    <TextBlock Text="{x:Bind ViewModel.AudioThroughput, Mode=OneWay}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </controls:SettingsCard>
                                <controls:SettingsCard Header="State Freshness"
                                                   Description="Time since last state update from audio process">
                                    <controls:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE2AD;"/>
                                    </controls:SettingsCard.HeaderIcon>
                                    <TextBlock Text="{x:Bind ViewModel.AudioStateFreshness, Mode=OneWay}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </controls:SettingsCard>
                            </controls:SettingsExpander.Items>
                        </controls:SettingsExpander>

                        <!-- IPC RTT Chart — full width -->
                        <Border Margin="0,0,0,12"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <diag:IpcLineChart x:Name="RttChart" Height="180"/>
                        </Border>

                        <!-- Clock Synchronization -->
                        <controls:SettingsExpander Margin="0,0,0,12"
                                               Header="Clock Synchronization"
                                               Description="NTP-style sync with Spotify's server clock">
                            <controls:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xE121;"/>
                            </controls:SettingsExpander.HeaderIcon>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.ClockOffsetMs, Mode=OneWay}"/>
                                <Run Text="ms offset"/>
                                </TextBlock>
                                <FontIcon Glyph="&#xE73E;" FontSize="12"
                                      Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                      Visibility="{x:Bind ViewModel.ClockIsSynced, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                            <controls:SettingsExpander.Items>
                                <controls:SettingsCard Header="Network round-trip"
                                                   Description="Latency of the best sync sample">
                                    <controls:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE968;"/>
                                    </controls:SettingsCard.HeaderIcon>
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Bind ViewModel.ClockLastRttMs, Mode=OneWay}"/>
                                    <Run Text="ms"/>
                                    </TextBlock>
                                </controls:SettingsCard>
                                <controls:SettingsCard Header="Sync interval"
                                                   Description="How often to re-synchronize">
                                    <controls:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE916;"/>
                                    </controls:SettingsCard.HeaderIcon>
                                    <ComboBox SelectedIndex="{x:Bind ViewModel.ClockSyncIntervalIndex, Mode=TwoWay}"
                                          MinWidth="140">
                                        <ComboBoxItem Content="5 minutes"/>
                                        <ComboBoxItem Content="10 minutes"/>
                                        <ComboBoxItem Content="15 minutes"/>
                                        <ComboBoxItem Content="30 minutes"/>
                                    </ComboBox>
                                </controls:SettingsCard>
                                <controls:SettingsCard Header="Last sync"
                                                   Description="{x:Bind ViewModel.ClockLastSyncDisplay, Mode=OneWay}">
                                    <controls:SettingsCard.HeaderIcon>
                                        <FontIcon Glyph="&#xE895;"/>
                                    </controls:SettingsCard.HeaderIcon>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <StackPanel VerticalAlignment="Center" Spacing="0">
                                            <TextBlock Text="Next sync in"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock Text="{x:Bind ViewModel.ClockNextSyncCountdown, Mode=OneWay}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <Button Content="Sync now" Command="{x:Bind ViewModel.RefreshClockCommand}"/>
                                    </StackPanel>
                                </controls:SettingsCard>
                            </controls:SettingsExpander.Items>
                        </controls:SettingsExpander>

                        <!-- Logs section -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Toolbar -->
                            <Border Grid.Row="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8,8,0,0" Padding="12,8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Level filters -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                                        <ToggleButton Content="VRB" IsChecked="{x:Bind ViewModel.ShowVerbose, Mode=TwoWay}"
                                              FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                              FontFamily="Consolas" CornerRadius="4"/>
                                        <ToggleButton Content="DBG" IsChecked="{x:Bind ViewModel.ShowDebug, Mode=TwoWay}"
                                              FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                              FontFamily="Consolas" CornerRadius="4"/>
                                        <ToggleButton Content="INF" IsChecked="{x:Bind ViewModel.ShowInfo, Mode=TwoWay}"
                                              FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                              FontFamily="Consolas" CornerRadius="4"/>
                                        <ToggleButton Content="WRN" IsChecked="{x:Bind ViewModel.ShowWarning, Mode=TwoWay}"
                                              FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                              FontFamily="Consolas" CornerRadius="4"/>
                                        <ToggleButton Content="ERR" IsChecked="{x:Bind ViewModel.ShowError, Mode=TwoWay}"
                                              FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                              FontFamily="Consolas" CornerRadius="4"/>
                                        <ToggleButton Content="FTL" IsChecked="{x:Bind ViewModel.ShowFatal, Mode=TwoWay}"
                                              FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                              FontFamily="Consolas" CornerRadius="4"/>
                                    </StackPanel>

                                    <!-- Separator -->
                                    <Border Grid.Column="1" Width="1" Height="20"
                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                                    <!-- Search -->
                                    <AutoSuggestBox Grid.Column="2"
                                            PlaceholderText="Filter..."
                                            QueryIcon="Find"
                                            Text="{x:Bind ViewModel.LogSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            VerticalAlignment="Center"
                                            MinWidth="120"/>

                                    <!-- Count badge -->
                                    <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                <Run Text="{x:Bind ViewModel.FilteredLogEntries.Count, Mode=OneWay}"/>
                                <Run Text="lines"/>
                                    </TextBlock>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4">
                                        <Button Content="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="12"
                                        ToolTipService.ToolTip="Clear (Ctrl+L)"
                                        Command="{x:Bind ViewModel.ClearLogsCommand}"
                                        Padding="8,6" MinWidth="0" MinHeight="0">
                                            <Button.KeyboardAccelerators>
                                                <KeyboardAccelerator Modifiers="Control" Key="L"
                                                             />
                                            </Button.KeyboardAccelerators>
                                        </Button>
                                        <Button Content="&#xE8A7;" FontFamily="Segoe Fluent Icons" FontSize="12"
                                        ToolTipService.ToolTip="Open logs folder"
                                        Command="{x:Bind ViewModel.OpenLogsFolderCommand}"
                                        Padding="8,6" MinWidth="0" MinHeight="0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Log list -->
                            <ListView Grid.Row="1" x:Name="LogListView"
                              ItemsSource="{x:Bind ViewModel.FilteredLogEntries, Mode=OneWay}"
                              SelectionMode="None" IsItemClickEnabled="False"
                              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="services:LogEntry">
                                        <Grid ColumnSpacing="10" Padding="4,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="76"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Level pill -->
                                            <Border Grid.Column="0" CornerRadius="4"
                                            Padding="4,1" HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                                <TextBlock Text="{x:Bind LevelShort}" FontSize="9"
                                                   FontFamily="Consolas" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- Timestamp -->
                                            <TextBlock Grid.Column="1" Text="{x:Bind TimeString}"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>

                                            <!-- Source -->
                                            <TextBlock Grid.Column="2" Text="{x:Bind Category}"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>

                                            <!-- Message -->
                                            <TextBlock Grid.Column="3" Text="{x:Bind Message}"
                                               FontFamily="Consolas" FontSize="11"
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                               VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="MinHeight" Value="26"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>

                            <!-- Resume auto-scroll floating button -->
                            <Button x:Name="ResumeScrollButton" Grid.Row="1"
                            HorizontalAlignment="Center" VerticalAlignment="Top"
                            Margin="0,12,0,0" Visibility="Collapsed"
                            Click="ResumeScroll_Click"
                            CornerRadius="16" Padding="16,8"
                            Style="{StaticResource AccentButtonStyle}"
                            Canvas.ZIndex="10">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE74A;" FontSize="12"/>
                                    <TextBlock Text="New logs" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <!-- Past logs bar -->
                            <Grid Grid.Row="2" Margin="0,12,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Past Logs" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <ListView Grid.Column="1" ItemsSource="{x:Bind ViewModel.PastLogFiles, Mode=OneWay}"
                                  SelectionMode="None">
                                    <ListView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6"/>
                                        </ItemsPanelTemplate>
                                    </ListView.ItemsPanel>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PastLogFile">
                                            <Button CommandParameter="{x:Bind FilePath}"
                                            Click="OpenLogFile_Click"
                                            Padding="10,4" CornerRadius="4">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE8A5;" FontSize="11"/>
                                                    <TextBlock Text="{x:Bind FileName}" FontSize="11" FontFamily="Consolas"/>
                                                    <TextBlock Text="{x:Bind FileSize}" FontSize="10"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                </ListView>
                            </Grid>
                        </Grid>
                        <!-- end Logs section -->
                    </StackPanel>
                </ScrollViewer>

                <!-- ═══════════════════ About ═══════════════════ -->
                <Grid x:Name="AboutContent" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0">
                        <StackPanel Spacing="4" Padding="0,16,0,24">

                            <!-- App identity -->
                            <StackPanel Spacing="4" Margin="0,0,0,20">
                                <TextBlock Text="Wavee" FontSize="32" FontWeight="SemiBold"/>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13">
                                    <Run Text="v"/>
                                    <Run Text="{x:Bind ViewModel.AppVersion}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{x:Bind ViewModel.DistributionModeDisplay}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Updates -->
                            <TextBlock Text="Updates" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>
                            <controls:SettingsExpander Header="Check for updates"
                                                       Description="{x:Bind ViewModel.UpdateService.Status, Mode=OneWay}">
                                <controls:SettingsExpander.HeaderIcon>
                                    <FontIcon Glyph="&#xE895;"/>
                                </controls:SettingsExpander.HeaderIcon>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="{x:Bind ViewModel.UpdateService.LatestVersion, Mode=OneWay}"/>
                                    <Button Content="Check now" Command="{x:Bind ViewModel.CheckForUpdateCommand}"/>
                                </StackPanel>
                                <controls:SettingsExpander.Items>
                                    <controls:SettingsCard Header="Current version">
                                        <controls:SettingsCard.HeaderIcon>
                                            <FontIcon Glyph="&#xE7C3;"/>
                                        </controls:SettingsCard.HeaderIcon>
                                        <TextBlock Text="{x:Bind ViewModel.AppVersion}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </controls:SettingsCard>
                                    <controls:SettingsCard Header="Distribution">
                                        <controls:SettingsCard.HeaderIcon>
                                            <FontIcon Glyph="&#xE71B;"/>
                                        </controls:SettingsCard.HeaderIcon>
                                        <TextBlock Text="{x:Bind ViewModel.DistributionModeDisplay}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </controls:SettingsCard>
                                    <controls:SettingsCard Header="Changelog"
                                                           Description="{x:Bind ViewModel.UpdateService.Changelog, Mode=OneWay}">
                                        <controls:SettingsCard.HeaderIcon>
                                            <FontIcon Glyph="&#xE8FD;"/>
                                        </controls:SettingsCard.HeaderIcon>
                                    </controls:SettingsCard>
                                    <controls:SettingsCard Header="Error"
                                                           Description="{x:Bind ViewModel.UpdateService.ErrorMessage, Mode=OneWay}"
                                                           Visibility="{x:Bind ViewModel.HasUpdateError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <controls:SettingsCard.HeaderIcon>
                                            <FontIcon Glyph="&#xEA39;" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </controls:SettingsCard.HeaderIcon>
                                        <Button Content="Retry" Command="{x:Bind ViewModel.CheckForUpdateCommand}"/>
                                    </controls:SettingsCard>
                                </controls:SettingsExpander.Items>
                            </controls:SettingsExpander>

                            <!-- Feedback -->
                            <TextBlock Text="Help" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8"/>
                            <controls:SettingsCard Header="Send feedback"
                                                   Description="Report bugs, request features, or share your thoughts"
                                                   IsClickEnabled="True"
                                                   Click="Feedback_Click">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xED15;"/>
                                </controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                            </controls:SettingsCard>

                            <!-- Links -->
                            <TextBlock Text="Links" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8"/>
                            <controls:SettingsCard Header="Source code"
                                                   Description="View the project on GitHub"
                                                   IsClickEnabled="True"
                                                   Click="GitHub_Click">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE943;"/>
                                </controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                            </controls:SettingsCard>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer -->
                    <TextBlock Grid.Row="1" HorizontalAlignment="Center"
                               Margin="0,8,0,12" FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Text="Built with WinUI 3 and .NET"/>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Page>
