<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///CommunityToolkit.WinUI.Controls.Segmented/Segmented/Segmented.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Padding="32,24,32,0" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Uid="Views_SettingsPage__TextBlock_1" Grid.Row="0"
                   Text="Settings"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,4"/>

        <InfoBar Grid.Row="1"
                 IsOpen="{x:Bind ViewModel.HasPendingRestart, Mode=OneWay}"
                 Title="{x:Bind ViewModel.PendingRestartTitle, Mode=OneWay}"
                 Message="{x:Bind ViewModel.PendingRestartMessage, Mode=OneWay}"
                 Severity="{x:Bind ViewModel.PendingRestartSeverity, Mode=OneWay}"
                 IsClosable="False"
                 Margin="0,0,0,4">
            <InfoBar.ActionButton>
                <Button Content="{x:Bind ViewModel.RestartNowActionText, Mode=OneWay}"
                        Command="{x:Bind ViewModel.RestartNowCommand}"
                        IsEnabled="{x:Bind ViewModel.CanRestartNow, Mode=OneWay}"/>
            </InfoBar.ActionButton>
        </InfoBar>

        <controls:Segmented x:Name="SettingsSelectorBar"
                            Grid.Row="2"
                            SelectedIndex="0"
                            Style="{StaticResource PivotSegmentedStyle}"
                            SelectionChanged="SelectorBar_SelectionChanged">
            <controls:SegmentedItem x:Uid="Views_SettingsPage__SegmentedItem_2" x:Name="GeneralItem" Content="General" Tag="general"/>
            <controls:SegmentedItem x:Uid="Views_SettingsPage__SegmentedItem_3" x:Name="PlaybackItem" Content="Playback" Tag="playback"/>
            <controls:SegmentedItem x:Uid="Views_SettingsPage__SegmentedItem_4" x:Name="AudioItem" Content="Audio" Tag="audio"/>
            <controls:SegmentedItem x:Uid="Views_SettingsPage__SegmentedItem_5" x:Name="StorageItem" Content="Storage &amp; Network" Tag="storage"/>
            <controls:SegmentedItem x:Uid="Views_SettingsPage__SegmentedItem_6" x:Name="DiagnosticsItem" Content="Diagnostics" Tag="diagnostics"/>
            <controls:SegmentedItem x:Uid="Views_SettingsPage__SegmentedItem_7" x:Name="AboutItem" Content="About" Tag="about"/>
        </controls:Segmented>

        <ContentControl x:Name="ContentHost"
                        Grid.Row="3"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch">
            <ContentControl.ContentTransitions>
                <TransitionCollection>
                    <ContentThemeTransition/>
                </TransitionCollection>
            </ContentControl.ContentTransitions>
        </ContentControl>
    </Grid>
</Page>
