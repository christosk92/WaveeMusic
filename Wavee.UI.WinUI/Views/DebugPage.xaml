<Page
    x:Class="Wavee.UI.WinUI.Views.DebugPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Wavee.UI.WinUI.Views"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <local:IndexToVisibilityConverter x:Key="IndexToVisibilityConverter"/>
        <local:BoolNegationConverter x:Key="BoolNegationConverter"/>
    </Page.Resources>

    <Grid Padding="24,20,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Base URL + Preset -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{x:Bind ViewModel.BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Cascadia Code, Consolas" FontSize="13"
                     PlaceholderText="https://spclient.wg.spotify.com"/>

            <Button Grid.Column="1" Content="&#xE72C;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    ToolTipService.ToolTip="Reset to session URL"
                    Command="{x:Bind ViewModel.ResetBaseUrlCommand}"
                    Padding="10,8"/>

            <ComboBox Grid.Column="2"
                      ItemsSource="{x:Bind ViewModel.Presets}"
                      SelectedIndex="{x:Bind ViewModel.SelectedPresetIndex, Mode=TwoWay}"
                      Width="180" PlaceholderText="Preset"/>
        </Grid>

        <!-- Row 1: Method + Path + Send -->
        <Grid Grid.Row="1" ColumnSpacing="0"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              Padding="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      ItemsSource="{x:Bind ViewModel.HttpMethods}"
                      SelectedValue="{x:Bind ViewModel.SelectedMethod, Mode=TwoWay}"
                      BorderThickness="0"
                      Background="Transparent"
                      FontFamily="Cascadia Code, Consolas"
                      FontWeight="SemiBold"
                      MinWidth="100"/>

            <TextBox Grid.Column="1"
                     Text="{x:Bind ViewModel.Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     BorderThickness="0"
                     Background="Transparent"
                     FontFamily="Cascadia Code, Consolas" FontSize="14"
                     VerticalAlignment="Center"
                     PlaceholderText="/collection/v2/paging"/>

            <Button Grid.Column="2"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.SendCommand}"
                    IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                    Padding="20,8" Margin="4,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Width="16" Height="16"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Foreground="White"/>
                    <TextBlock Text="Send" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Preset fields: Collection Page -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10"
                    Visibility="{x:Bind ViewModel.SelectedPresetIndex, Mode=OneWay, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=1}">
            <TextBox Header="Username" Width="220" Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Header="Set" Width="140" Text="{x:Bind ViewModel.Set, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="collection"/>
            <NumberBox Header="Limit" Width="100" Value="{x:Bind ViewModel.Limit, Mode=TwoWay}" Minimum="1" Maximum="1000" SpinButtonPlacementMode="Compact"/>
            <TextBox Header="Page Token" Width="280" Text="{x:Bind ViewModel.PaginationToken, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="(empty = first page)"/>
        </StackPanel>

        <!-- Preset fields: Collection Delta -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10"
                    Visibility="{x:Bind ViewModel.SelectedPresetIndex, Mode=OneWay, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=2}">
            <TextBox Header="Username" Width="220" Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Header="Set" Width="140" Text="{x:Bind ViewModel.Set, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="collection"/>
            <TextBox Header="Sync Token" Width="400" Text="{x:Bind ViewModel.LastSyncToken, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="(empty = full sync)"/>
        </StackPanel>

        <!-- Preset fields: Collection Write -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10"
                    Visibility="{x:Bind ViewModel.SelectedPresetIndex, Mode=OneWay, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=3}">
            <TextBox Header="Username" Width="220" Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Header="Set" Width="140" Text="{x:Bind ViewModel.Set, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="collection"/>
            <TextBox Header="URI" Width="300" Text="{x:Bind ViewModel.ItemUri, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="spotify:track:xxxxx"/>
            <ToggleSwitch Header="Remove" IsOn="{x:Bind ViewModel.IsRemoved, Mode=TwoWay}" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Custom body (only when preset = Custom) -->
        <StackPanel Grid.Row="2" Spacing="6"
                    Visibility="{x:Bind ViewModel.SelectedPresetIndex, Mode=OneWay, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=0}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Request Body" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                    <TextBox Width="200" Text="{x:Bind ViewModel.ContentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11" Padding="6,4" PlaceholderText="Content-Type"/>
                    <Button Content="Format JSON" Command="{x:Bind ViewModel.FormatBodyCommand}" Padding="8,4" FontSize="11"/>
                </StackPanel>
            </Grid>
            <TextBox Text="{x:Bind ViewModel.RequestBody, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     MinHeight="60" MaxHeight="160"
                     FontFamily="Cascadia Code, Consolas" FontSize="12"
                     PlaceholderText="Request body (leave empty for GET)"/>
        </StackPanel>

        <!-- Row 3: Response tabs -->
        <Pivot Grid.Row="3" SelectedIndex="{x:Bind ViewModel.SelectedResponseTab, Mode=TwoWay}"
               Margin="0,4,0,0" Padding="0">
            <Pivot.HeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" FontSize="13"/>
                </DataTemplate>
            </Pivot.HeaderTemplate>

            <PivotItem Header="Body"/>
            <PivotItem Header="Headers"/>
        </Pivot>

        <!-- Row 4: Response content -->
        <ScrollViewer Grid.Row="4"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      CornerRadius="6" Padding="16"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1">

            <!-- Body tab -->
            <controls:JsonRichTextBlock
                       Visibility="{x:Bind ViewModel.SelectedResponseTab, Mode=OneWay, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=0}"
                       Text="{x:Bind ViewModel.ResponseBody, Mode=OneWay}"/>
        </ScrollViewer>

        <!-- Headers overlay (same grid row, swapped by visibility) -->
        <ScrollViewer Grid.Row="4"
                      Visibility="{x:Bind ViewModel.SelectedResponseTab, Mode=OneWay, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=1}"
                      VerticalScrollBarVisibility="Auto"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      CornerRadius="6" Padding="16"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1">
            <TextBlock Text="{x:Bind ViewModel.ResponseHeaders, Mode=OneWay}"
                       FontFamily="Cascadia Code, Consolas"
                       FontSize="12"
                       IsTextSelectionEnabled="True"
                       TextWrapping="Wrap"/>
        </ScrollViewer>

        <!-- Row 5: Status bar -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="16" Padding="0,4,0,0">
            <TextBlock Text="{x:Bind ViewModel.StatusCode, Mode=OneWay}"
                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Text="{x:Bind ViewModel.StatusTime, Mode=OneWay}" FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
            <TextBlock Text="{x:Bind ViewModel.StatusSize, Mode=OneWay}" FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
