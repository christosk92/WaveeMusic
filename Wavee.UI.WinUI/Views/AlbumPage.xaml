<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.AlbumPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:trackList="using:Wavee.UI.WinUI.Controls.TrackList"
    xmlns:tdg="using:Wavee.UI.WinUI.Controls.TrackDataGrid"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI.Media"
    xmlns:winUi="using:CommunityToolkit.WinUI"
    xmlns:lyrics="using:Wavee.Controls.Lyrics.Controls"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:contracts="using:Wavee.UI.WinUI.Data.Contracts"
    xmlns:controls1="using:Wavee.UI.WinUI.Controls"
    xmlns:shelf="using:Wavee.UI.WinUI.Controls.Shelf"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">
    <Grid x:Name="RootGrid" SizeChanged="RootGrid_SizeChanged">
        <!-- Responsive: driven by SizeChanged in code-behind -->
        <!-- Responsive layout: narrow hides the left panel, wide hides the inline header.
             Loading state (shimmer vs content) is controlled by IsLoading bindings, NOT by visual states. -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState">
                    <VisualState.Setters>
                        <Setter Target="NarrowAlbumHeader.Visibility" Value="Collapsed"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.Setters>
                        <Setter Target="WideAlbumPanel.Visibility" Value="Collapsed"/>
                        <Setter Target="ShimmerContainer.Visibility" Value="Collapsed"/>
                        <Setter Target="NarrowAlbumHeader.Visibility" Value="Visible"/>
                        <Setter Target="AlbumSplitter.Visibility" Value="Collapsed"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Blurred album art background (composition visual inserted in code-behind) -->
        <Border x:Name="BlurredBackground" Opacity="1"/>

        <!-- Two-column layout. TrackListView owns scrolling so row virtualization stays active. -->
        <Grid x:Name="TwoColumnGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="LeftPanelColumn" Width="280" MinWidth="200" MaxWidth="500"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Shimmer skeleton for left panel (visible while loading) -->
                    <StackPanel x:Name="ShimmerContainer" Grid.Column="0" Spacing="14"
                                HorizontalAlignment="Center" VerticalAlignment="Top" 
                                Padding="16,24"
                                MaxWidth="280"
                                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <controls:Shimmer Width="120" Height="16" HorizontalAlignment="Center"/>
                        <controls:Shimmer Width="240" Height="240" CornerRadius="8"/>
                        <controls:Shimmer Width="180" Height="20" HorizontalAlignment="Center"/>
                        <controls:Shimmer Width="150" Height="20" HorizontalAlignment="Center"/>
                        <controls:Shimmer Width="110" Height="14" HorizontalAlignment="Center"/>
                        <controls:Shimmer Width="130" Height="14" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <controls:Shimmer Width="48" Height="48" CornerRadius="24"/>
                            <controls:Shimmer Width="40" Height="40" CornerRadius="20"/>
                            <controls:Shimmer Width="40" Height="40" CornerRadius="20"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Left panel (sticky via Composition in code-behind) -->
                    <StackPanel x:Name="WideAlbumPanel" Grid.Column="0"
                                Padding="16,24" Spacing="14" HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">

                        <Grid MinHeight="20" HorizontalAlignment="Center">
                            <HyperlinkButton Content="{x:Bind ViewModel.ArtistName, Mode=OneWay}"
                                             Click="Artist_Click" Padding="0"
                                             HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                             Visibility="{x:Bind ViewModel.ArtistName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <controls:Shimmer Width="120" Height="16" HorizontalAlignment="Center"
                                              Visibility="{x:Bind ViewModel.ArtistName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                        </Grid>

                        <Grid HorizontalAlignment="Stretch">
                            <winUi:Effects.Shadow>
                                <ui:AttachedCardShadow BlurRadius="32" Offset="0,12" Opacity="0.28" Color="Black" CornerRadius="8" InnerContentClipMode="CompositionMaskBrush"/>
                            </winUi:Effects.Shadow>
                            <Border x:Name="AlbumArtContainer" CornerRadius="8"
                                    HorizontalAlignment="Stretch"
                                    SizeChanged="AlbumArtContainer_SizeChanged"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Grid>
                                    <lyrics:ShadowImage
                                        Source="{x:Bind ViewModel.AlbumImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='280'}"
                                        Stretch="UniformToFill"
                                        CornerRadiusAmount="8"
                                        ShadowAmount="0"
                                        Visibility="{x:Bind ViewModel.AlbumImageUrl, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <FontIcon Glyph="&#xE93C;" FontSize="64" Opacity="0.3"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Visibility="{x:Bind ViewModel.AlbumImageUrl, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <TextBlock Text="{x:Bind ViewModel.AlbumName, Mode=OneWay}"
                                   FontSize="20" FontWeight="Bold" TextAlignment="Center"
                                   TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4"
                                    Visibility="{x:Bind ViewModel.Year, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{x:Bind ViewModel.AlbumType, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="·" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.Year, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4"
                                    Visibility="{x:Bind ViewModel.TotalTracks, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind ViewModel.TotalTracks, Mode=OneWay}"/><Run x:Uid="Views_AlbumPage__Run_1" Text=" songs"/>
                            </TextBlock>
                            <TextBlock Text=" · " Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind ViewModel.TotalDuration, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalDuration, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind ViewModel.TotalDuration, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12"
                                    HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Button Style="{StaticResource AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.PlayAlbumCommand}" Padding="20,10" CornerRadius="20">
                                <FontIcon Glyph="&#xE768;" FontSize="18"/>
                            </Button>
                            <Button Command="{x:Bind ViewModel.ToggleSaveCommand}"
                                    Padding="10,8" Background="Transparent" BorderThickness="1">
                                <FontIcon Glyph="{x:Bind ViewModel.IsSaved, Mode=OneWay, Converter={StaticResource BoolToHeartGlyphConverter}}" FontSize="16"/>
                            </Button>
                            <Button Command="{x:Bind ViewModel.ShuffleAlbumCommand}"
                                    Padding="10,8" Background="Transparent" BorderThickness="1">
                                <FontIcon Glyph="&#xE8B1;" FontSize="16"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <controls1:GridSplitter
                        x:Name="AlbumSplitter"
                        Grid.Column="1"
                        Width="12"
                        ResizeCompleted="AlbumSplitter_ResizeCompleted"/>

                    <tdg:TrackDataGrid
                        x:Name="TrackGrid"
                        Grid.Column="2"
                        VerticalAlignment="Stretch"
                        Margin="0,0,0,0"
                        PageKey="album"
                        ShowToolbar="False"
                        AllowHorizontalRowScroll="False"
                        ItemsSource="{x:Bind ViewModel.FilteredTracks, Mode=OneWay}"
                        PlayCommand="{x:Bind ViewModel.PlayTrackCommand}">
                        <tdg:TrackDataGrid.FooterContent>
                            <StackPanel>
                                <!-- More by artist -->
                                <StackPanel x:Name="MoreByArtistSection" Margin="16,32,16,24" Spacing="12"
                                            Visibility="{x:Bind ViewModel.HasMoreByArtist, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource SubtitleTextBlockStyle}"
                                                   VerticalAlignment="Center">
                                            <Run x:Uid="Views_AlbumPage__Run_5" Text="More by "/><Run Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}"/>
                                        </TextBlock>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                                    Visibility="{x:Bind MoreByArtistShelf.HasOverflow, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Button Style="{StaticResource ShelfChevronButtonStyle}"
                                                    Command="{x:Bind MoreByArtistShelf.PageLeftCommand, Mode=OneTime}">
                                                <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                                            </Button>
                                            <Button Style="{StaticResource ShelfChevronButtonStyle}"
                                                    Command="{x:Bind MoreByArtistShelf.PageRightCommand, Mode=OneTime}">
                                                <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Grid wrapper + fade Border mirrors HomePage's shelf pattern
                                         so the right edge fades when more cards are available. -->
                                    <Grid HorizontalAlignment="Stretch">
                                        <shelf:ShelfScroller x:Name="MoreByArtistShelf"
                                                             HorizontalAlignment="Stretch"
                                                             ItemsSource="{x:Bind ViewModel.MoreByArtist, Mode=OneWay}"
                                                             MinItemWidth="160" MaxItemWidth="200" Spacing="12">
                                            <shelf:ShelfScroller.ItemTemplate>
                                                <DataTemplate x:DataType="contracts:AlbumRelatedResult">
                                                    <cards:ContentCard
                                                        Width="160"
                                                        Tag="{x:Bind}"
                                                        ImageUrl="{x:Bind ImageUrl}"
                                                        Title="{x:Bind Name}"
                                                        Subtitle="{x:Bind Year}"
                                                        NavigationUri="{x:Bind Uri}"
                                                        CardClick="RelatedAlbum_Click"/>
                                                </DataTemplate>
                                            </shelf:ShelfScroller.ItemTemplate>
                                        </shelf:ShelfScroller>
                                        <Border
                                            HorizontalAlignment="Right"
                                            Width="96"
                                            IsHitTestVisible="False"
                                            Background="{ThemeResource ShelfFadeRightBrush}"
                                            Visibility="{Binding ElementName=MoreByArtistShelf, Path=CanPageRight, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                </StackPanel>

                                <!-- No related releases: friendly empty state -->
                                <Border x:Name="NoRelatedSection"
                                        Margin="16,32,16,24"
                                        Padding="32,40"
                                        CornerRadius="12"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Stretch"
                                        Visibility="{x:Bind ViewModel.HasNoRelatedAlbums, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel HorizontalAlignment="Center" MaxWidth="440" Spacing="16">
                                        <Grid Width="64" Height="64"
                                              HorizontalAlignment="Center"
                                              CornerRadius="32"
                                              Background="{ThemeResource AccentFillColorTertiaryBrush}">
                                            <FontIcon Glyph="&#xE735;" FontSize="26"
                                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        </Grid>

                                        <TextBlock Text="One-of-a-kind"
                                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"/>

                                        <TextBlock TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Opacity="0.7"
                                                   MaxWidth="380"
                                                   Style="{StaticResource BodyTextBlockStyle}">
                                            <Run Text="Nothing else quite like it. Jump back into more from "/><Run Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}" FontWeight="SemiBold"/><Run Text=", or dip into your library."/>
                                        </TextBlock>

                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="12"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,8,0,0">
                                            <Button Style="{StaticResource AccentButtonStyle}"
                                                    Command="{x:Bind ViewModel.OpenArtistCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <FontIcon Glyph="&#xE77B;" FontSize="14"/>
                                                    <TextBlock>
                                                        <Run Text="Go to "/><Run Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{x:Bind ViewModel.OpenLikedSongsCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <FontIcon Glyph="&#xEB52;" FontSize="14"/>
                                                    <TextBlock Text="Liked Songs"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Merch -->
                                <StackPanel x:Name="MerchSection" Margin="16,32,16,24" Spacing="12"
                                            Visibility="{x:Bind ViewModel.HasMerch, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock x:Uid="Views_AlbumPage__TextBlock_6" Text="Merch" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.MerchItems, Mode=OneWay}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Orientation="Horizontal" Spacing="12"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="contracts:AlbumMerchItemResult">
                                                <cards:ContentCard
                                                    Width="160"
                                                    ImageUrl="{x:Bind ImageUrl}"
                                                    Title="{x:Bind Name}"
                                                    Subtitle="{x:Bind Price}"
                                                    CardClick="MerchItem_Click"/>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>

                                <!-- Album info: release date, label, copyrights -->
                                <StackPanel Margin="16,24,16,16" Spacing="6"
                                            Visibility="{x:Bind ViewModel.ReleaseDateFormatted, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="{x:Bind ViewModel.ReleaseDateFormatted, Mode=OneWay}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.Label, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Visibility="{x:Bind ViewModel.Label, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
                                    <TextBlock Text="{x:Bind ViewModel.CopyrightsText, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               Visibility="{x:Bind ViewModel.CopyrightsText, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
                                </StackPanel>
                            </StackPanel>
                        </tdg:TrackDataGrid.FooterContent>
                    </tdg:TrackDataGrid>

                    <!-- Legacy TrackListView host kept hidden so CustomColumns + event handlers
                         in AlbumPage.xaml.cs continue to reference a live control. -->
                    <trackList:TrackListView
                        x:Name="TrackList"
                        Grid.Column="2" VerticalAlignment="Top"
                        Visibility="Collapsed"
                        Margin="0,24,0,0"
                        ViewModel="{x:Bind ViewModel, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.FilteredTracks, Mode=OneWay}"
                        IsLoading="False"
                        HeaderBackground="Transparent"
                        HasError="{x:Bind ViewModel.HasError, Mode=OneWay}"
                        ErrorMessage="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                        RetryCommand="{x:Bind ViewModel.RetryCommand}"
                        ShowAlbumColumn="False"
                        ShowAlbumArtColumn="False"
                        ShowDateAddedColumn="False"
                        ShowArtistColumn="False"
                        PlaceholderColorHex="{x:Bind ViewModel.ColorHex, Mode=OneWay}"
                        RemoveActionLabel="Remove from library"
                        ArtistClicked="TrackList_ArtistClicked"
                        NewPlaylistRequested="TrackList_NewPlaylistRequested">

                        <!-- CustomColumns set in code-behind with ValueSelector (no reflection) -->

                        <!-- NARROW MODE: Compact header -->
                        <trackList:TrackListView.HeaderContent>
                            <Grid x:Name="NarrowAlbumHeader" Padding="8,20,8,16" Visibility="Visible">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Width="140" Height="140" Margin="0,0,24,0">
                                    <winUi:Effects.Shadow>
                                        <ui:AttachedCardShadow BlurRadius="20" Offset="0,8" Opacity="0.22" Color="Black" CornerRadius="8" InnerContentClipMode="CompositionMaskBrush"/>
                                    </winUi:Effects.Shadow>
                                    <Border Width="140" Height="140" CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <Grid>
                                            <lyrics:ShadowImage
                                                Source="{x:Bind ViewModel.AlbumImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='140'}"
                                                Stretch="UniformToFill"
                                                CornerRadiusAmount="8"
                                                ShadowAmount="0"
                                                Visibility="{x:Bind ViewModel.AlbumImageUrl, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <FontIcon Glyph="&#xE93C;" FontSize="48" Opacity="0.3"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Visibility="{x:Bind ViewModel.AlbumImageUrl, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ViewModel.AlbumType, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontWeight="SemiBold" CharacterSpacing="50"/>
                                    <TextBlock Text="{x:Bind ViewModel.AlbumName, Mode=OneWay}"
                                               FontSize="24" FontWeight="Bold" MaxLines="2"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <HyperlinkButton Content="{x:Bind ViewModel.ArtistName, Mode=OneWay}"
                                                     Click="Artist_Click" Padding="0" FontSize="14" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4"
                                                Visibility="{x:Bind ViewModel.Year, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{x:Bind ViewModel.Year, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text=" · " Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{x:Bind ViewModel.TotalTracks, Mode=OneWay}"/><Run x:Uid="Views_AlbumPage__Run_2" Text=" songs"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                        <Button Style="{StaticResource AccentButtonStyle}"
                                                Command="{x:Bind ViewModel.PlayAlbumCommand}" Padding="16,8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE768;" FontSize="14"/>
                                                <TextBlock x:Uid="Views_AlbumPage__TextBlock_3" Text="Play"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{x:Bind ViewModel.ShuffleAlbumCommand}" Padding="16,8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE8B1;" FontSize="14"/>
                                                <TextBlock x:Uid="Views_AlbumPage__TextBlock_4" Text="Shuffle"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{x:Bind ViewModel.ToggleSaveCommand}" Padding="12,8">
                                            <FontIcon Glyph="{x:Bind ViewModel.IsSaved, Mode=OneWay, Converter={StaticResource BoolToHeartGlyphConverter}}" FontSize="16"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </trackList:TrackListView.HeaderContent>

                        <trackList:TrackListView.EmptyStateContent>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                <FontIcon Glyph="&#xE93C;" FontSize="48" Opacity="0.3"/>
                                <TextBlock x:Uid="Views_AlbumPage__TextBlock_7" Text="No tracks available" Style="{StaticResource BodyTextBlockStyle}"
                                           Opacity="0.5" TextAlignment="Center"/>
                            </StackPanel>
                        </trackList:TrackListView.EmptyStateContent>
                    </trackList:TrackListView>

        </Grid>
    </Grid>
</Page>
