<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.StartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollView VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="48">

            <StackPanel
                MaxWidth="800"
                Margin="48,80,48,0"
                HorizontalAlignment="Center"
                Spacing="48">

                <!-- Header Section -->
                <StackPanel Spacing="24" HorizontalAlignment="Center">
                    <TextBlock x:Uid="Views_StartPage__TextBlock_1"
                        Text="What are you looking for?"
                        Style="{StaticResource TitleLargeTextBlockStyle}"
                        FontSize="32"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"/>

                    <!-- Search Box -->
                    <AutoSuggestBox x:Uid="Views_StartPage__AutoSuggestBox_2"
                        x:Name="SearchBox"
                        Width="400"
                        PlaceholderText="Search songs, artists, albums..."
                        QueryIcon="Find"
                        QuerySubmitted="SearchBox_QuerySubmitted"/>
                </StackPanel>

                <!-- Quick Access Section -->
                <StackPanel Spacing="16">
                    <TextBlock x:Uid="Views_StartPage__TextBlock_3"
                        Text="Quick Access"
                        Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.QuickAccessItems}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                MinItemWidth="150"
                                MinItemHeight="100"
                                MinColumnSpacing="12"
                                MinRowSpacing="12"
                                ItemsStretch="Fill"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:QuickAccessItem">
                                <Button
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Padding="16"
                                    CornerRadius="8"
                                    Click="QuickAccess_Click"
                                    Tag="{x:Bind}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <FontIcon
                                            Glyph="{x:Bind Glyph}"
                                            FontSize="28"/>
                                        <TextBlock
                                            Text="{x:Bind Title}"
                                            FontSize="14"
                                            FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>

            <!-- Recently Played Section: full width, adaptive like homepage -->
            <controls:RecentlyPlayedSection Margin="48,0,48,48"/>

        </StackPanel>
    </ScrollView>
</Page>
