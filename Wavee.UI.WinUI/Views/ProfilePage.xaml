<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:http="using:Wavee.Core.Http"
    xmlns:pathfinder="using:Wavee.Core.Http.Pathfinder"
    xmlns:layouts="using:Wavee.UI.WinUI.Controls.Layouts"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:trackList="using:Wavee.UI.WinUI.Controls.TrackList"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollView>
        <StackPanel>

            <!-- ===== Hero Banner with gradient from extracted color ===== -->
            <Grid x:Name="HeroBanner" MinHeight="340" HorizontalAlignment="Stretch">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop x:Name="HeroColorTop" Color="Transparent" Offset="0"/>
                        <GradientStop x:Name="HeroColorMid" Color="Transparent" Offset="0.6"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <StackPanel Orientation="Horizontal" Spacing="24" Padding="32,40"
                            VerticalAlignment="Bottom">
                    <!-- Large circular profile avatar -->
                    <PersonPicture x:Name="ProfileAvatar" Width="192" Height="192"
                                   DisplayName="{x:Bind ViewModel.DisplayName, Mode=OneWay}"/>

                    <!-- Name + stats -->
                    <StackPanel Spacing="8" VerticalAlignment="Bottom" Padding="0,0,0,8">
                        <TextBlock Text="Profile"
                                   Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7"/>
                        <TextBlock Text="{x:Bind ViewModel.DisplayName, Mode=OneWay}"
                                   FontSize="48" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.7">
                            <TextBlock Style="{StaticResource BodyTextBlockStyle}">
                                <Run Text="{x:Bind ViewModel.PublicPlaylistCount, Mode=OneWay}"/>
                                <Run Text=" Public Playlists"/>
                            </TextBlock>
                            <TextBlock Text="&#x00B7;" Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock Style="{StaticResource BodyTextBlockStyle}">
                                <Run Text="{x:Bind ViewModel.FollowingCount, Mode=OneWay}"/>
                                <Run Text=" Following"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ===== Loading shimmer skeletons ===== -->
            <StackPanel x:Name="ShimmerContainer"
                        Padding="32,0,32,32" Spacing="32" Margin="0,-30,0,0">

                <!-- Artist section skeleton -->
                <StackPanel Spacing="12">
                    <controls:Shimmer Width="220" Height="22" HorizontalAlignment="Left"/>
                    <controls:Shimmer Width="140" Height="14" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="150" Height="150" CornerRadius="75"/>
                            <controls:Shimmer Width="80" Height="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="150" Height="150" CornerRadius="75"/>
                            <controls:Shimmer Width="100" Height="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="150" Height="150" CornerRadius="75"/>
                            <controls:Shimmer Width="90" Height="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="150" Height="150" CornerRadius="75"/>
                            <controls:Shimmer Width="70" Height="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="150" Height="150" CornerRadius="75"/>
                            <controls:Shimmer Width="110" Height="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Track list skeleton -->
                <StackPanel Spacing="12">
                    <controls:Shimmer Width="200" Height="22" HorizontalAlignment="Left"/>
                    <controls:Shimmer Width="130" Height="14" HorizontalAlignment="Left"/>
                    <StackPanel Spacing="4">
                        <Grid Height="56" Padding="8,0" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/><ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="16" Height="16"/>
                            <controls:Shimmer Grid.Column="1" Width="40" Height="40" CornerRadius="4"/>
                            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                                <controls:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="100" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <controls:Shimmer Grid.Column="3" Width="40" Height="14"/>
                        </Grid>
                        <Grid Height="56" Padding="8,0" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/><ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="16" Height="16"/>
                            <controls:Shimmer Grid.Column="1" Width="40" Height="40" CornerRadius="4"/>
                            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                                <controls:Shimmer Width="220" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="120" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <controls:Shimmer Grid.Column="3" Width="40" Height="14"/>
                        </Grid>
                        <Grid Height="56" Padding="8,0" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/><ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="16" Height="16"/>
                            <controls:Shimmer Grid.Column="1" Width="40" Height="40" CornerRadius="4"/>
                            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                                <controls:Shimmer Width="160" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="90" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <controls:Shimmer Grid.Column="3" Width="40" Height="14"/>
                        </Grid>
                        <Grid Height="56" Padding="8,0" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/><ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="16" Height="16"/>
                            <controls:Shimmer Grid.Column="1" Width="40" Height="40" CornerRadius="4"/>
                            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                                <controls:Shimmer Width="200" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="110" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <controls:Shimmer Grid.Column="3" Width="40" Height="14"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Playlist section skeleton -->
                <StackPanel Spacing="12">
                    <controls:Shimmer Width="180" Height="22" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="150" Height="150" CornerRadius="8"/>
                            <controls:Shimmer Width="100" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="60" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="150" Height="150" CornerRadius="8"/>
                            <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="60" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="150" Height="150" CornerRadius="8"/>
                            <controls:Shimmer Width="90" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="60" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="150" Height="150" CornerRadius="8"/>
                            <controls:Shimmer Width="110" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="60" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- ===== Content sections (negative margin to overlap gradient) ===== -->
            <StackPanel x:Name="ContentContainer" Padding="32,0,32,32" Spacing="32" Margin="0,-30,0,0">

                <!-- ────────────────────────────────────────────── -->
                <!-- Section 1: Top Artists This Month              -->
                <!-- ────────────────────────────────────────────── -->
                <StackPanel Spacing="16">
                    <Grid Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Top artists this month" FontWeight="Bold" FontSize="20"/>
                            <TextBlock Text="Only visible to you"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <HyperlinkButton Content="Show all" HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.RecentArtists, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <layouts:SingleRowLayout MinItemWidth="160" Spacing="12"/>
                        </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="http:SpotifyProfileArtist">
                                    <cards:ContentCard
                                        ImageUrl="{x:Bind ImageUrl}"
                                        Title="{x:Bind Name}"
                                        Subtitle="Artist"
                                        PlaceholderGlyph="&#xE77B;"
                                        IsCircularImage="True"
                                        CenterText="True"
                                        NavigationUri="{x:Bind Uri}"
                                        NavigationTitle="{x:Bind Name}"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- ────────────────────────────────────────────── -->
                <!-- Section 2: Top Tracks This Month               -->
                <!-- ────────────────────────────────────────────── -->
                <StackPanel Spacing="16">
                    <Grid Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Top tracks this month" FontWeight="Bold" FontSize="20"/>
                            <TextBlock Text="Only visible to you"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <HyperlinkButton Content="Show all" HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>

                    <trackList:TrackListView
                        ViewModel="{x:Bind ViewModel, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.TopTrackItems, Mode=OneWay}"
                        IsCompact="False"
                        ShowColumnHeaders="False"
                        ShowAlbumArtColumn="True"
                        ShowAlbumColumn="True"
                        ShowArtistColumn="False"
                        ShowDateAddedColumn="False"
                        IsLoading="False"/>
                </StackPanel>

                <!-- ────────────────────────────────────────────── -->
                <!-- Section 3: Public Playlists                    -->
                <!-- ────────────────────────────────────────────── -->
                <StackPanel Spacing="16">
                    <Grid Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" FontSize="20">
                                <Run Text="Public Playlists"/>
                            </TextBlock>
                        </StackPanel>
                        <HyperlinkButton Content="Show all" HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.PublicPlaylists, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <layouts:SingleRowLayout MinItemWidth="160" Spacing="12"/>
                        </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="http:SpotifyProfilePlaylist">
                                    <cards:ContentCard
                                        ImageUrl="{x:Bind ImageUrl}"
                                        Title="{x:Bind Name}"
                                        Subtitle="{x:Bind OwnerName}"
                                        IsCircularImage="False"
                                        NavigationUri="{x:Bind Uri}"
                                        NavigationTitle="{x:Bind Name}"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- ────────────────────────────────────────────── -->
                <!-- Section 4: Following                           -->
                <!-- ────────────────────────────────────────────── -->
                <StackPanel Spacing="16">
                    <Grid Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" FontSize="20">
                                <Run Text="Following"/>
                            </TextBlock>
                        </StackPanel>
                        <HyperlinkButton Content="Show all" HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.FollowingArtists, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <layouts:SingleRowLayout MinItemWidth="160" Spacing="12"/>
                        </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="http:SpotifyProfileArtist">
                                    <cards:ContentCard
                                        ImageUrl="{x:Bind ImageUrl}"
                                        Title="{x:Bind Name}"
                                        Subtitle="Artist"
                                        PlaceholderGlyph="&#xE77B;"
                                        IsCircularImage="True"
                                        CenterText="True"
                                        NavigationUri="{x:Bind Uri}"
                                        NavigationTitle="{x:Bind Name}"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Sign out link -->
                <HyperlinkButton Content="Sign out of Spotify" HorizontalAlignment="Center"
                                 Command="{x:Bind ViewModel.SignOutCommand}"
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                 Margin="0,16,0,0"/>
            </StackPanel>
        </StackPanel>
    </ScrollView>
</Page>
