<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:layouts="using:Wavee.UI.WinUI.Controls.Layouts"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:pathfinder="using:Wavee.Core.Http.Pathfinder"
    xmlns:search="using:Wavee.UI.WinUI.Controls.Search"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Disabled"
    Background="Transparent">

    <ScrollView VerticalScrollBarVisibility="Auto" ContentOrientation="Vertical">
        <StackPanel x:Name="RootPanel" Padding="20,18,20,28" Spacing="0">

            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                          HorizontalScrollMode="Enabled"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="0,0,0,18">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <RadioButton x:Name="FilterAll" Content="All" GroupName="SearchFilter"
                                 IsChecked="True" Click="FilterChip_Click" Tag="All"
                                 Style="{StaticResource DefaultToggleButtonStyle}"
                                 CornerRadius="19" MinHeight="38" MinWidth="0" Padding="18,8"/>
                    <RadioButton x:Uid="Views_SearchPage__RadioButton_1" x:Name="FilterSongs" Content="Songs" GroupName="SearchFilter"
                                 Click="FilterChip_Click" Tag="Songs"
                                 Style="{StaticResource DefaultToggleButtonStyle}"
                                 CornerRadius="19" MinHeight="38" MinWidth="0" Padding="18,8"/>
                    <RadioButton x:Uid="Views_SearchPage__RadioButton_2" x:Name="FilterArtists" Content="Artists" GroupName="SearchFilter"
                                 Click="FilterChip_Click" Tag="Artists"
                                 Style="{StaticResource DefaultToggleButtonStyle}"
                                 CornerRadius="19" MinHeight="38" MinWidth="0" Padding="18,8"/>
                    <RadioButton x:Uid="Views_SearchPage__RadioButton_4" x:Name="FilterPlaylists" Content="Playlists" GroupName="SearchFilter"
                                 Click="FilterChip_Click" Tag="Playlists"
                                 Style="{StaticResource DefaultToggleButtonStyle}"
                                 CornerRadius="19" MinHeight="38" MinWidth="0" Padding="18,8"/>
                    <RadioButton x:Uid="Views_SearchPage__RadioButton_3" x:Name="FilterAlbums" Content="Albums" GroupName="SearchFilter"
                                 Click="FilterChip_Click" Tag="Albums"
                                 Style="{StaticResource DefaultToggleButtonStyle}"
                                 CornerRadius="19" MinHeight="38" MinWidth="0" Padding="18,8"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Spacing="10">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="24">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <toolkit:Shimmer Width="96" Height="96" CornerRadius="18"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="10">
                            <toolkit:Shimmer Width="220" Height="18" CornerRadius="6" HorizontalAlignment="Left"/>
                            <toolkit:Shimmer Width="360" Height="34" CornerRadius="8" HorizontalAlignment="Left"/>
                            <toolkit:Shimmer Width="240" Height="14" CornerRadius="4" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <toolkit:Shimmer Grid.Column="2" Width="64" Height="64" CornerRadius="32" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <toolkit:Shimmer Width="56" Height="56" CornerRadius="14"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <toolkit:Shimmer Width="260" Height="16" CornerRadius="5" HorizontalAlignment="Left"/>
                                <toolkit:Shimmer Width="180" Height="12" CornerRadius="4" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <toolkit:Shimmer Grid.Column="2" Width="72" Height="28" CornerRadius="14" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <toolkit:Shimmer Width="56" Height="56" CornerRadius="14"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <toolkit:Shimmer Width="220" Height="16" CornerRadius="5" HorizontalAlignment="Left"/>
                                <toolkit:Shimmer Width="150" Height="12" CornerRadius="4" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <toolkit:Shimmer Grid.Column="2" Width="72" Height="28" CornerRadius="14" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <toolkit:Shimmer Width="56" Height="56" CornerRadius="14"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <toolkit:Shimmer Width="240" Height="16" CornerRadius="5" HorizontalAlignment="Left"/>
                                <toolkit:Shimmer Width="172" Height="12" CornerRadius="4" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <toolkit:Shimmer Grid.Column="2" Width="72" Height="28" CornerRadius="14" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="10"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <search:SearchResultHeroCard x:Name="TopResultCard"
                                            
                                             Margin="0,0,0,10"
                                             Item="{x:Bind ViewModel.TopResult, Mode=OneWay}"
                                             Tapped="TopResult_Tapped"
                                             Visibility="{x:Bind ViewModel.ShowHeroCard, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!--
                    Horizontal adaptive rows for SearchSectionEntity groups
                    (e.g. "Featuring JJ Lin" playlists, "Music videos" video tracks).
                    Reuses the HomePage pattern: ContentCard inside a SingleRowLayout
                    ItemsRepeater with MinItemWidth=160, MaxItemWidth=200, Spacing=12.
                    Only visible on the "All" filter — specific filters show section
                    items inline in the flat list instead.
                -->
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Sections, Mode=OneWay}"
                               Margin="0,8,0,0"
                               Visibility="{x:Bind ViewModel.ShowSections, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="24"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:SearchSectionViewModel">
                            <StackPanel>
                                <TextBlock Text="{x:Bind Title}"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           FontWeight="Bold"
                                           Margin="0,0,0,12"/>
                                <ItemsRepeater ItemsSource="{x:Bind Items}">
                                    <ItemsRepeater.Layout>
                                        <layouts:SingleRowLayout MinItemWidth="160" MaxItemWidth="200" Spacing="12"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="pathfinder:SearchResultItem">
                                            <cards:ContentCard
                                                ImageUrl="{x:Bind ImageUrl}"
                                                Title="{x:Bind Name}"
                                                Subtitle="{x:Bind DisplaySubtitle}"
                                                IsCircularImage="False"
                                                NavigationUri="{x:Bind Uri}"
                                                NavigationTitle="{x:Bind Name}"/>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.VisibleResults, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.HasVisibleResults, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="pathfinder:SearchResultItem">
                            <search:SearchResultRowCard Item="{x:Bind}" Tapped="ResultRow_Tapped"/>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <controls:ErrorStateView
                    Margin="0,40,0,0"
                    Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    Title="{x:Bind ViewModel.ErrorTitle, Mode=OneWay}"
                    Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    RetryCommand="{x:Bind ViewModel.RetryCommand}"/>

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Margin="0,40,0,0"
                    Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <FontIcon Glyph="&#xE721;" FontSize="48" Opacity="0.3"/>
                    <TextBlock Text="{x:Bind ViewModel.EmptyStateMessage, Mode=OneWay}"
                               HorizontalAlignment="Center"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.5"
                               TextAlignment="Center"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollView>
</Page>
