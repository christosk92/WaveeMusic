<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pathfinder="using:Wavee.Core.Http.Pathfinder"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Disabled"
    Background="Transparent">

    <ScrollView VerticalScrollBarVisibility="Auto" ContentOrientation="Vertical">
        <StackPanel x:Name="RootPanel" Padding="20,18,20,28" Spacing="0">

            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                          HorizontalScrollMode="Enabled"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="0,0,0,18">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <RadioButton x:Name="FilterAll" Content="All" GroupName="SearchFilter"
                                 IsChecked="True" Click="FilterChip_Click" Tag="All"
                                 Style="{StaticResource DefaultToggleButtonStyle}"
                                 CornerRadius="19" MinHeight="38" MinWidth="0" Padding="18,8"/>
                    <RadioButton x:Uid="Views_SearchPage__RadioButton_1" x:Name="FilterSongs" Content="Songs" GroupName="SearchFilter"
                                 Click="FilterChip_Click" Tag="Songs"
                                 Style="{StaticResource DefaultToggleButtonStyle}"
                                 CornerRadius="19" MinHeight="38" MinWidth="0" Padding="18,8"/>
                    <RadioButton x:Uid="Views_SearchPage__RadioButton_2" x:Name="FilterArtists" Content="Artists" GroupName="SearchFilter"
                                 Click="FilterChip_Click" Tag="Artists"
                                 Style="{StaticResource DefaultToggleButtonStyle}"
                                 CornerRadius="19" MinHeight="38" MinWidth="0" Padding="18,8"/>
                    <RadioButton x:Uid="Views_SearchPage__RadioButton_4" x:Name="FilterPlaylists" Content="Playlists" GroupName="SearchFilter"
                                 Click="FilterChip_Click" Tag="Playlists"
                                 Style="{StaticResource DefaultToggleButtonStyle}"
                                 CornerRadius="19" MinHeight="38" MinWidth="0" Padding="18,8"/>
                    <RadioButton x:Uid="Views_SearchPage__RadioButton_3" x:Name="FilterAlbums" Content="Albums" GroupName="SearchFilter"
                                 Click="FilterChip_Click" Tag="Albums"
                                 Style="{StaticResource DefaultToggleButtonStyle}"
                                 CornerRadius="19" MinHeight="38" MinWidth="0" Padding="18,8"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Spacing="10">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="24">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <toolkit:Shimmer Width="96" Height="96" CornerRadius="18"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="10">
                            <toolkit:Shimmer Width="220" Height="18" CornerRadius="6" HorizontalAlignment="Left"/>
                            <toolkit:Shimmer Width="360" Height="34" CornerRadius="8" HorizontalAlignment="Left"/>
                            <toolkit:Shimmer Width="240" Height="14" CornerRadius="4" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <toolkit:Shimmer Grid.Column="2" Width="64" Height="64" CornerRadius="32" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <toolkit:Shimmer Width="56" Height="56" CornerRadius="14"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <toolkit:Shimmer Width="260" Height="16" CornerRadius="5" HorizontalAlignment="Left"/>
                                <toolkit:Shimmer Width="180" Height="12" CornerRadius="4" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <toolkit:Shimmer Grid.Column="2" Width="72" Height="28" CornerRadius="14" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <toolkit:Shimmer Width="56" Height="56" CornerRadius="14"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <toolkit:Shimmer Width="220" Height="16" CornerRadius="5" HorizontalAlignment="Left"/>
                                <toolkit:Shimmer Width="150" Height="12" CornerRadius="4" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <toolkit:Shimmer Grid.Column="2" Width="72" Height="28" CornerRadius="14" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <toolkit:Shimmer Width="56" Height="56" CornerRadius="14"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <toolkit:Shimmer Width="240" Height="16" CornerRadius="5" HorizontalAlignment="Left"/>
                                <toolkit:Shimmer Width="172" Height="12" CornerRadius="4" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <toolkit:Shimmer Grid.Column="2" Width="72" Height="28" CornerRadius="14" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="10"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Border x:Name="TopResultCard"
                        Margin="0,0,0,10"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderThickness="0"
                        CornerRadius="26"
                        Padding="22"
                        Tapped="TopResult_Tapped"
                        PointerEntered="InteractiveCard_PointerEntered"
                        PointerExited="InteractiveCard_PointerExited"
                        Visibility="{x:Bind ViewModel.ShowHeroCard, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="104"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Width="104" Height="104">
                            <Border Background="{ThemeResource CardBackgroundFillColorTertiaryBrush}"
                                    CornerRadius="20"/>
                            <FontIcon Glyph="{x:Bind ViewModel.TopResult.GetPlaceholderGlyph(), Mode=OneWay}"
                                      FontSize="28"
                                      Opacity="0.4"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            <Image Source="{x:Bind ViewModel.TopResult.ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=160}"
                                   Stretch="UniformToFill"
                                   Width="104"
                                   Height="104"/>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="10">
                            <Border Background="{ThemeResource CardBackgroundFillColorTertiaryBrush}"
                                    CornerRadius="12"
                                    Padding="9,4"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{x:Bind ViewModel.TopResult.GetTypeTag(), Mode=OneWay}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Border>

                            <TextBlock Text="{x:Bind ViewModel.TopResult.Name, Mode=OneWay}"
                                       FontSize="38"
                                       FontWeight="Bold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Text="{x:Bind ViewModel.TopResult.GetSubtitle(), Mode=OneWay}"
                                       FontSize="17"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Width="64"
                                Height="64"
                                CornerRadius="32"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                            <FontIcon Glyph="{x:Bind ViewModel.TopResult.GetActionGlyph(), Mode=OneWay}"
                                      FontSize="22"
                                      Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.VisibleResults, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.HasVisibleResults, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="pathfinder:SearchResultItem">
                            <Border x:Name="ResultRowCard"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Padding="10,8"
                                    Tag="{x:Bind}"
                                    Tapped="ResultRow_Tapped"
                                    PointerEntered="InteractiveCard_PointerEntered"
                                    PointerExited="InteractiveCard_PointerExited">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Width="52" Height="52">
                                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                CornerRadius="14"/>
                                        <FontIcon Glyph="{x:Bind GetPlaceholderGlyph(), Mode=OneWay}"
                                                  FontSize="17"
                                                  Opacity="0.32"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        <Image Source="{x:Bind ImageUrl, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=64}"
                                               Stretch="UniformToFill"
                                               Width="52"
                                               Height="52"/>
                                    </Grid>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{x:Bind Name}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind GetSubtitle(), Mode=OneWay}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Background="{ThemeResource CardBackgroundFillColorTertiaryBrush}"
                                            CornerRadius="12"
                                            Padding="9,4"
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0"
                                            IsHitTestVisible="False">
                                        <TextBlock Text="{x:Bind GetTypeTag(), Mode=OneWay}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Border>

                                    <Border Grid.Column="3"
                                            Width="28"
                                            Height="28"
                                            CornerRadius="14"
                                            Background="Transparent"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Margin="12,0,0,0"
                                            IsHitTestVisible="False">
                                        <FontIcon Glyph="{x:Bind GetActionGlyph(), Mode=OneWay}"
                                                  FontSize="16"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Margin="0,40,0,0"
                    Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <FontIcon Glyph="&#xE783;" FontSize="48" Opacity="0.3"/>
                    <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                               HorizontalAlignment="Center"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.5"/>
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Margin="0,40,0,0"
                    Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <FontIcon Glyph="&#xE721;" FontSize="48" Opacity="0.3"/>
                    <TextBlock Text="{x:Bind ViewModel.EmptyStateMessage, Mode=OneWay}"
                               HorizontalAlignment="Center"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.5"
                               TextAlignment="Center"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollView>
</Page>
