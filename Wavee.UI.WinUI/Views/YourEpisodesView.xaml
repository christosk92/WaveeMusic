<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Views.YourEpisodesView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:appcontrols="using:Wavee.UI.WinUI.Controls"
    xmlns:comments="using:Wavee.UI.WinUI.Controls.Comments"
    xmlns:tdg="using:Wavee.UI.WinUI.Controls.TrackDataGrid"
    xmlns:dto="using:Wavee.UI.WinUI.Data.DTOs"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    mc:Ignorable="d"
    Background="Transparent">

    <UserControl.Resources>
        <DataTemplate x:Key="PodcastShowItemTemplate" x:DataType="dto:LibraryPodcastShowDto">
            <Grid Padding="8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Width="44"
                    Height="44"
                    CornerRadius="6"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid>
                        <FontIcon
                            Glyph="{x:Bind PlaceholderGlyph}"
                            FontSize="18"
                            Opacity="0.35"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                        <Image
                            Source="{x:Bind ImageUrl, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='88'}"
                            Stretch="UniformToFill"
                            Visibility="{x:Bind ImageUrl, Converter={StaticResource NullToVisibilityConverter}}"
                            behaviors:ImageFallbackBehavior.HideOnError="True"
                            behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                            behaviors:ImageFallbackBehavior.DecodePixelWidth="88"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock
                        Text="{x:Bind Name}"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="1"/>
                    <TextBlock
                        Text="{x:Bind Metadata}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="1"/>
                </StackPanel>

                <Border
                    Grid.Column="2"
                    MinWidth="24"
                    Height="20"
                    Padding="6,0"
                    CornerRadius="10"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind HasSavedEpisodes, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock
                        Text="{x:Bind SavedEpisodeCount}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="EpisodeGroupTemplate" x:DataType="vm:PodcastEpisodeGroupViewModel">
            <StackPanel Spacing="8">
                <Button
                    Command="{x:Bind ToggleExpandedCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Visibility="{x:Bind ShowHeader, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border
                        Grid.Column="0"
                        Width="36"
                        Height="36"
                        CornerRadius="5"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Grid>
                                <FontIcon
                                Glyph="&#xEC05;"
                                FontSize="15"
                                Opacity="0.35"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                                <Image
                                Source="{x:Bind ImageUrl, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='72'}"
                                Stretch="UniformToFill"
                                Visibility="{x:Bind ImageUrl, Converter={StaticResource NullToVisibilityConverter}}"
                                behaviors:ImageFallbackBehavior.HideOnError="True"
                                behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                behaviors:ImageFallbackBehavior.DecodePixelWidth="72"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                            <TextBlock
                            Text="{x:Bind Title}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="1"/>
                            <TextBlock
                            Text="{x:Bind Summary}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="1"/>
                        </StackPanel>
                        <FontIcon
                        Grid.Column="2"
                        Glyph="{x:Bind ExpandGlyph, Mode=OneWay}"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <tdg:TrackDataGrid
                    PageKey="podcasts"
                    ShowToolbar="False"
                    UseCardRows="True"
                    AllowHorizontalRowScroll="False"
                    ItemsSource="{x:Bind Episodes}"
                    PlayCommand="{x:Bind PlayEpisodeCommand}"
                    SelectionChangedCommand="{x:Bind SelectEpisodeCommand}"
                    Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    Loaded="EpisodeGroupGrid_Loaded"
                    Unloaded="EpisodeGroupGrid_Unloaded"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="EpisodeRecommendationTemplate" x:DataType="dto:PodcastEpisodeRecommendationDto">
            <Grid Padding="0,6" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="44"
                    Height="44"
                    CornerRadius="6"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid>
                        <FontIcon
                            Glyph="&#xEC05;"
                            FontSize="18"
                            Opacity="0.35"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                        <Image
                            Source="{x:Bind ImageUrl, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='88'}"
                            Stretch="UniformToFill"
                            Visibility="{x:Bind ImageUrl, Converter={StaticResource NullToVisibilityConverter}}"
                            behaviors:ImageFallbackBehavior.HideOnError="True"
                            behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                            behaviors:ImageFallbackBehavior.DecodePixelWidth="88"/>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock
                        Text="{x:Bind Title}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="2"/>
                    <TextBlock
                        Text="{x:Bind Subtitle}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="1"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <Style x:Key="EpisodeCommentReactionChipStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <DataTemplate x:Key="EpisodeReplyTemplate" x:DataType="vm:PodcastReplyViewModel">
            <Grid Padding="0,6" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <PersonPicture Grid.Column="0"
                               Width="28" Height="28"
                               VerticalAlignment="Top"
                               DisplayName="{x:Bind Data.AuthorName}"
                               ProfilePicture="{x:Bind Data.AuthorImageUrl, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='56'}"/>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                               Style="{StaticResource CaptionTextBlockStyle}">
                        <Run Text="{x:Bind Data.AuthorName}" FontWeight="SemiBold"
                             Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <Run Text=" · "
                             Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <Run Text="{x:Bind Data.CreatedAtFormatted}"
                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>
                    <TextBlock
                        Text="{x:Bind Data.Text}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        TextWrapping="Wrap"
                        MaxLines="6"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button
                            Padding="0"
                            MinHeight="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="ShowCommentReactionsButton_Click"
                            Visibility="{x:Bind HasReactions, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Style="{StaticResource EpisodeCommentReactionChipStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind TopReactionEmojiString}"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind ReactionsLabel}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                        <Button
                            Content="React"
                            Padding="8,3"
                            MinHeight="0"
                            IsEnabled="{x:Bind CanReact, Mode=OneWay}">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="&#x2764;&#xFE0F;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x2764;&#xFE0F;"/>
                                    <MenuFlyoutItem Text="&#x1F602;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F602;"/>
                                    <MenuFlyoutItem Text="&#x1F62E;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F62E;"/>
                                    <MenuFlyoutItem Text="&#x1F44E;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F44E;"/>
                                    <MenuFlyoutItem Text="&#x1F44F;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F44F;"/>
                                    <MenuFlyoutItem Text="&#x1F525;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F525;"/>
                                    <MenuFlyoutItem Text="&#x1F44D;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F44D;"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="EpisodeCommentTemplate" x:DataType="vm:PodcastCommentViewModel">
            <Grid Padding="0,10" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <PersonPicture Grid.Column="0"
                               Width="36" Height="36"
                               VerticalAlignment="Top"
                               DisplayName="{x:Bind Data.AuthorName}"
                               ProfilePicture="{x:Bind Data.AuthorImageUrl, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='72'}"/>
                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                               Style="{StaticResource CaptionTextBlockStyle}">
                        <Run Text="{x:Bind Data.AuthorName}"
                             FontWeight="SemiBold"
                             Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <Run Text=" · "
                             Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <Run Text="{x:Bind Data.CreatedAtFormatted}"
                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>

                    <TextBlock
                        Text="{x:Bind Data.Text}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button
                            Padding="0"
                            MinHeight="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="ShowCommentReactionsButton_Click"
                            Visibility="{x:Bind HasReactions, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Style="{StaticResource EpisodeCommentReactionChipStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind TopReactionEmojiString}"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind ReactionsLabel}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                        <Button
                            Content="React"
                            Padding="8,3"
                            MinHeight="0"
                            IsEnabled="{x:Bind CanReact, Mode=OneWay}">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="&#x2764;&#xFE0F;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x2764;&#xFE0F;"/>
                                    <MenuFlyoutItem Text="&#x1F602;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F602;"/>
                                    <MenuFlyoutItem Text="&#x1F62E;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F62E;"/>
                                    <MenuFlyoutItem Text="&#x1F44E;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F44E;"/>
                                    <MenuFlyoutItem Text="&#x1F44F;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F44F;"/>
                                    <MenuFlyoutItem Text="&#x1F525;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F525;"/>
                                    <MenuFlyoutItem Text="&#x1F44D;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F44D;"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <HyperlinkButton
                            Content="Reply"
                            Padding="2,4"
                            Command="{x:Bind ShowReplyComposerCommand, Mode=OneWay}"/>
                    </StackPanel>

                    <StackPanel
                        Spacing="6"
                        Visibility="{x:Bind IsReplyComposerOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBox
                            PlaceholderText="{x:Bind ReplyPlaceholder, Mode=OneWay}"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            MinHeight="54"
                            MaxLength="500"
                            Text="{x:Bind ReplyDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind ReplyCharacterCount, Mode=OneWay}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                VerticalAlignment="Center"/>

                            <Button
                                Grid.Column="1"
                                Content="Cancel"
                                Padding="10,5"
                                Command="{x:Bind CancelReplyCommand, Mode=OneWay}"/>

                            <Button
                                Grid.Column="2"
                                Content="Reply"
                                Padding="12,5"
                                IsEnabled="{x:Bind CanSubmitReply, Mode=OneWay}"
                                Click="SubmitReplyButton_Click"/>
                        </Grid>
                    </StackPanel>

                    <TextBlock
                        Text="{x:Bind ReplyComposerStatus, Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{x:Bind HasReplyComposerStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Expander
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        ExpandDirection="Down"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0,4,0,0"
                        IsExpanded="{x:Bind IsRepliesExpanded, Mode=TwoWay}"
                        Visibility="{x:Bind HasReplies, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <appcontrols:StackedAvatars
                                    ItemsSource="{x:Bind TopReplyAvatarItems, Mode=OneWay}"
                                    AvatarSize="20"
                                    RingThickness="2"
                                    Overlap="8"
                                    MaxVisible="3"
                                    Visibility="{x:Bind HasTopReplyAvatars, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Text="{x:Bind RepliesLabel}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Spacing="4" Padding="0,4,0,0">
                            <ItemsRepeater
                                ItemsSource="{x:Bind Replies}"
                                ItemTemplate="{StaticResource EpisodeReplyTemplate}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="2"/>
                                </ItemsRepeater.Layout>
                            </ItemsRepeater>
                            <StackPanel Spacing="6"
                                Visibility="{x:Bind IsLoadingReplies, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:Shimmer Grid.Column="0" Width="28" Height="28" CornerRadius="14"/>
                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                        <controls:Shimmer Width="120" Height="10" CornerRadius="3" HorizontalAlignment="Left"/>
                                        <controls:Shimmer Width="220" Height="10" CornerRadius="3" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:Shimmer Grid.Column="0" Width="28" Height="28" CornerRadius="14"/>
                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                        <controls:Shimmer Width="100" Height="10" CornerRadius="3" HorizontalAlignment="Left"/>
                                        <controls:Shimmer Width="180" Height="10" CornerRadius="3" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                            <HyperlinkButton
                                Content="Load more replies"
                                Padding="0,2"
                                Command="{x:Bind LoadMoreRepliesCommand}"
                                Visibility="{x:Bind HasMoreReplies, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <Style x:Key="EpisodeMetaChipBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <DataTemplate x:Key="EpisodeDetailPanelTemplate" x:DataType="vm:YourEpisodesViewModel">
            <Grid
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
                <ScrollView
                    Loaded="EpisodeDetailScrollView_Loaded"
                    Unloaded="EpisodeDetailScrollView_Unloaded"
                    ViewChanged="EpisodeDetailScrollView_ViewChanged"
                    Visibility="{x:Bind HasSelectedEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="18" Padding="0,0,2,0">

                        <!-- Hero: artwork + title + show hyperlink + meta line -->
                        <Grid x:Name="EpisodeDetailHero" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="112"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.Column="0"
                                Width="112"
                                Height="112"
                                CornerRadius="10"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Grid>
                                    <FontIcon
                                        Glyph="&#xEC05;"
                                        FontSize="42"
                                        Opacity="0.35"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                    <Image
                                        Source="{x:Bind SelectedEpisodeImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='224'}"
                                        Stretch="UniformToFill"
                                        Visibility="{x:Bind SelectedEpisodeImageUrl, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                        behaviors:ImageFallbackBehavior.HideOnError="True"
                                        behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                        behaviors:ImageFallbackBehavior.DecodePixelWidth="224"/>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <HyperlinkButton
                                    Content="{x:Bind SelectedEpisodeShowName, Mode=OneWay}"
                                    Command="{x:Bind OpenSelectedEpisodeShowCommand, Mode=OneWay}"
                                    Padding="0,0,0,2"
                                    Visibility="{x:Bind HasShowName, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock
                                    Text="{x:Bind SelectedEpisodeTitle, Mode=OneWay}"
                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                    TextWrapping="Wrap"
                                    MaxLines="3"/>
                                <TextBlock
                                    Text="{x:Bind SelectedEpisodeMetaLine, Mode=OneWay}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="WrapWholeWords"
                                    MaxLines="2"
                                    Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Resume progress -->
                        <StackPanel
                            Spacing="4"
                            Visibility="{x:Bind HasResumeProgress, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ProgressBar
                                Minimum="0"
                                Maximum="100"
                                Value="{x:Bind ResumeProgressPercent, Mode=OneWay}"
                                Height="4"/>
                            <TextBlock
                                Text="{x:Bind SelectedEpisodeResumeText, Mode=OneWay}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Action bar -->
                        <controls:WrapPanel Orientation="Horizontal" HorizontalSpacing="8" VerticalSpacing="6">
                            <Button
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind PlaySelectedEpisodeCommand, Mode=OneWay}"
                                Padding="14,6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE768;" FontSize="14"/>
                                    <TextBlock Text="Play"/>
                                </StackPanel>
                            </Button>
                            <Button
                                Command="{x:Bind OpenSelectedEpisodeShowCommand, Mode=OneWay}"
                                Padding="12,6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE7B3;" FontSize="14"/>
                                    <TextBlock Text="Show"/>
                                </StackPanel>
                            </Button>
                            <Button
                                Command="{x:Bind CopyEpisodeLinkCommand, Mode=OneWay}"
                                Padding="12,6"
                                Visibility="{x:Bind HasShareUrl, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="Copy episode link">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE71B;" FontSize="14"/>
                                    <TextBlock Text="Copy link"/>
                                </StackPanel>
                            </Button>
                        </controls:WrapPanel>

                        <!-- Status chips -->
                        <controls:WrapPanel Orientation="Horizontal" HorizontalSpacing="6" VerticalSpacing="6">
                            <Border
                                Style="{StaticResource EpisodeMetaChipBorderStyle}"
                                Visibility="{x:Bind HasExplicit, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="Explicit content">
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock
                                        Text="E"
                                        FontWeight="SemiBold"
                                        FontSize="11"
                                        VerticalAlignment="Center"/>
                                    <TextBlock
                                        Text="Explicit"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border
                                Style="{StaticResource EpisodeMetaChipBorderStyle}"
                                Visibility="{x:Bind HasVideo, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="Includes video">
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE714;" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock
                                        Text="Video"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border
                                Style="{StaticResource EpisodeMetaChipBorderStyle}"
                                Visibility="{x:Bind HasTranscript, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="{x:Bind TranscriptLanguagesTooltip, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8D2;" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock
                                        Text="Transcript"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border
                                Style="{StaticResource EpisodeMetaChipBorderStyle}"
                                Visibility="{x:Bind HasPaywalled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="Subscriber-only">
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE785;" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock
                                        Text="Paywalled"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
