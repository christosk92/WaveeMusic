                    <ScrollView>
                        <ItemsRepeater
                            ItemsSource="{x:Bind ViewModel.EpisodeGroups, Mode=OneWay}"
                            ItemTemplate="{StaticResource EpisodeGroupTemplate}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="22"/>
                            </ItemsRepeater.Layout>
                        </ItemsRepeater>
                    </ScrollView>
                </Grid>

                <Grid
                    Visibility="{x:Bind ViewModel.ShowNarrowEpisodeDetailsStage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ContentControl
                        Content="{x:Bind ViewModel}"
                        ContentTemplate="{StaticResource EpisodeDetailPanelTemplate}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
