<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.ArtistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:track="using:Wavee.UI.WinUI.Controls.Track"
    xmlns:hero="using:Wavee.UI.WinUI.Controls.HeroHeader"
    xmlns:layouts="using:Wavee.UI.WinUI.Controls.Layouts"
    xmlns:albumDetail="using:Wavee.UI.WinUI.Controls.AlbumDetailPanel" 
    xmlns:controls1="using:Wavee.UI.WinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True"/>
        <converters:BoolToGridListGlyphConverter x:Key="BoolToGridListGlyphConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Page.Resources>

    <ScrollView x:Name="PageScrollView">
        <StackPanel>

            <!-- HERO HEADER -->
            <hero:HeroHeader x:Name="HeroGrid"
                             ImageUrl="{x:Bind ViewModel.HeaderImageUrl, Mode=OneWay}"
                             MinHeight="300"
                             InitialScale="1.0"
                             FinalScale="1.05"
                             AnimationDuration="0:0:0.8"
                             FadeStart="0.55"
                             FadeEnd="0.95">
                <hero:HeroHeader.OverlayContent>
                    <StackPanel Padding="32,0,32,24" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <!-- Avatar / Watch Feed Video (connected animation target) -->
                            <Grid x:Name="ArtistImageContainer" Width="120" Height="120">
                                <Border CornerRadius="60" Width="120" Height="120">
                                    <Grid>
                                        <!-- Static artist image (always present, video fades in on top) -->
                                        <Ellipse x:Name="ArtistImageEllipse" Width="120" Height="120">
                                            <Ellipse.Fill>
                                                <ImageBrush
                                                    ImageSource="{x:Bind ViewModel.ArtistImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                                                    Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!-- Watch feed video (fades in over artist image when ready) -->
                                        <Grid x:Name="WatchFeedGrid" Opacity="0"/>

                                        <!-- Hover overlay (shows play icon on hover, hidden until video loads) -->
                                        <Border x:Name="WatchFeedHoverOverlay" CornerRadius="60" Opacity="0"
                                                Background="#60000000" Visibility="Collapsed"
                                                PointerEntered="WatchFeedOverlay_PointerEntered"
                                                PointerExited="WatchFeedOverlay_PointerExited"
                                                Tapped="WatchFeedOverlay_Tapped">
                                            <FontIcon Glyph="&#xE768;" FontSize="28" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>

                            <StackPanel VerticalAlignment="Bottom" Spacing="4">
                                <!-- Name: show text or shimmer -->
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                Visibility="{x:Bind ViewModel.ArtistName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}"
                                                   FontSize="36" FontWeight="Bold"/>
                                        <FontIcon Glyph="&#xE735;" FontSize="18"
                                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                  Visibility="{x:Bind ViewModel.IsVerified, Mode=OneWay}"
                                                  VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <controls:Shimmer Width="280" Height="36" HorizontalAlignment="Left"
                                                      Visibility="{x:Bind ViewModel.ArtistName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                </Grid>

                                <!-- Stats: show text or shimmer -->
                                <Grid>
                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Visibility="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                        <Run Text="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay}"/>
                                        <Run Text=" monthly listeners"/>
                                    </TextBlock>
                                    <controls:Shimmer Width="160" Height="16" HorizontalAlignment="Left"
                                                      Visibility="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- Action buttons row -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0"
                                    VerticalAlignment="Bottom">
                            <Button Style="{StaticResource AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.PlayTopTracksCommand}"
                                    VerticalAlignment="Center"
                                    Padding="20,10" CornerRadius="20">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="16"/>
                                    <TextBlock Text="Play"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{x:Bind ViewModel.ToggleFollowCommand}"
                                    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                                    VerticalAlignment="Center"
                                    Padding="16,10" CornerRadius="20">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xEB51;" FontSize="14"/>
                                    <TextBlock Text="Follow"/>
                                </StackPanel>
                            </Button>

                            <!-- Pinned item compact pill -->
                            <Button Padding="0" Background="Transparent" BorderThickness="0"
                                    CornerRadius="20" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Click="PinnedItem_Click"
                                    Visibility="{x:Bind ViewModel.HasPinnedItem, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border CornerRadius="20" Padding="4,4,12,4"
                                        Background="{ThemeResource AccentAcrylicBackgroundFillColorBaseBrush}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="32" Height="32" CornerRadius="16">
                                            <Image Source="{x:Bind ViewModel.PinnedItem.ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center" MaxWidth="120">
                                            <TextBlock Text="{x:Bind ViewModel.PinnedItem.Title, Mode=OneWay}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                            <TextBlock Text="{x:Bind ViewModel.PinnedItem.Comment, Mode=OneWay}"
                                                       FontSize="10" Opacity="0.7"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Button>

                        </StackPanel>
                    </StackPanel>
                </hero:HeroHeader.OverlayContent>
            </hero:HeroHeader>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- SHIMMER LOADING SKELETON (sections below hero)  -->
            <!-- ═══════════════════════════════════════════════ -->
            <StackPanel x:Name="ShimmerContainer">
                <!-- Top tracks shimmer -->
                <StackPanel Padding="32,24,32,0" Spacing="12">
                    <controls:Shimmer Width="140" Height="22" HorizontalAlignment="Left"/>
                    <StackPanel Spacing="4">
                        <Grid Height="56" Padding="8,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="4"/>
                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                <controls:Shimmer Width="200" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="120" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                        <Grid Height="56" Padding="8,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="4"/>
                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                <controls:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="100" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                        <Grid Height="56" Padding="8,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="4"/>
                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                <controls:Shimmer Width="220" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="140" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
                <!-- Discography shimmer -->
                <StackPanel Padding="32,24,32,32" Spacing="12">
                    <controls:Shimmer Width="120" Height="22" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="60" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="100" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="140" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="70" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="110" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="55" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- CONTENT SECTIONS (fades in after shimmer)       -->
            <!-- ═══════════════════════════════════════════════ -->
            <StackPanel x:Name="ContentContainer" Padding="32,24,32,32" Spacing="32">

                <!-- ─── Top Tracks (Apple Music grid style) ─── -->
                <StackPanel Spacing="12">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Top Tracks" FontWeight="Bold" FontSize="20"/>
                            <HyperlinkButton Content="Show all >" Padding="4,0"
                                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                             VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                            <Button Style="{StaticResource DefaultButtonStyle}" Padding="8,6"
                                    Background="Transparent" BorderThickness="0"
                                    Command="{x:Bind ViewModel.PreviousPageCommand}">
                                <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                            </Button>
                            <Button Style="{StaticResource DefaultButtonStyle}" Padding="8,6"
                                    Background="Transparent" BorderThickness="0"
                                    Command="{x:Bind ViewModel.NextPageCommand}">
                                <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Top tracks grid (column-first, max 3 rows) -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.PagedTopTracks, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <layouts:ColumnsFirstGridLayout x:Name="TopTracksLayout" MaxRows="3" MinItemWidth="280"
                                                            ItemHeight="56" RowSpacing="4" ColumnSpacing="8"
                                                            ColumnCountChanged="TopTracksLayout_ColumnCountChanged"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyTrackItem">
                                <track:TrackCell
                                    Track="{x:Bind Data, Mode=OneWay}"
                                    IsLoading="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- ─── Albums ─── -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.AlbumsTotalCount, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid>
                        <TextBlock FontWeight="Bold" FontSize="20" VerticalAlignment="Center">
                            <Run Text="Albums"/>
                            <Run Text=" · " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Run Text="{x:Bind ViewModel.AlbumsTotalCount, Mode=OneWay}"
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6"
                                    Command="{x:Bind ViewModel.ToggleAlbumsViewCommand}">
                                <FontIcon Glyph="{x:Bind ViewModel.AlbumsGridView, Mode=OneWay, Converter={StaticResource BoolToGridListGlyphConverter}}" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <!-- Grid view (wrapping multi-row, click to expand inline) -->
                    <ItemsRepeater x:Name="AlbumsGridRepeater"
                                   ItemsSource="{x:Bind ViewModel.Albums, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.AlbumsGridView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="160" MinItemHeight="240"
                                               MinRowSpacing="12" MinColumnSpacing="12"
                                               ItemsStretch="Uniform"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid>
                                    <cards:ContentCard
                                        Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ImageUrl="{x:Bind Data.ImageUrl, Mode=OneWay}"
                                        Title="{x:Bind Data.Name, Mode=OneWay}"
                                        Subtitle="{x:Bind Data.Year, Mode=OneWay}"
                                        CardClick="AlbumCard_Click"
                                        CardHover="AlbumCard_Hover"/>
                                    <StackPanel Spacing="8" Padding="8"
                                                Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <controls:Shimmer Height="150" CornerRadius="8"/>
                                        <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                                        <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <!-- List view -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Albums, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.AlbumsGridView, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="2"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid Padding="8,6" ColumnSpacing="12" CornerRadius="4"
                                      Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <Image Source="{x:Bind Data.ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                                               Stretch="UniformToFill"
                                               behaviors:ImageFallbackBehavior.HideOnError="True"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Data.Name, Mode=OneWay}" FontWeight="SemiBold" MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" FontSize="13"/>
                                        <TextBlock Text="{x:Bind Data.Year, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind Data.TrackCount, Mode=OneWay}"/>
                                        <Run Text=" tracks"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- ─── Singles ─── -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.SinglesTotalCount, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid>
                        <TextBlock FontWeight="Bold" FontSize="20" VerticalAlignment="Center">
                            <Run Text="Singles &amp; EPs"/>
                            <Run Text=" · " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Run Text="{x:Bind ViewModel.SinglesTotalCount, Mode=OneWay}"
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6"
                                    Command="{x:Bind ViewModel.ToggleSinglesViewCommand}">
                                <FontIcon Glyph="{x:Bind ViewModel.SinglesGridView, Mode=OneWay, Converter={StaticResource BoolToGridListGlyphConverter}}" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <!-- Grid view (wrapping multi-row, click to expand inline) -->
                    <ItemsRepeater x:Name="SinglesGridRepeater"
                                   ItemsSource="{x:Bind ViewModel.Singles, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.SinglesGridView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="160" MinItemHeight="240"
                                               MinRowSpacing="12" MinColumnSpacing="12"
                                               ItemsStretch="Uniform"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid>
                                    <cards:ContentCard
                                        Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ImageUrl="{x:Bind Data.ImageUrl, Mode=OneWay}"
                                        Title="{x:Bind Data.Name, Mode=OneWay}"
                                        Subtitle="{x:Bind Data.Year, Mode=OneWay}"
                                        CardClick="AlbumCard_Click"
                                        CardHover="AlbumCard_Hover"/>
                                    <StackPanel Spacing="8" Padding="8"
                                                Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <controls:Shimmer Height="150" CornerRadius="8"/>
                                        <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                                        <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <!-- List view -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Singles, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.SinglesGridView, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="2"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid Padding="8,6" ColumnSpacing="12" CornerRadius="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <Image Source="{x:Bind Data.ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                                               Stretch="UniformToFill"
                                               behaviors:ImageFallbackBehavior.HideOnError="True"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Data.Name, Mode=OneWay}" FontWeight="SemiBold" MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" FontSize="13"/>
                                        <TextBlock Text="{x:Bind Data.Year, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind Data.TrackCount, Mode=OneWay}"/><Run Text=" tracks"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- ─── Compilations ─── -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.CompilationsTotalCount, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock FontWeight="Bold" FontSize="20">
                                <Run Text="Compilations"/>
                                <Run Text=" · " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Run Text="{x:Bind ViewModel.CompilationsTotalCount, Mode=OneWay}"
                                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </TextBlock>
                            <HyperlinkButton Content="Show all >" Padding="4,0"
                                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                             VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6">
                                <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6">
                                <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <!-- Horizontal single-row list -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Compilations, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <layouts:SingleRowLayout MinItemWidth="160" MaxItemWidth="200" Spacing="12"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid>
                                    <!-- Loaded: real card -->
                                    <cards:ContentCard
                                        Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ImageUrl="{x:Bind Data.ImageUrl, Mode=OneWay}"
                                        Title="{x:Bind Data.Name, Mode=OneWay}"
                                        Subtitle="{x:Bind Data.Year, Mode=OneWay}"
                                        CardClick="AlbumCard_Click"
                                        CardHover="AlbumCard_Hover"/>
                                    <!-- Loading: shimmer card -->
                                    <StackPanel Spacing="8" Padding="8"
                                                Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <controls:Shimmer Height="150" CornerRadius="8"/>
                                        <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                                        <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- ─── Concerts ─── -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.HasConcerts, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Concerts" FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                        <HyperlinkButton Click="OpenLocationDialog_Click" VerticalAlignment="Center" Padding="0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE81D;" FontSize="12"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.UserLocationName, Mode=OneWay}"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Visibility="{x:Bind ViewModel.UserLocationName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                <TextBlock Text="Set location" FontSize="13"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           Visibility="{x:Bind ViewModel.UserLocationName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                            </StackPanel>
                        </HyperlinkButton>
                    </StackPanel>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Concerts, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ConcertVm">
                                <Border CornerRadius="8" Padding="16,12" Width="200"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        Tapped="ConcertCard_Tapped"
                                        PointerEntered="ConcertCard_PointerEntered"
                                        PointerExited="ConcertCard_PointerExited">
                                    <Grid RowSpacing="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Date badge -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind DateFormatted}" FontWeight="Bold" FontSize="16"
                                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Bind DayOfWeek}" FontSize="12" Opacity="0.6"
                                                       VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                            <Border CornerRadius="4" Padding="6,2" Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                    Visibility="{x:Bind IsNearUser, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="Near you" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Venue -->
                                        <TextBlock Grid.Row="1" Text="{x:Bind Venue}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>

                                        <!-- City -->
                                        <TextBlock Grid.Row="2" Text="{x:Bind City}" FontSize="12" Opacity="0.6"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>

                                        <!-- Title (lineup) -->
                                        <TextBlock Grid.Row="3" Text="{x:Bind Title}" FontSize="11" Opacity="0.5"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1" Margin="0,4,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- ─── Related Artists ─── -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Fans Also Like" FontWeight="Bold" FontSize="20"/>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.RelatedArtists, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <layouts:SingleRowLayout MinItemWidth="140" Spacing="12"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:RelatedArtistVm">
                                <cards:ContentCard
                                    ImageUrl="{x:Bind ImageUrl}"
                                    Title="{x:Bind Name}"
                                    Subtitle="Artist"
                                    PlaceholderGlyph="&#xE77B;"
                                    IsCircularImage="True"
                                    CenterText="True"
                                    NavigationUri="{x:Bind Uri}"
                                    NavigationTitle="{x:Bind Name}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- ─── Biography ─── -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.Biography, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="About" FontWeight="Bold" FontSize="20"/>
                    <controls1:HtmlTextBlock Text="{x:Bind ViewModel.Biography, Mode=OneWay}"
                                            MaxLines="6"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

            </StackPanel> <!-- ContentContainer -->

        </StackPanel>
    </ScrollView>
</Page>
