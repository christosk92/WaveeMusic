<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.ArtistPage"
    x:Name="ArtistPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:track="using:Wavee.UI.WinUI.Controls.Track"
    xmlns:trackBehaviors="using:Wavee.UI.WinUI.Controls.Track.Behaviors"
    xmlns:hero="using:Wavee.UI.WinUI.Controls.HeroHeader"
    xmlns:layouts="using:Wavee.UI.WinUI.Controls.Layouts"
    xmlns:albumDetail="using:Wavee.UI.WinUI.Controls.AlbumDetailPanel"
    xmlns:controls1="using:Wavee.UI.WinUI.Controls"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:shelf="using:Wavee.UI.WinUI.Controls.Shelf"
    xmlns:transitions="using:CommunityToolkit.WinUI"
    xmlns:waveeHelpers="using:Wavee.UI.WinUI.Helpers"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">
    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PinnedItemNormalBackgroundBrush" Color="#66101010"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBackgroundBrush" Color="#88202020"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBackgroundBrush" Color="#AA050505"/>
                    <SolidColorBrush x:Key="PinnedItemNormalBorderBrush" Color="#44FFFFFF"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBorderBrush" Color="#88FFFFFF"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBorderBrush" Color="#BBFFFFFF"/>
                    <SolidColorBrush x:Key="PinnedItemForegroundBrush" Color="White"/>
                    <SolidColorBrush x:Key="PinnedItemAvatarBorderBrush" Color="#66FFFFFF"/>
                    <SolidColorBrush x:Key="ShyHeaderBorderBrush" Color="#66FFFFFF"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <!-- Inverted: bright translucent pill over the now white-scrimmed hero. -->
                    <SolidColorBrush x:Key="PinnedItemNormalBackgroundBrush" Color="#66F4F4F4"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBackgroundBrush" Color="#88EAEAEA"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBackgroundBrush" Color="#AADDDDDD"/>
                    <SolidColorBrush x:Key="PinnedItemNormalBorderBrush" Color="#33000000"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBorderBrush" Color="#66000000"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBorderBrush" Color="#99000000"/>
                    <SolidColorBrush x:Key="PinnedItemForegroundBrush" Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="PinnedItemAvatarBorderBrush" Color="#33000000"/>
                    <SolidColorBrush x:Key="ShyHeaderBorderBrush" Color="#33000000"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="PinnedItemNormalBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBackgroundBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBackgroundBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                    <SolidColorBrush x:Key="PinnedItemNormalBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                    <SolidColorBrush x:Key="PinnedItemForegroundBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                    <SolidColorBrush x:Key="PinnedItemAvatarBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                    <SolidColorBrush x:Key="ShyHeaderBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True"/>
            <converters:BoolToGridListGlyphConverter x:Key="BoolToGridListGlyphConverter"/>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:NullToForegroundConverter x:Key="NullToForegroundConverter"/>

        <!-- Shy-header morph: hero overlay panel <-> floating compact card.
             Matched ids on inner avatar/name/badge/meta/play/follow elements
             interpolate between the two states. Unpaired chrome (the floating
             card border) fades in via the helper's independent show animation. -->
        <transitions:TransitionHelper x:Key="ArtistShyHeaderTransition"
                                      Duration="0:0:0.36"
                                      ReverseDuration="0:0:0.30"
                                      DefaultEasingMode="EaseInOut"
                                      SourceToggleMethod="ByVisibility"
                                      TargetToggleMethod="ByVisibility"
                                      IndependentElementShowDuration="0:0:0.18"
                                      IndependentElementShowDelay="0:0:0.10"
                                      IndependentElementHideDuration="0:0:0.12"
                                      IsHitTestVisibleWhenAnimating="False">
            <transitions:TransitionConfig Id="card-shell" ScaleMode="Scale"/>
            <transitions:TransitionConfig Id="artist-avatar" ScaleMode="Scale"/>
            <transitions:TransitionConfig Id="artist-name" ScaleMode="Custom">
                <transitions:TransitionConfig.CustomScalingCalculator>
                    <waveeHelpers:TransitionTextScalingCalculator/>
                </transitions:TransitionConfig.CustomScalingCalculator>
            </transitions:TransitionConfig>
            <transitions:TransitionConfig Id="artist-badge" ScaleMode="Scale"/>
            <transitions:TransitionConfig Id="artist-meta" ScaleMode="Custom">
                <transitions:TransitionConfig.CustomScalingCalculator>
                    <waveeHelpers:TransitionTextScalingCalculator/>
                </transitions:TransitionConfig.CustomScalingCalculator>
            </transitions:TransitionConfig>
            <transitions:TransitionConfig Id="artist-play" ScaleMode="Scale"/>
            <transitions:TransitionConfig Id="artist-follow" ScaleMode="Scale"/>
        </transitions:TransitionHelper>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <ScrollView x:Name="PageScrollView">
            <ScrollView.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition />
                </TransitionCollection>
            </ScrollView.Transitions>
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="HeroRow" Height="300" MinHeight="200" MaxHeight="700"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page tint wash — gets a LinearGradientBrush derived from HeaderHeroColorHex
                 so the artist's palette color extends past the hero into the content area.
                 Fill is assigned from code-behind whenever the hex changes. -->
            <Rectangle x:Name="PageTintFill"
                       Grid.Row="0"
                       Grid.RowSpan="4"
                       VerticalAlignment="Top"
                       Height="600"
                       IsHitTestVisible="False"/>

            <!-- HERO HEADER -->
            <hero:HeroHeader x:Name="HeroGrid"
                             Grid.Row="0"
                             ImageUrl="{x:Bind ViewModel.HeaderImageUrl, Mode=OneWay}"
                             ColorHex="{x:Bind ViewModel.HeaderHeroColorHex, Mode=OneWay}"
                             MinHeight="200"
                             InitialScale="1.0"
                             FinalScale="1.05"
                             AnimationDuration="0:0:0.8"
                             FadeStart="0.55"
                             FadeEnd="0.95">
                <hero:HeroHeader.OverlayContent>
                    <!-- Grid wrapper hosts the source-side matched-id chrome
                         alongside the visible content. The chrome itself is invisible
                         here (transparent fill, no border) — it exists purely to give
                         TransitionHelper a source bounds to morph the floating card
                         chrome FROM. -->
                    <Grid x:Name="HeroOverlayPanel">
                        <Border transitions:TransitionHelper.Id="card-shell"
                                Background="Transparent"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
                        <StackPanel Padding="32,0,32,24" Spacing="8">
                        <StackPanel Orientation="Horizontal">
                            <!-- Avatar wrapper — Width animates 136 → 0 when the artist has a
                                 header image but no watch-feed video, reclaiming the space for
                                 the name/stats block. 136 = 120 avatar + 16 gap. -->
                            <Grid x:Name="AvatarWrapper" Width="136">
                                <!-- Avatar / Watch Feed Video (connected animation target) -->
                                <Grid x:Name="ArtistImageContainer"
                                      Width="120"
                                      Height="120"
                                      HorizontalAlignment="Left"
                                      transitions:TransitionHelper.Id="artist-avatar">
                                <Border CornerRadius="60" Width="120" Height="120">
                                    <Grid>
                                        <!-- Static artist image (always present, video fades in on top) -->
                                        <Ellipse x:Name="ArtistImageEllipse" Width="120" Height="120">
                                            <Ellipse.Fill>
                                                <ImageBrush
                                                    ImageSource="{x:Bind ViewModel.ArtistImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=120}"
                                                    Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!-- Watch feed video (fades in over artist image when ready) -->
                                        <Grid x:Name="WatchFeedGrid" Opacity="0"/>

                                        <!-- Hover overlay (shows play icon on hover, hidden until video loads) -->
                                        <Border x:Name="WatchFeedHoverOverlay" CornerRadius="60" Opacity="0"
                                                Background="#60000000" Visibility="Collapsed"
                                                PointerEntered="WatchFeedOverlay_PointerEntered"
                                                PointerExited="WatchFeedOverlay_PointerExited"
                                                Tapped="WatchFeedOverlay_Tapped">
                                            <FontIcon Glyph="&#xE768;" FontSize="28" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                </Grid>
                            </Grid>

                            <StackPanel VerticalAlignment="Bottom" Spacing="4">
                                <!-- Name: show text or shimmer -->
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                Visibility="{x:Bind ViewModel.ArtistName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                        <Grid>
                                      
                                            <TextBlock Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}"
                                                       FontSize="48" FontWeight="Black"
                                                       Foreground="{x:Bind ViewModel.HeaderImageUrl, Mode=OneWay, Converter={StaticResource NullToForegroundConverter}}"
                                                       transitions:TransitionHelper.Id="artist-name"/>
                                        </Grid>
                                        <Border Width="28" Height="28" CornerRadius="14"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                Visibility="{x:Bind ViewModel.IsVerified, Mode=OneWay}"
                                                VerticalAlignment="Center"
                                                transitions:TransitionHelper.Id="artist-badge">
                                            <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <controls:Shimmer Width="280" Height="36" HorizontalAlignment="Left"
                                                      Visibility="{x:Bind ViewModel.ArtistName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                </Grid>

                                <!-- Stats: show text or shimmer -->
                                <Grid>
                                    <Grid Visibility="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{x:Bind ViewModel.HeaderImageUrl, Mode=OneWay, Converter={StaticResource NullToForegroundConverter}}" Opacity=".9"
                                                   transitions:TransitionHelper.Id="artist-meta">
                                            <Run Text="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay}"/><Run x:Uid="Views_ArtistPage__Run_1" Text=" monthly listeners"/>
                                        </TextBlock>
                                    </Grid>
                                    <controls:Shimmer Width="160" Height="16" HorizontalAlignment="Left"
                                                      Visibility="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- Action buttons row -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0"
                                    VerticalAlignment="Bottom">
                            <Button Style="{StaticResource AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.PlayTopTracksCommand}"
                                    VerticalAlignment="Center"
                                    Padding="20,10" CornerRadius="20"
                                    transitions:TransitionHelper.Id="artist-play">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <playback:PlaybackActionContent IconSize="16"
                                                                   SpinnerSize="16"
                                                                   IsPlaying="{x:Bind ViewModel.IsArtistContextPlaying, Mode=OneWay}"
                                                                   IsPending="{x:Bind ViewModel.IsPlayPending, Mode=OneWay}"
                                                                   ActionForeground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                    <TextBlock x:Uid="Views_ArtistPage__TextBlock_2"
                                               Text="{x:Bind ViewModel.ArtistPlayButtonText, Mode=OneWay}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{x:Bind ViewModel.ToggleFollowCommand}"
                                    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                                    VerticalAlignment="Center"
                                    Padding="16,10" CornerRadius="20"
                                    transitions:TransitionHelper.Id="artist-follow">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="{x:Bind ViewModel.IsFollowing, Mode=OneWay, Converter={StaticResource BoolToFollowGlyphConverter}}" FontSize="14"/>
                                    <TextBlock Text="{x:Bind ViewModel.IsFollowing, Mode=OneWay, Converter={StaticResource BoolToFollowTextConverter}}"/>
                                </StackPanel>
                            </Button>

                            <!-- Pinned item compact pill -->
                            <Button x:Name="PinnedItemButton"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="20"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Click="PinnedItem_Click"
                                    PointerEntered="PinnedItem_PointerEntered"
                                    PointerExited="PinnedItem_PointerExited"
                                    PointerPressed="PinnedItem_PointerPressed"
                                    PointerReleased="PinnedItem_PointerReleased"
                                    PointerCanceled="PinnedItem_PointerCanceled"
                                    Visibility="{x:Bind ViewModel.HasPinnedItem, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FlyoutBase.AttachedFlyout>
                                    <Flyout x:Name="PinnedItemPreviewFlyout"
                                            Placement="BottomEdgeAlignedLeft"
                                            ShouldConstrainToRootBounds="True"
                                            Opened="PinnedItemPreviewFlyout_Opened"
                                            Closed="PinnedItemPreviewFlyout_Closed">
                                        <Flyout.FlyoutPresenterStyle>
                                            <Style TargetType="FlyoutPresenter">
                                                <Setter Property="MinWidth" Value="300"/>
                                                <Setter Property="MaxWidth" Value="340"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="CornerRadius" Value="8"/>
                                                <Setter Property="Background" Value="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"/>
                                                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </Style>
                                        </Flyout.FlyoutPresenterStyle>
                                        <Grid x:Name="PinnedItemPreviewRoot"
                                              Width="320"
                                              PointerEntered="PinnedItemPreview_PointerEntered"
                                              PointerExited="PinnedItemPreview_PointerExited">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="150"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0"
                                                    CornerRadius="8,8,0,0"
                                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                                <Grid>
                                                    <Image Source="{x:Bind ViewModel.PinnedItem.BackgroundImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=320}"
                                                           Stretch="UniformToFill"
                                                           Visibility="{x:Bind ViewModel.PinnedItem.BackgroundImageUrl, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    <Image Source="{x:Bind ViewModel.PinnedItem.ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=160}"
                                                           Stretch="UniformToFill"
                                                           Opacity=".72"
                                                           Visibility="{x:Bind ViewModel.PinnedItem.BackgroundImageUrl, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                                    <Border>
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#14000000" Offset="0"/>
                                                                <GradientStop Color="#AA000000" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <Border Width="48"
                                                            Height="48"
                                                            CornerRadius="8"
                                                            Margin="14"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Bottom"
                                                            BorderBrush="#66FFFFFF"
                                                            BorderThickness="1"
                                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                        <Image Source="{x:Bind ViewModel.PinnedItem.ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=64}"
                                                               Stretch="UniformToFill"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Row="1"
                                                        Padding="14,12,14,14"
                                                        Spacing="4">
                                                <TextBlock Text="{x:Bind ViewModel.PinnedItem.Type, Mode=OneWay}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           CharacterSpacing="80"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"/>
                                                <TextBlock Text="{x:Bind ViewModel.PinnedItem.Title, Mode=OneWay}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"/>
                                                <TextBlock Text="{x:Bind ViewModel.PinnedItem.Subtitle, Mode=OneWay}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"
                                                           Visibility="{x:Bind ViewModel.PinnedItem.Subtitle, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                <TextBlock Text="{x:Bind ViewModel.PinnedItem.Comment, Mode=OneWay}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="2"
                                                           Visibility="{x:Bind ViewModel.PinnedItem.Comment, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Flyout>
                                </FlyoutBase.AttachedFlyout>
                                <Border x:Name="PinnedItemPill"
                                        CornerRadius="20"
                                        Padding="4,4,12,4"
                                        Background="{ThemeResource PinnedItemNormalBackgroundBrush}"
                                        BorderBrush="{ThemeResource PinnedItemNormalBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="32"
                                                Height="32"
                                                CornerRadius="16"
                                                BorderBrush="{ThemeResource PinnedItemAvatarBorderBrush}"
                                                BorderThickness="1"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                            <Image Source="{x:Bind ViewModel.PinnedItem.ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=32}"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center" MaxWidth="120">
                                            <TextBlock Text="{x:Bind ViewModel.PinnedItem.Title, Mode=OneWay}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{ThemeResource PinnedItemForegroundBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                            <TextBlock Text="{x:Bind ViewModel.PinnedItem.Subtitle, Mode=OneWay}"
                                                       FontSize="10" Opacity="0.82"
                                                       Foreground="{ThemeResource PinnedItemForegroundBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"
                                                       Visibility="{x:Bind ViewModel.PinnedItem.Subtitle, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            <TextBlock Text="{x:Bind ViewModel.PinnedItem.Comment, Mode=OneWay}"
                                                       FontSize="10" Opacity="0.82"
                                                       Foreground="{ThemeResource PinnedItemForegroundBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"
                                                       Visibility="{x:Bind ViewModel.PinnedItem.Subtitle, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Button>

                        </StackPanel>
                        </StackPanel>
                    </Grid>
                </hero:HeroHeader.OverlayContent>
            </hero:HeroHeader>

            <controls1:GridSplitter
                x:Name="HeroSplitter"
                Grid.Row="1"
                Orientation="Vertical"
                Height="8"
                HorizontalAlignment="Stretch"
                ResizeCompleted="HeroSplitter_ResizeCompleted"/>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- SHIMMER LOADING SKELETON (sections below hero)  -->
            <!-- ═══════════════════════════════════════════════ -->
            <StackPanel x:Name="ShimmerContainer" Grid.Row="2">
                <!-- Top tracks shimmer -->
                <StackPanel Padding="32,24,32,0" Spacing="12">
                    <controls:Shimmer Width="140" Height="22" HorizontalAlignment="Left"/>
                    <StackPanel Spacing="4">
                        <Grid Height="56" Padding="8,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="4"/>
                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                <controls:Shimmer Width="200" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="120" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                        <Grid Height="56" Padding="8,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="4"/>
                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                <controls:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="100" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                        <Grid Height="56" Padding="8,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="4"/>
                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                <controls:Shimmer Width="220" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="140" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
                <!-- Discography shimmer -->
                <StackPanel Padding="32,24,32,32" Spacing="12">
                    <controls:Shimmer Width="120" Height="22" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="60" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="100" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="140" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="70" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="110" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="55" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- CONTENT SECTIONS (fades in after shimmer)       -->
            <!-- ═══════════════════════════════════════════════ -->
            <StackPanel x:Name="ContentContainer" Grid.Row="3" Padding="32,24,32,32" Spacing="32">
                <!-- ─── Top Tracks (Apple Music grid style) ─── -->
                <StackPanel Spacing="12">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Uid="Views_ArtistPage__TextBlock_3" Text="Top Tracks" FontWeight="Bold" FontSize="20"/>
                            <HyperlinkButton x:Uid="Views_ArtistPage__HyperlinkButton_4" Content="Show all >" Padding="4,0"
                                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                             VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                            <Button Style="{StaticResource DefaultButtonStyle}" Padding="8,6"
                                    Background="Transparent" BorderThickness="0"
                                    Command="{x:Bind ViewModel.PreviousPageCommand}">
                                <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                            </Button>
                            <Button Style="{StaticResource DefaultButtonStyle}" Padding="8,6"
                                    Background="Transparent" BorderThickness="0"
                                    Command="{x:Bind ViewModel.NextPageCommand}">
                                <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Top tracks grid (column-first, max 3 rows) -->
                    <ItemsRepeater x:Name="TopTracksRepeater" ItemsSource="{x:Bind ViewModel.PagedTopTracks, Mode=OneWay}"
                                    ElementPrepared="TopTracksRepeater_ElementPrepared">
                        <ItemsRepeater.Layout>
                            <layouts:ColumnsFirstGridLayout x:Name="TopTracksLayout" MaxRows="3" MinItemWidth="280"
                                                            ItemHeight="56" RowSpacing="4" ColumnSpacing="8"
                                                            ColumnCountChanged="TopTracksLayout_ColumnCountChanged"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyTrackItem">
                                <track:TrackItem
                                    Track="{x:Bind Data, Mode=OneWay}"
                                    IsLoading="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                    PlayCommand="{Binding ViewModel.PlayTrackCommand, ElementName=ArtistPageRoot}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- ─── Albums ─── -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.AlbumsTotalCount, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid>
                        <TextBlock FontWeight="Bold" FontSize="20" VerticalAlignment="Center">
                            <Run x:Uid="Views_ArtistPage__Run_5" Text="Albums"/>
                            <Run Text=" · " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Run Text="{x:Bind ViewModel.AlbumsTotalCount, Mode=OneWay}"
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6"
                                    Command="{x:Bind ViewModel.ToggleAlbumsViewCommand}">
                                <FontIcon Glyph="{x:Bind ViewModel.AlbumsGridView, Mode=OneWay, Converter={StaticResource BoolToGridListGlyphConverter}}" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <!-- Grid view (wrapping multi-row, click to expand inline) -->
                    <ItemsRepeater x:Name="AlbumsGridRepeater"
                                   ItemsSource="{x:Bind ViewModel.Albums, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.AlbumsGridView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="140" MinItemHeight="200"
                                               MinRowSpacing="12" MinColumnSpacing="12"
                                               ItemsStretch="Uniform"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid>
                                    <cards:ContentCard
                                        Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ImageUrl="{x:Bind Data.ImageUrl, Mode=OneWay}"
                                        Title="{x:Bind Data.Name, Mode=OneWay}"
                                        Subtitle="{x:Bind Data.Year, Mode=OneWay}"
                                        PlaceholderColorHex="{x:Bind Data.ColorHex, Mode=OneWay}"
                                        CardClick="AlbumCard_Click"
                                        CardHover="AlbumCard_Hover"/>
                                    <StackPanel Spacing="8" Padding="8"
                                                Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <controls:Shimmer Height="150" CornerRadius="8"/>
                                        <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                                        <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <!-- List view -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Albums, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.AlbumsGridView, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="2"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid Padding="8,6" ColumnSpacing="12" CornerRadius="4"
                                      Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <Image Source="{x:Bind Data.ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=48}"
                                               Stretch="UniformToFill"
                                               behaviors:ImageFallbackBehavior.HideOnError="True"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Data.Name, Mode=OneWay}" FontWeight="SemiBold" MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" FontSize="13"/>
                                        <TextBlock Text="{x:Bind Data.Year, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind Data.TrackCount, Mode=OneWay}"/>
                                        <Run x:Uid="Views_ArtistPage__Run_6" Text=" tracks"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <controls1:ErrorStateView x:Uid="Views_ArtistPage__ErrorStateView_7"
                        Visibility="{x:Bind ViewModel.HasAlbumsError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Title="Couldn't load all albums"
                        Message="Some albums may be missing"
                        RetryCommand="{x:Bind ViewModel.RetryDiscographyCommand}"
                        HorizontalAlignment="Left"
                        Padding="0,4,0,0"/>
                </StackPanel>

                <!-- ─── Singles ─── -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.SinglesTotalCount, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid>
                        <TextBlock FontWeight="Bold" FontSize="20" VerticalAlignment="Center">
                            <Run x:Uid="Views_ArtistPage__Run_8" Text="Singles &amp; EPs"/>
                            <Run Text=" · " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Run Text="{x:Bind ViewModel.SinglesTotalCount, Mode=OneWay}"
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6"
                                    Command="{x:Bind ViewModel.ToggleSinglesViewCommand}">
                                <FontIcon Glyph="{x:Bind ViewModel.SinglesGridView, Mode=OneWay, Converter={StaticResource BoolToGridListGlyphConverter}}" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <!-- Grid view (wrapping multi-row, click to expand inline) -->
                    <ItemsRepeater x:Name="SinglesGridRepeater"
                                   ItemsSource="{x:Bind ViewModel.Singles, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.SinglesGridView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="140" MinItemHeight="200"
                                               MinRowSpacing="12" MinColumnSpacing="12"
                                               ItemsStretch="Uniform"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid>
                                    <cards:ContentCard
                                        Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ImageUrl="{x:Bind Data.ImageUrl, Mode=OneWay}"
                                        Title="{x:Bind Data.Name, Mode=OneWay}"
                                        Subtitle="{x:Bind Data.Year, Mode=OneWay}"
                                        PlaceholderColorHex="{x:Bind Data.ColorHex, Mode=OneWay}"
                                        CardClick="AlbumCard_Click"
                                        CardHover="AlbumCard_Hover"/>
                                    <StackPanel Spacing="8" Padding="8"
                                                Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <controls:Shimmer Height="150" CornerRadius="8"/>
                                        <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                                        <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <!-- List view -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Singles, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.SinglesGridView, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="2"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid Padding="8,6" ColumnSpacing="12" CornerRadius="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <Image Source="{x:Bind Data.ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=48}"
                                               Stretch="UniformToFill"
                                               behaviors:ImageFallbackBehavior.HideOnError="True"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Data.Name, Mode=OneWay}" FontWeight="SemiBold" MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" FontSize="13"/>
                                        <TextBlock Text="{x:Bind Data.Year, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind Data.TrackCount, Mode=OneWay}"/><Run x:Uid="Views_ArtistPage__Run_9" Text=" tracks"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <controls1:ErrorStateView x:Uid="Views_ArtistPage__ErrorStateView_10"
                        Visibility="{x:Bind ViewModel.HasSinglesError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Title="Couldn't load all singles"
                        Message="Some singles may be missing"
                        RetryCommand="{x:Bind ViewModel.RetryDiscographyCommand}"
                        HorizontalAlignment="Left"
                        Padding="0,4,0,0"/>
                </StackPanel>

                <!-- ─── Compilations ─── -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.CompilationsTotalCount, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock FontWeight="Bold" FontSize="20">
                                <Run x:Uid="Views_ArtistPage__Run_11" Text="Compilations"/>
                                <Run Text=" · " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Run Text="{x:Bind ViewModel.CompilationsTotalCount, Mode=OneWay}"
                                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </TextBlock>
                            <HyperlinkButton x:Uid="Views_ArtistPage__HyperlinkButton_12" Content="Show all >" Padding="4,0"
                                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                             VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                    Visibility="{x:Bind CompilationsShelf.HasOverflow, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button Style="{StaticResource ShelfChevronButtonStyle}"
                                    Command="{x:Bind CompilationsShelf.PageLeftCommand, Mode=OneTime}">
                                <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                            </Button>
                            <Button Style="{StaticResource ShelfChevronButtonStyle}"
                                    Command="{x:Bind CompilationsShelf.PageRightCommand, Mode=OneTime}">
                                <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <shelf:ShelfScroller x:Name="CompilationsShelf"
                                         ItemsSource="{x:Bind ViewModel.Compilations, Mode=OneWay}"
                                         MinItemWidth="160" MaxItemWidth="200" Spacing="12">
                        <shelf:ShelfScroller.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid Width="160">
                                    <!-- Loaded: real card -->
                                    <cards:ContentCard
                                        Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ImageUrl="{x:Bind Data.ImageUrl, Mode=OneWay}"
                                        Title="{x:Bind Data.Name, Mode=OneWay}"
                                        Subtitle="{x:Bind Data.Year, Mode=OneWay}"
                                        PlaceholderColorHex="{x:Bind Data.ColorHex, Mode=OneWay}"
                                        CardClick="AlbumCard_Click"
                                        CardHover="AlbumCard_Hover"/>
                                    <!-- Loading: shimmer card -->
                                    <StackPanel Spacing="8" Padding="8"
                                                Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <controls:Shimmer Height="150" CornerRadius="8"/>
                                        <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                                        <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </shelf:ShelfScroller.ItemTemplate>
                    </shelf:ShelfScroller>
                    <controls1:ErrorStateView x:Uid="Views_ArtistPage__ErrorStateView_13"
                        Visibility="{x:Bind ViewModel.HasCompilationsError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Title="Couldn't load all compilations"
                        Message="Some compilations may be missing"
                        RetryCommand="{x:Bind ViewModel.RetryDiscographyCommand}"
                        HorizontalAlignment="Left"
                        Padding="0,4,0,0"/>
                </StackPanel>

                <!-- ─── Concerts ─── -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.HasConcerts, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock x:Uid="Views_ArtistPage__TextBlock_14" Text="Concerts" FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                        <controls1:LocationButton
                            LocationName="{x:Bind ViewModel.UserLocationName, Mode=TwoWay}"
                            LocationChanged="LocationButton_LocationChanged"/>
                    </StackPanel>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Concerts, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ConcertVm">
                                <Button Click="ConcertCard_Click" Padding="16,12" Width="200"
                                        CornerRadius="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        HorizontalContentAlignment="Left"
                                        Tag="{x:Bind Uri}">
                                    <Grid RowSpacing="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Date badge -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind DateFormatted}" FontWeight="Bold" FontSize="16"
                                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Bind DayOfWeek}" FontSize="12" Opacity="0.6"
                                                       VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                            <Border CornerRadius="4" Padding="6,2" Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                    Visibility="{x:Bind IsNearUser, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Uid="Views_ArtistPage__TextBlock_15" Text="Near you" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Venue -->
                                        <TextBlock Grid.Row="1" Text="{x:Bind Venue}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>

                                        <!-- City -->
                                        <TextBlock Grid.Row="2" Text="{x:Bind City}" FontSize="12" Opacity="0.6"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>

                                        <!-- Title (lineup) -->
                                        <TextBlock Grid.Row="3" Text="{x:Bind Title}" FontSize="11" Opacity="0.5"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1" Margin="0,4,0,0"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- ─── Related Artists ─── -->
                <shelf:SectionShelf x:Uid="Views_ArtistPage__SectionShelf_FansAlsoLike"
                                    Title="Fans Also Like"
                                    ItemsSource="{x:Bind ViewModel.RelatedArtists, Mode=OneWay}"
                                    MinItemWidth="140">
                    <shelf:SectionShelf.ItemTemplate>
                        <DataTemplate x:DataType="vm:RelatedArtistVm">
                            <cards:ContentCard
                                Width="140"
                                ImageUrl="{x:Bind ImageUrl}"
                                Title="{x:Bind Name}"
                                Subtitle="Artist"
                                PlaceholderGlyph="&#xE77B;"
                                IsCircularImage="True"
                                CenterText="True"
                                NavigationUri="{x:Bind Uri}"
                                NavigationTitle="{x:Bind Name}"/>
                        </DataTemplate>
                    </shelf:SectionShelf.ItemTemplate>
                </shelf:SectionShelf>

                <!-- ─── Biography ─── -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.Biography, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock x:Uid="Views_ArtistPage__TextBlock_17" Text="About" FontWeight="Bold" FontSize="20"/>
                    <controls1:HtmlTextBlock Text="{x:Bind ViewModel.Biography, Mode=OneWay}"
                                            MaxLines="6"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

            </StackPanel> <!-- ContentContainer -->

            </Grid>
        </ScrollView>

        <Grid x:Name="ShyHeaderHost"
              Canvas.ZIndex="5"
              VerticalAlignment="Top"
              Margin="16,16,16,0">
            <Grid x:Name="ShyHeaderCard"
                  HorizontalAlignment="Center"
                  MaxWidth="760"
                  MinHeight="68"
                  Visibility="Collapsed">
                <!-- Chrome layer: matched-id "card-shell" pairs with the invisible
                     chrome inside HeroOverlayPanel. TransitionHelper morphs this
                     visible chrome FROM the source chrome bounds (full-width, bottom
                     of hero) TO this floating-card position — translation+scale
                     interpolation gives the chrome itself a true morph instead of
                     just appearing in place. -->
                <Border transitions:TransitionHelper.Id="card-shell"
                        CornerRadius="18"
                        BorderBrush="{ThemeResource ShyHeaderBorderBrush}"
                        BorderThickness="1.5">
                    <Border.Background>
                        <AcrylicBrush TintColor="{ThemeResource SolidBackgroundFillColorBase}"
                                      TintOpacity="0.78"
                                      FallbackColor="{ThemeResource CardBackgroundFillColorDefault}"/>
                    </Border.Background>
                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>
                </Border>

                <Grid Padding="12,10" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="40"
                            Height="40"
                            CornerRadius="20"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            transitions:TransitionHelper.Id="artist-avatar">
                        <Image Source="{x:Bind ViewModel.ArtistImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=64}"
                               Stretch="UniformToFill"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"
                                       transitions:TransitionHelper.Id="artist-name"/>
                            <Border Width="20"
                                    Height="20"
                                    CornerRadius="10"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    Visibility="{x:Bind ViewModel.IsVerified, Mode=OneWay}"
                                    transitions:TransitionHelper.Id="artist-badge">
                                <FontIcon Glyph="&#xE73E;"
                                          FontSize="10"
                                          Foreground="White"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"
                                   Visibility="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                   transitions:TransitionHelper.Id="artist-meta">
                            <Run Text="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay}"/>
                            <Run Text=" monthly listeners"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.PlayTopTracksCommand}"
                                Padding="16,8"
                                CornerRadius="18"
                                MinWidth="92"
                                transitions:TransitionHelper.Id="artist-play">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <playback:PlaybackActionContent IconSize="14"
                                                               SpinnerSize="14"
                                                               IsPlaying="{x:Bind ViewModel.IsArtistContextPlaying, Mode=OneWay}"
                                                               IsPending="{x:Bind ViewModel.IsPlayPending, Mode=OneWay}"
                                                               ActionForeground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.ArtistPlayButtonText, Mode=OneWay}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.ToggleFollowCommand}"
                                Padding="14,8"
                                CornerRadius="18"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                transitions:TransitionHelper.Id="artist-follow">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="{x:Bind ViewModel.IsFollowing, Mode=OneWay, Converter={StaticResource BoolToFollowGlyphConverter}}"
                                          FontSize="12"/>
                                <TextBlock Text="{x:Bind ViewModel.IsFollowing, Mode=OneWay, Converter={StaticResource BoolToFollowTextConverter}}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
