<?xml version="1.0" encoding="utf-8"?>
<winuiex:WindowEx
    x:Class="Wavee.UI.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winuiex="using:WinUIEx"
    xmlns:splash="using:Wavee.UI.WinUI.Controls.Splash"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Uid="MainWindow"
    mc:Ignorable="d"
    Title="Wavee"
    MinWidth="800"
    MinHeight="600"
    PersistenceId="WaveeMainWindow">

    <winuiex:WindowEx.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </winuiex:WindowEx.SystemBackdrop>

    <!-- BootSplash sits over RootFrame (z-order: above) and covers the
         ~150ms cold-start gap between Activate() and ShellPage's first
         layout pass. MainWindow.InitializeApplicationAsync triggers the
         splash fade-out once Frame.Navigated has fired. -->
    <Grid>
        <Frame x:Name="RootFrame" />
        <splash:BootSplash x:Name="Splash" />
    </Grid>
</winuiex:WindowEx>
