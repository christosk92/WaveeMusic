<?xml version="1.0" encoding="utf-8" ?>
<!--
    Windows 11 AI brand language for WaveeMusic.

    The Copilot AI mark is a rainbow gradient (blue → violet → magenta → orange)
    paired with the FluentIcons / Segoe Fluent Icons "Sparkle" glyph. This
    dictionary defines reusable brushes, an icon button style, and the caption
    style used to label any AI-generated text in the app.

    Light/dark variants follow Fluent's ThemeDictionaries pattern. The gradient
    stops are intentionally kept identical across light/dark — the gradient is
    the brand mark, not a tonal accent. Border + caption surfaces use neutral
    Fluent tokens that adapt automatically.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!-- ────────────────────────────────────────────────────────────────
             Light theme
             ──────────────────────────────────────────────────────────────── -->
        <ResourceDictionary x:Key="Light">
            <!-- Copilot rainbow gradient. Stop positions roughly mirror the AI
                 search-bar treatment in Windows 11 Settings → AI components. -->
            <LinearGradientBrush x:Key="AiAccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#2D5DFF" Offset="0.00" />
                <GradientStop Color="#7B43E0" Offset="0.30" />
                <GradientStop Color="#A33EBC" Offset="0.50" />
                <GradientStop Color="#E94BC9" Offset="0.72" />
                <GradientStop Color="#F4793A" Offset="1.00" />
            </LinearGradientBrush>

            <!-- Sampled mid-color. Used where a flat fill reads better than a
                 gradient (small chips, captions on cluttered backgrounds). -->
            <SolidColorBrush x:Key="AiAccentSolidBrush" Color="#A33EBC" />

            <!-- Subtle border for AI panels (e.g. the explanation flyout). -->
            <SolidColorBrush x:Key="AiBorderBrush" Color="#33A33EBC" />

            <!-- Background tint for the AI panel itself. ~6% accent over the
                 default card color so it reads as related to the gradient
                 without competing with body text contrast. -->
            <SolidColorBrush x:Key="AiPanelBackgroundBrush" Color="#0FA33EBC" />
        </ResourceDictionary>

        <!-- ────────────────────────────────────────────────────────────────
             Dark theme — same gradient, slightly brighter mid for contrast
             ──────────────────────────────────────────────────────────────── -->
        <ResourceDictionary x:Key="Dark">
            <LinearGradientBrush x:Key="AiAccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#5B85FF" Offset="0.00" />
                <GradientStop Color="#9E6EF5" Offset="0.30" />
                <GradientStop Color="#C261D8" Offset="0.50" />
                <GradientStop Color="#F26FDC" Offset="0.72" />
                <GradientStop Color="#FF9456" Offset="1.00" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="AiAccentSolidBrush" Color="#C261D8" />
            <SolidColorBrush x:Key="AiBorderBrush" Color="#55C261D8" />
            <SolidColorBrush x:Key="AiPanelBackgroundBrush" Color="#1FC261D8" />
        </ResourceDictionary>

        <!-- ────────────────────────────────────────────────────────────────
             High-contrast theme — drop the gradient, use SystemColor tokens
             ──────────────────────────────────────────────────────────────── -->
        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="AiAccentGradientBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AiAccentSolidBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AiBorderBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AiPanelBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ────────────────────────────────────────────────────────────────────
         Button style for AI affordances. Compact, transparent background by
         default, gradient-stroke border on hover, gradient-tinted glyph.
         Designed for inline use next to lyrics or in section headers — no
         heavy surface, just a hint that "this does something AI-flavored".
         ──────────────────────────────────────────────────────────────────── -->
    <Style x:Key="SparkleAffordanceButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource AiAccentSolidBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.BorderBrush" Value="{ThemeResource AiAccentGradientBrush}" />
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource AiPanelBackgroundBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.BorderBrush" Value="{ThemeResource AiAccentGradientBrush}" />
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource AiPanelBackgroundBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Opacity" Value="0.45" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ────────────────────────────────────────────────────────────────────
         Caption style for "AI interpretation" labels next to any model output.
         Small caps-style line, gradient underline (via a separate Border in
         the consumer XAML — there's no reliable XAML way to put a gradient
         under a TextBlock without an additional element).
         ──────────────────────────────────────────────────────────────────── -->
    <Style x:Key="AiCaptionTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
        <Setter Property="Foreground" Value="{ThemeResource AiAccentSolidBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="50" />
        <Setter Property="Opacity" Value="0.95" />
    </Style>

    <!-- The "AI interpretation" caption pairs with this thin gradient bar to
         get the underline effect without sub-pixel positioning hacks. Drop
         it directly under the TextBlock in consumer XAML. Thickness 2 px. -->
    <Style x:Key="AiCaptionUnderlineStyle" TargetType="Border">
        <Setter Property="Height" Value="2" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{ThemeResource AiAccentGradientBrush}" />
        <Setter Property="CornerRadius" Value="1" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

</ResourceDictionary>
