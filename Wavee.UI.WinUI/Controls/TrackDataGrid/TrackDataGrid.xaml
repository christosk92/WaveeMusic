<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.TrackDataGrid.TrackDataGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:contracts="using:Wavee.UI.WinUI.Data.Contracts"
    xmlns:local="using:Wavee.UI.WinUI.Controls.TrackDataGrid"
    xmlns:track="using:Wavee.UI.WinUI.Controls.Track">

    <UserControl.Resources>
        <!--
            Self-contained ToggleButton style — matches IconButtonStyle's visual shape
            (32×32, transparent, subtle fill on hover/check). Defined inline because the
            app's SubtleToggleButtonStyle lives in Styles/PlayerBarStyles.xaml, which is
            only merged into PlayerBar.xaml's local scope and not reachable from here.
        -->
        <Style x:Key="TrackDataGridToggleButtonStyle" BasedOn="{StaticResource DefaultToggleButtonStyle}" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </UserControl.Resources>

    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--
            Files-app-style toolbar: right-aligned icon-only buttons. No Play/Shuffle/Like —
            those live in the page's left hero column. The Details toggle opens the right
            panel in TrackDetails mode with whatever row is currently selected in the grid.
            ShowToolbar=false on the grid collapses this whole block (album page uses that).
        -->
        <Grid
            x:Name="ToolbarHost"
            Grid.Row="0"
            Padding="8,6,8,6"
            Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--
                Page-specific left-side content (e.g. Liked Songs' Play/Shuffle + stats).
                Empty by default, so pages that don't set ToolbarLeftContent keep today's
                layout with the icon cluster spanning the full row.
            -->
            <ContentPresenter
                Grid.Column="0"
                Content="{x:Bind ToolbarLeftContent, Mode=OneWay}"
                HorizontalAlignment="Left"
                VerticalAlignment="Center" />

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="2">
                <ToggleButton
                    x:Name="FilterToggle"
                    Style="{StaticResource TrackDataGridToggleButtonStyle}"
                    Checked="FilterToggle_Toggled"
                    Unchecked="FilterToggle_Toggled"
                    ToolTipService.ToolTip="Filter">
                    <FontIcon
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        FontSize="14"
                        Glyph="&#xE71C;" />
                </ToggleButton>

                <!--  Selection menu — Select all / Invert / Clear. Matches Files' selection flyout.  -->
                <Button
                    x:Name="SelectionButton"
                    Style="{ThemeResource IconButtonStyle}"
                    ToolTipService.ToolTip="Selection">
                    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <FontIcon
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="14"
                            Glyph="&#xE762;" />
                        <FontIcon
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="10"
                            Opacity="0.7"
                            Glyph="&#xE70D;" />
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem
                                Text="Select all"
                                Click="SelectAllItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE762;" />
                                </MenuFlyoutItem.Icon>
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="A" Modifiers="Control" />
                                </MenuFlyoutItem.KeyboardAccelerators>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem
                                Text="Invert selection"
                                Click="InvertSelectionItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8B9;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem
                                x:Name="ClearSelectionItem"
                                Text="Clear selection"
                                Click="ClearSelectionItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE711;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <Button
                    x:Name="SortButton"
                    Style="{ThemeResource IconButtonStyle}"
                    ToolTipService.ToolTip="Sort">
                    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <FontIcon
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="14"
                            Glyph="&#xE8CB;" />
                        <FontIcon
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="10"
                            Opacity="0.7"
                            Glyph="&#xE70D;" />
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutSubItem x:Name="SortBySubItem" Text="Sort by">
                                <MenuFlyoutSubItem.Icon>
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8CB;" />
                                </MenuFlyoutSubItem.Icon>
                            </MenuFlyoutSubItem>
                            <MenuFlyoutSeparator />
                            <RadioMenuFlyoutItem
                                x:Name="SortAscendingItem"
                                Text="Ascending"
                                GroupName="TrackGridSortDirection"
                                Click="SortDirectionItem_Click"
                                Tag="Ascending"
                                IsChecked="True" />
                            <RadioMenuFlyoutItem
                                x:Name="SortDescendingItem"
                                Text="Descending"
                                GroupName="TrackGridSortDirection"
                                Click="SortDirectionItem_Click"
                                Tag="Descending" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <Button
                    x:Name="ViewButton"
                    Style="{ThemeResource IconButtonStyle}"
                    ToolTipService.ToolTip="View">
                    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <FontIcon
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="14"
                            Glyph="&#xE8FD;" />
                        <FontIcon
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="10"
                            Opacity="0.7"
                            Glyph="&#xE70D;" />
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel Width="280" Spacing="14">
                                <TextBlock Text="Size" FontWeight="SemiBold" FontSize="13" />
                                <Slider
                                    x:Name="DensitySlider"
                                    Minimum="0"
                                    Maximum="4"
                                    StepFrequency="1"
                                    SnapsTo="StepValues"
                                    TickFrequency="1"
                                    TickPlacement="Outside"
                                    ValueChanged="DensitySlider_ValueChanged" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="XS" FontSize="10" HorizontalAlignment="Center" Opacity="0.6" />
                                    <TextBlock Grid.Column="1" Text="S" FontSize="10" HorizontalAlignment="Center" Opacity="0.6" />
                                    <TextBlock Grid.Column="2" Text="M" FontSize="10" HorizontalAlignment="Center" Opacity="0.6" />
                                    <TextBlock Grid.Column="3" Text="L" FontSize="10" HorizontalAlignment="Center" Opacity="0.6" />
                                    <TextBlock Grid.Column="4" Text="XL" FontSize="10" HorizontalAlignment="Center" Opacity="0.6" />
                                </Grid>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <ToggleButton
                    x:Name="DetailsToggle"
                    Style="{StaticResource TrackDataGridToggleButtonStyle}"
                    Click="DetailsToggle_Click"
                    ToolTipService.ToolTip="Details">
                    <FontIcon
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        FontSize="14"
                        Glyph="&#xE946;" />
                </ToggleButton>
            </StackPanel>
        </Grid>

        <!--  Inline filter TextBox — collapses until the toolbar toggle expands it.  -->
        <Border
            x:Name="FilterHost"
            Grid.Row="1"
            Padding="12,6,12,8"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Visibility="Collapsed">
            <TextBox
                x:Name="FilterBox"
                PlaceholderText="Filter tracks"
                TextChanged="FilterBox_TextChanged" />
        </Border>

        <!--  Header + list. The ListView uses its OWN internal ScrollViewer
              for both axes (horizontal = Auto, vertical = Auto) so
              virtualization is preserved per Microsoft's guidance. The
              HeaderHost sits OUTSIDE the ListView and stays vertically pinned;
              TrackDataGrid.xaml.cs syncs its X translation to the ListView's
              internal ScrollViewer.HorizontalOffset via ViewChanged.  -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header row: built in code-behind from Columns. The wrapping
                  ScrollViewer with both scroll modes DISABLED provides
                  automatic clipping of the HeaderHost's X translation so
                  scrolled-out header content doesn't visually bleed out of
                  the page bounds. The actual horizontal offset is driven
                  programmatically from the RowsList's internal ScrollViewer
                  via HeaderScrollTransform.  -->
            <ScrollViewer
                Grid.Row="0"
                Height="40"
                HorizontalScrollMode="Disabled"
                HorizontalScrollBarVisibility="Hidden"
                VerticalScrollMode="Disabled"
                VerticalScrollBarVisibility="Hidden"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <!-- HorizontalAlignment must be Stretch (NOT Left). With Left, the Grid
                     measures itself in shrink-to-content mode and any * column collapses
                     to MinWidth — producing exactly the same misalignment as the WinUI 3
                     ListView.Header bug (#3682), even though this Grid is OUTSIDE the
                     ListView. Rows inside RowsList stretch to viewport width via
                     HorizontalContentAlignment="Stretch", so their * Title column expands
                     to its MaxWidth (640) while a Left-aligned header would stay at
                     MinWidth (120). Stretch makes both sides resolve identically.

                     Padding="8,0" mirrors TrackItem.xaml's RowRoot Padding="8,8" — without
                     it, every header column starts 8 px left of the matching row column. -->
                <Grid
                    x:Name="HeaderHost"
                    HorizontalAlignment="Stretch"
                    MinWidth="500"
                    Padding="8,0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="HeaderScrollTransform" />
                    </Grid.RenderTransform>
                </Grid>
            </ScrollViewer>

            <ListView
                x:Name="RowsList"
                Grid.Row="1"
                HorizontalContentAlignment="Stretch"
                Padding="0"
                ScrollViewer.HorizontalScrollMode="Auto"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                KeyDown="RowsList_KeyDown"
                SelectionMode="Extended">
                <!--
                    ItemContainerStyle + ItemTemplate mirror TrackListView — selection pill,
                    hover paint, heart toggle, index/play/equalizer swap, tap-to-play, and
                    context menu all live inside TrackItem (Row mode). This grid contributes
                    only the toolbar + header chrome on top.
                -->
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="contracts:ITrackItem">
                        <track:TrackItem Track="{x:Bind}" Mode="Row" />
                    </DataTemplate>
                </ListView.ItemTemplate>

                <!-- Footer. StackPanel HorizontalAlignment=Stretch + ContentPresenter
                     HorizontalContentAlignment=Stretch mirror the Header pattern used
                     elsewhere: WinUI 3's implicit ListView.Footer container doesn't
                     propagate viewport width during measure, so a bare ContentPresenter
                     collapses to zero width.

                     NOTE: pages hosting a horizontally-scrolling widget in FooterContent
                     (e.g. a shelf) must set AllowHorizontalRowScroll="False" on the
                     TrackDataGrid itself. Otherwise the widget's full content extent
                     propagates upward and adds a page-level horizontal scrollbar. -->
                <ListView.Footer>
                    <StackPanel HorizontalAlignment="Stretch">
                        <ContentPresenter Content="{x:Bind FooterContent, Mode=OneWay}"
                                          HorizontalContentAlignment="Stretch"/>
                    </StackPanel>
                </ListView.Footer>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
