<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.LocationButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Wavee.UI.WinUI.Converters">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True"/>
    </UserControl.Resources>

    <HyperlinkButton Click="OnClick" Padding="0" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6">
            <FontIcon Glyph="&#xE81D;" FontSize="12"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Text="{x:Bind LocationName, Mode=OneWay}"
                       FontSize="13"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind LocationName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
            <TextBlock Text="Set location" FontSize="13"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Visibility="{x:Bind LocationName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
        </StackPanel>
    </HyperlinkButton>
</UserControl>
