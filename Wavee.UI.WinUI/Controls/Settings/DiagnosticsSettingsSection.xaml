<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Settings.DiagnosticsSettingsSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:diag="using:Wavee.UI.WinUI.Controls.Diagnostics"
    xmlns:services="using:Wavee.UI.WinUI.Services"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    mc:Ignorable="d">

    <ScrollView VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Hidden">
        <StackPanel Spacing="0" Padding="0,16,0,24">
            <controls:SettingsCard Margin="0,0,0,12"
                                   Header="Verbose logging"
                                   Description="Captures detailed diagnostic output to the rolling log file. Useful for bug reports. Restart the app for the audio engine to pick up the change.">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE9D9;"/>
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch IsOn="{x:Bind ViewModel.VerboseLoggingEnabled, Mode=TwoWay}"/>
            </controls:SettingsCard>

            <controls:SettingsExpander x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsExpander_1" Margin="0,0,0,12"
                                       Header="Audio Pipeline"
                                       Description="{x:Bind ViewModel.AudioPipelineMode, Mode=OneWay}">
                <controls:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE767;"/>
                </controls:SettingsExpander.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ViewModel.AudioPipelineStatus, Mode=OneWay}"/>
                </StackPanel>
                <controls:SettingsExpander.Items>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_2" Header="Process ID"
                                           Description="PID of the audio engine process (0 = in-process)">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE943;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioPipelinePid, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_3" Header="Restart Count"
                                           Description="Number of auto-restarts this session">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE72C;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioRestartCount, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_4" Header="Audio Underruns"
                                           Description="PortAudio buffer underflows (causes audible glitches)">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7BA;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioUnderrunCount, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_5" Header="GC Collections"
                                           Description="Garbage collection counts (Gen2 causes audio freezes)">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE74D;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioGcStats, Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_6" Header="Slowest UI Operations"
                                           Description="Profiled operations that block the UI thread">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE916;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioProfilerTop, Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="11"
                                   MaxWidth="300" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_7" Header="IPC Throughput"
                                           Description="Messages sent/received over the Named Pipe">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8AB;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioThroughput, Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_8" Header="State Freshness"
                                           Description="Time since last state update from audio process">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE2AD;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioStateFreshness, Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

            <Border Margin="0,0,0,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                <diag:IpcLineChart x:Name="RttChart" Height="180"/>
            </Border>

            <controls:SettingsExpander x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsExpander_9" Margin="0,0,0,12"
                                       Header="Clock Synchronization"
                                       Description="NTP-style sync with Spotify's server clock">
                <controls:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE121;"/>
                </controls:SettingsExpander.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="{x:Bind ViewModel.ClockOffsetMs, Mode=OneWay}"/>
                        <Run x:Uid="Controls_Settings_DiagnosticsSettingsSection__Run_10" Text="ms offset"/>
                    </TextBlock>
                    <FontIcon Glyph="&#xE73E;" FontSize="12"
                              Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                              Visibility="{x:Bind ViewModel.ClockIsSynced, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
                <controls:SettingsExpander.Items>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_11" Header="Network round-trip"
                                           Description="Latency of the best sync sample">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE968;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.ClockLastRttMs, Mode=OneWay}"/>
                            <Run x:Uid="Controls_Settings_DiagnosticsSettingsSection__Run_12" Text="ms"/>
                        </TextBlock>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_13" Header="Sync interval"
                                           Description="How often to re-synchronize">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE916;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox SelectedIndex="{x:Bind ViewModel.ClockSyncIntervalIndex, Mode=TwoWay}"
                                  MinWidth="140">
                            <ComboBoxItem x:Uid="Controls_Settings_DiagnosticsSettingsSection__ComboBoxItem_14" Content="5 minutes"/>
                            <ComboBoxItem x:Uid="Controls_Settings_DiagnosticsSettingsSection__ComboBoxItem_15" Content="10 minutes"/>
                            <ComboBoxItem x:Uid="Controls_Settings_DiagnosticsSettingsSection__ComboBoxItem_16" Content="15 minutes"/>
                            <ComboBoxItem x:Uid="Controls_Settings_DiagnosticsSettingsSection__ComboBoxItem_17" Content="30 minutes"/>
                        </ComboBox>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_18" Header="Last sync"
                                           Description="{x:Bind ViewModel.ClockLastSyncDisplay, Mode=OneWay}">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE895;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel VerticalAlignment="Center" Spacing="0">
                                <TextBlock x:Uid="Controls_Settings_DiagnosticsSettingsSection__TextBlock_19" Text="Next sync in"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.ClockNextSyncCountdown, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button x:Uid="Controls_Settings_DiagnosticsSettingsSection__Button_20" Content="Sync now" Command="{x:Bind ViewModel.RefreshClockCommand}"/>
                        </StackPanel>
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

            <Grid MinHeight="360" Height="520">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8,8,0,0" Padding="12,8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                            <ToggleButton Content="VRB" IsChecked="{x:Bind ViewModel.ShowVerbose, Mode=TwoWay}"
                                          FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                          FontFamily="Consolas" CornerRadius="4"/>
                            <ToggleButton Content="DBG" IsChecked="{x:Bind ViewModel.ShowDebug, Mode=TwoWay}"
                                          FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                          FontFamily="Consolas" CornerRadius="4"/>
                            <ToggleButton Content="INF" IsChecked="{x:Bind ViewModel.ShowInfo, Mode=TwoWay}"
                                          FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                          FontFamily="Consolas" CornerRadius="4"/>
                            <ToggleButton Content="WRN" IsChecked="{x:Bind ViewModel.ShowWarning, Mode=TwoWay}"
                                          FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                          FontFamily="Consolas" CornerRadius="4"/>
                            <ToggleButton Content="ERR" IsChecked="{x:Bind ViewModel.ShowError, Mode=TwoWay}"
                                          FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                          FontFamily="Consolas" CornerRadius="4"/>
                            <ToggleButton Content="FTL" IsChecked="{x:Bind ViewModel.ShowFatal, Mode=TwoWay}"
                                          FontSize="10" Padding="6,2" MinWidth="0" MinHeight="0"
                                          FontFamily="Consolas" CornerRadius="4"/>
                        </StackPanel>

                        <Border Grid.Column="1" Width="1" Height="20"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                        <AutoSuggestBox x:Uid="Controls_Settings_DiagnosticsSettingsSection__AutoSuggestBox_21" Grid.Column="2"
                                        PlaceholderText="Filter..."
                                        QueryIcon="Find"
                                        Text="{x:Bind ViewModel.LogSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        VerticalAlignment="Center"
                                        MinWidth="120"/>

                        <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                   FontSize="11" FontFamily="Consolas"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                            <Run Text="{x:Bind ViewModel.FilteredLogEntries.Count, Mode=OneWay}"/>
                            <Run x:Uid="Controls_Settings_DiagnosticsSettingsSection__Run_22" Text="lines"/>
                        </TextBlock>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4">
                            <Button x:Uid="Controls_Settings_DiagnosticsSettingsSection__Button_23" Content="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="12"
                                    ToolTipService.ToolTip="Clear (Ctrl+L)"
                                    Command="{x:Bind ViewModel.ClearLogsCommand}"
                                    Padding="8,6" MinWidth="0" MinHeight="0">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="Control" Key="L"/>
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button x:Uid="Controls_Settings_DiagnosticsSettingsSection__Button_24" Content="&#xE8A7;" FontFamily="Segoe Fluent Icons" FontSize="12"
                                    ToolTipService.ToolTip="Open logs folder"
                                    Command="{x:Bind ViewModel.OpenLogsFolderCommand}"
                                    Padding="8,6" MinWidth="0" MinHeight="0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1,0,1,1"
                        CornerRadius="0,0,8,8">
                    <ScrollView x:Name="LogScrollView"
                                ContentOrientation="Vertical"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Hidden"
                                PointerWheelChanged="LogScrollView_PointerWheelChanged">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.FilteredLogEntries, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="0"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="services:LogEntry">
                                    <Grid MinHeight="26" ColumnSpacing="10" Padding="12,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="76"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" CornerRadius="4"
                                                Padding="4,1" HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <TextBlock Text="{x:Bind LevelShort}" FontSize="9"
                                                       FontFamily="Consolas" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Grid.Column="1" Text="{x:Bind TimeString}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2" Text="{x:Bind Category}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3" Text="{x:Bind Message}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollView>
                </Border>

                <Button x:Name="ResumeScrollButton" Grid.Row="1"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Margin="0,12,0,0" Visibility="Collapsed"
                        Click="ResumeScroll_Click"
                        CornerRadius="16" Padding="16,8"
                        Style="{StaticResource AccentButtonStyle}"
                        Canvas.ZIndex="10">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74A;" FontSize="12"/>
                        <TextBlock x:Uid="Controls_Settings_DiagnosticsSettingsSection__TextBlock_25" Text="New logs" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Grid Grid.Row="2" Margin="0,12,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="Controls_Settings_DiagnosticsSettingsSection__TextBlock_26" Grid.Column="0" Text="Past Logs" FontSize="13" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ItemsRepeater Grid.Column="1" ItemsSource="{x:Bind ViewModel.PastLogFiles, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:PastLogFile">
                                <Button CommandParameter="{x:Bind FilePath}"
                                        Click="OpenLogFile_Click"
                                        Padding="10,4" CornerRadius="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE8A5;" FontSize="11"/>
                                        <TextBlock Text="{x:Bind FileName}" FontSize="11" FontFamily="Consolas"/>
                                        <TextBlock Text="{x:Bind FileSize}" FontSize="10"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </Grid>
            </Grid>
        </StackPanel>
    </ScrollView>
</UserControl>
