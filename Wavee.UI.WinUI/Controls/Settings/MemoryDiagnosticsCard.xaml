<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Settings.MemoryDiagnosticsCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded"
    mc:Ignorable="d">

    <controls:SettingsExpander Margin="0,0,0,12"
                               Header="Memory diagnostics"
                               Description="Live process memory + cache + retained-page counts. Use this to find what grows during navigation.">
        <controls:SettingsExpander.HeaderIcon>
            <FontIcon Glyph="&#xE950;"/>
        </controls:SettingsExpander.HeaderIcon>

        <TextBlock VerticalAlignment="Center"
                   FontFamily="Consolas" FontSize="12"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="{x:Bind ViewModel.WorkingSetMb, Mode=OneWay}"/>

        <controls:SettingsExpander.Items>
            <controls:SettingsCard Header="Managed heap"
                                   Description="GC.GetTotalMemory">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE74D;"/>
                </controls:SettingsCard.HeaderIcon>
                <TextBlock Text="{x:Bind ViewModel.ManagedMb, Mode=OneWay}"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Heap committed"
                                   Description="Total committed bytes (incl. fragmentation)">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7B8;"/>
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.HeapCommittedMb, Mode=OneWay}"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center">
                        <Run Text="frag"/>
                        <Run Text="{x:Bind ViewModel.HeapFragmentedMb, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </controls:SettingsCard>

            <controls:SettingsCard Header="GC collections"
                                   Description="Counts since process start">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE72C;"/>
                </controls:SettingsCard.HeaderIcon>
                <TextBlock Text="{x:Bind ViewModel.GcCounts, Mode=OneWay}"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </controls:SettingsCard>

            <controls:SettingsCard Header="CPU usage"
                                   Description="% of all logical cores since previous sample (matches Task Manager)">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE950;"/>
                </controls:SettingsCard.HeaderIcon>
                <TextBlock Text="{x:Bind ViewModel.CpuPercent, Mode=OneWay}"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Tabs / cached pages"
                                   Description="Open tabs and total retained Page instances across them">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8FD;"/>
                </controls:SettingsCard.HeaderIcon>
                <TextBlock FontFamily="Consolas" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="{x:Bind ViewModel.TabCount, Mode=OneWay}"/>
                    <Run Text="tabs · "/>
                    <Run Text="{x:Bind ViewModel.CachedPageCount, Mode=OneWay}"/>
                    <Run Text="pages"/>
                </TextBlock>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Image cache"
                                   Description="BitmapImage entries (bucketed by URL × decode size)">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xEB9F;"/>
                </controls:SettingsCard.HeaderIcon>
                <TextBlock Text="{x:Bind ViewModel.ImageCacheCount, Mode=OneWay}"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Cache breakdown"
                                   Description="Counts per ICleanableCache instance">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8F1;"/>
                </controls:SettingsCard.HeaderIcon>
                <TextBlock Text="{x:Bind ViewModel.CacheBreakdown, Mode=OneWay}"
                           FontFamily="Consolas" FontSize="11"
                           MaxWidth="320" TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Live ViewModels"
                                   Description="Tracked via WeakReference. Counts that don't drop after navigating away indicate leaks.">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7C3;"/>
                </controls:SettingsCard.HeaderIcon>
                <TextBlock Text="{x:Bind ViewModel.LiveViewModels, Mode=OneWay}"
                           FontFamily="Consolas" FontSize="11"
                           MaxWidth="320" TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Actions"
                                   Description="Run experiments and append snapshots to %AppData%\Wavee\diag\memory-{date}.csv">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE945;"/>
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Vertical" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="Force GC" Command="{x:Bind ViewModel.ForceGcCommand}"
                                Padding="10,4"/>
                        <Button Content="Release working set" Command="{x:Bind ViewModel.ReleaseWorkingSetCommand}"
                                Padding="10,4"/>
                        <Button Content="Snapshot" Command="{x:Bind ViewModel.SnapshotCommand}"
                                Padding="10,4"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="Clear image cache" Command="{x:Bind ViewModel.ClearImageCacheCommand}"
                                Padding="10,4"/>
                        <Button Content="Clear all caches" Command="{x:Bind ViewModel.ClearAllCachesCommand}"
                                Padding="10,4"/>
                        <Button Content="Drop tab cache" Command="{x:Bind ViewModel.DropTabCacheCommand}"
                                Padding="10,4"/>
                    </StackPanel>
                </StackPanel>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Last action"
                                   Description="{x:Bind ViewModel.LastAction, Mode=OneWay}">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;"/>
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
        </controls:SettingsExpander.Items>
    </controls:SettingsExpander>
</UserControl>
