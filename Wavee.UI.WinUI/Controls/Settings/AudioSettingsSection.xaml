<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Settings.AudioSettingsSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:eq="using:Wavee.UI.WinUI.Controls.Equalizer"
    mc:Ignorable="d">

    <Grid Padding="0,16,0,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0" Header="Preset"
                      SelectedIndex="{x:Bind ViewModel.SelectedEqPresetIndex, Mode=TwoWay}"
                      MinWidth="160">
                <ComboBoxItem Content="Flat"/>
                <ComboBoxItem Content="Bass Boost"/>
                <ComboBoxItem Content="Treble Boost"/>
                <ComboBoxItem Content="Vocal"/>
                <ComboBoxItem Content="Radio"/>
            </ComboBox>

            <ToggleSwitch Grid.Column="2" Header="Equalizer"
                          IsOn="{x:Bind ViewModel.IsEqualizerEnabled, Mode=TwoWay}"
                          OnContent="On" OffContent="Off"
                          Margin="0,0,16,0"/>

            <Button Grid.Column="3" Content="Reset" VerticalAlignment="Bottom"
                    Command="{x:Bind ViewModel.ResetEqCommand}"/>
        </Grid>

        <TextBlock Grid.Row="1"
                   Text="{x:Bind ViewModel.EqPresetDescription, Mode=OneWay}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   FontSize="12" Margin="0,0,0,12"/>

        <eq:EqualizerCurveControl Grid.Row="2"
                                  Bands="{x:Bind ViewModel.EqBands, Mode=OneWay}"
                                  MinHeight="250" MaxHeight="400"/>
    </Grid>
</UserControl>
