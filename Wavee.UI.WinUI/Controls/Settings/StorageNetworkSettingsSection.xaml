<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Settings.StorageNetworkSettingsSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:CachingProfileTooltipConverter x:Key="CachingProfileTooltipConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollView>
        <StackPanel Spacing="4" Padding="0,16,0,24">
            <TextBlock x:Uid="Controls_Settings_StorageNetworkSettingsSection__TextBlock_1" Text="Memory Caches" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>

            <controls:SettingsCard x:Uid="Controls_Settings_StorageNetworkSettingsSection__SettingsCard_2" Header="Caching profile"
                                   Description="Balances memory usage against network refetches and browsing speed. Medium matches the default.">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8F1;"/>
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Right">
                    <Slider MinWidth="280"
                            Minimum="0"
                            Maximum="3"
                            StepFrequency="1"
                            SnapsTo="Ticks"
                            TickFrequency="1"
                            TickPlacement="Outside"
                            Value="{x:Bind ViewModel.CachingProfileIndex, Mode=TwoWay}"
                            ThumbToolTipValueConverter="{StaticResource CachingProfileTooltipConverter}"/>
                    <Grid MinWidth="280">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Low"
                                   HorizontalAlignment="Left"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Uid="Controls_Settings_StorageNetworkSettingsSection__TextBlock_3" Grid.Column="1" Text="Medium"
                                   HorizontalAlignment="Center"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Uid="Controls_Settings_StorageNetworkSettingsSection__TextBlock_4" Grid.Column="2" Text="High"
                                   HorizontalAlignment="Center"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Uid="Controls_Settings_StorageNetworkSettingsSection__TextBlock_5" Grid.Column="3" Text="Very&#x0a;Aggressive"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"
                                   TextWrapping="Wrap"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                    <TextBlock Text="{x:Bind ViewModel.CachingProfileSummary, Mode=OneWay}"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </controls:SettingsCard>

            <TextBlock x:Uid="Controls_Settings_StorageNetworkSettingsSection__TextBlock_6" Text="Audio Cache" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8"/>

            <controls:SettingsCard x:Uid="Controls_Settings_StorageNetworkSettingsSection__SettingsCard_7" Header="Enable cache"
                                   Description="Cache audio files locally for faster playback">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE74E;"/>
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch IsOn="{x:Bind ViewModel.CacheEnabled, Mode=TwoWay}"
                              OnContent="" OffContent=""/>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="Controls_Settings_StorageNetworkSettingsSection__SettingsCard_8" Header="Cache size limit"
                                   Description="Oldest tracks are automatically removed when the limit is reached">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xEDA2;"/>
                </controls:SettingsCard.HeaderIcon>
                <ComboBox SelectedIndex="{x:Bind ViewModel.CacheSizeLimitIndex, Mode=TwoWay}"
                          MinWidth="140">
                    <ComboBoxItem x:Uid="Controls_Settings_StorageNetworkSettingsSection__ComboBoxItem_9" Content="500 MB"/>
                    <ComboBoxItem x:Uid="Controls_Settings_StorageNetworkSettingsSection__ComboBoxItem_10" Content="1 GB"/>
                    <ComboBoxItem x:Uid="Controls_Settings_StorageNetworkSettingsSection__ComboBoxItem_11" Content="2 GB"/>
                    <ComboBoxItem x:Uid="Controls_Settings_StorageNetworkSettingsSection__ComboBoxItem_12" Content="5 GB"/>
                </ComboBox>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="Controls_Settings_StorageNetworkSettingsSection__SettingsCard_13" Header="Cache location"
                                   Description="{x:Bind ViewModel.CacheLocationDisplay}">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8B7;"/>
                </controls:SettingsCard.HeaderIcon>
                <TextBlock Text="{x:Bind ViewModel.CacheSizeDisplay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="Controls_Settings_StorageNetworkSettingsSection__SettingsCard_14" Header="Clear cache"
                                   Description="Delete all cached audio files">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE74D;"/>
                </controls:SettingsCard.HeaderIcon>
                <Button x:Uid="Controls_Settings_StorageNetworkSettingsSection__Button_15" Content="Clear Cache" Command="{x:Bind ViewModel.ClearCacheCommand}"/>
            </controls:SettingsCard>
            <controls:SettingsCard Header="Clear collection revisions"
                                   Description="Forces a full refresh of your library (Liked Songs, albums, artists, shows). Use if something looks out of date.">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE895;"/>
                </controls:SettingsCard.HeaderIcon>
                <Button Content="Clear &amp; resync" Click="ClearCollectionRevisions_Click"/>
            </controls:SettingsCard>

            <!-- ── Local Files ─────────────────────────────────────────────── -->
            <TextBlock Text="Local Files" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8"/>

            <controls:SettingsCard Header="Show on Home"
                                   Description="Display a Local files shelf near the top of Home when indexed files are available.">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE80F;"/>
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch IsOn="{x:Bind ViewModel.ShowLocalFilesOnHome, Mode=TwoWay}"
                              OnContent=""
                              OffContent=""/>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Watched folders"
                                   Description="Wavee scans these folders for music and adds it to Search and your library. Indexes update in the background.">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8B7;"/>
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Rescan now"
                            Click="RescanAllLocal_Click"/>
                    <Button Content="Add folder…"
                            Style="{ThemeResource AccentButtonStyle}"
                            Click="AddLocalFolder_Click"/>
                </StackPanel>
            </controls:SettingsCard>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.LocalFiles.Folders, Mode=OneWay}"
                           Margin="0,4,0,0">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:LocalFolderRow">
                        <controls:SettingsCard Header="{x:Bind Path}"
                                               Description="{x:Bind StatusDisplay}">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8F1;"/>
                            </controls:SettingsCard.HeaderIcon>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind LastScanDisplay}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Content="Remove"
                                        Click="RemoveLocalFolder_Click"
                                        Tag="{x:Bind}"/>
                            </StackPanel>
                        </controls:SettingsCard>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <controls:SettingsCard Header="Sync progress"
                                   Description="{x:Bind ViewModel.LocalFiles.ProgressCurrentFile, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.LocalFiles.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE895;"/>
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Vertical" Spacing="4" MinWidth="280">
                    <ProgressBar Minimum="0"
                                 Maximum="{x:Bind ViewModel.LocalFiles.ProgressTotal, Mode=OneWay}"
                                 Value="{x:Bind ViewModel.LocalFiles.ProgressDone, Mode=OneWay}"/>
                </StackPanel>
            </controls:SettingsCard>

            <TextBlock Text="{x:Bind ViewModel.LocalFiles.StatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Margin="4,4,0,0"/>

            <TextBlock x:Uid="Controls_Settings_StorageNetworkSettingsSection__TextBlock_16" Text="Connection" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8"/>
            <controls:SettingsCard x:Uid="Controls_Settings_StorageNetworkSettingsSection__SettingsCard_17" Header="Auto-reconnect"
                                   Description="Automatically reconnect when the connection is lost">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE703;"/>
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch IsOn="{x:Bind ViewModel.AutoReconnect, Mode=TwoWay}"
                              OnContent="" OffContent=""/>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="Controls_Settings_StorageNetworkSettingsSection__SettingsCard_18" Header="Connection timeout"
                                   Description="Maximum time to wait when connecting">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE916;"/>
                </controls:SettingsCard.HeaderIcon>
                <ComboBox SelectedIndex="{x:Bind ViewModel.ConnectionTimeoutIndex, Mode=TwoWay}"
                          MinWidth="140">
                    <ComboBoxItem x:Uid="Controls_Settings_StorageNetworkSettingsSection__ComboBoxItem_19" Content="10 seconds"/>
                    <ComboBoxItem x:Uid="Controls_Settings_StorageNetworkSettingsSection__ComboBoxItem_20" Content="30 seconds"/>
                    <ComboBoxItem x:Uid="Controls_Settings_StorageNetworkSettingsSection__ComboBoxItem_21" Content="60 seconds"/>
                </ComboBox>
            </controls:SettingsCard>
        </StackPanel>
    </ScrollView>
</UserControl>
