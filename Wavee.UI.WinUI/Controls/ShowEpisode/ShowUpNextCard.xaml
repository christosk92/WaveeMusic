<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.ShowEpisode.ShowUpNextCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    mc:Ignorable="d">

    <Border x:Name="CardRoot"
            Height="92"
            CornerRadius="8"
            Background="{ThemeResource SubtleFillColorTransparentBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            PointerEntered="CardRoot_PointerEntered"
            PointerExited="CardRoot_PointerExited"
            Tapped="CardRoot_Tapped">

        <Grid Padding="10,8,10,8"
              ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="48"
                    Height="48"
                    CornerRadius="6"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    VerticalAlignment="Top">
                <Grid>
                    <FontIcon x:Name="CoverPlaceholderIcon"
                              Glyph="&#xE93E;"
                              FontSize="18"
                              Opacity="0.36"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    <Image x:Name="CoverImage"
                           Stretch="UniformToFill"
                           IsHitTestVisible="False"
                           behaviors:ImageFallbackBehavior.HideOnError="True"
                           behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                           behaviors:ImageFallbackBehavior.DecodePixelWidth="96"/>
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="EpisodeNumberChip"
                            Grid.Column="0"
                            CornerRadius="6"
                            Padding="7,1,7,2"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="EpisodeNumberText"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock Grid.Column="2"
                               x:Name="DurationText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>

                <TextBlock Grid.Row="1"
                           x:Name="TitleText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           MaxLines="1"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               x:Name="DateText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <Button x:Name="PlayButton"
                            Grid.Column="1"
                            Width="28" Height="28" Padding="0"
                            CornerRadius="14"
                            BorderThickness="0"
                            Opacity="0"
                            Click="PlayButton_Click"
                            ToolTipService.ToolTip="Play episode">
                        <FontIcon Glyph="&#xE768;" FontSize="10"/>
                    </Button>
                </Grid>
            </Grid>

            <Grid Grid.Column="0"
                  Grid.ColumnSpan="2"
                  x:Name="ProgressLane"
                  Height="2"
                  Margin="0"
                  VerticalAlignment="Bottom"
                  Visibility="Collapsed">
                <Border Background="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="1"/>
                <Border x:Name="ProgressFill"
                        HorizontalAlignment="Left"
                        CornerRadius="1"
                        Width="0"
                        SizeChanged="ProgressLane_SizeChanged"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
