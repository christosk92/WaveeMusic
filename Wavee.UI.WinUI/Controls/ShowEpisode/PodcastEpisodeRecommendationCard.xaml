<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.ShowEpisode.PodcastEpisodeRecommendationCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    mc:Ignorable="d">

    <Border x:Name="CardRoot"
            CornerRadius="6"
            Background="Transparent"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            PointerEntered="CardRoot_PointerEntered"
            PointerExited="CardRoot_PointerExited"
            Tapped="CardRoot_Tapped">
        <Grid Padding="14,10"
              ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="HoverFill"
                    Grid.ColumnSpan="3"
                    Grid.RowSpan="3"
                    CornerRadius="6"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    Opacity="0"
                    IsHitTestVisible="False"/>

            <Border x:Name="CoverContainer"
                    Grid.Column="0"
                    Grid.RowSpan="3"
                    Width="58"
                    Height="58"
                    CornerRadius="6"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    VerticalAlignment="Top">
                <Grid>
                    <FontIcon x:Name="CoverPlaceholderIcon"
                              Glyph="&#xE93E;"
                              FontSize="22"
                              Opacity="0.4"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    <Image x:Name="CoverImage"
                           Stretch="UniformToFill"
                           Visibility="Collapsed"
                           IsHitTestVisible="False"
                           behaviors:ImageFallbackBehavior.HideOnError="True"
                           behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                           behaviors:ImageFallbackBehavior.DecodePixelWidth="96"/>
                </Grid>
            </Border>

            <TextBlock x:Name="TitleText"
                       Grid.Column="1"
                       Grid.Row="0"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1"
                       VerticalAlignment="Center"/>

            <TextBlock x:Name="DurationText"
                       Grid.Column="2"
                       Grid.Row="0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

            <TextBlock x:Name="SubtitleText"
                       Grid.Column="1"
                       Grid.Row="1"
                       Margin="0,8,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1"/>

            <StackPanel x:Name="ActionCluster"
                        Grid.Column="2"
                        Grid.Row="1"
                        Orientation="Horizontal"
                        Opacity="0"
                        VerticalAlignment="Center">
                <Button x:Name="PlayButton"
                        Width="36"
                        Height="36"
                        Padding="0"
                        CornerRadius="18"
                        BorderThickness="0"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        Click="PlayButton_Click"
                        ToolTipService.ToolTip="Play episode">
                    <FontIcon Glyph="&#xE768;" FontSize="13"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
