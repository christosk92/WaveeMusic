<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Cards.LikedSongsRecentCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <CornerRadius x:Key="CardCornerRadius">6</CornerRadius>
    </UserControl.Resources>

    <!-- ── Outer container ──────────────────────────────────────────────
         This Grid does NOT have a CornerRadius / Background so children
         can extend beyond its bounds (the hover fan pops out to the
         right + above the chrome). The card's visual chrome
         (background + rounded border) sits on a separate sibling
         <Border CardChrome/> at the same Grid cell — it gets the
         CornerRadius so it clips itself to a rounded rect, but it has
         no children, so nothing else is clipped.
         ──────────────────────────────────────────────────────────── -->
    <Grid x:Name="CardRoot"
          Background="Transparent"
          PointerEntered="CardRoot_PointerEntered"
          PointerExited="CardRoot_PointerExited"
          Tapped="CardRoot_Tapped">

        <!-- Card chrome — visual background + border. Stretches to fill the
             outer Grid's cell. No children → nothing to clip. -->
        <Border x:Name="CardChrome"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"/>

        <!-- Content — laid out over the chrome. Composition visuals attached
             to ThumbnailHost can render past this Grid's bounds since the
             outer CardRoot doesn't clip. -->
        <Grid x:Name="ContentRoot" Padding="8,8,8,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid x:Name="ImageArea" Grid.Row="0" SizeChanged="ImageArea_SizeChanged">
                <Border x:Name="ThumbnailHost" Background="Transparent"/>

                <!-- Heart tile — badge-size so the fanned thumbnails read as
                     the primary visual. ~30-35% of the card width keeps the
                     heart legible without crowding the covers. -->
                <Border x:Name="HeartTile"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="4,0,0,4"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Width="56" Height="56">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#5038A0" Offset="0"/>
                            <GradientStop Color="#7B5FCC" Offset="0.5"/>
                            <GradientStop Color="#9CC5C5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <FontIcon
                        Glyph="&#xEB52;"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="22"
                        Foreground="White"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,12,0,0" Spacing="2">
                <TextBlock x:Name="TitleText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"/>
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <FontIcon
                        x:Name="AddedCheckGlyph"
                        Glyph="&#xE73E;"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="12"
                        Foreground="#1ED760"
                        VerticalAlignment="Center"
                        Visibility="Collapsed"/>
                    <TextBlock x:Name="SubtitleText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
