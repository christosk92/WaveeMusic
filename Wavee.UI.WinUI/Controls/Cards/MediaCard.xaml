<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Cards.MediaCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Button x:Name="CardButton"
            Padding="0" Background="Transparent" BorderThickness="0"
            HorizontalContentAlignment="Stretch"
            Click="CardButton_Click"
            RightTapped="CardButton_RightTapped">
        <StackPanel x:Name="RootPanel" Spacing="8">
            <!-- Image container -->
            <Grid x:Name="ImageContainer" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <Image x:Name="CardImage" Stretch="UniformToFill"/>
                <FontIcon x:Name="PlaceholderIcon" Glyph="&#xE8D6;" FontSize="32"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Opacity="0.3"/>
            </Grid>
            <!-- Title -->
            <TextBlock x:Name="TitleText" FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
            <!-- Subtitle -->
            <TextBlock x:Name="SubtitleText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
        </StackPanel>
    </Button>
</UserControl>
