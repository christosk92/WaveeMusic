<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Cards.BaselineHomeCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:ui="using:CommunityToolkit.WinUI.Media"
    xmlns:winUi="using:CommunityToolkit.WinUI"
    mc:Ignorable="d"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Top"
    PointerEntered="Card_PointerEntered"
    PointerExited="Card_PointerExited"
    SizeChanged="BaselineHomeCard_SizeChanged"
    Unloaded="Card_Unloaded">

    <Grid
        x:Name="CardRoot"
        CornerRadius="14"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        PointerPressed="CardRoot_PointerPressed"
        RightTapped="CardRoot_RightTapped"
        Tapped="CardRoot_Tapped">
        <winUi:Effects.Shadow>
            <ui:AttachedCardShadow
                BlurRadius="26"
                CornerRadius="14"
                Offset="0,8"
                Opacity="0.22"/>
        </winUi:Effects.Shadow>

        <Grid.RowDefinitions>
            <RowDefinition Height="84*"/>
            <RowDefinition Height="36*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="ImageStage" Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Image
                x:Name="HeroImage"
                Stretch="UniformToFill"
                Opacity="0.94"/>

            <MediaPlayerElement
                x:Name="CanvasPlayer"
                x:Load="False"
                AreTransportControlsEnabled="False"
                Stretch="UniformToFill"
                IsHitTestVisible="False"
                Opacity="0"
                Visibility="Collapsed"/>

            <Border x:Name="ColorWash" Opacity="0.24"/>

            <Border>
                <Border.Background>
                    <RadialGradientBrush Center="0.16,0.08" GradientOrigin="0.16,0.08" RadiusX="1.18" RadiusY="0.96">
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroHighlightStartColor}" Offset="0"/>
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroHighlightMidColor}" Offset="0.46"/>
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroHighlightEndColor}" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroShadowTopColor}" Offset="0"/>
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroShadowMidColor}" Offset="0.42"/>
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroShadowBottomColor}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid
                x:Name="PreviewOverlayRoot"
                Margin="0"
                HorizontalAlignment="Stretch"
                Height="92"
                VerticalAlignment="Bottom"
                Visibility="Collapsed"
                IsHitTestVisible="False">
                <cards:PreviewAudioVisualizer
                    x:Name="PreviewVisualizer"
                    Visibility="Collapsed"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    BarColor="{ThemeResource HomeBaselineCardPreviewVisualizerForegroundColor}"
                    TrackColor="{ThemeResource HomeBaselineCardPreviewVisualizerTrackColor}"/>
            </Grid>

            <Border
                x:Name="CoverThumbBorder"
                Width="58"
                Height="58"
                Margin="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                CornerRadius="10"
                Background="{ThemeResource HomeBaselineCardOverlayThumbBackgroundBrush}"
                BorderBrush="{ThemeResource HomeBaselineCardOverlayThumbBorderBrush}"
                BorderThickness="1">
                <winUi:Effects.Shadow>
                    <ui:AttachedCardShadow
                        BlurRadius="18"
                        CornerRadius="10"
                        Offset="0,6"
                        Opacity="0.18"/>
                </winUi:Effects.Shadow>
                <Grid>
                    <Image
                        x:Name="CoverThumbImage"
                        Stretch="UniformToFill"/>
                    <FontIcon
                        x:Name="CoverThumbPlaceholder"
                        Glyph="&#xE8D6;"
                        FontSize="20"
                        Foreground="{ThemeResource HomeBaselineCardOverlaySecondaryTextBrush}"
                        Opacity="0.45"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <StackPanel
                x:Name="TitleOverlay"
                VerticalAlignment="Bottom"
                Padding="18,0,18,28"
                Spacing="4">
                <TextBlock
                    x:Name="TitleText"
                    TextWrapping="Wrap"
                    FontSize="26"
                    FontWeight="ExtraBold"
                    Foreground="{ThemeResource HomeBaselineCardOverlayPrimaryTextBrush}"
                    MaxLines="3"
                    TextTrimming="CharacterEllipsis"/>
                <TextBlock
                    x:Name="TypeText"
                    Text="Playlist"
                    FontSize="11"
                    FontWeight="SemiBold"
                    CharacterSpacing="120"
                    Foreground="{ThemeResource HomeBaselineCardOverlaySecondaryTextBrush}"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Grid
                x:Name="HoverChrome"
                x:Load="False"
                Margin="14"
                Opacity="0"
                Visibility="Collapsed"
                VerticalAlignment="Top">
                <Button
                    x:Name="PreviewAudioButton"
                    HorizontalAlignment="Right"
                    Width="36"
                    Height="36"
                    Padding="0"
                    CornerRadius="10"
                    Background="{ThemeResource HomeBaselineCardOverlayChromeBackgroundBrush}"
                    BorderBrush="{ThemeResource HomeBaselineCardOverlayChromeBorderBrush}"
                    BorderThickness="1"
                    Click="PreviewAudioButton_Click"
                    Visibility="Collapsed">
                    <FontIcon
                        x:Name="PreviewAudioIcon"
                        Glyph="&#xE198;"
                        FontSize="15"
                        Foreground="{ThemeResource HomeBaselineCardOverlayPrimaryTextBrush}"/>
                </Button>
            </Grid>

            <Button
                x:Name="PreviousPreviewTrackButton"
                Width="34"
                Height="34"
                Margin="10,0,0,18"
                Padding="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{ThemeResource HomeBaselineCardOverlayChromeBackgroundBrush}"
                BorderBrush="{ThemeResource HomeBaselineCardOverlayChromeBorderBrush}"
                BorderThickness="1"
                CornerRadius="17"
                Click="PreviousPreviewTrackButton_Click"
                Visibility="Collapsed">
                <FontIcon
                    Glyph="&#xE76B;"
                    FontSize="13"
                    Foreground="{ThemeResource HomeBaselineCardOverlayPrimaryTextBrush}"/>
            </Button>

            <Button
                x:Name="NextPreviewTrackButton"
                Width="34"
                Height="34"
                Margin="0,0,10,18"
                Padding="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Background="{ThemeResource HomeBaselineCardOverlayChromeBackgroundBrush}"
                BorderBrush="{ThemeResource HomeBaselineCardOverlayChromeBorderBrush}"
                BorderThickness="1"
                CornerRadius="17"
                Click="NextPreviewTrackButton_Click"
                Visibility="Collapsed">
                <FontIcon
                    Glyph="&#xE76C;"
                    FontSize="13"
                    Foreground="{ThemeResource HomeBaselineCardOverlayPrimaryTextBrush}"/>
            </Button>
        </Grid>

        <Border
            x:Name="BottomPanel"
            Grid.Row="1"
            Padding="18,16,18,20"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border
                    Height="1"
                    Margin="0,0,0,8"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource HomeBaselineCardDividerBrush}"
                    CornerRadius="999"/>

                <TextBlock
                    x:Name="PreviewEyebrowText"
                    Grid.Row="1"
                    Text="FEATURING"
                    FontSize="11"
                    FontWeight="SemiBold"
                    CharacterSpacing="180"
                    Foreground="{ThemeResource HomeBaselineCardOverlayTertiaryTextBrush}"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"
                    Visibility="Collapsed"/>

                <TextBlock
                    x:Name="PreviewTrackText"
                    Grid.Row="2"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource HomeBaselineCardOverlayPrimaryTextBrush}"
                    MaxLines="2"
                    TextWrapping="Wrap"
                    TextTrimming="CharacterEllipsis"
                    Visibility="Collapsed"/>

                <TextBlock
                    x:Name="SubtitleText"
                    Grid.Row="3"
                    Margin="0,6,0,0"
                    FontSize="13"
                    Foreground="{ThemeResource HomeBaselineCardOverlaySecondaryTextBrush}"
                    MaxLines="3"
                    TextWrapping="Wrap"
                    TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <Grid
            x:Name="ShimmerOverlay"
            x:Load="False"
            Grid.RowSpan="2"
            Padding="14"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="72*"/>
                <RowDefinition Height="28*"/>
            </Grid.RowDefinitions>
            <controls:Shimmer
                Grid.Row="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                CornerRadius="6"/>
            <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Spacing="10">
                <controls:Shimmer Height="18" Width="220" HorizontalAlignment="Left" CornerRadius="4"/>
                <controls:Shimmer Height="14" Width="300" HorizontalAlignment="Left" CornerRadius="4"/>
                <controls:Shimmer Height="14" Width="240" HorizontalAlignment="Left" CornerRadius="4"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
