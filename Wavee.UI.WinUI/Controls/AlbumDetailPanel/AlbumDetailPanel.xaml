<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.AlbumDetailPanel.AlbumDetailPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    mc:Ignorable="d">

    <!-- Implicit show/hide animations -->
    <animations:Implicit.ShowAnimations>
        <animations:OpacityAnimation From="0" To="1" Duration="0:0:0.35"/>
        <animations:TranslationAnimation From="0,20,0" To="0" Duration="0:0:0.4"/>
    </animations:Implicit.ShowAnimations>
    <animations:Implicit.HideAnimations>
        <animations:OpacityAnimation To="0" Duration="0:0:0.2"/>
        <animations:TranslationAnimation To="0,-10,0" Duration="0:0:0.2"/>
    </animations:Implicit.HideAnimations>

    <Grid>
        <!-- Upward-pointing notch with rounded tip connecting to the clicked card -->
        <Path x:Name="NotchTriangle"
              Data="M 0,14 L 10,3 Q 14,0 18,3 L 28,14 Z"
              VerticalAlignment="Top"
              HorizontalAlignment="Left"
              Margin="0,-13,0,0"
              IsHitTestVisible="False">
            <Path.RenderTransform>
                <TranslateTransform x:Name="NotchTranslate" X="0"/>
            </Path.RenderTransform>
        </Path>

        <!-- Main panel body -->
        <Grid x:Name="OuterGrid" CornerRadius="8" MinHeight="200" Margin="0,0,0,4">
            <!-- Color gradient background (extracted from album art) -->
            <Border x:Name="ColorBackground" CornerRadius="8"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Content (left column) -->
                <Grid Grid.Column="0" Padding="28,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="14">
                        <!-- Header: album name + type + year -->
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="AlbumNameText" FontSize="22" FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis" MaxLines="2"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="TypeText"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.7"/>
                                <TextBlock Text="·" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.5"/>
                                <TextBlock x:Name="YearText"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Style="{StaticResource AccentButtonStyle}" Padding="14,6" CornerRadius="16"
                                    Click="PlayButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE768;" FontSize="12"/>
                                    <TextBlock Text="Play" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Padding="14,6" CornerRadius="16" Click="ShuffleButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8B1;" FontSize="12"/>
                                    <TextBlock Text="Shuffle" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Padding="8,6" Background="Transparent" BorderThickness="0">
                                <FontIcon Glyph="&#xEB51;" FontSize="14"/>
                            </Button>
                            <Button Padding="8,6" Background="Transparent" BorderThickness="0"
                                    Click="ViewAlbumButton_Click">
                                <FontIcon Glyph="&#xE7B3;" FontSize="14"/>
                            </Button>
                        </StackPanel>

                        <!-- Track list -->
                        <ItemsRepeater x:Name="TrackRepeater">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="2"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:LazyTrackItem">
                                    <Grid Padding="4,2" ColumnSpacing="8" Height="36">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Track number -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind Index, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Opacity="0.5"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <!-- Track title / shimmer -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Data.Title, Mode=OneWay}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <toolkit:Shimmer Grid.Column="1" Width="180" Height="14"
                                                         HorizontalAlignment="Left" VerticalAlignment="Center"
                                                         Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                                        <!-- Duration -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind Data.DurationFormatted, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Opacity="0.5"
                                                   VerticalAlignment="Center"
                                                   Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <toolkit:Shimmer Grid.Column="2" Width="40" Height="12"
                                                         VerticalAlignment="Center"
                                                         Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                                        <!-- More button -->
                                        <Button Grid.Column="3" Background="Transparent" BorderThickness="0"
                                                Padding="4" VerticalAlignment="Center"
                                                Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <FontIcon Glyph="&#xE712;" FontSize="12" Opacity="0.5"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- Footer -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <HyperlinkButton Content="View album" Padding="0"
                                             Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                             Click="ViewAlbumButton_Click"/>
                            <TextBlock x:Name="FooterYearText"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Opacity="0.5"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Close button -->
                    <Button Grid.Column="1" VerticalAlignment="Top"
                            Background="Transparent" BorderThickness="0" Padding="8"
                            Click="CloseButton_Click">
                        <FontIcon Glyph="&#xE711;" FontSize="14" Opacity="0.7"/>
                    </Button>
                </Grid>

                <!-- Album art (right column, square aspect ratio) -->
                <Grid Grid.Column="1" x:Name="ImageArea" CornerRadius="0,8,8,0">
                    <Border x:Name="ArtBackground" CornerRadius="0,8,8,0">
                        <Border.Background>
                            <ImageBrush x:Name="ArtBrush" Stretch="UniformToFill" AlignmentX="Center"/>
                        </Border.Background>
                    </Border>
                    <!-- Gradient: album color fades into the image (left to right) -->
                    <Border x:Name="ArtGradientOverlay" CornerRadius="0,8,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop x:Name="ArtGradientStop" Color="#FF1A1A1A" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="0.5"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
