<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Omnibar.SearchFlyoutPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Wavee.UI.WinUI.Controls.Omnibar"
    xmlns:contracts="using:Wavee.UI.WinUI.Data.Contracts"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <UserControl.Resources>
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>

        <!-- Text suggestion (search query) -->
        <DataTemplate x:Key="TextQueryTemplate" x:DataType="contracts:SearchSuggestionItem">
            <Grid Padding="12,10" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="16"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          VerticalAlignment="Center"/>
                <local:BoldMatchTextBlock Grid.Column="1"
                    Text="{x:Bind Title}" MatchText="{x:Bind QueryText}"
                    VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <!-- Entity (artist, track, album, playlist) -->
        <DataTemplate x:Key="EntityTemplate" x:DataType="contracts:SearchSuggestionItem">
            <Grid Padding="12,8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Image (circular for artists, rounded square for others) -->
                <Border Grid.Column="0" Width="48" Height="48"
                        CornerRadius="{x:Bind local:SearchFlyoutPanel.GetImageCornerRadius(Type)}"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Image Stretch="UniformToFill"
                           Source="{x:Bind ImageUrl, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=48}"/>
                </Border>

                <!-- Title + Subtitle -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" FontSize="14"
                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                    <TextBlock Text="{x:Bind Subtitle}" FontSize="12"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                </StackPanel>

                <!-- Action button (matches app's IconButtonStyle pattern) -->
                <Button Grid.Column="2" VerticalAlignment="Center"
                        Style="{StaticResource IconButtonStyle}"
                        Visibility="{x:Bind local:SearchFlyoutPanel.GetActionVisibility(Type)}"
                        ToolTipService.ToolTip="{x:Bind local:SearchFlyoutPanel.GetActionTooltip(Type)}"
                        Click="ActionButton_Click">
                    <FontIcon Glyph="{x:Bind local:SearchFlyoutPanel.GetActionGlyph(Type)}" FontSize="16"/>
                </Button>
            </Grid>
        </DataTemplate>

        <local:SearchSuggestionTemplateSelector x:Key="SuggestionTemplateSelector"
            TextQueryTemplate="{StaticResource TextQueryTemplate}"
            EntityTemplate="{StaticResource EntityTemplate}"/>
    </UserControl.Resources>

    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8"
            Translation="0,0,32">
        <Border.Background>
            <AcrylicBrush TintColor="{ThemeResource SolidBackgroundFillColorQuarternary}"
                          TintOpacity="0.9"
                          FallbackColor="{ThemeResource SolidBackgroundFillColorQuarternary}"/>
        </Border.Background>
        <Border.Shadow>
            <ThemeShadow/>
        </Border.Shadow>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header (shown for recent searches) -->
            <TextBlock x:Name="HeaderText" Grid.Row="0"
                       Text="Recent searches" FontWeight="Bold" FontSize="14"
                       Padding="16,12,16,8" Visibility="Collapsed"/>

            <!-- Shimmer loading state -->
            <StackPanel x:Name="ShimmerPanel" Grid.Row="1" Padding="12,8" Spacing="12"
                        Visibility="Collapsed">
                <!-- 6 shimmer rows matching entity layout -->
                <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="24"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <controls:Shimmer Width="140" Height="14" HorizontalAlignment="Left"/>
                        <controls:Shimmer Width="80" Height="12" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>
                <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="24"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <controls:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                        <controls:Shimmer Width="60" Height="12" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>
                <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="4"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <controls:Shimmer Width="200" Height="14" HorizontalAlignment="Left"/>
                        <controls:Shimmer Width="100" Height="12" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>
                <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="24"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                        <controls:Shimmer Width="70" Height="12" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>
                <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="4"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <controls:Shimmer Width="160" Height="14" HorizontalAlignment="Left"/>
                        <controls:Shimmer Width="90" Height="12" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>
                <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="24"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <controls:Shimmer Width="150" Height="14" HorizontalAlignment="Left"/>
                        <controls:Shimmer Width="80" Height="12" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Results list (hidden during shimmer) -->
            <ListView x:Name="ResultsList" Grid.Row="1"
                      MaxHeight="420"
                      SelectionMode="Single" IsItemClickEnabled="True"
                      ItemTemplateSelector="{StaticResource SuggestionTemplateSelector}"
                      ItemClick="ResultsList_ItemClick">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>
    </Border>
</UserControl>
