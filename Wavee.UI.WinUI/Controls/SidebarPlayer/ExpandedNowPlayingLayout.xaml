<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.SidebarPlayer.ExpandedNowPlayingLayout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    xmlns:imaging="using:Wavee.UI.WinUI.Controls.Imaging"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Styles/PlayerBarStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:VolumeToGlyphConverter x:Key="VolumeGlyphConverter" />
            <converters:RepeatModeToGlyphConverter x:Key="RepeatGlyphConverter" />
            <converters:RepeatModeToCheckedConverter x:Key="RepeatCheckedConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True" />
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Apple-Music iPad-style left column. Generous padding, large rounded
         album art with drop shadow, big transport row with a 56 px play button,
         horizontal volume slider, AirPlay/device picker pinned bottom-left.
         Reuses HeartButton / OutputDevicePicker / CompositionProgressBar /
         PlaybackActionContent — no parallel widgets. -->
    <Grid Padding="40,28,40,24" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="220"/>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Album art — square, capped at min(row height, column width).
             AspectRatioGrid trick: use a Viewbox with Stretch=Uniform so the
             square content scales down to fit the smaller of the two axes. -->
        <Viewbox Grid.Row="0"
                 Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Grid Width="540" Height="540">
                <toolkit:Effects.Shadow>
                    <media:AttachedCardShadow
                        BlurRadius="56"
                        Offset="0,18"
                        Opacity="0.45"
                        Color="Black"
                        CornerRadius="14"
                        InnerContentClipMode="CompositionMaskBrush" />
                </toolkit:Effects.Shadow>
                <Grid x:Name="AlbumArtHost"
                      CornerRadius="14"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <imaging:CrossFadeImage
                        x:Name="AlbumArtImage"
                        toolkit:TransitionHelper.Id="albumArt"
                        Source="{x:Bind ViewModel.AlbumArtLarge, Mode=OneWay}"
                        FallbackSource="{x:Bind ViewModel.AlbumArt, Mode=OneWay}"
                        DecodePixelWidth="768"
                        Stretch="UniformToFill"
                        CornerRadius="14" />
                    <FontIcon Glyph="&#xE8D6;"
                              FontSize="56"
                              IsHitTestVisible="False"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Visibility="{x:Bind ViewModel.AlbumArt, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}" />
                </Grid>
            </Grid>
        </Viewbox>

        <!-- Title row — large title + artist on the left, heart + ⋯ at right -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                <TextBlock x:Name="TrackTitleText"
                           toolkit:TransitionHelper.Id="trackTitle"
                           Text="{x:Bind ViewModel.TrackTitle, Mode=OneWay}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           MaxLines="1"
                           TextTrimming="CharacterEllipsis" />
                <ctk:MetadataControl x:Name="ArtistMetadata"
                                     toolkit:TransitionHelper.Id="artistMetadata"
                                     Items="{x:Bind ViewModel.ArtistMetadataItems, Mode=OneWay}"
                                     Separator=", ">
                    <ctk:MetadataControl.TextBlockStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="Opacity" Value="0.72" />
                            <Setter Property="Foreground" Value="{ThemeResource ApplicationForegroundThemeBrush}" />
                            <Setter Property="MaxLines" Value="1" />
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        </Style>
                    </ctk:MetadataControl.TextBlockStyle>
                </ctk:MetadataControl>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
                <controls:HeartButton x:Name="HeartButton" Width="32" Height="32" />
            </StackPanel>
        </Grid>

        <!-- Progress: time | slider | time -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{x:Bind ViewModel.PositionText, Mode=OneWay}"
                       FontSize="11"
                       Opacity="0.6"
                       VerticalAlignment="Center" />
            <playback:CompositionProgressBar x:Name="ProgressSlider"
                                             Grid.Column="1"
                                             VerticalAlignment="Center"
                                             PositionMs="{x:Bind ViewModel.AnchorPositionMs, Mode=OneWay}"
                                             DurationMs="{x:Bind ViewModel.Duration, Mode=OneWay}"
                                             IsPlaying="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                                             IsBuffering="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
                                             SeekStarted="ProgressBar_SeekStarted"
                                             SeekCommitted="ProgressBar_SeekCommitted" />
            <TextBlock Grid.Column="2"
                       Text="{x:Bind ViewModel.DurationText, Mode=OneWay}"
                       FontSize="11"
                       Opacity="0.6"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Transport — apple-style: shuffle | prev | PLAY (large) | next | repeat -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="12">
            <ToggleButton Style="{StaticResource SubtleToggleButtonStyle}"
                          Width="40" Height="40" Padding="0"
                          IsChecked="{x:Bind ViewModel.IsShuffle, Mode=OneWay}"
                          Command="{x:Bind ViewModel.ToggleShuffleCommand}"
                          ToolTipService.ToolTip="Shuffle">
                <FontIcon Glyph="&#xE8B1;" FontSize="16" />
            </ToggleButton>
            <Button Style="{StaticResource TransparentButtonStyle}"
                    Width="44" Height="44" Padding="0"
                    Command="{x:Bind ViewModel.PreviousCommand}"
                    ToolTipService.ToolTip="Previous">
                <FontIcon Glyph="&#xF8AC;" FontSize="20" />
            </Button>
            <Button Style="{StaticResource TransparentButtonStyle}"
                    Width="60" Height="60" Padding="0"
                    Command="{x:Bind ViewModel.PlayPauseCommand}"
                    ToolTipService.ToolTip="Play/Pause">
                <playback:PlaybackActionContent
                    IconSize="28"
                    SpinnerSize="32"
                    IsPlaying="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                    IsPending="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
                    ActionForeground="{ThemeResource TextFillColorPrimaryBrush}" />
            </Button>
            <Button Style="{StaticResource TransparentButtonStyle}"
                    Width="44" Height="44" Padding="0"
                    Command="{x:Bind ViewModel.NextCommand}"
                    ToolTipService.ToolTip="Next">
                <FontIcon Glyph="&#xF8AD;" FontSize="20" />
            </Button>
            <ToggleButton Style="{StaticResource SubtleToggleButtonStyle}"
                          Width="40" Height="40" Padding="0"
                          IsChecked="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatCheckedConverter}}"
                          Command="{x:Bind ViewModel.ToggleRepeatCommand}"
                          ToolTipService.ToolTip="Repeat">
                <FontIcon Glyph="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatGlyphConverter}}"
                          FontSize="16" />
            </ToggleButton>
        </StackPanel>

        <!-- Volume — horizontal slider with low/high glyphs -->
        <Grid Grid.Row="4"
              ColumnSpacing="10"
              MaxWidth="420"
              HorizontalAlignment="Stretch"
              Margin="36,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <FontIcon Grid.Column="0"
                      Glyph="&#xE993;"
                      FontSize="13"
                      Opacity="0.6"
                      VerticalAlignment="Center" />
            <Slider Grid.Column="1"
                    MinWidth="160"
                    Minimum="0" Maximum="100"
                    Value="{x:Bind ViewModel.Volume, Mode=TwoWay}"
                    IsEnabled="{x:Bind ViewModel.IsVolumeRestricted, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                    IsThumbToolTipEnabled="False"
                    VerticalAlignment="Center" />
            <FontIcon Grid.Column="2"
                      Glyph="&#xE995;"
                      FontSize="13"
                      Opacity="0.6"
                      VerticalAlignment="Center" />
        </Grid>

        <!-- AirPlay / device picker bottom-left -->
        <playback:OutputDevicePicker
            Grid.Row="5"
            HorizontalAlignment="Left" />
    </Grid>
</UserControl>
