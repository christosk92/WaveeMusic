<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.SidebarPlayer.SidebarPlayerWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:rightpanel="using:Wavee.UI.WinUI.Controls.RightPanel"
    xmlns:imaging="using:Wavee.UI.WinUI.Controls.Imaging"
    xmlns:toolkit="using:CommunityToolkit.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:media="using:CommunityToolkit.WinUI.Media"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Styles/PlayerBarStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:VolumeToGlyphConverter x:Key="VolumeGlyphConverter" />
            <converters:RepeatModeToGlyphConverter x:Key="RepeatGlyphConverter" />
            <converters:RepeatModeToCheckedConverter x:Key="RepeatCheckedConverter" />
            <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True" />
            <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />

            <!-- Mirrors PlayerBarStyles.xaml's PlayerVolumeFlyoutPresenterStyle but locally
                 duplicated so we don't depend on it being exported. Tight padding so the
                 vertical slider sits flush. -->
            <Style x:Key="SidebarVolumeFlyoutPresenterStyle" BasedOn="{StaticResource DefaultFlyoutPresenterStyle}" TargetType="FlyoutPresenter">
                <Setter Property="Padding" Value="12" />
                <Setter Property="MinWidth" Value="0" />
            </Style>

            <!-- Device picker styling lives inside AudioOutputPicker. -->

            <!-- Theme-aware chevron pill: white-ish translucent over album art in dark mode,
                 black-ish translucent over album art in light mode. Glyph follows the theme's
                 primary text token so it reads against either backdrop. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SidebarPlayerChevronBackground" Color="#99FFFFFF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="SidebarPlayerChevronBackground" Color="#80000000" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="SidebarPlayerChevronBackground" Color="{ThemeResource SystemColorWindowColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Expanded ⇄ Collapsed swap is driven directly from code-behind
         (ApplyCollapseState) — VSM with UserControl-level state groups silently
         no-ops in WinUI 3 when triggered after Loaded. Direct Visibility
         assignment is reliable and the property-change animations on
         ExpandedRoot / CollapsedRoot still fire via Implicit.Show/HideAnimations. -->

    <!-- Edge-to-edge widget — no card chrome. The palette tint is a vertical gradient
         from the album's dominant color at top, fading to transparent at the bottom so
         it bleeds into the sidebar surface below. PointerEntered/PointerExited drive
         the chevron's hover-to-reveal. The gradient stop colors are set in code-behind
         via WidgetTintColor / WidgetTintColorTransparent (animations on color changes). -->
    <Border
        x:Name="WidgetRoot"
        Padding="8,8,8,4"
        BorderThickness="0"
        PointerEntered="WidgetRoot_PointerEntered"
        PointerExited="WidgetRoot_PointerExited"
        behaviors:DragToDetachBehavior.Panel="Player"
        Visibility="{x:Bind ViewModel.HasTrack, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
        <animations:Implicit.ShowAnimations>
            <animations:OpacityAnimation Duration="0:0:0.25" From="0" To="1" />
            <animations:TranslationAnimation Duration="0:0:0.25" From="0,-12,0" To="0" />
        </animations:Implicit.ShowAnimations>
        <animations:Implicit.HideAnimations>
            <animations:OpacityAnimation Duration="0:0:0.18" From="1" To="0" />
            <animations:TranslationAnimation Duration="0:0:0.18" From="0" To="0,-8,0" />
        </animations:Implicit.HideAnimations>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop x:Name="WidgetGradientTop" Color="{ThemeResource CardBackgroundFillColorDefault}" Offset="0" />
                <GradientStop x:Name="WidgetGradientMid" Color="{ThemeResource CardBackgroundFillColorDefault}" Offset="0.55" />
                <GradientStop x:Name="WidgetGradientBottom" Color="Transparent" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <StackPanel Spacing="6">
        <Grid>
            <!-- Chevron toggle, top-right. Sits on top of the album art / title row in
                 both layouts via Canvas.ZIndex; theme-aware pill backdrop keeps it readable
                 against any palette in both light and dark modes. -->
            <Button
                x:Name="ChevronButton"
                Width="26"
                Height="26"
                Padding="0"
                MinWidth="0"
                MinHeight="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,2,2,0"
                CornerRadius="13"
                Background="{ThemeResource SidebarPlayerChevronBackground}"
                BorderThickness="0"
                Canvas.ZIndex="2"
                Click="ChevronButton_Click">
                <ToolTipService.ToolTip>
                    <TextBlock x:Name="ChevronTooltip" Text="Collapse" />
                </ToolTipService.ToolTip>
                <FontIcon
                    x:Name="ChevronGlyph"
                    Glyph="&#xE70E;"
                    FontSize="11"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </Button>

            <!-- ============ EXPANDED LAYOUT ============ -->
            <Grid x:Name="ExpandedRoot" RowSpacing="6">
                <animations:Implicit.ShowAnimations>
                    <animations:OpacityAnimation Duration="0:0:0.2" From="0" To="1" />
                </animations:Implicit.ShowAnimations>
                <animations:Implicit.HideAnimations>
                    <animations:OpacityAnimation Duration="0:0:0.12" From="1" To="0" />
                </animations:Implicit.HideAnimations>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Album art (square, full width minus padding) — wrapped in an outer Grid
                     that hosts the AttachedCardShadow so the art has the same drop shadow
                     style as the Album page hero (BlurRadius=32, Offset=0,12, Opacity=0.28). -->
                <Grid Grid.Row="0" HorizontalAlignment="Stretch">
                    <toolkit:Effects.Shadow>
                        <media:AttachedCardShadow
                            BlurRadius="24"
                            Offset="0,8"
                            Opacity="0.28"
                            Color="Black"
                            CornerRadius="6"
                            InnerContentClipMode="CompositionMaskBrush" />
                    </toolkit:Effects.Shadow>
                    <!-- ExpandedAlbumArtHost: width-stretches to the column, height is
                         locked to width via SizeChanged in code-behind so the slot stays
                         square even before the first image arrives. The CrossFadeImage
                         inside swaps covers without ever nulling the visible layer, so
                         the row no longer collapses to 0×0 between tracks. -->
                    <Grid
                        x:Name="ExpandedAlbumArtHost"
                        HorizontalAlignment="Stretch"
                        CornerRadius="6"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        SizeChanged="ExpandedAlbumArtHost_SizeChanged"
                        Tapped="AlbumArt_Tapped">
                        <imaging:CrossFadeImage
                            x:Name="ExpandedAlbumArtImage"
                            toolkit:TransitionHelper.Id="albumArt"
                            Source="{x:Bind ViewModel.AlbumArtLarge, Mode=OneWay}"
                            FallbackSource="{x:Bind ViewModel.AlbumArt, Mode=OneWay}"
                            DecodePixelWidth="512"
                            CornerRadius="6"
                            Stretch="UniformToFill" />
                        <Grid
                            x:Name="ExpandedVideoHost"
                            Canvas.ZIndex="1"
                            Background="Black"
                            CornerRadius="6"
                            Visibility="Collapsed"
                            Tapped="VideoHost_Tapped">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <ToggleMenuFlyoutItem
                                        x:Name="VideoStretchNoneItem"
                                        Text="None"
                                        Click="VideoStretchNone_Click" />
                                    <ToggleMenuFlyoutItem
                                        x:Name="VideoStretchUniformItem"
                                        Text="Uniform"
                                        Click="VideoStretchUniform_Click" />
                                    <ToggleMenuFlyoutItem
                                        x:Name="VideoStretchUniformToFillItem"
                                        Text="Uniform to fill"
                                        Click="VideoStretchUniformToFill_Click" />
                                    <ToggleMenuFlyoutItem
                                        x:Name="VideoStretchFillItem"
                                        Text="Fill"
                                        Click="VideoStretchFill_Click" />
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid
                                x:Name="ExpandedVideoStatusOverlay"
                                Canvas.ZIndex="1"
                                Background="#66000000"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="6">
                                    <ProgressRing
                                        Width="26"
                                        Height="26"
                                        IsActive="True"
                                        Foreground="White" />
                                    <TextBlock
                                        x:Name="ExpandedVideoStatusText"
                                        Text="Buffering"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="White" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                        <FontIcon
                            Glyph="&#xE8D6;"
                            FontSize="32"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.AlbumArt, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}" />
                    </Grid>
                </Grid>

                <!-- Title row: title/artist on the left taking all available space; heart + ⋯
                     pinned to the right edge inside a horizontal stack so they sit visibly apart
                     from the title text regardless of how short the title is. -->
                <Grid Grid.Row="1" Margin="2,0,2,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="0" Margin="0,0,12,0">
                        <HyperlinkButton
                            Padding="0"
                            MinHeight="0"
                            MinWidth="0"
                            Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                            Click="TrackTitle_Click">
                            <TextBlock
                                toolkit:TransitionHelper.Id="trackTitle"
                                Text="{x:Bind ViewModel.TrackTitle, Mode=OneWay}"
                                FontSize="14"
                                FontWeight="SemiBold"
                                MaxLines="1"
                                TextTrimming="CharacterEllipsis" />
                        </HyperlinkButton>
                        <ctk:MetadataControl
                            toolkit:TransitionHelper.Id="artistMetadata"
                            Items="{x:Bind ViewModel.ArtistMetadataItems, Mode=OneWay}"
                            Separator=", ">
                            <ctk:MetadataControl.TextBlockStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="Opacity" Value="0.7" />
                                    <Setter Property="Foreground" Value="{ThemeResource ApplicationForegroundThemeBrush}" />
                                    <Setter Property="MaxLines" Value="1" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                </Style>
                            </ctk:MetadataControl.TextBlockStyle>
                        </ctk:MetadataControl>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="2"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right">
                    <controls:HeartButton
                        x:Name="ExpandedHeartButton"
                        Width="28"
                        Height="28" />
                    <Button
                        x:Name="ExpandedOverflowButton"
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="28"
                        Height="28"
                        Padding="0"
                        ToolTipService.ToolTip="More">
                        <Button.Flyout>
                            <MenuFlyout>
                                <ToggleMenuFlyoutItem
                                    Text="Queue"
                                    IsChecked="{x:Bind ViewModel.IsQueuePanelActive, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.ToggleQueuePanelCommand}">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE142;" FontSize="14" />
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <ToggleMenuFlyoutItem
                                    Text="Lyrics"
                                    IsChecked="{x:Bind ViewModel.IsLyricsPanelActive, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.ToggleLyricsPanelCommand}">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xED1E;" FontSize="14" />
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <ToggleMenuFlyoutItem
                                    Text="Details"
                                    IsChecked="{x:Bind ViewModel.IsDetailsPanelActive, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.ToggleDetailsPanelCommand}">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE946;" FontSize="14" />
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <ToggleMenuFlyoutItem
                                    Text="Friends Activity"
                                    IsChecked="{x:Bind ViewModel.IsFriendsPanelActive, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.ToggleFriendsPanelCommand}">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE716;" FontSize="14" />
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <ToggleMenuFlyoutItem
                                    Text="Mute"
                                    IsChecked="{x:Bind ViewModel.IsMuted, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.ToggleMuteCommand}">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon
                                            FontSize="14"
                                            Glyph="{x:Bind ViewModel.Volume, Mode=OneWay, Converter={StaticResource VolumeGlyphConverter}}" />
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem
                                    Text="Skip back 10 seconds"
                                    Command="{x:Bind ViewModel.SkipBackwardCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xED3C;" FontSize="14" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    Text="Skip forward 30 seconds"
                                    Command="{x:Bind ViewModel.SkipForwardCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xED3D;" FontSize="14" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem
                                    Text="Pop out to window"
                                    Click="PopOutToWindow_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    Text="Move back to bottom bar"
                                    Click="MoveToBottomBar_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74A;" FontSize="14" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                        <FontIcon Glyph="&#xE712;" FontSize="12" />
                    </Button>
                    </StackPanel>
                </Grid>

                <!-- Output device picker — reusable combobox-style control.
                     Self-contained: subscribes to IPlaybackStateService and
                     handles row click → IPlaybackService internally. The
                     trigger renders the active device + chevron. Replaces a
                     ~200-line chip+flyout block previously inlined here. -->
                <playback:AudioOutputPicker
                    Grid.Row="2"
                    Margin="2,0,2,0"
                    HorizontalAlignment="Left" />


                <!-- Progress: time | slider | time -->
                <Grid Grid.Row="3" Margin="2,0,2,0" ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="{x:Bind ViewModel.PositionText, Mode=OneWay}"
                        FontSize="10"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <playback:CompositionProgressBar
                        x:Name="ExpandedProgressSlider"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        PositionMs="{x:Bind ViewModel.AnchorPositionMs, Mode=OneWay}"
                        DurationMs="{x:Bind ViewModel.Duration, Mode=OneWay}"
                        IsPlaying="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                        IsBuffering="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
                        SeekStarted="ProgressBar_SeekStarted"
                        SeekCommitted="ProgressBar_SeekCommitted"
                        Visibility="{x:Bind ViewModel.IsBuffering, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    <TextBlock
                        Grid.Column="2"
                        Text="{x:Bind ViewModel.DurationText, Mode=OneWay}"
                        FontSize="10"
                        VerticalAlignment="Center"
                        Opacity="0.6"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>

                <!-- Primary transport row (centered): shuffle | -10 | prev | play | next | +30 | repeat -->
                <StackPanel
                    x:Name="ExpandedTransportRow"
                    Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="2">
                    <ToggleButton
                        Style="{StaticResource SubtleToggleButtonStyle}"
                        Width="28"
                        Height="28"
                        Padding="0"
                        IsChecked="{x:Bind ViewModel.IsShuffle, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ToggleShuffleCommand}"
                        ToolTipService.ToolTip="Shuffle">
                        <FontIcon Glyph="&#xE8B1;" FontSize="12" />
                    </ToggleButton>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="26"
                        Height="26"
                        Padding="0"
                        Command="{x:Bind ViewModel.SkipBackwardCommand}"
                        Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Back 15 seconds">
                        <TextBlock Text="-15" FontSize="9" FontWeight="SemiBold" />
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Command="{x:Bind ViewModel.SkipBackwardCommand}"
                        Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Back 15 seconds">
                        <TextBlock Text="-15" FontSize="10" FontWeight="SemiBold" />
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="30"
                        Height="30"
                        Padding="0"
                        Command="{x:Bind ViewModel.PreviousCommand}"
                        ToolTipService.ToolTip="Previous">
                        <FontIcon Glyph="&#xF8AC;" FontSize="14" />
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="40"
                        Height="40"
                        Padding="0"
                        Command="{x:Bind ViewModel.PlayPauseCommand}"
                        ToolTipService.ToolTip="Play/Pause">
                        <playback:PlaybackActionContent
                            IconSize="18"
                            SpinnerSize="20"
                            IsPlaying="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                            IsPending="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
                            ActionForeground="{ThemeResource TextFillColorPrimaryBrush}" />
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="30"
                        Height="30"
                        Padding="0"
                        Command="{x:Bind ViewModel.NextCommand}"
                        ToolTipService.ToolTip="Next">
                        <FontIcon Glyph="&#xF8AD;" FontSize="14" />
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Command="{x:Bind ViewModel.SkipForwardCommand}"
                        Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Forward 15 seconds">
                        <TextBlock Text="+15" FontSize="10" FontWeight="SemiBold" />
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="38"
                        Height="28"
                        Padding="0"
                        Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Playback speed">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="0.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="0.5" />
                                <MenuFlyoutItem Text="0.75x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="0.75" />
                                <MenuFlyoutItem Text="1x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1" />
                                <MenuFlyoutItem Text="1.25x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.25" />
                                <MenuFlyoutItem Text="1.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.5" />
                                <MenuFlyoutItem Text="1.75x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.75" />
                                <MenuFlyoutItem Text="2x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="2" />
                                <MenuFlyoutItem Text="2.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="2.5" />
                                <MenuFlyoutItem Text="3x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="3" />
                            </MenuFlyout>
                        </Button.Flyout>
                        <TextBlock Text="{x:Bind ViewModel.PlaybackSpeedText, Mode=OneWay}" FontSize="10" FontWeight="SemiBold" />
                    </Button>
                    <ToggleButton
                        Style="{StaticResource SubtleToggleButtonStyle}"
                        Width="28"
                        Height="28"
                        Padding="0"
                        IsChecked="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatCheckedConverter}}"
                        Command="{x:Bind ViewModel.ToggleRepeatCommand}"
                        ToolTipService.ToolTip="Repeat">
                        <FontIcon
                            Glyph="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatGlyphConverter}}"
                            FontSize="12" />
                    </ToggleButton>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Command="{x:Bind ViewModel.SwitchToVideoCommand}"
                        IsEnabled="{x:Bind ViewModel.IsResolvingVideo, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        Visibility="{x:Bind ViewModel.IsCurrentTrackVideoCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Watch Video">
                        <Grid Width="14" Height="14">
                            <FontIcon
                                Glyph="&#xE714;"
                                FontSize="12"
                                Visibility="{x:Bind ViewModel.IsResolvingVideo, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                            <ProgressRing
                                Width="14"
                                Height="14"
                                IsActive="{x:Bind ViewModel.IsResolvingVideo, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsResolvingVideo, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Command="{x:Bind ViewModel.SwitchToAudioCommand}"
                        IsEnabled="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        Visibility="{x:Bind ViewModel.IsCurrentTrackAudioCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Listen as audio">
                        <Grid Width="14" Height="14">
                            <FontIcon
                                Glyph="&#xE8D6;"
                                FontSize="12"
                                Visibility="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                            <ProgressRing
                                Width="14"
                                Height="14"
                                IsActive="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Button>
                    <Button
                        x:Name="ExpandedVolumeButton"
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="28"
                        Height="28"
                        Padding="0"
                        IsEnabled="{x:Bind ViewModel.IsVolumeRestricted, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        ToolTipService.ToolTip="Volume">
                        <Button.Flyout>
                            <Flyout Placement="Top">
                                <Flyout.FlyoutPresenterStyle>
                                    <StaticResource ResourceKey="SidebarVolumeFlyoutPresenterStyle" />
                                </Flyout.FlyoutPresenterStyle>
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        Glyph="{x:Bind ViewModel.Volume, Mode=OneWay, Converter={StaticResource VolumeGlyphConverter}}" />
                                    <Slider
                                        Height="132"
                                        Orientation="Vertical"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="{x:Bind ViewModel.Volume, Mode=TwoWay}"
                                        IsEnabled="{x:Bind ViewModel.IsVolumeRestricted, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                        IsThumbToolTipEnabled="False" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                        <FontIcon
                            FontSize="12"
                            Glyph="{x:Bind ViewModel.Volume, Mode=OneWay, Converter={StaticResource VolumeGlyphConverter}}" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============ COLLAPSED LAYOUT ============ -->
            <Grid x:Name="CollapsedRoot" RowSpacing="6" Visibility="Collapsed">
                <animations:Implicit.ShowAnimations>
                    <animations:OpacityAnimation Duration="0:0:0.2" From="0" To="1" />
                </animations:Implicit.ShowAnimations>
                <animations:Implicit.HideAnimations>
                    <animations:OpacityAnimation Duration="0:0:0.12" From="1" To="0" />
                </animations:Implicit.HideAnimations>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title row: small art + meta + heart pinned right (chevron sits over the right edge).
                     ⋯ moved to the transport row in this layout. -->
                <Grid Grid.Row="0" Margin="0,0,28,0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        x:Name="CollapsedAlbumArtHost"
                        Grid.Column="0"
                        Width="44"
                        Height="44"
                        CornerRadius="4"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        Tapped="AlbumArt_Tapped">
                        <imaging:CrossFadeImage
                            x:Name="CollapsedAlbumArtImage"
                            Width="44"
                            Height="44"
                            Source="{x:Bind ViewModel.AlbumArt, Mode=OneWay}"
                            FallbackSource="{x:Bind ViewModel.AlbumArtLarge, Mode=OneWay}"
                            DecodePixelWidth="96"
                            CornerRadius="4"
                            Stretch="UniformToFill" />
                        <FontIcon
                            Glyph="&#xE8D6;"
                            FontSize="16"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.AlbumArt, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}" />
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                        <HyperlinkButton
                            Padding="0"
                            MinHeight="0"
                            MinWidth="0"
                            Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                            Click="TrackTitle_Click">
                            <TextBlock
                                Text="{x:Bind ViewModel.TrackTitle, Mode=OneWay}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                MaxLines="1"
                                TextTrimming="CharacterEllipsis" />
                        </HyperlinkButton>
                        <ctk:MetadataControl
                            Items="{x:Bind ViewModel.ArtistMetadataItems, Mode=OneWay}"
                            Separator=", ">
                            <ctk:MetadataControl.TextBlockStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="10" />
                                    <Setter Property="Opacity" Value="0.7" />
                                    <Setter Property="Foreground" Value="{ThemeResource ApplicationForegroundThemeBrush}" />
                                    <Setter Property="MaxLines" Value="1" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                </Style>
                            </ctk:MetadataControl.TextBlockStyle>
                        </ctk:MetadataControl>
                    </StackPanel>

                    <controls:HeartButton
                        x:Name="CollapsedHeartButton"
                        Grid.Column="2"
                        Width="22"
                        Height="22"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right" />
                </Grid>

                <!-- Progress bar (no inline times) -->
                <playback:CompositionProgressBar
                    x:Name="CollapsedProgressSlider"
                    Grid.Row="1"
                    VerticalAlignment="Center"
                    Margin="2,0"
                    PositionMs="{x:Bind ViewModel.AnchorPositionMs, Mode=OneWay}"
                    DurationMs="{x:Bind ViewModel.Duration, Mode=OneWay}"
                    IsPlaying="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                    IsBuffering="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
                    SeekStarted="ProgressBar_SeekStarted"
                    SeekCommitted="ProgressBar_SeekCommitted"
                    Visibility="{x:Bind ViewModel.IsBuffering, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                <!-- Centered transport: shuffle | prev | play | next | repeat -->
                <StackPanel
                    x:Name="CollapsedTransportRow"
                    Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="4">
                    <ToggleButton
                        Style="{StaticResource SubtleToggleButtonStyle}"
                        Width="26"
                        Height="26"
                        Padding="0"
                        IsChecked="{x:Bind ViewModel.IsShuffle, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ToggleShuffleCommand}"
                        ToolTipService.ToolTip="Shuffle">
                        <FontIcon Glyph="&#xE8B1;" FontSize="12" />
                    </ToggleButton>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Command="{x:Bind ViewModel.PreviousCommand}"
                        ToolTipService.ToolTip="Previous">
                        <FontIcon Glyph="&#xF8AC;" FontSize="13" />
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Command="{x:Bind ViewModel.PlayPauseCommand}"
                        ToolTipService.ToolTip="Play/Pause">
                        <playback:PlaybackActionContent
                            IconSize="14"
                            SpinnerSize="16"
                            IsPlaying="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                            IsPending="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
                            ActionForeground="{ThemeResource TextFillColorPrimaryBrush}" />
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Command="{x:Bind ViewModel.NextCommand}"
                        ToolTipService.ToolTip="Next">
                        <FontIcon Glyph="&#xF8AD;" FontSize="13" />
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="26"
                        Height="26"
                        Padding="0"
                        Command="{x:Bind ViewModel.SkipForwardCommand}"
                        Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Forward 15 seconds">
                        <TextBlock Text="+15" FontSize="9" FontWeight="SemiBold" />
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="34"
                        Height="26"
                        Padding="0"
                        Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Playback speed">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="0.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="0.5" />
                                <MenuFlyoutItem Text="0.75x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="0.75" />
                                <MenuFlyoutItem Text="1x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1" />
                                <MenuFlyoutItem Text="1.25x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.25" />
                                <MenuFlyoutItem Text="1.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.5" />
                                <MenuFlyoutItem Text="1.75x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.75" />
                                <MenuFlyoutItem Text="2x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="2" />
                                <MenuFlyoutItem Text="2.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="2.5" />
                                <MenuFlyoutItem Text="3x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="3" />
                            </MenuFlyout>
                        </Button.Flyout>
                        <TextBlock Text="{x:Bind ViewModel.PlaybackSpeedText, Mode=OneWay}" FontSize="9" FontWeight="SemiBold" />
                    </Button>
                    <ToggleButton
                        Style="{StaticResource SubtleToggleButtonStyle}"
                        Width="26"
                        Height="26"
                        Padding="0"
                        IsChecked="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatCheckedConverter}}"
                        Command="{x:Bind ViewModel.ToggleRepeatCommand}"
                        ToolTipService.ToolTip="Repeat">
                        <FontIcon
                            Glyph="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatGlyphConverter}}"
                            FontSize="12" />
                    </ToggleButton>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="26"
                        Height="26"
                        Padding="0"
                        Command="{x:Bind ViewModel.SwitchToVideoCommand}"
                        IsEnabled="{x:Bind ViewModel.IsResolvingVideo, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        Visibility="{x:Bind ViewModel.IsCurrentTrackVideoCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Watch Video">
                        <Grid Width="13" Height="13">
                            <FontIcon
                                Glyph="&#xE714;"
                                FontSize="11"
                                Visibility="{x:Bind ViewModel.IsResolvingVideo, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                            <ProgressRing
                                Width="13"
                                Height="13"
                                IsActive="{x:Bind ViewModel.IsResolvingVideo, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsResolvingVideo, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Button>
                    <Button
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="26"
                        Height="26"
                        Padding="0"
                        Command="{x:Bind ViewModel.SwitchToAudioCommand}"
                        IsEnabled="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        Visibility="{x:Bind ViewModel.IsCurrentTrackAudioCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Listen as audio">
                        <Grid Width="13" Height="13">
                            <FontIcon
                                Glyph="&#xE8D6;"
                                FontSize="11"
                                Visibility="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                            <ProgressRing
                                Width="13"
                                Height="13"
                                IsActive="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Button>
                    <Button
                        x:Name="CollapsedOverflowButton"
                        Style="{StaticResource TransparentButtonStyle}"
                        Width="26"
                        Height="26"
                        Padding="0"
                        ToolTipService.ToolTip="More">
                        <Button.Flyout>
                            <MenuFlyout>
                                <ToggleMenuFlyoutItem
                                    Text="Queue"
                                    IsChecked="{x:Bind ViewModel.IsQueuePanelActive, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.ToggleQueuePanelCommand}">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE142;" FontSize="14" />
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <ToggleMenuFlyoutItem
                                    Text="Lyrics"
                                    IsChecked="{x:Bind ViewModel.IsLyricsPanelActive, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.ToggleLyricsPanelCommand}">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xED1E;" FontSize="14" />
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <ToggleMenuFlyoutItem
                                    Text="Details"
                                    IsChecked="{x:Bind ViewModel.IsDetailsPanelActive, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.ToggleDetailsPanelCommand}">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE946;" FontSize="14" />
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <ToggleMenuFlyoutItem
                                    Text="Friends Activity"
                                    IsChecked="{x:Bind ViewModel.IsFriendsPanelActive, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.ToggleFriendsPanelCommand}">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE716;" FontSize="14" />
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <ToggleMenuFlyoutItem
                                    Text="Mute"
                                    IsChecked="{x:Bind ViewModel.IsMuted, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.ToggleMuteCommand}">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon
                                            FontSize="14"
                                            Glyph="{x:Bind ViewModel.Volume, Mode=OneWay, Converter={StaticResource VolumeGlyphConverter}}" />
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <MenuFlyoutItem
                                    Text="Skip back 10 seconds"
                                    Command="{x:Bind ViewModel.SkipBackwardCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xED3C;" FontSize="14" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    Text="Skip forward 30 seconds"
                                    Command="{x:Bind ViewModel.SkipForwardCommand}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xED3D;" FontSize="14" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem
                                    Text="Pop out to window"
                                    Click="PopOutToWindow_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    Text="Move back to bottom bar"
                                    Click="MoveToBottomBar_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74A;" FontSize="14" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                        <FontIcon Glyph="&#xE712;" FontSize="11" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- End-of-context inline notice — mirrors PlayerBar's EndOfContextBar but inline at the
             bottom of the widget. Auto-clears on resume; user can dismiss via the X button. -->
        <Grid
            x:Name="EndOfContextBar"
            MinHeight="28"
            Padding="8,4"
            CornerRadius="6"
            Background="{ThemeResource InfoBarInformationalSeverityBackgroundBrush}"
            BorderBrush="{ThemeResource InfoBarBorderBrush}"
            BorderThickness="1"
            Visibility="{x:Bind ViewModel.IsAtEndOfContext, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon
                Grid.Column="0"
                Glyph="&#xE946;"
                FontSize="11"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Foreground="{ThemeResource InfoBarInformationalSeverityIconBackground}" />

            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontSize="11"
                TextWrapping="Wrap"
                Text="End of queue — click Play to restart." />

            <Button
                Grid.Column="2"
                Background="Transparent"
                BorderThickness="0"
                Padding="2"
                MinWidth="22"
                MinHeight="22"
                Click="EndOfContextDismiss_Click"
                ToolTipService.ToolTip="Dismiss">
                <FontIcon Glyph="&#xE711;" FontSize="9" />
            </Button>
        </Grid>
        </StackPanel>
    </Border>
</UserControl>
