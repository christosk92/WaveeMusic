<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.RightPanel.RightPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    mc:Ignorable="d"
    MinWidth="200"
    MaxWidth="500"
    Loaded="RightPanelView_Loaded">

    <animations:Implicit.ShowAnimations>
        <animations:OpacityAnimation Duration="0:0:0.25" From="0" To="1" />
        <animations:TranslationAnimation Duration="0:0:0.25" From="40,0,0" To="0" />
    </animations:Implicit.ShowAnimations>
    <animations:Implicit.HideAnimations>
        <animations:OpacityAnimation Duration="0:0:0.2" From="1" To="0" />
        <animations:TranslationAnimation Duration="0:0:0.2" From="0" To="40,0,0" />
    </animations:Implicit.HideAnimations>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>  <!-- Resize gripper -->
            <ColumnDefinition Width="*"/>     <!-- Panel content -->
        </Grid.ColumnDefinitions>

        <!-- Resize gripper -->
        <Border
            x:Name="PanelResizer"
            Grid.Column="0"
            MinWidth="4"
            Margin="0,60,0,40"
            HorizontalAlignment="Left"
            Background="Transparent"
            BorderBrush="Transparent"
            Canvas.ZIndex="100"
            CornerRadius="2"
            ManipulationMode="TranslateX"
            ManipulationStarted="Resizer_ManipulationStarted"
            ManipulationDelta="Resizer_ManipulationDelta"
            ManipulationCompleted="Resizer_ManipulationCompleted"
            PointerEntered="Resizer_PointerEntered"
            PointerExited="Resizer_PointerExited"
            DoubleTapped="Resizer_DoubleTapped"/>

        <!-- Panel content -->
        <Grid Grid.Column="1" Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Tab header -->
                <RowDefinition Height="*"/>     <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Tab header -->
            <StackPanel
                Grid.Row="0"
                Orientation="Horizontal"
                Spacing="2"
                Padding="12,12,12,8"
                HorizontalAlignment="Left">

                <ToggleButton
                    x:Name="QueueTab"
                    Content="Queue"
                    Click="QueueTab_Click"
                    Style="{StaticResource DefaultToggleButtonStyle}"
                    MinHeight="28"
                    Padding="12,4"
                    FontSize="12"
                    CornerRadius="14"/>

                <ToggleButton
                    x:Name="LyricsTab"
                    Content="Lyrics"
                    Click="LyricsTab_Click"
                    Style="{StaticResource DefaultToggleButtonStyle}"
                    MinHeight="28"
                    Padding="12,4"
                    FontSize="12"
                    CornerRadius="14"/>

                <ToggleButton
                    x:Name="FriendsTab"
                    Content="Friends"
                    Click="FriendsTab_Click"
                    Style="{StaticResource DefaultToggleButtonStyle}"
                    MinHeight="28"
                    Padding="12,4"
                    FontSize="12"
                    CornerRadius="14"/>
            </StackPanel>

            <!-- Content area -->
            <Grid Grid.Row="1" Padding="12,0,12,12">

                <!-- Queue placeholder -->
                <StackPanel x:Name="QueueContent" Spacing="8">
                    <TextBlock
                        Text="Queue"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Margin="0,0,0,8"/>
                    <TextBlock
                        Text="Your queue is empty. Play something to see it here."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords"
                        FontSize="13"/>
                </StackPanel>

                <!-- Lyrics panel -->
                <Grid x:Name="LyricsContent" Visibility="Collapsed">

                    <!-- Loading shimmer -->
                    <StackPanel x:Name="LyricsShimmer"
                                Visibility="{x:Bind _lyricsVm.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                Spacing="16" Padding="8,16" VerticalAlignment="Top">
                        <controls:Shimmer Width="200" Height="20" HorizontalAlignment="Left" CornerRadius="4"/>
                        <controls:Shimmer Width="240" Height="20" HorizontalAlignment="Left" CornerRadius="4"/>
                        <controls:Shimmer Width="160" Height="20" HorizontalAlignment="Left" CornerRadius="4"/>
                        <controls:Shimmer Width="220" Height="20" HorizontalAlignment="Left" CornerRadius="4"/>
                        <controls:Shimmer Width="180" Height="20" HorizontalAlignment="Left" CornerRadius="4"/>
                        <controls:Shimmer Width="250" Height="20" HorizontalAlignment="Left" CornerRadius="4"/>
                    </StackPanel>

                    <!-- No lyrics available -->
                    <StackPanel Visibility="{x:Bind _lyricsVm.HasNoLyrics, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xED11;" FontSize="32" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Opacity="0.5"/>
                        <TextBlock Text="No lyrics available"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Lyrics list -->
                    <ScrollViewer x:Name="LyricsScrollViewer"
                                  Visibility="{x:Bind _lyricsVm.HasLyrics, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                  VerticalScrollBarVisibility="Hidden"
                                  Padding="0">
                        <ItemsRepeater x:Name="LyricsRepeater"
                                       ItemsSource="{x:Bind _lyricsVm.Lines, Mode=OneWay}"
                                       Margin="4,40,4,200">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="2"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:LyricsLineItem">
                                    <Button Command="{x:Bind SeekCommand}"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="8,8"
                                            CornerRadius="4"
                                            Opacity="{x:Bind Opacity, Mode=OneWay}">
                                        <TextBlock Text="{x:Bind Words, Mode=OneTime}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="WrapWholeWords"
                                                   Foreground="White"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>

                    <!-- Fade mask host: overlays the ScrollViewer, renders the masked visual -->
                    <Border x:Name="LyricsFadeMaskHost"
                            IsHitTestVisible="False"
                            Visibility="{x:Bind _lyricsVm.HasLyrics, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>

                <!-- Friends Activity placeholder -->
                <StackPanel x:Name="FriendsContent" Spacing="8" Visibility="Collapsed">
                    <TextBlock
                        Text="Friends Activity"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Margin="0,0,0,8"/>
                    <TextBlock
                        Text="See what your friends are listening to."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords"
                        FontSize="13"/>
                </StackPanel>
            </Grid>
        </Grid>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="ResizerStates">
                <VisualState x:Name="ResizerNormal" />
                <VisualState x:Name="ResizerPointerOver">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PanelResizer" Storyboard.TargetProperty="Background">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource CardStrokeColorDefaultSolidBrush}" />
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="ResizerPressed">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PanelResizer" Storyboard.TargetProperty="Background">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SolidBackgroundFillColorSecondaryBrush}" />
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>
