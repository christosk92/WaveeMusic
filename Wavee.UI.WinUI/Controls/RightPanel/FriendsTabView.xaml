<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.RightPanel.FriendsTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <animations:Implicit.ShowAnimations>
            <animations:OpacityAnimation Duration="0:0:0.2" From="0" To="1"/>
            <animations:TranslationAnimation Duration="0:0:0.2" From="0,8,0" To="0"/>
        </animations:Implicit.ShowAnimations>
        <animations:Implicit.HideAnimations>
            <animations:OpacityAnimation Duration="0:0:0.15" From="1" To="0"/>
        </animations:Implicit.HideAnimations>
        <TextBlock x:Uid="Controls_RightPanel_FriendsTabView__TextBlock_1"
            Text="Friends Activity"
            Style="{StaticResource SubtitleTextBlockStyle}"
            Margin="0,0,0,8"/>
        <TextBlock x:Uid="Controls_RightPanel_FriendsTabView__TextBlock_2"
            Text="See what your friends are listening to."
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            TextWrapping="WrapWholeWords"
            FontSize="13"/>
    </StackPanel>
</UserControl>
