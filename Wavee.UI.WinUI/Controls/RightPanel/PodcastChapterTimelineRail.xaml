<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.RightPanel.PodcastChapterTimelineRail"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="18"
    MinHeight="46"
    IsHitTestVisible="False">

    <Grid x:Name="RootRail">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Rectangle x:Name="TopTrack"
                   Grid.Row="0"
                   Width="2"
                   Fill="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                   Opacity="0.55"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Stretch"
                   RadiusX="1"
                   RadiusY="1"/>

        <Rectangle x:Name="TopProgressFill"
                   Grid.Row="0"
                   Width="2"
                   Fill="{ThemeResource AccentFillColorDefaultBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Stretch"
                   RadiusX="1"
                   RadiusY="1"/>

        <Rectangle x:Name="BottomTrack"
                   Grid.Row="2"
                   Width="2"
                   Fill="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                   Opacity="0.55"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Stretch"
                   RadiusX="1"
                   RadiusY="1"/>

        <Rectangle x:Name="BottomProgressFill"
                   Grid.Row="2"
                   Width="2"
                   Fill="{ThemeResource AccentFillColorDefaultBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Stretch"
                   RadiusX="1"
                   RadiusY="1"/>

        <Border x:Name="DotHalo"
                Grid.Row="1"
                Width="20"
                Height="20"
                CornerRadius="10"
                Background="{ThemeResource AccentFillColorTertiaryBrush}"
                Opacity="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>

        <Border x:Name="Dot"
                Grid.Row="1"
                Width="10"
                Height="10"
                CornerRadius="5"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
    </Grid>
</UserControl>
