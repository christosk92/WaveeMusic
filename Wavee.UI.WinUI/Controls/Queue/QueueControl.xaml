<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Queue.QueueControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Wavee.UI.WinUI.Controls.Queue"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:shimmer="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:SpotifyImageConverter x:Key="SpotifyImageConverter"/>

        <!-- Shared track row template with shimmer loading state -->
        <DataTemplate x:Key="TrackTemplate" x:DataType="local:QueueDisplayItem">
            <Grid Padding="4,4" ColumnSpacing="10" Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Album art or shimmer -->
                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="4"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Image Stretch="UniformToFill"
                           Visibility="{x:Bind IsLoaded, Mode=OneTime}"
                           Source="{x:Bind ImageUrl, Mode=OneTime, Converter={StaticResource SpotifyImageConverter}, ConverterParameter=36}"/>
                </Border>
                <shimmer:Shimmer Grid.Column="0" Width="36" Height="36"
                                 Visibility="{x:Bind IsShimmer, Mode=OneTime}"/>

                <!-- Title/artist or shimmer -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1"
                            Visibility="{x:Bind IsLoaded, Mode=OneTime}">
                    <TextBlock Text="{x:Bind Title, Mode=OneTime}" FontSize="13"
                               MaxLines="1" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{x:Bind Subtitle, Mode=OneTime}" FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               MaxLines="1" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4"
                            Visibility="{x:Bind IsShimmer, Mode=OneTime}">
                    <shimmer:Shimmer Width="160" Height="12" HorizontalAlignment="Left"/>
                    <shimmer:Shimmer Width="100" Height="10" HorizontalAlignment="Left"/>
                </StackPanel>

                <FontIcon Grid.Column="2" Glyph="{x:Bind BadgeGlyph, Mode=OneTime}" FontSize="12"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          VerticalAlignment="Center"
                          Visibility="{x:Bind HasBadge, Mode=OneTime}"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <ScrollView VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" Padding="0,0,0,16">

                <!-- Now Playing -->
                <Grid x:Name="NowPlayingSection" Visibility="Collapsed" Margin="0,0,0,4">
                    <Grid Padding="8,8" ColumnSpacing="10" Height="60"
                          CornerRadius="6"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Image x:Name="NowPlayingArt" Stretch="UniformToFill"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Uid="Controls_Queue_QueueControl__TextBlock_1" Text="Now Playing" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <TextBlock x:Name="NowPlayingTitle" FontSize="13" FontWeight="SemiBold"
                                       MaxLines="1" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="NowPlayingArtist" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       MaxLines="1" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <FontIcon Grid.Column="2" Glyph="&#xE995;" FontSize="16"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                  VerticalAlignment="Center" Margin="8,0"/>
                    </Grid>
                </Grid>

                <!-- User Queue section -->
                <StackPanel x:Name="UserQueueSection" Visibility="Collapsed" Spacing="0">
                    <TextBlock x:Name="UserQueueHeader"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,12,0,4"/>
                    <ItemsRepeater x:Name="UserQueueRepeater"
                                   ItemTemplate="{StaticResource TrackTemplate}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="0"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Next up / autoplay section -->
                <StackPanel x:Name="NextUpSection" Visibility="Collapsed" Spacing="0">
                    <TextBlock x:Name="NextUpHeader"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,12,0,4"/>
                    <ItemsRepeater x:Name="NextUpRepeater"
                                   ItemTemplate="{StaticResource TrackTemplate}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="0"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Delimiter -->
                <StackPanel x:Name="DelimiterSection" Visibility="Collapsed"
                            HorizontalAlignment="Center" Spacing="4" Margin="0,16,0,4">
                    <FontIcon Glyph="&#xE71A;" FontSize="18"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="DelimiterText" FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ScrollView>

        <!-- Empty state -->
        <TextBlock x:Uid="Controls_Queue_QueueControl__TextBlock_2" x:Name="EmptyState"
                   Text="Your queue is empty. Play something to see it here."
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextWrapping="WrapWholeWords"
                   FontSize="13"
                   Visibility="Collapsed"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Margin="16"/>
    </Grid>
</UserControl>
