<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Comments.CommentThreadItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:appcontrols="using:Wavee.UI.WinUI.Controls"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True"/>
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>

        <Style x:Key="ReactionChipStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Per-reply renderer used inside the replies expander. Same shape as
             the comment header but slimmer, no replies-of-replies. -->
        <DataTemplate x:Key="ReplyTemplate" x:DataType="vm:PodcastReplyViewModel">
            <Grid Padding="0,6" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <PersonPicture Grid.Column="0"
                               Width="28" Height="28"
                               VerticalAlignment="Top"
                               DisplayName="{x:Bind Data.AuthorName}"
                               ProfilePicture="{x:Bind Data.AuthorImageUrl, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='56'}"/>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                               Style="{StaticResource CaptionTextBlockStyle}">
                        <Run Text="{x:Bind Data.AuthorName}" FontWeight="SemiBold"
                             Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <Run Text=" · "
                             Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <Run Text="{x:Bind Data.CreatedAtFormatted}"
                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>
                    <TextBlock
                        Text="{x:Bind Data.Text}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        TextWrapping="Wrap"
                        MaxLines="6"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button
                            Padding="0"
                            MinHeight="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Tag="{x:Bind}"
                            Click="ReplyReactionsChip_Click"
                            Visibility="{x:Bind HasReactions, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Style="{StaticResource ReactionChipStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind TopReactionEmojiString}"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind ReactionsLabel}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                        <Button
                            Content="React"
                            Padding="8,3"
                            MinHeight="0"
                            IsEnabled="{x:Bind CanReact, Mode=OneWay}">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="&#x2764;&#xFE0F;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x2764;&#xFE0F;"/>
                                    <MenuFlyoutItem Text="&#x1F602;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F602;"/>
                                    <MenuFlyoutItem Text="&#x1F62E;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F62E;"/>
                                    <MenuFlyoutItem Text="&#x1F44E;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F44E;"/>
                                    <MenuFlyoutItem Text="&#x1F44F;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F44F;"/>
                                    <MenuFlyoutItem Text="&#x1F525;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F525;"/>
                                    <MenuFlyoutItem Text="&#x1F44D;" Command="{x:Bind ReactCommand, Mode=OneWay}" CommandParameter="&#x1F44D;"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Padding="0,10" ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="AvatarColumn" Width="36"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <PersonPicture x:Name="AvatarPicture"
                       Grid.Column="0"
                       Width="36" Height="36"
                       VerticalAlignment="Top"/>

        <StackPanel Grid.Column="1" Spacing="6">
            <TextBlock x:Name="HeaderText"
                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                       Style="{StaticResource CaptionTextBlockStyle}"/>

            <TextBlock x:Name="BodyText"
                       Style="{StaticResource BodyTextBlockStyle}"
                       TextWrapping="Wrap"/>

            <StackPanel x:Name="ActionRow" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="ReactionsChipButton"
                        Padding="0"
                        MinHeight="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="ReactionsChip_Click">
                    <Border Style="{StaticResource ReactionChipStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock x:Name="ReactionEmojiText"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ReactionsLabelText"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>
                <Button x:Name="ReactButton"
                        Content="React"
                        Padding="8,3"
                        MinHeight="0">
                    <Button.Flyout>
                        <MenuFlyout x:Name="ReactMenu">
                            <MenuFlyoutItem Text="&#x2764;&#xFE0F;" Click="ReactionMenuItem_Click" Tag="&#x2764;&#xFE0F;"/>
                            <MenuFlyoutItem Text="&#x1F602;" Click="ReactionMenuItem_Click" Tag="&#x1F602;"/>
                            <MenuFlyoutItem Text="&#x1F62E;" Click="ReactionMenuItem_Click" Tag="&#x1F62E;"/>
                            <MenuFlyoutItem Text="&#x1F44E;" Click="ReactionMenuItem_Click" Tag="&#x1F44E;"/>
                            <MenuFlyoutItem Text="&#x1F44F;" Click="ReactionMenuItem_Click" Tag="&#x1F44F;"/>
                            <MenuFlyoutItem Text="&#x1F525;" Click="ReactionMenuItem_Click" Tag="&#x1F525;"/>
                            <MenuFlyoutItem Text="&#x1F44D;" Click="ReactionMenuItem_Click" Tag="&#x1F44D;"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <HyperlinkButton x:Name="ReplyHyperlink"
                                 Content="Reply"
                                 Padding="2,4"
                                 Click="ReplyHyperlink_Click"/>
            </StackPanel>

            <!-- Reply composer — bound to the per-comment VM's reply fields. -->
            <StackPanel x:Name="ReplyComposerPanel" Spacing="6" Visibility="Collapsed">
                <TextBox x:Name="ReplyTextBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="54"
                         MaxLength="500"
                         TextChanged="ReplyTextBox_TextChanged"/>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ReplyCharCount"
                               Grid.Column="0"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="ReplyCancelButton"
                            Grid.Column="1"
                            Content="Cancel"
                            Padding="10,5"
                            Click="ReplyCancel_Click"/>
                    <Button x:Name="ReplySubmitButton"
                            Grid.Column="2"
                            Content="Reply"
                            Padding="12,5"
                            Click="ReplySubmit_Click"/>
                </Grid>
            </StackPanel>

            <TextBlock x:Name="ReplyStatusText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed"/>

            <!-- Replies expander. -->
            <Expander x:Name="RepliesExpander"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      ExpandDirection="Down"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0,4,0,0">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <appcontrols:StackedAvatars x:Name="ReplyAvatarStack"
                                                    AvatarSize="20"
                                                    RingThickness="2"
                                                    Overlap="8"
                                                    MaxVisible="3"
                                                    Visibility="Collapsed"/>
                        <TextBlock x:Name="RepliesLabelText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="4" Padding="0,4,0,0">
                    <ItemsRepeater x:Name="RepliesRepeater"
                                   ItemTemplate="{StaticResource ReplyTemplate}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="2"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                    <StackPanel x:Name="RepliesLoadingPanel" Spacing="6" Visibility="Collapsed">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="28" Height="28" CornerRadius="14"/>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <controls:Shimmer Width="120" Height="10" CornerRadius="3" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="220" Height="10" CornerRadius="3" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="28" Height="28" CornerRadius="14"/>
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <controls:Shimmer Width="100" Height="10" CornerRadius="3" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="180" Height="10" CornerRadius="3" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    <HyperlinkButton x:Name="LoadMoreRepliesButton"
                                     Content="Load more replies"
                                     Padding="0,2"/>
                </StackPanel>
            </Expander>
        </StackPanel>
    </Grid>
</UserControl>
