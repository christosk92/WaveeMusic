<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Playback.AudioOutputPicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:local="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="AudioOutputRowStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorTransparentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid"
                              Background="{TemplateBinding Background}"
                              CornerRadius="{TemplateBinding CornerRadius}"
                              Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="AudioOutputRowTemplate" x:DataType="local:AudioOutputDeviceRowViewModel">
            <Button
                Click="DeviceRow_Click"
                Tag="{x:Bind}"
                Background="{x:Bind RowBackground, Mode=OneWay}"
                Style="{StaticResource AudioOutputRowStyle}">
                <Grid ColumnSpacing="10" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        Grid.Column="0"
                        Glyph="{x:Bind Icon}"
                        FontSize="14"
                        HorizontalAlignment="Center"
                        Foreground="{x:Bind RowForeground, Mode=OneWay}" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{x:Bind Name}"
                        FontSize="13"
                        VerticalAlignment="Center"
                        MaxLines="1"
                        TextTrimming="CharacterEllipsis"
                        ToolTipService.ToolTip="{x:Bind Name}"
                        Foreground="{x:Bind RowForeground, Mode=OneWay}" />
                    <Grid Grid.Column="2" Width="18" Height="18">
                        <FontIcon
                            Glyph="&#xE73E;"
                            FontSize="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Visibility="{x:Bind CheckVisibility, Mode=OneWay}" />
                        <ProgressRing
                            Width="14"
                            Height="14"
                            IsActive="True"
                            Visibility="{x:Bind SpinnerVisibility, Mode=OneWay}" />
                    </Grid>
                </Grid>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Button
            x:Name="CompactRoot"
            Padding="8,4"
            CornerRadius="4"
            MaxWidth="{x:Bind CompactMaxWidth, Mode=OneWay}"
            Background="{ThemeResource SubtleFillColorTransparentBrush}"
            BorderThickness="0"
            ToolTipService.ToolTip="Choose output device"
            HorizontalContentAlignment="Stretch">
            <Grid ColumnSpacing="6" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon
                    x:Name="CompactDeviceIcon"
                    Glyph="&#xE767;"
                    FontSize="12"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    x:Name="CompactDeviceName"
                    Grid.Column="1"
                    Text="This device"
                    FontSize="12"
                    Opacity="0.9"
                    MinWidth="0"
                    VerticalAlignment="Center"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <FontIcon
                    Grid.Column="2"
                    Glyph="&#xE76C;"
                    FontSize="9"
                    Margin="2,0,0,0"
                    VerticalAlignment="Center"
                    Opacity="0.55"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>
            <Button.Flyout>
                <Flyout
                    x:Name="PickerFlyout"
                    Placement="BottomEdgeAlignedLeft"
                    Opening="PickerFlyout_Opening">
                    <Flyout.FlyoutPresenterStyle>
                        <Style TargetType="FlyoutPresenter" BasedOn="{StaticResource DefaultFlyoutPresenterStyle}">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinWidth" Value="300" />
                            <Setter Property="MaxWidth" Value="420" />
                            <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
                            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
                        </Style>
                    </Flyout.FlyoutPresenterStyle>
                    <StackPanel Padding="6" Spacing="2" MaxWidth="420">
                        <Grid x:Name="FlyoutVolumePanel"
                              Padding="10,8,10,6"
                              ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                x:Name="FlyoutVolumeIcon"
                                Grid.Column="0"
                                Glyph="&#xE767;"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Slider
                                x:Name="FlyoutVolumeSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="100"
                                SmallChange="1"
                                LargeChange="10"
                                IsThumbToolTipEnabled="False"
                                VerticalAlignment="Center"
                                ValueChanged="VolumeSlider_ValueChanged" />
                            <TextBlock
                                x:Name="FlyoutVolumeText"
                                Grid.Column="2"
                                Text="100"
                                FontSize="12"
                                TextAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <Border
                            Height="1"
                            Margin="10,2,10,4"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                        <TextBlock x:Name="FlyoutLocalHeader"
                                   Text="LOCAL AUDIO"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="80"
                                   Margin="10,8,10,4"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <ItemsRepeater x:Name="FlyoutLocalDeviceList"
                                       ItemTemplate="{StaticResource AudioOutputRowTemplate}" />
                        <Border x:Name="FlyoutSeparator"
                                Height="1"
                                Margin="10,8,10,4"
                                Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                        <TextBlock x:Name="FlyoutConnectHeader"
                                   Text="SPOTIFY CONNECT"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="80"
                                   Margin="10,4,10,4"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <ItemsRepeater x:Name="FlyoutConnectDeviceList"
                                       ItemTemplate="{StaticResource AudioOutputRowTemplate}" />
                        <TextBlock x:Name="FlyoutEmptyText"
                                   Text="No other devices available"
                                   FontSize="12"
                                   Margin="10,14,10,14"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Flyout>
            </Button.Flyout>
        </Button>

        <Border x:Name="CardRoot"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
            <StackPanel>
                <Button x:Name="CardHeader"
                        Style="{StaticResource AudioOutputRowStyle}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Padding="14,12"
                        CornerRadius="8"
                        Click="CardHeader_Click">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon x:Name="CardDeviceIcon"
                                  Glyph="&#xE995;"
                                  FontSize="20"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                            <TextBlock x:Name="CardDeviceLabel"
                                       Text="Playing on"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="CardDeviceName"
                                       Text="This device"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="This device"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                        <FontIcon x:Name="CardChevron"
                                  Grid.Column="2"
                                  Glyph="&#xE70D;"
                                  FontSize="10"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5">
                            <FontIcon.RenderTransform>
                                <RotateTransform x:Name="CardChevronRotation" Angle="0" />
                            </FontIcon.RenderTransform>
                        </FontIcon>
                    </Grid>
                </Button>

                <Grid x:Name="CardVolumePanel"
                      Padding="14,0,14,12"
                      ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="38" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        x:Name="CardVolumeIcon"
                        Grid.Column="0"
                        Glyph="&#xE767;"
                        FontSize="15"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Slider
                        x:Name="CardVolumeSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="100"
                        SmallChange="1"
                        LargeChange="10"
                        IsThumbToolTipEnabled="False"
                        VerticalAlignment="Center"
                        ValueChanged="VolumeSlider_ValueChanged" />
                    <TextBlock
                        x:Name="CardVolumeText"
                        Grid.Column="2"
                        Text="100%"
                        FontSize="12"
                        TextAlignment="Right"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>

                <StackPanel x:Name="CardExpandedPanel"
                            Visibility="Collapsed"
                            Padding="0,0,0,8">
                    <animations:Implicit.ShowAnimations>
                        <animations:OpacityAnimation Duration="0:0:0.18" From="0" To="1" />
                        <animations:TranslationAnimation Duration="0:0:0.18" From="0,-4,0" To="0" />
                    </animations:Implicit.ShowAnimations>

                    <Border Height="1"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            Margin="0,0,0,6" />
                    <TextBlock x:Name="CardLocalHeader"
                               Text="LOCAL AUDIO"
                               FontSize="10"
                               FontWeight="SemiBold"
                               CharacterSpacing="80"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Margin="14,6,14,4" />
                    <ItemsRepeater x:Name="CardLocalDeviceList"
                                   Margin="6,0"
                                   ItemTemplate="{StaticResource AudioOutputRowTemplate}" />
                    <Border x:Name="CardSeparator"
                            Height="1"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            Margin="14,6,14,6" />
                    <TextBlock x:Name="CardConnectHeader"
                               Text="SPOTIFY CONNECT"
                               FontSize="10"
                               FontWeight="SemiBold"
                               CharacterSpacing="80"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Margin="14,6,14,4" />
                    <ItemsRepeater x:Name="CardConnectDeviceList"
                                   Margin="6,0"
                                   ItemTemplate="{StaticResource AudioOutputRowTemplate}" />
                    <TextBlock x:Name="CardEmptyText"
                               Text="No other devices nearby"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,6"
                               Visibility="Collapsed" />
                </StackPanel>

                <Grid x:Name="CardOfflinePanel"
                      Padding="14,12"
                      ColumnSpacing="12"
                      Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE74F;"
                              FontSize="18"
                              Foreground="{ThemeResource SystemFillColorCautionBrush}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="Audio engine offline"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button Grid.Column="2"
                            Content="Retry"
                            FontSize="12"
                            Style="{StaticResource AudioOutputRowStyle}"
                            Click="Retry_Click" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
