<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Playback.OutputDevicePicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:rightpanel="using:Wavee.UI.WinUI.Controls.RightPanel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True" />

        <!-- Row style mirrors LibrarySortViewPanel's SortOptionRowStyle:
             transparent at rest, subtle hover/press tint, no active-state
             background. Active state signalled by the check glyph at right. -->
        <Style x:Key="OutputDevicePickerRowStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorTransparentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid"
                              Background="{TemplateBinding Background}"
                              CornerRadius="{TemplateBinding CornerRadius}"
                              Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- Trigger button: combobox-style. Shows the active device name + a chevron.
         Click opens the picker flyout. The trigger style is themed to be small +
         transparent so consumers can drop it inline anywhere (status chip, table
         cell, settings row). Padding is the only knob — change via the host. -->
    <Button
        x:Name="TriggerButton"
        Padding="8,4"
        CornerRadius="4"
        Background="{ThemeResource SubtleFillColorTransparentBrush}"
        BorderThickness="0"
        ToolTipService.ToolTip="Choose output device"
        HorizontalContentAlignment="Stretch">
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <FontIcon
                x:Name="TriggerIcon"
                Glyph="&#xE767;"
                FontSize="11"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
                x:Name="TriggerLabel"
                Text="This device"
                FontSize="12"
                Opacity="0.85"
                VerticalAlignment="Center"
                TextTrimming="CharacterEllipsis"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            <FontIcon
                Glyph="&#xE76C;"
                FontSize="9"
                Margin="2,0,0,0"
                VerticalAlignment="Center"
                Opacity="0.55"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
        <Button.Flyout>
            <Flyout
                x:Name="PickerFlyout"
                Placement="BottomEdgeAlignedLeft"
                Opening="PickerFlyout_Opening">
                <Flyout.FlyoutPresenterStyle>
                    <Style TargetType="FlyoutPresenter" BasedOn="{StaticResource DefaultFlyoutPresenterStyle}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinWidth" Value="260" />
                        <Setter Property="MaxWidth" Value="340" />
                        <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
                        <Setter Property="ScrollViewer.VerticalScrollMode" Value="Disabled" />
                        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
                        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
                    </Style>
                </Flyout.FlyoutPresenterStyle>
                <StackPanel Padding="4" Spacing="2">
                    <TextBlock
                        x:Name="LocalHeader"
                        Text="LOCAL AUDIO"
                        FontSize="10"
                        FontWeight="SemiBold"
                        CharacterSpacing="80"
                        Margin="12,8,12,4"
                        Opacity="0.55"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ItemsRepeater x:Name="LocalDeviceList">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="rightpanel:OutputDeviceRowViewModel">
                                <Button
                                    Click="DevicePickerRow_Click"
                                    Tag="{x:Bind}"
                                    Style="{StaticResource OutputDevicePickerRowStyle}">
                                    <Grid ColumnSpacing="12" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            Grid.Column="0"
                                            Glyph="{x:Bind Icon}"
                                            FontSize="14"
                                            HorizontalAlignment="Center"
                                            Foreground="{x:Bind RowForeground, Mode=OneWay}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind Name}"
                                            FontSize="13"
                                            VerticalAlignment="Center"
                                            TextTrimming="CharacterEllipsis"
                                            Foreground="{x:Bind RowForeground, Mode=OneWay}" />
                                        <Grid Grid.Column="2" Width="14" Height="14">
                                            <!-- EqualizerVisibility = Visible when IsActive && !IsSwitching.
                                                 The VM explicitly raises PropertyChanged on flips, which
                                                 x:Bind in a DataTemplate observes correctly. The earlier
                                                 IsActive + BoolToVisibilityConverter combo missed updates
                                                 inside ItemsRepeater recycling. -->
                                            <FontIcon
                                                Glyph="&#xE73E;"
                                                FontSize="14"
                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                Visibility="{x:Bind EqualizerVisibility, Mode=OneWay}" />
                                            <ProgressRing
                                                Width="14"
                                                Height="14"
                                                IsActive="True"
                                                Visibility="{x:Bind SpinnerVisibility, Mode=OneWay}" />
                                        </Grid>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <Border
                        x:Name="ListSeparator"
                        Height="1"
                        Margin="12,8,12,4"
                        Opacity="0.4"
                        Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <TextBlock
                        x:Name="ConnectHeader"
                        Text="SPOTIFY CONNECT"
                        FontSize="10"
                        FontWeight="SemiBold"
                        CharacterSpacing="80"
                        Margin="12,4,12,4"
                        Opacity="0.55"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ItemsRepeater x:Name="ConnectDeviceList">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="rightpanel:OutputDeviceRowViewModel">
                                <Button
                                    Click="DevicePickerRow_Click"
                                    Tag="{x:Bind}"
                                    Style="{StaticResource OutputDevicePickerRowStyle}">
                                    <Grid ColumnSpacing="12" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            Grid.Column="0"
                                            Glyph="{x:Bind Icon}"
                                            FontSize="14"
                                            HorizontalAlignment="Center"
                                            Foreground="{x:Bind RowForeground, Mode=OneWay}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind Name}"
                                            FontSize="13"
                                            VerticalAlignment="Center"
                                            TextTrimming="CharacterEllipsis"
                                            Foreground="{x:Bind RowForeground, Mode=OneWay}" />
                                        <Grid Grid.Column="2" Width="14" Height="14">
                                            <FontIcon
                                                Glyph="&#xE73E;"
                                                FontSize="14"
                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                Visibility="{x:Bind EqualizerVisibility, Mode=OneWay}" />
                                            <ProgressRing
                                                Width="14"
                                                Height="14"
                                                IsActive="True"
                                                Visibility="{x:Bind SpinnerVisibility, Mode=OneWay}" />
                                        </Grid>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <TextBlock
                        x:Name="EmptyText"
                        Text="No other devices available"
                        FontSize="12"
                        Opacity="0.55"
                        Margin="12,16,12,16"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="Collapsed" />
                </StackPanel>
            </Flyout>
        </Button.Flyout>
    </Button>
</UserControl>
