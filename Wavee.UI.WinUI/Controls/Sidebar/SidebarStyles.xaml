<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:local="using:Wavee.UI.WinUI.Controls.Sidebar">

    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    <converters:BoolToVisibilityConverter x:Key="SidebarBoolToVisibilityConverter" />

    <x:Double x:Key="SidebarOpenPaneLength">300</x:Double>
    <x:Double x:Key="SidebarNegativeOpenPaneLength">-300</x:Double>
    <x:Double x:Key="SidebarCompactOpenPaneLength">56</x:Double>
    <x:Double x:Key="SidebarNegativeCompactOpenPaneLength">-56</x:Double>

    <DataTemplate x:Key="DefaultSidebarItemTemplate">
        <local:SidebarItem
            AutomationProperties.AutomationId="{Binding Text, Mode=OneWay}"
            IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
            Item="{Binding}" />
    </DataTemplate>

    <Style TargetType="local:SidebarItem">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:SidebarItem">
                    <Grid x:Name="RootPanel" Padding="4,0,4,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Drag Target Indicator  -->
                        <Rectangle
                            x:Name="DragTargetIndicator"
                            Grid.ColumnSpan="3"
                            Height="2"
                            Margin="4,-2"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            AutomationProperties.AccessibilityView="Raw"
                            Fill="{ThemeResource AccentFillColorDefaultBrush}"
                            RadiusX="4"
                            RadiusY="4"
                            Visibility="Collapsed" />

                        <!--  Focusable Visual  -->
                        <Border
                            x:Name="ElementBorder"
                            Grid.Row="0"
                            Height="44"
                            Background="Transparent"
                            Padding="{Binding Depth, Converter={StaticResource DepthToThicknessConverter}, ConverterParameter=20}">
                            <Grid
                                x:Name="ElementGrid"
                                Margin="0,2,0,2"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource SubtleFillColorTransparentBrush}"
                                BackgroundSizing="InnerBorderEdge"
                                BorderThickness="1"
                                CornerRadius="{ThemeResource ControlCornerRadius}"
                                IsTabStop="True"
                                TabFocusNavigation="Once"
                                ToolTipService.ToolTip="{Binding ToolTip, Mode=OneWay}"
                                UseSystemFocusVisuals="True">
                                <Grid.ColumnDefinitions>
                                    <!--  Selection Indicator  -->
                                    <ColumnDefinition Width="3" />
                                    <!--  Icon  -->
                                    <ColumnDefinition Width="Auto" />
                                    <!--  Text  -->
                                    <ColumnDefinition Width="*" />
                                    <!--  Badge  -->
                                    <ColumnDefinition Width="Auto" />
                                    <!--  Decorator  -->
                                    <ColumnDefinition Width="Auto" />
                                    <!--  Chevron  -->
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Selection Rectangle  -->
                                <Rectangle
                                    x:Name="SelectionIndicator"
                                    Grid.Column="0"
                                    Width="3"
                                    Height="16"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    AutomationProperties.AccessibilityView="Raw"
                                    Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                    Opacity="0"
                                    RadiusX="2"
                                    RadiusY="2" />

                                <!--  Icon  -->
                                <ContentPresenter
                                    x:Name="IconPresenter"
                                    Grid.Column="1"
                                    Width="16"
                                    Height="16"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                                <!--  Text  -->
                                <TextBlock
                                    x:Name="ItemNameTextBlock"
                                    Grid.Column="2"
                                    Margin="12,0,12,2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    AutomationProperties.AccessibilityView="Raw"
                                    FontFamily="{ThemeResource ContentControlThemeFontFamily}"
                                    LineHeight="16"
                                    Text="{Binding Text, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />

                                <!--  Badge  -->
                                <!--
                                    The badge lives inside a host so the Compact VisualState can collapse the
                                    whole column cleanly. In WinUI 3 a local Visibility binding outranks a
                                    VisualState setter targeting the same property, so the original
                                    Visibility="{Binding BadgeCount, ...}" on the InfoBadge itself left
                                    stale badges visible in the narrow sidebar. The host has NO binding —
                                    only the VisualState touches its Visibility — while the null-check
                                    binding stays on the inner InfoBadge, which the VS never targets.
                                -->
                                <Grid
                                    x:Name="ItemBadgeHost"
                                    Grid.Column="3"
                                    Margin="0,0,4,0"
                                    VerticalAlignment="Center">
                                    <InfoBadge
                                        x:Name="ItemBadge"
                                        Value="{Binding BadgeCount, Mode=OneWay}"
                                        Visibility="{Binding BadgeCount, Converter={StaticResource NullToVisibilityConverter}, Mode=OneWay}" />
                                </Grid>

                                <!--  Decorator  -->
                                <ContentPresenter
                                    x:Name="ItemDecoratorPresenter"
                                    Grid.Column="4"
                                    Margin="0,0,4,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    BorderThickness="0"
                                    Content="{Binding Decorator, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                    Visibility="Collapsed" />

                                <!--  Chevron  -->
                                <AnimatedIcon
                                    x:Name="ExpandCollapseChevron"
                                    Grid.Column="5"
                                    Width="{StaticResource ExpanderChevronGlyphSize}"
                                    Height="{StaticResource ExpanderChevronGlyphSize}"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    AnimatedIcon.State="NormalOff"
                                    AutomationProperties.AccessibilityView="Raw"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    RenderTransformOrigin="0.5, 0.5"
                                    Visibility="Collapsed">
                                    <animatedvisuals:AnimatedChevronUpDownSmallVisualSource />
                                    <AnimatedIcon.FallbackIconSource>
                                        <FontIconSource
                                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                                            FontSize="12"
                                            Glyph="{StaticResource ExpanderChevronDownGlyph}"
                                            IsTextScaleFactorEnabled="False" />
                                    </AnimatedIcon.FallbackIconSource>
                                    <AnimatedIcon.RenderTransform>
                                        <RotateTransform x:Name="ExpandCollapseChevronRotateTransform" Angle="0" />
                                    </AnimatedIcon.RenderTransform>
                                </AnimatedIcon>

                                <!--  Overflow  -->
                                <FlyoutBase.AttachedFlyout>
                                    <Flyout x:Name="ChildrenFlyout" Placement="Right">
                                        <Flyout.FlyoutPresenterStyle>
                                            <Style BasedOn="{StaticResource DefaultFlyoutPresenterStyle}" TargetType="FlyoutPresenter">
                                                <Setter Target="Padding" Value="0,4" />
                                                <Setter Target="MinWidth" Value="200" />
                                                <Setter Target="MinHeight" Value="20" />
                                            </Style>
                                        </Flyout.FlyoutPresenterStyle>
                                        <ItemsRepeater
                                            x:Name="FlyoutChildrenPresenter"
                                            HorizontalAlignment="Stretch"
                                            local:SidebarItem.TemplateRoot="{Binding ElementName=RootPanel}"
                                            AutomationProperties.AccessibilityView="Content"
                                            ItemsSource="{Binding Children, Mode=OneWay}"
                                            XYFocusKeyboardNavigation="Enabled">
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate>
                                                    <local:SidebarItem
                                                        AutomationProperties.AutomationId="{Binding Text, Mode=OneWay}"
                                                        IsInFlyout="True"
                                                        Item="{Binding}" />
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </Flyout>
                                </FlyoutBase.AttachedFlyout>
                            </Grid>
                        </Border>

                        <!--
                            Depth guide — one 1-px hairline per expanded folder. Sits at
                            x = Depth*20 + 10 (middle of the folder's own indent column).
                            Takes its vertical height from the Grid.Row=2 row, which is
                            Height="Auto" and sized by the visible ChildrenPresenter. When
                            the folder collapses, ChildrenPresenter.Visibility=Collapsed →
                            row height = 0 → guide renders 0 px tall = invisible. No
                            separate collapse animation needed.
                        -->
                        <Rectangle
                            x:Name="DepthGuide"
                            Grid.Row="2"
                            Width="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Margin="{Binding Depth, Converter={StaticResource DepthToThicknessConverter}, ConverterParameter='20,10'}"
                            Fill="{ThemeResource TextFillColorTertiaryBrush}"
                            Opacity="0.25"
                            IsHitTestVisible="False"
                            Visibility="{Binding IsFolder, Converter={StaticResource SidebarBoolToVisibilityConverter}, Mode=OneWay}" />

                        <!--  Children  -->
                        <ItemsRepeater
                            x:Name="ChildrenPresenter"
                            Grid.Row="2"
                            Margin="0"
                            HorizontalAlignment="Stretch"
                            local:SidebarItem.TemplateRoot="{Binding ElementName=RootPanel}"
                            AutomationProperties.AccessibilityView="Content"
                            ItemTemplate="{StaticResource DefaultSidebarItemTemplate}"
                            ItemsSource="{Binding Children, Mode=OneWay}"
                            Visibility="Collapsed"
                            XYFocusKeyboardNavigation="Enabled">
                            <ItemsRepeater.Layout>
                                <StackLayout />
                            </ItemsRepeater.Layout>
                        </ItemsRepeater>

                        <!--
                            Empty Section Placeholder (Drag-Drop Style)
                            The outer Grid is left-indented by Depth*20 + 24 so the placeholder
                            sits one indent level INSIDE the folder (or the section), not flush
                            against the sidebar's left edge. The inner Grid carries the 4,4,4,8
                            frame used before.
                        -->
                        <Grid
                            x:Name="EmptyPlaceholder"
                            Grid.Row="2"
                            Margin="{Binding Depth, Converter={StaticResource DepthToThicknessConverter}, ConverterParameter='20,24'}"
                            HorizontalAlignment="Stretch"
                            Visibility="Collapsed">
                            <Grid Margin="0,4,4,8">
                                <Rectangle
                                    RadiusX="4"
                                    RadiusY="4"
                                    Stroke="{ThemeResource TextFillColorTertiaryBrush}"
                                    StrokeDashArray="4,3"
                                    StrokeThickness="1"
                                    Opacity="0.5" />
                                <TextBlock
                                    Margin="12,10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Opacity="0.7"
                                    Text="{Binding EmptyPlaceholderText, Mode=OneWay}"
                                    TextWrapping="Wrap"
                                    TextAlignment="Center" />
                            </Grid>
                        </Grid>

                        <VisualStateManager.VisualStateGroups>

                            <VisualStateGroup x:Name="ExpansionStates">

                                <VisualState x:Name="NoExpansion">
                                    <VisualState.Setters>
                                        <Setter Target="ItemDecoratorPresenter.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="NoExpansionWithPadding">
                                    <VisualState.Setters>
                                        <Setter Target="ItemDecoratorPresenter.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="NoChildren">
                                    <VisualState.Setters>
                                        <Setter Target="ItemDecoratorPresenter.Visibility" Value="Visible" />
                                        <!--  Empty folder: no children to group, so no guide.  -->
                                        <Setter Target="DepthGuide.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>

                                <!--
                                    Empty folder (or empty Pinned/Playlists section) — expanded:
                                    chevron points down, drop-target placeholder visible. Guide
                                    is hidden because there are no children to group.
                                -->
                                <VisualState x:Name="NoChildrenWithPlaceholderExpanded">
                                    <VisualState.Setters>
                                        <Setter Target="ItemDecoratorPresenter.Visibility" Value="Visible" />
                                        <Setter Target="ExpandCollapseChevron.Visibility" Value="Visible" />
                                        <Setter Target="EmptyPlaceholder.Visibility" Value="Visible" />
                                        <Setter Target="DepthGuide.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="NoChildrenWithPlaceholderCollapsed">
                                    <VisualState.Setters>
                                        <Setter Target="ItemDecoratorPresenter.Visibility" Value="Visible" />
                                        <Setter Target="ExpandCollapseChevron.Visibility" Value="Visible" />
                                        <Setter Target="DepthGuide.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="Expanded">
                                    <VisualState.Setters>
                                        <Setter Target="ChildrenPresenter.Visibility" Value="Visible" />
                                        <Setter Target="ExpandCollapseChevron.Visibility" Value="Visible" />
                                        <Setter Target="ItemDecoratorPresenter.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="Collapsed">
                                    <VisualState.Setters>
                                        <Setter Target="ExpandCollapseChevron.Visibility" Value="Visible" />
                                        <Setter Target="ItemDecoratorPresenter.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>

                                <!--
                                    Top-level section labels ("Your Library", "Playlists", "Made For You").
                                    Chromeless, non-interactive-looking tertiary caption. Driven by
                                    SidebarItemModel.IsSectionHeader; SidebarItem.UpdateExpansionState
                                    routes here instead of the Expanded/Collapsed path. Expand/collapse
                                    still works — SectionHeaderCollapsed simply hides ChildrenPresenter.
                                -->
                                <VisualState x:Name="SectionHeaderExpanded">
                                    <VisualState.Setters>
                                        <Setter Target="ElementBorder.Height" Value="28" />
                                        <Setter Target="ElementGrid.Background" Value="Transparent" />
                                        <Setter Target="ElementGrid.BorderBrush" Value="Transparent" />
                                        <Setter Target="SelectionIndicator.Visibility" Value="Collapsed" />
                                        <Setter Target="IconPresenter.Visibility" Value="Collapsed" />
                                        <Setter Target="ExpandCollapseChevron.Visibility" Value="Collapsed" />
                                        <Setter Target="ItemDecoratorPresenter.Visibility" Value="Visible" />
                                        <Setter Target="ItemNameTextBlock.Margin" Value="8,0,12,0" />
                                        <Setter Target="ItemNameTextBlock.FontSize" Value="11" />
                                        <Setter Target="ItemNameTextBlock.FontWeight" Value="SemiBold" />
                                        <Setter Target="ItemNameTextBlock.CharacterSpacing" Value="50" />
                                        <Setter Target="ItemNameTextBlock.Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <Setter Target="ItemNameTextBlock.Opacity" Value="0.7" />
                                        <Setter Target="ChildrenPresenter.Visibility" Value="Visible" />
                                        <Setter Target="EmptyPlaceholder.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="SectionHeaderExpandedWithPlaceholder">
                                    <VisualState.Setters>
                                        <Setter Target="ElementBorder.Height" Value="28" />
                                        <Setter Target="ElementGrid.Background" Value="Transparent" />
                                        <Setter Target="ElementGrid.BorderBrush" Value="Transparent" />
                                        <Setter Target="SelectionIndicator.Visibility" Value="Collapsed" />
                                        <Setter Target="IconPresenter.Visibility" Value="Collapsed" />
                                        <Setter Target="ExpandCollapseChevron.Visibility" Value="Collapsed" />
                                        <Setter Target="ItemDecoratorPresenter.Visibility" Value="Visible" />
                                        <Setter Target="ItemNameTextBlock.Margin" Value="8,0,12,0" />
                                        <Setter Target="ItemNameTextBlock.FontSize" Value="11" />
                                        <Setter Target="ItemNameTextBlock.FontWeight" Value="SemiBold" />
                                        <Setter Target="ItemNameTextBlock.CharacterSpacing" Value="50" />
                                        <Setter Target="ItemNameTextBlock.Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <Setter Target="ItemNameTextBlock.Opacity" Value="0.7" />
                                        <Setter Target="ChildrenPresenter.Visibility" Value="Visible" />
                                        <Setter Target="EmptyPlaceholder.Visibility" Value="Visible" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="SectionHeaderCollapsed">
                                    <VisualState.Setters>
                                        <Setter Target="ElementBorder.Height" Value="28" />
                                        <Setter Target="ElementGrid.Background" Value="Transparent" />
                                        <Setter Target="ElementGrid.BorderBrush" Value="Transparent" />
                                        <Setter Target="SelectionIndicator.Visibility" Value="Collapsed" />
                                        <Setter Target="IconPresenter.Visibility" Value="Collapsed" />
                                        <Setter Target="ExpandCollapseChevron.Visibility" Value="Collapsed" />
                                        <Setter Target="ItemDecoratorPresenter.Visibility" Value="Visible" />
                                        <Setter Target="ItemNameTextBlock.Margin" Value="8,0,12,0" />
                                        <Setter Target="ItemNameTextBlock.FontSize" Value="11" />
                                        <Setter Target="ItemNameTextBlock.FontWeight" Value="SemiBold" />
                                        <Setter Target="ItemNameTextBlock.CharacterSpacing" Value="50" />
                                        <Setter Target="ItemNameTextBlock.Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <Setter Target="ItemNameTextBlock.Opacity" Value="0.7" />
                                        <Setter Target="ChildrenPresenter.Visibility" Value="Collapsed" />
                                        <Setter Target="EmptyPlaceholder.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualStateGroup.Transitions>
                                    <VisualTransition From="Collapsed" To="Expanded">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ChildrenPresenter" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames
                                                EnableDependentAnimation="True"
                                                Storyboard.TargetName="ChildrenPresenter"
                                                Storyboard.TargetProperty="MaxHeight">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                                <SplineDoubleKeyFrame
                                                    KeySpline="0.1,0.9 0.2,1.0"
                                                    KeyTime="0:0:0.35"
                                                    Value="{Binding ChildrenPresenterHeight, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualTransition>

                                    <VisualTransition From="Expanded">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ChildrenPresenter" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames
                                                EnableDependentAnimation="True"
                                                Storyboard.TargetName="ChildrenPresenter"
                                                Storyboard.TargetProperty="MaxHeight">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="{Binding ChildrenPresenterHeight, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                                                <SplineDoubleKeyFrame
                                                    KeySpline="0.1,0.9 0.2,1.0"
                                                    KeyTime="0:0:0.35"
                                                    Value="0" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualTransition>

                                    <VisualTransition From="NoExpansion" To="Expanded">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ChildrenPresenter" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames
                                                EnableDependentAnimation="True"
                                                Storyboard.TargetName="ChildrenPresenter"
                                                Storyboard.TargetProperty="MaxHeight">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                                <SplineDoubleKeyFrame
                                                    KeySpline="0.1,0.9 0.2,1.0"
                                                    KeyTime="0:0:0.35"
                                                    Value="{Binding ChildrenPresenterHeight, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                                            </DoubleAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualTransition>

                                    <VisualTransition From="NoExpansion" To="Compact">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ChildrenPresenter" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames
                                                EnableDependentAnimation="True"
                                                Storyboard.TargetName="ChildrenPresenter"
                                                Storyboard.TargetProperty="MaxHeight">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                                <SplineDoubleKeyFrame
                                                    KeySpline="0.1,0.9 0.2,1.0"
                                                    KeyTime="0:0:0.35"
                                                    Value="{Binding ChildrenPresenterHeight, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualTransition>
                                </VisualStateGroup.Transitions>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="ExpansionIconStates">
                                <VisualState x:Name="ExpandedIconNormal">
                                    <VisualState.Setters>
                                        <Setter Target="ExpandCollapseChevron.(AnimatedIcon.State)" Value="NormalOn" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="ExpandedIconPressed">
                                    <VisualState.Setters>
                                        <Setter Target="ExpandCollapseChevron.(AnimatedIcon.State)" Value="PressedOn" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CollapsedIconNormal">
                                    <VisualState.Setters>
                                        <Setter Target="ExpandCollapseChevron.(AnimatedIcon.State)" Value="NormalOff" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="CollapsedIconPressed">
                                    <VisualState.Setters>
                                        <Setter Target="ExpandCollapseChevron.(AnimatedIcon.State)" Value="PressedOff" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="SelectionStates">
                                <VisualState x:Name="Unselected" />
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Target="SelectionIndicator.Opacity" Value="1" />
                                        <Setter Target="ElementGrid.BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
                                        <Setter Target="ElementGrid.Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="PointerStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="NormalSelected">
                                    <VisualState.Setters>
                                        <Setter Target="ElementGrid.Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
                                        <Setter Target="ElementGrid.BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="ElementGrid.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Setter Target="ElementGrid.BorderBrush" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOverSelected">
                                    <VisualState.Setters>
                                        <Setter Target="ElementGrid.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                                        <Setter Target="ElementGrid.BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="ElementGrid.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                        <Setter Target="ElementGrid.BorderBrush" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PressedSelected">
                                    <VisualState.Setters>
                                        <Setter Target="ElementGrid.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                                        <Setter Target="ElementGrid.BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState x:Name="DragInsertAbove">
                                    <VisualState.Setters>
                                        <Setter Target="DragTargetIndicator.Visibility" Value="Visible" />
                                        <Setter Target="DragTargetIndicator.VerticalAlignment" Value="Top" />
                                        <Setter Target="ElementGrid.Margin" Value="4,-2" />
                                        <Setter Target="ElementGrid.Height" Value="34" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="DragInsertBelow">
                                    <VisualState.Setters>
                                        <Setter Target="DragTargetIndicator.Visibility" Value="Visible" />
                                        <Setter Target="DragTargetIndicator.VerticalAlignment" Value="Bottom" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="DragOnTop">
                                    <VisualState.Setters>
                                        <Setter Target="ElementGrid.Background" Value="{ThemeResource AccentFillColorTertiaryBrush}" />
                                        <Setter Target="ElementGrid.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                        <Setter Target="ElementGrid.BorderThickness" Value="2" />
                                        <Setter Target="SelectionIndicator.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="DragAvailable">
                                    <VisualState.Setters>
                                        <Setter Target="ElementGrid.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Setter Target="ElementGrid.BorderBrush" Value="{ThemeResource AccentFillColorTertiaryBrush}" />
                                        <Setter Target="ElementGrid.BorderThickness" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>

                            <VisualStateGroup x:Name="DisplayModes">
                                <!--
                                    NonCompact must explicitly restore every property Compact
                                    touches. WinUI 3's VSM does not reliably roll back Visibility
                                    (and some layout properties) when returning to an empty state,
                                    so without these setters a row that transitioned Compact → Expanded
                                    keeps its text hidden and icon centered. Values are the template's
                                    literal base values. ExpandCollapseChevron / ChildrenPresenter
                                    Visibility are intentionally NOT listed here — they're owned by
                                    the ExpansionStates group, and duplicating them would race.
                                -->
                                <VisualState x:Name="NonCompact">
                                    <VisualState.Setters>
                                        <Setter Target="RootPanel.MaxWidth" Value="Infinity" />
