<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Diagnostics.UiHealthOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        x:Name="RootBorder"
        Padding="8,4"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
        BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
        BorderThickness="1"
        CornerRadius="4"
        Margin="0,32,8,0"
        Opacity="0.9">
        <StackPanel Spacing="2">
            <!-- Compact stats -->
            <TextBlock
                x:Name="FpsText"
                FontFamily="Consolas"
                FontSize="11"
                Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" />
            <TextBlock
                x:Name="FrameText"
                FontFamily="Consolas"
                FontSize="11"
                Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" />
            <TextBlock
                x:Name="StallText"
                FontFamily="Consolas"
                FontSize="11"
                Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}" />

            <!-- Buttons row -->
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                <Button
                    x:Name="ExpandButton"
                    Content="Graph"
                    FontSize="10"
                    Padding="6,2"
                    MinHeight="0"
                    MinWidth="0"
                    Click="ExpandButton_Click" />
                <Button
                    x:Name="CopyButton"
                    Content="Copy"
                    FontSize="10"
                    Padding="6,2"
                    MinHeight="0"
                    MinWidth="0"
                    Click="CopyButton_Click" />
                <Button
                    x:Name="ResetButton"
                    Content="Reset"
                    FontSize="10"
                    Padding="6,2"
                    MinHeight="0"
                    MinWidth="0"
                    Click="ResetButton_Click" />
            </StackPanel>

            <!-- Expandable graph area -->
            <Canvas
                x:Name="GraphCanvas"
                Width="280"
                Height="100"
                Visibility="Collapsed"
                Margin="0,4,0,0"
                Background="#20808080" />

            <!-- Graph legend (shown when expanded) -->
            <StackPanel x:Name="GraphLegend" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Border Width="8" Height="8" Background="#4CAF50" CornerRadius="1" VerticalAlignment="Center" />
                    <TextBlock Text="&lt;16ms" FontSize="9" FontFamily="Consolas" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Border Width="8" Height="8" Background="#FFC107" CornerRadius="1" VerticalAlignment="Center" />
                    <TextBlock Text="&lt;50ms" FontSize="9" FontFamily="Consolas" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Border Width="8" Height="8" Background="#F44336" CornerRadius="1" VerticalAlignment="Center" />
                    <TextBlock Text="&gt;50ms" FontSize="9" FontFamily="Consolas" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
