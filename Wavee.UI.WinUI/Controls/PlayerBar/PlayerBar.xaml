<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.PlayerBar.PlayerBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    xmlns:toolkit="using:CommunityToolkit.WinUI"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Styles/PlayerBarStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToPlayPauseGlyphConverter x:Key="PlayPauseGlyphConverter" />
            <converters:VolumeToGlyphConverter x:Key="VolumeGlyphConverter" />
            <converters:RepeatModeToGlyphConverter x:Key="RepeatGlyphConverter" />
            <converters:RepeatModeToCheckedConverter x:Key="RepeatCheckedConverter" />
            <converters:RepeatModeToSymbolConverter x:Key="RepeatSymbolConverter" />
            <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Shadow wrapper (must be separate from CornerRadius to avoid clipping) -->
    <Border
        Visibility="{x:Bind ViewModel.HasTrack, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
        <toolkit:Effects.Shadow>
            <media:AttachedCardShadow BlurRadius="32"  Offset="0,-2" Opacity="0.4" Color="Black" CornerRadius="8" />
        </toolkit:Effects.Shadow>

        <!-- Inner border with visual styling -->
        <Border
            CornerRadius="4"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <Border.Background>
                <AcrylicBrush
                    x:Name="PlayerBarTintBrush"
                    TintColor="#C05040"
                    TintOpacity="0.88"  TintLuminosityOpacity="0.25"
                    FallbackColor="{ThemeResource SolidBackgroundFillColorBase}"/>
            </Border.Background>

        <!-- Single-row layout -->
        <Grid Height="56" Padding="0,0,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />           <!-- Album art + track info -->
                <ColumnDefinition Width="Auto" />           <!-- Transport controls -->
                <ColumnDefinition Width="Auto" />           <!-- Current time -->
                <ColumnDefinition Width="*" />              <!-- Progress slider -->
                <ColumnDefinition Width="Auto" />           <!-- Duration -->
                <ColumnDefinition Width="Auto" />           <!-- Secondary controls + volume -->
            </Grid.ColumnDefinitions>

            <!-- Buffering indicator (full width, top edge) -->
            <ProgressBar
                Grid.ColumnSpan="6"
                IsIndeterminate="True"
                Visibility="{x:Bind ViewModel.IsBuffering, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                Height="2" Margin="0"
                VerticalAlignment="Top"
                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />

            <!-- Column 0: Album Art + Track Info -->
            <Grid
                Grid.Column="0"
                VerticalAlignment="Center"
                MinWidth="200"
                MaxWidth="280">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Album Art (48x48) — tap to expand in sidebar -->
                <Grid
                    Width="48"
                    Height="48"
                    Margin="4"
                    CornerRadius="4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Tapped="AlbumArt_Tapped"
                    Visibility="{x:Bind ViewModel.IsAlbumArtExpanded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <animations:Implicit.ShowAnimations>
                        <animations:OpacityAnimation Duration="0:0:0.2" From="0" To="1" />
                        <animations:ScaleAnimation Duration="0:0:0.2" From="0.8,0.8,1" To="1,1,1" />
                    </animations:Implicit.ShowAnimations>
                    <animations:Implicit.HideAnimations>
                        <animations:OpacityAnimation Duration="0:0:0.15" From="1" To="0" />
                        <animations:ScaleAnimation Duration="0:0:0.15" From="1,1,1" To="0.8,0.8,1" />
                    </animations:Implicit.HideAnimations>
                    <Image
                        Width="48"
                        Height="48"
                        Source="{x:Bind ViewModel.AlbumArt, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=48}"
                        Stretch="UniformToFill"
                        behaviors:ImageFallbackBehavior.HideOnError="True"
                        behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                        behaviors:ImageFallbackBehavior.DecodePixelWidth="96"/>
                    <FontIcon
                        Glyph="&#xE8D6;"
                        FontSize="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.AlbumArt, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}" />
                </Grid>

                <!-- Track info -->
                <StackPanel
                    Grid.Column="1"
                    Margin="8,0,16,0"
                    VerticalAlignment="Center"
                    Spacing="0">
                    <HyperlinkButton
                        Padding="0" MinHeight="0" MinWidth="0"
                        Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                        Click="TrackTitle_Click">
                        <TextBlock
                            Text="{x:Bind ViewModel.TrackTitle, Mode=OneWay}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            MaxLines="1"
                            TextWrapping="WrapWholeWords"
                            TextTrimming="CharacterEllipsis" />
                    </HyperlinkButton>
                    <ctk:MetadataControl
                        Items="{x:Bind ViewModel.ArtistMetadataItems, Mode=OneWay}"
                        Separator=", ">
                        <ctk:MetadataControl.TextBlockStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="Opacity" Value="0.6" />
                                <Setter Property="Foreground" Value="{ThemeResource ApplicationForegroundThemeBrush}" />
                                <Setter Property="MaxLines" Value="1" />
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            </Style>
                        </ctk:MetadataControl.TextBlockStyle>
                    </ctk:MetadataControl>
                    <!-- Remote device indicator -->
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="4"
                        Visibility="{x:Bind ViewModel.IsPlayingRemotely, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <FontIcon Glyph="&#xE703;" FontSize="9" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.ActiveDeviceName, Mode=OneWay, FallbackValue='Remote device'}"
                            FontSize="10"
                            Opacity="0.7"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Heart button (after track info) -->
                <controls:HeartButton x:Name="PlayerHeartButton"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Width="28" Height="28"
                                       Margin="0,0,4,0"/>
            </Grid>

            <!-- Column 1: Transport Controls (prev, play/pause, next) -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Spacing="0"
                Margin="0,0,12,0">
                <Button x:Uid="Controls_PlayerBar_PlayerBar__Button_1"
                    Style="{StaticResource TransparentButtonStyle}"
                    Width="32" Height="32" Padding="0"
                    Command="{x:Bind ViewModel.PreviousCommand}"
                    ToolTipService.ToolTip="Previous">
                    <FontIcon Glyph="&#xF8AC;" FontSize="14" />
                </Button>
                <Button x:Uid="Controls_PlayerBar_PlayerBar__Button_2"
                    Style="{StaticResource TransparentButtonStyle}"
                    Width="36" Height="36" Padding="0"
                    Command="{x:Bind ViewModel.PlayPauseCommand}"
                    ToolTipService.ToolTip="Play/Pause">
                    <Grid>
                        <FontIcon
                            FontSize="18"
                            Glyph="{x:Bind ViewModel.IsPlaying, Mode=OneWay, Converter={StaticResource PlayPauseGlyphConverter}}"
                            Visibility="{x:Bind ViewModel.IsBuffering, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                        <ProgressRing
                            Width="20" Height="20"
                            IsActive="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsBuffering, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </Grid>
                </Button>
                <Button x:Uid="Controls_PlayerBar_PlayerBar__Button_3"
                    Style="{StaticResource TransparentButtonStyle}"
                    Width="32" Height="32" Padding="0"
                    Command="{x:Bind ViewModel.NextCommand}"
                    ToolTipService.ToolTip="Next">
                    <FontIcon Glyph="&#xF8AD;" FontSize="14" />
                </Button>
            </StackPanel>

            <!-- Column 2: Current Time -->
            <TextBlock
                Grid.Column="2"
                Text="{x:Bind ViewModel.PositionText, Mode=OneWay}"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Margin="4,0,8,0" />

            <!-- Column 3: Progress Slider (inline) -->
            <Slider x:Name="ProgressSlider"
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Value="{x:Bind ViewModel.Position, Mode=TwoWay}"
                    Maximum="{x:Bind ViewModel.SliderMaximum, Mode=OneWay}"
                    IsThumbToolTipEnabled="False"
                    Visibility="{x:Bind ViewModel.IsBuffering, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                    PointerPressed="ProgressSlider_PointerPressed"
                    PointerReleased="ProgressSlider_PointerReleased"
                    PointerCaptureLost="ProgressSlider_PointerCaptureLost"
                    Style="{StaticResource PlayerProgressSliderStyle}" />

            <!-- Column 4: Duration -->
            <TextBlock
                Grid.Column="4"
                Text="{x:Bind ViewModel.DurationText, Mode=OneWay}"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Opacity="0.6"
                Margin="8,0,12,0" />

            <!-- Column 5: Secondary Controls + Volume -->
            <StackPanel
                Grid.Column="5"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Spacing="0">

                <!-- Shuffle -->
                <ToggleButton x:Uid="Controls_PlayerBar_PlayerBar__ToggleButton_4"
                    Style="{StaticResource SubtleToggleButtonStyle}"
                    Width="32" Height="32" Padding="0"
                    IsChecked="{x:Bind ViewModel.IsShuffle, Mode=OneWay}"
                    Command="{x:Bind ViewModel.ToggleShuffleCommand}"
                    ToolTipService.ToolTip="Shuffle">
                    <FontIcon Glyph="&#xE8B1;" FontSize="14" />
                </ToggleButton>

                <!-- Repeat -->
                <ToggleButton x:Uid="Controls_PlayerBar_PlayerBar__ToggleButton_5"
                    Style="{StaticResource SubtleToggleButtonStyle}"
                    Width="32" Height="32" Padding="0"
                    IsChecked="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatCheckedConverter}}"
                    Command="{x:Bind ViewModel.ToggleRepeatCommand}"
                    ToolTipService.ToolTip="Repeat">
                    <FontIcon Glyph="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatGlyphConverter}}" FontSize="14" />
                </ToggleButton>

                <!-- Volume icon -->
                <Button x:Uid="Controls_PlayerBar_PlayerBar__Button_6"
                    Style="{StaticResource TransparentButtonStyle}"
                    Width="32" Height="32" Padding="0"
                    Command="{x:Bind ViewModel.ToggleMuteCommand}"
                    IsEnabled="{x:Bind ViewModel.IsVolumeRestricted, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                    ToolTipService.ToolTip="Volume">
                    <FontIcon
                        FontSize="14"
                        Glyph="{x:Bind ViewModel.Volume, Mode=OneWay, Converter={StaticResource VolumeGlyphConverter}}" />
                </Button>

                <!-- Volume slider -->
                <Slider
                    x:Name="VolumeSlider"
                    Width="90"
                    VerticalAlignment="Center"
                    Minimum="0"
                    Maximum="100"
                    Value="{x:Bind ViewModel.Volume, Mode=TwoWay}"
                    IsEnabled="{x:Bind ViewModel.IsVolumeRestricted, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                    IsThumbToolTipEnabled="False" />

                <!-- Queue -->
                <ToggleButton x:Uid="Controls_PlayerBar_PlayerBar__ToggleButton_7"
                    Style="{StaticResource SubtleToggleButtonStyle}"
                    Width="32" Height="32" Padding="0"
                    IsChecked="{x:Bind ViewModel.IsQueuePanelActive, Mode=OneWay}"
                    Command="{x:Bind ViewModel.ToggleQueuePanelCommand}"
                    ToolTipService.ToolTip="Queue">
                    <FontIcon Glyph="&#xE142;" FontSize="14" />
                </ToggleButton>

                <!-- Details -->
                <ToggleButton x:Uid="Controls_PlayerBar_PlayerBar__ToggleButton_8"
                    Style="{StaticResource SubtleToggleButtonStyle}"
                    Width="32" Height="32" Padding="0"
                    IsChecked="{x:Bind ViewModel.IsDetailsPanelActive, Mode=OneWay}"
                    Command="{x:Bind ViewModel.ToggleDetailsPanelCommand}"
                    ToolTipService.ToolTip="Details">
                    <FontIcon Glyph="&#xE946;" FontSize="14" />
                </ToggleButton>

                <!-- Lyrics -->
                <ToggleButton x:Uid="Controls_PlayerBar_PlayerBar__ToggleButton_9"
                    Style="{StaticResource SubtleToggleButtonStyle}"
                    Width="32" Height="32" Padding="0"
                    IsChecked="{x:Bind ViewModel.IsLyricsPanelActive, Mode=OneWay}"
                    Command="{x:Bind ViewModel.ToggleLyricsPanelCommand}"
                    ToolTipService.ToolTip="Lyrics">
                    <FontIcon Glyph="&#xED1E;" FontSize="14" />
                </ToggleButton>

                <!-- Friends Activity -->
                <ToggleButton x:Uid="Controls_PlayerBar_PlayerBar__ToggleButton_10"
                    Style="{StaticResource SubtleToggleButtonStyle}"
                    Width="32" Height="32" Padding="0"
                    IsChecked="{x:Bind ViewModel.IsFriendsPanelActive, Mode=OneWay}"
                    Command="{x:Bind ViewModel.ToggleFriendsPanelCommand}"
                    ToolTipService.ToolTip="Friends Activity">
                    <FontIcon Glyph="&#xE716;" FontSize="14" />
                </ToggleButton>
            </StackPanel>
        </Grid>
        </Border>
    </Border>
</UserControl>