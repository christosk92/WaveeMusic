<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Track.TrackCell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:controls1="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Padding="8,4" ColumnSpacing="12" Height="56"
          Background="Transparent" CornerRadius="4">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="PlaybackStates">
                <VisualState x:Name="NotPlaying"/>
                <VisualState x:Name="Playing">
                    <VisualState.Setters>
                        <Setter Target="TitleText.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <Setter Target="NowPlayingIndicator.Visibility" Value="Visible"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Paused">
                    <VisualState.Setters>
                        <Setter Target="TitleText.Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <Setter Target="NowPlayingIndicator.Visibility" Value="Visible"/>
                        <Setter Target="NowPlayingIndicator.Opacity" Value="0.5"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
            <VisualStateGroup x:Name="HoverStates">
                <VisualState x:Name="Normal"/>
                <VisualState x:Name="PointerOver">
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Album art / shimmer -->
        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Image x:Name="AlbumArt" Stretch="UniformToFill"
                   behaviors:ImageFallbackBehavior.HideOnError="True"
                   behaviors:ImageFallbackBehavior.FadeInOnLoad="True"/>
        </Border>
        <!-- Now playing indicator (overlays album art, theme-aware) -->
        <Border x:Name="NowPlayingIndicator" Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" Visibility="Collapsed"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Opacity="0.85">
            <FontIcon Glyph="&#xE995;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <controls1:Shimmer x:Name="ArtShimmer" Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                          Visibility="Collapsed"/>

        <!-- Track info / shimmer -->
        <StackPanel x:Name="InfoPanel" Grid.Column="1" VerticalAlignment="Center" Spacing="2">
            <Grid ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleText" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" MaxLines="1" FontSize="13"/>
                <Border x:Name="ExplicitBadge" Grid.Column="1" Visibility="Collapsed"
                        Background="{ThemeResource TextFillColorTertiaryBrush}"
                        CornerRadius="2" Padding="4,1" VerticalAlignment="Center">
                    <TextBlock Text="E" FontSize="9" FontWeight="Bold"/>
                </Border>
            </Grid>
            <TextBlock x:Name="SubtitleText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
        </StackPanel>
        <StackPanel x:Name="InfoShimmer" Grid.Column="1" VerticalAlignment="Center" Spacing="6"
                    Visibility="Collapsed">
            <controls1:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
            <controls1:Shimmer Width="110" Height="12" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- Duration (only when loaded) -->
        <TextBlock x:Name="DurationText" Grid.Column="2"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   VerticalAlignment="Center" Padding="6,0"/>
    </Grid>
</UserControl>
