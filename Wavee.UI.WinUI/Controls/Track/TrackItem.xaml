<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Track.TrackItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls1="using:CommunityToolkit.WinUI.Controls"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    mc:Ignorable="d">

    <UserControl.Resources>
    </UserControl.Resources>

    <Grid>
        <!-- ═══════════════ COMPACT MODE (grid cells: artist top tracks, search) ═══════════════ -->
        <Border x:Name="CompactBorder" Visibility="Visible"
                CornerRadius="6" BorderThickness="0" Background="Transparent">
        <Grid>
        <Grid x:Name="CompactRoot"
              Padding="8,4" ColumnSpacing="12" Height="56">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Album art stack (art + now-playing overlay + hover play button) -->
            <Grid Grid.Column="0" Width="48" Height="48">
                <Border x:Name="CompactAlbumArtBorder" CornerRadius="4"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid>
                        <FontIcon x:Name="CompactArtPlaceholder"
                                  Glyph="&#xE8D6;" FontSize="18" Opacity="0.35"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image x:Name="CompactAlbumArt" Stretch="UniformToFill"
                               behaviors:ImageFallbackBehavior.HideOnError="True"
                               behaviors:ImageFallbackBehavior.FadeInOnLoad="True"/>
                    </Grid>
                </Border>

                <Border x:Name="CompactNowPlaying" CornerRadius="4"
                        Background="#D9000000" Visibility="Collapsed">
                    <cards:LottieEqualizer x:Name="CompactNowPlayingEqualizer"
                                           IconSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                </Border>

                <ProgressRing x:Name="CompactBufferingRing"
                              Width="24" Height="24"
                              IsActive="False" Visibility="Collapsed"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Button x:Name="CompactPlayButton"
                        Visibility="Collapsed" Opacity="0"
                        Width="48" Height="48" CornerRadius="4"
                        Padding="0" Background="#CC000000" BorderThickness="0"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <playback:PlaybackActionContent x:Name="CompactPlayContent"
                                                   IconSize="20"
                                                   ActionForeground="White"/>
                </Button>

                <controls1:Shimmer x:Name="CompactArtShimmer" Width="48" Height="48"
                                   CornerRadius="4" Visibility="Collapsed"/>
            </Grid>

            <StackPanel x:Name="CompactInfoPanel" Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                <Grid ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CompactTitle" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" MaxLines="1" FontSize="13"/>
                    <Border x:Name="CompactExplicit" Grid.Column="1" Visibility="Collapsed"
                            Background="{ThemeResource TextFillColorTertiaryBrush}"
                            CornerRadius="2" Padding="4,1" VerticalAlignment="Center">
                        <TextBlock Text="E" FontSize="9" FontWeight="Bold"/>
                    </Border>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="0">
                    <TextBlock x:Name="CompactSubtitle"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                    <TextBlock x:Name="CompactVideoSeparator" Text=" · "
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="Collapsed"/>
                    <FontIcon x:Name="CompactVideoIcon" Glyph="&#xE714;" FontSize="9"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              VerticalAlignment="Center" Margin="0,0,3,0"
                              Visibility="Collapsed"/>
                    <TextBlock x:Uid="Controls_Track_TrackItem__TextBlock_1" x:Name="CompactVideoLabel" Text="Music Video"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="CompactInfoShimmer" Grid.Column="1" VerticalAlignment="Center"
                        Spacing="6" Visibility="Collapsed">
                <controls1:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                <controls1:Shimmer Width="110" Height="12" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Heart button (left of duration) -->
            <controls:HeartButton x:Name="CompactHeartButton" Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Width="28" Height="28" Visibility="Collapsed"/>

            <TextBlock x:Name="CompactDuration" Grid.Column="3"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center" Padding="6,0"/>
        </Grid>
        <!-- Selection indicator: left-edge accent bar, shown when IsSelected=true.
             Declared last so it paints ON TOP of CompactRoot's 48-px album art. -->
        <Border x:Name="CompactSelectionIndicator"
                Width="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Margin="0,10"
                CornerRadius="2"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                Opacity="0"
                IsHitTestVisible="False"/>
        </Grid>
        </Border>

        <!-- ═══════════════ ROW MODE (table rows: playlists, albums, liked songs) ═══════════════ -->
        <Border x:Name="RowRoot" Visibility="Collapsed"
                Padding="8,8" CornerRadius="6"
                Background="Transparent">
            <Grid>
                <Grid x:Name="RowContentGrid" ColumnSpacing="0">
                    <!--
                        Artist is rendered as a subline under the Title (column 3) rather
                        than occupying its own grid column. Saves ~180 px per row and
                        matches the Spotify/Apple Music row layout.
                    -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="RowIndexColDef" Width="40"/>
                        <ColumnDefinition x:Name="RowHeartColDef" Width="32"/>
                        <ColumnDefinition x:Name="RowArtColDef" Width="42"/>
                        <ColumnDefinition Width="*" MinWidth="120" MaxWidth="640"/>
                        <ColumnDefinition x:Name="RowAlbumColDef" Width="180"/>
                        <ColumnDefinition x:Name="RowDateColDef" Width="120"/>
                        <ColumnDefinition x:Name="RowPlayCountColDef" Width="0"/>
                        <ColumnDefinition x:Name="RowDurationColDef" Width="60"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row number / Now Playing icon / Play button area -->
                    <Grid Grid.Column="0">
                        <TextBlock x:Name="RowIndexText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <cards:LottieEqualizer x:Name="RowNowPlayingEqualizer"
                                               IconSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                        <ProgressRing x:Name="RowBufferingRing"
                                      Width="16" Height="16"
                                      IsActive="False" Visibility="Collapsed"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button x:Name="RowPlayButton"
                                Visibility="Collapsed"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <playback:PlaybackActionContent x:Name="RowPlayContent"
                                                           IconSize="14"
                                                           ActionForeground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Heart button -->
                    <controls:HeartButton x:Name="RowHeartButton" Grid.Column="1"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Width="28" Height="28" Visibility="Collapsed"/>

                    <!-- Album thumbnail (34x34) -->
                    <Border x:Name="RowAlbumArtBorder" Grid.Column="2" Width="34" Height="34" CornerRadius="4"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid>
                            <FontIcon x:Name="RowArtPlaceholder" Glyph="&#xE8D6;" FontSize="16" Opacity="0.3"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="RowAlbumArt" Stretch="UniformToFill"
                                   behaviors:ImageFallbackBehavior.HideOnError="True"
                                   behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                   behaviors:ImageFallbackBehavior.DecodePixelWidth="68"/>
                        </Grid>
                    </Border>

                    <!-- Title stacked over Artist subline -->
                    <StackPanel Grid.Column="3" Orientation="Vertical" Spacing="0"
                                Margin="12,0,8,0" VerticalAlignment="Center">
                        <!-- 2-column Grid (not StackPanel) so RowTitle actually
                             gets a bounded measure width and TextTrimming kicks
                             in. Horizontal StackPanel hands children infinite
                             width and the title bleeds into the Album column. -->
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="RowTitle"
                                       Grid.Column="0"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"/>
                            <Border x:Name="RowExplicit" Grid.Column="1" Visibility="Collapsed"
                                    Background="{ThemeResource TextFillColorSecondaryBrush}"
                                    CornerRadius="2" Padding="4,1" VerticalAlignment="Center">
                                <TextBlock Text="E" FontSize="9" FontWeight="Bold"
                                           Foreground="{ThemeResource SolidBackgroundFillColorBaseBrush}"/>
                            </Border>
                        </Grid>
                        <HyperlinkButton x:Name="RowArtistLink"
                                         Padding="0,0,0,0"
                                         Margin="0,-2,0,0"
                                         HorizontalAlignment="Left"
                                         Visibility="Collapsed">
                            <HyperlinkButton.ContentTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                </DataTemplate>
                            </HyperlinkButton.ContentTemplate>
                        </HyperlinkButton>
                    </StackPanel>

                    <!-- Album (clickable) -->
                    <HyperlinkButton x:Name="RowAlbumLink" Grid.Column="4"
                                     Padding="0" VerticalAlignment="Center">
                        <HyperlinkButton.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1"/>
                            </DataTemplate>
                        </HyperlinkButton.ContentTemplate>
                    </HyperlinkButton>

                    <!-- Date Added -->
                    <TextBlock x:Name="RowDateAdded" Grid.Column="5"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Play count (album page) -->
                    <TextBlock x:Name="RowPlayCount" Grid.Column="6"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>

                    <!-- Duration -->
                    <TextBlock x:Name="RowDuration" Grid.Column="7"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Shimmer overlay for lazy/loading rows. Mirrors RowContentGrid's 8 columns
                     so individual shimmer rectangles align under the column headers. The
                     conditional column widths are kept in sync with the real row in
                     ApplyShowFlags (TrackItem.xaml.cs). -->
                <Grid x:Name="RowShimmerOverlay" VerticalAlignment="Center"
                      Visibility="Collapsed"
                      ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition x:Name="ShimHeartColDef" Width="32"/>
                        <ColumnDefinition x:Name="ShimArtColDef" Width="42"/>
                        <ColumnDefinition Width="*" MinWidth="120" MaxWidth="640"/>
                        <ColumnDefinition x:Name="ShimAlbumColDef" Width="180"/>
                        <ColumnDefinition x:Name="ShimDateColDef" Width="120"/>
                        <ColumnDefinition x:Name="ShimPlayCountColDef" Width="0"/>
                        <ColumnDefinition x:Name="ShimDurationColDef" Width="60"/>
                    </Grid.ColumnDefinitions>
                    <controls1:Shimmer Grid.Column="2" Width="34" Height="34" CornerRadius="4" HorizontalAlignment="Left"/>
                    <StackPanel Grid.Column="3" Spacing="6" VerticalAlignment="Center" Margin="12,0,8,0">
                        <controls1:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                        <controls1:Shimmer Width="100" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <controls1:Shimmer Grid.Column="4" Width="120" Height="12" HorizontalAlignment="Left"/>
                    <controls1:Shimmer Grid.Column="5" Width="80" Height="12" HorizontalAlignment="Left"/>
                    <controls1:Shimmer Grid.Column="7" Width="36" Height="12" HorizontalAlignment="Right"/>
                </Grid>
                <Border x:Name="RowSelectionIndicator"
                        Width="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Margin="0,10"
                        CornerRadius="2"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        Opacity="0"
                        IsHitTestVisible="False"/>
            </Grid>
        </Border>
        <cards:PendingBorderBeam x:Name="PlaybackPendingBeam"
                                 x:Load="False"
                                 Canvas.ZIndex="10"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 CornerRadius="6"
                                 BeamThickness="2"/>
    </Grid>

</UserControl>
