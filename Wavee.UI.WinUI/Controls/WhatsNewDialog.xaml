<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Wavee.UI.WinUI.Controls.WhatsNewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Wavee.UI.WinUI.Data.Models"
    mc:Ignorable="d"
    DefaultButton="None"
    Style="{StaticResource DefaultContentDialogStyle}">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">820</x:Double>
    </ContentDialog.Resources>

    <Grid Width="750" MinHeight="460">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: title + version badge -->
        <StackPanel Grid.Row="0" Spacing="12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Bind ReleaseTitle, Mode=OneTime}"
                           Style="{StaticResource TitleTextBlockStyle}"
                           FontSize="24"/>

                <!-- Version badge -->
                <Border Grid.Column="1"
                        CornerRadius="12"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="v"/>
                        <Run Text="{x:Bind VersionDisplay, Mode=OneTime}"/>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- Developer announcement -->
            <Border x:Name="AnnouncementBorder"
                    CornerRadius="{ThemeResource ControlCornerRadius}"
                    Padding="14,10"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Visibility="{x:Bind HasAnnouncement, Mode=OneTime}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE789;" FontSize="16"
                              Foreground="{StaticResource App.Theme.AccentBrush}"
                              VerticalAlignment="Top" Margin="0,2,0,0"/>
                    <TextBlock Text="{x:Bind Announcement, Mode=OneTime}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Two-column content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Feature list (Notepad-style — title + description, no icons) -->
            <ListView x:Name="FeatureList"
                      Grid.Column="0"
                      ItemsSource="{x:Bind Features, Mode=OneTime}"
                      SelectionMode="Single"
                      SingleSelectionFollowsFocus="True"
                      SelectionChanged="FeatureList_SelectionChanged"
                      Padding="0"
                      Margin="0,0,8,0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="14,12"/>
                        <Setter Property="Margin" Value="0,0,0,2"/>
                        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ChangelogFeature">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Bind Title}"
                                       FontWeight="SemiBold"
                                       FontSize="13"/>
                            <TextBlock Text="{x:Bind ShortDescription}"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       MaxLines="2"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Right: Detail panel (image top, text below, button at bottom) -->
            <Grid Grid.Column="1" Padding="16,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel" Spacing="16">
                        <!-- Feature image (top, like Notepad) -->
                        <Border CornerRadius="8"
                                Visibility="Collapsed"
                                x:Name="DetailImageBorder"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Image x:Name="DetailImage"
                                   MaxHeight="240"
                                   Stretch="Uniform"/>
                        </Border>

                        <!-- Detail title -->
                        <TextBlock x:Name="DetailTitle"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>

                        <!-- Detail description -->
                        <TextBlock x:Name="DetailDescription"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   LineHeight="22"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer: release link + CTA button -->
                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <HyperlinkButton Grid.Column="0"
                                     Content="View full changelog on GitHub"
                                     VerticalAlignment="Center"
                                     Padding="0"
                                     Visibility="{x:Bind HasReleaseUrl, Mode=OneTime}"
                                     Click="ReleaseLink_Click"/>

                    <Button Grid.Column="1"
                            Content="Start exploring"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="24,8"
                            Click="GotIt_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ContentDialog>
