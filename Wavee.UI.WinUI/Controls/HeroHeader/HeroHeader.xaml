<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.HeroHeader.HeroHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" MinHeight="300">
        <!-- Image rendered via composition with gradient opacity mask + scale animation -->
        <Border x:Name="ImageBorder"/>

        <!-- Optional overlay content (artist info, buttons, etc.) -->
        <ContentPresenter x:Name="OverlayPresenter"
                          Content="{x:Bind OverlayContent, Mode=OneWay}"
                          VerticalAlignment="Bottom"
                          HorizontalAlignment="Stretch"/>
    </Grid>
</UserControl>
