<?xml version="1.0" encoding="utf-8"?>
<winuiex:WindowEx
    x:Class="Wavee.UI.WinUI.Floating.PlayerFloatingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winuiex="using:WinUIEx"
    xmlns:sidebarplayer="using:Wavee.UI.WinUI.Controls.SidebarPlayer"
    xmlns:transitions="using:CommunityToolkit.WinUI"
    xmlns:waveeHelpers="using:Wavee.UI.WinUI.Helpers"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Wavee — Player"
    MinWidth="360"
    MinHeight="380"
    PersistenceId="WaveePlayerFloating">

    <winuiex:WindowEx.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </winuiex:WindowEx.SystemBackdrop>

    <!-- Compact (vertical card) and Expanded (Apple-Music 2-column) views are
         siblings in RootGrid. The TransitionHelper resource morphs matched-Id
         elements between them on expand/collapse — Source = CompactHost,
         Target = ExpandedHost (wired in code-behind). Same pattern as
         ArtistPage.xaml's hero → shy-header transition.
         CompactHost is capped (MaxWidth) so resizing the window doesn't blow
         up the small layout — it just sits centered while ExpandedHost grows
         around it during the morph. -->
    <Grid x:Name="RootGrid">

        <Grid.Resources>
            <transitions:TransitionHelper x:Key="PlayerExpandTransition"
                                          Duration="0:0:0.36"
                                          ReverseDuration="0:0:0.30"
                                          DefaultEasingMode="EaseInOut"
                                          SourceToggleMethod="ByVisibility"
                                          TargetToggleMethod="ByVisibility"
                                          IndependentElementShowDuration="0:0:0.20"
                                          IndependentElementShowDelay="0:0:0.12"
                                          IndependentElementHideDuration="0:0:0.14"
                                          IsHitTestVisibleWhenAnimating="False">
                <transitions:TransitionConfig Id="albumArt" ScaleMode="Scale"/>
                <transitions:TransitionConfig Id="trackTitle" ScaleMode="Custom">
                    <transitions:TransitionConfig.CustomScalingCalculator>
                        <waveeHelpers:TransitionTextScalingCalculator/>
                    </transitions:TransitionConfig.CustomScalingCalculator>
                </transitions:TransitionConfig>
                <transitions:TransitionConfig Id="artistMetadata" ScaleMode="Custom">
                    <transitions:TransitionConfig.CustomScalingCalculator>
                        <waveeHelpers:TransitionTextScalingCalculator/>
                    </transitions:TransitionConfig.CustomScalingCalculator>
                </transitions:TransitionConfig>
            </transitions:TransitionHelper>
        </Grid.Resources>

        <Border x:Name="WindowBackdrop" IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop x:Name="WindowBackdropTop" Offset="0" Color="Transparent" />
                    <GradientStop x:Name="WindowBackdropMid" Offset="0.58" Color="Transparent" />
                    <GradientStop x:Name="WindowBackdropBottom" Offset="1" Color="Transparent" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Compact: vertical mini player. MaxWidth keeps the layout from
             blowing up when the window is large (during/after expand). -->
        <ScrollViewer
            x:Name="CompactHost"
            MinWidth="320"
            MaxWidth="340"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch"
            VerticalScrollBarVisibility="Hidden"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled"
            Padding="0,32,0,0">
            <sidebarplayer:SidebarPlayerWidget
                x:Name="PlayerHost"
                VerticalAlignment="Top" />
        </ScrollViewer>

        <!-- Expanded: 2-column now-playing layout. Hidden until first expand. -->
        <sidebarplayer:ExpandedPlayerView
            x:Name="ExpandedHost"
            Visibility="Collapsed" />

        <!-- Title-bar drag region overlay (transparent). -->
        <Border x:Name="DragRegion"
                Height="32"
                VerticalAlignment="Top"
                Background="Transparent" />

        <StackPanel
            x:Name="WindowModeButtons"
            Orientation="Horizontal"
            Spacing="4"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,2,142,0"
            Canvas.ZIndex="20">
            <Button x:Name="CompactFocusButton"
                    Width="34"
                    Height="28"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="4"
                    Click="CompactFocusButton_Click"
                    ToolTipService.ToolTip="Open focus player">
                <FontIcon Glyph="&#xE73F;" FontSize="12" />
            </Button>
            <Button x:Name="ExpandedCompactButton"
                    Width="34"
                    Height="28"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="4"
                    Visibility="Collapsed"
                    Click="ExpandedCompactButton_Click"
                    ToolTipService.ToolTip="Back to mini player">
                <FontIcon Glyph="&#xE740;" FontSize="12" />
            </Button>
        </StackPanel>
    </Grid>
</winuiex:WindowEx>
