<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Theme-aware gradient brushes (copied from Rise PlayerStyles.xaml) -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <LinearGradientBrush x:Key="TransportControlsButtonGradientBrush">
                <GradientStop Offset="0.1" Color="{ThemeResource SystemAccentColorLight2}" />
                <GradientStop Color="{ThemeResource SystemAccentColorLight1}" />
                <GradientStop Offset="0.8" Color="{ThemeResource SystemAccentColorLight1}" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="PlayerBarBackgroundBrush" Color="#1A1A1A" />

            <!-- Toggle button checked state: foreground only, no background change -->
            <SolidColorBrush x:Key="AppBarToggleButtonBackgroundChecked" Color="Transparent" />
            <SolidColorBrush x:Key="AppBarToggleButtonBackgroundCheckedPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="AppBarToggleButtonBackgroundCheckedPressed" Color="Transparent" />
            <StaticResource x:Key="AppBarToggleButtonForegroundChecked" ResourceKey="TransportControlsButtonGradientBrush" />
            <StaticResource x:Key="AppBarToggleButtonForegroundCheckedPointerOver" ResourceKey="TransportControlsButtonGradientBrush" />
            <StaticResource x:Key="AppBarToggleButtonForegroundCheckedPressed" ResourceKey="TransportControlsButtonGradientBrush" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <LinearGradientBrush x:Key="TransportControlsButtonGradientBrush">
                <GradientStop Offset="0.1" Color="{ThemeResource SystemAccentColor}" />
                <GradientStop Color="{ThemeResource SystemAccentColor}" />
                <GradientStop Offset="0.8" Color="{ThemeResource SystemAccentColorDark2}" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="PlayerBarBackgroundBrush" Color="#F5F5F5" />

            <!-- Toggle button checked state: foreground only, no background change -->
            <SolidColorBrush x:Key="AppBarToggleButtonBackgroundChecked" Color="Transparent" />
            <SolidColorBrush x:Key="AppBarToggleButtonBackgroundCheckedPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="AppBarToggleButtonBackgroundCheckedPressed" Color="Transparent" />
            <StaticResource x:Key="AppBarToggleButtonForegroundChecked" ResourceKey="TransportControlsButtonGradientBrush" />
            <StaticResource x:Key="AppBarToggleButtonForegroundCheckedPointerOver" ResourceKey="TransportControlsButtonGradientBrush" />
            <StaticResource x:Key="AppBarToggleButtonForegroundCheckedPressed" ResourceKey="TransportControlsButtonGradientBrush" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="TransportControlsButtonGradientBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="PlayerBarBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />

            <!-- Toggle button checked state: foreground only -->
            <SolidColorBrush x:Key="AppBarToggleButtonBackgroundChecked" Color="Transparent" />
            <SolidColorBrush x:Key="AppBarToggleButtonBackgroundCheckedPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="AppBarToggleButtonBackgroundCheckedPressed" Color="Transparent" />
            <StaticResource x:Key="AppBarToggleButtonForegroundChecked" ResourceKey="TransportControlsButtonGradientBrush" />
            <StaticResource x:Key="AppBarToggleButtonForegroundCheckedPointerOver" ResourceKey="TransportControlsButtonGradientBrush" />
            <StaticResource x:Key="AppBarToggleButtonForegroundCheckedPressed" ResourceKey="TransportControlsButtonGradientBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- AppBarButton compact style (from Rise CustomStyles.xaml) -->
    <Style x:Key="AppBarButtonCompactStyle" BasedOn="{StaticResource DefaultAppBarButtonStyle}" TargetType="AppBarButton">
        <Setter Property="LabelPosition" Value="Collapsed" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Width" Value="40" />
    </Style>

    <!-- AppBarToggleButton compact style (from Rise CustomStyles.xaml) -->
    <Style x:Key="AppBarToggleButtonCompactStyle" BasedOn="{StaticResource DefaultAppBarToggleButtonStyle}" TargetType="AppBarToggleButton">
        <Setter Property="LabelPosition" Value="Collapsed" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Width" Value="40" />
    </Style>

    <!-- Transparent button style (from Rise CustomStyles.xaml) -->
    <Style x:Key="TransparentButtonStyle" BasedOn="{StaticResource DefaultButtonStyle}" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Subtle toggle button style for shuffle/repeat — transparent, accent when checked -->
    <Style x:Key="SubtleToggleButtonStyle" BasedOn="{StaticResource DefaultToggleButtonStyle}" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- Play/Pause AppBarButton style with gradient border on hover (Rise style) -->
    <Style x:Key="PlayPauseAppBarButtonStyle" BasedOn="{StaticResource DefaultAppBarButtonStyle}" TargetType="AppBarButton">
        <Setter Property="LabelPosition" Value="Collapsed" />
        <Setter Property="Width" Value="52" />
        <Setter Property="Height" Value="60" />
        <Setter Property="Margin" Value="0,-7,0,0" />
        <Setter Property="BorderThickness" Value="4" />
        <Setter Property="CornerRadius" Value="50" />
    </Style>

    <!-- Time text style -->
    <Style x:Key="PlayerTimeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Track title style (16px SemiBold like Rise) -->
    <Style x:Key="PlayerTrackTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MaxLines" Value="2" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Artist name style (~14px like Rise default) -->
    <Style x:Key="PlayerArtistNameStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Opacity" Value="0.7" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- Thumb: small accent circle -->
    <Style x:Key="PlayerProgressThumbStyle" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Ellipse Width="12" Height="12"
                             Fill="{ThemeResource AccentFillColorDefaultBrush}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Progress slider: thin bar at top of player, thumb hidden until hover -->
    <Style x:Key="PlayerProgressSliderStyle" TargetType="Slider">
        <Setter Property="Height" Value="16"/>
        <Setter Property="MinHeight" Value="16"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="IsThumbToolTipEnabled" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid x:Name="SliderContainer" Background="Transparent"
                          Margin="{TemplateBinding Padding}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HorizontalThumb"
                                            Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="HorizontalTrackRect"
                                            Storyboard.TargetProperty="Height" To="3" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="HorizontalDecreaseRect"
                                            Storyboard.TargetProperty="Height" To="3" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HorizontalThumb"
                                            Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="HorizontalTrackRect"
                                            Storyboard.TargetProperty="Height" To="4" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="HorizontalDecreaseRect"
                                            Storyboard.TargetProperty="Height" To="4" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HorizontalThumb"
                                            Storyboard.TargetProperty="Opacity" To="1" Duration="0"/>
                                        <DoubleAnimation Storyboard.TargetName="HorizontalTrackRect"
                                            Storyboard.TargetProperty="Height" To="4" Duration="0"/>
                                        <DoubleAnimation Storyboard.TargetName="HorizontalDecreaseRect"
                                            Storyboard.TargetProperty="Height" To="4" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HorizontalThumb"
                                            Storyboard.TargetProperty="Opacity" To="0" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Grid x:Name="HorizontalTemplate" MinHeight="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Rectangle x:Name="HorizontalTrackRect" Grid.ColumnSpan="3"
                                       Height="3" Fill="{ThemeResource ControlFillColorTertiaryBrush}"
                                       RadiusX="1.5" RadiusY="1.5" VerticalAlignment="Center"/>

                            <Rectangle x:Name="HorizontalDecreaseRect" Grid.Column="0"
                                       Height="3" Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                       RadiusX="1.5" RadiusY="1.5" VerticalAlignment="Center"/>

                            <Thumb x:Name="HorizontalThumb" Grid.Column="1"
                                   Width="12" Height="12" Opacity="0"
                                   AutomationProperties.AccessibilityView="Raw"
                                   DataContext="{TemplateBinding Value}"
                                   FocusVisualMargin="-6,-8,-6,-8"
                                   Style="{StaticResource PlayerProgressThumbStyle}"/>
                        </Grid>

                        <!-- Required vertical template (collapsed, prevents crashes) -->
                        <Grid x:Name="VerticalTemplate" Visibility="Collapsed" MinWidth="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Rectangle x:Name="VerticalTrackRect" Grid.RowSpan="3" Width="3"
                                       Fill="{ThemeResource ControlFillColorTertiaryBrush}"/>
                            <Rectangle x:Name="VerticalDecreaseRect" Grid.Row="2" Width="3"
                                       Fill="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <Thumb x:Name="VerticalThumb" Grid.Row="1" Width="12" Height="12"
                                   Style="{StaticResource PlayerProgressThumbStyle}"/>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
