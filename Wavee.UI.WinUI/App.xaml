                <!-- INLINE ThemeDictionaries for TabView overrides (Files pattern) -->
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Light">
                            <!-- App backgrounds -->
                            <SolidColorBrush x:Key="App.Theme.BackgroundBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="App.Theme.Sidebar.BackgroundBrush" Color="{StaticResource LayerOnMicaBaseAltFillColorDefault}"/>
                            <SolidColorBrush x:Key="App.Theme.Content.BackgroundBrush" Color="{StaticResource CardBackgroundFillColorDefault}"/>
                            <SolidColorBrush x:Key="App.Theme.Player.BackgroundBrush" Color="{StaticResource CardBackgroundFillColorSecondary}"/>
                            <SolidColorBrush x:Key="App.Theme.AddressBar.BackgroundBrush" Color="{StaticResource LayerOnMicaBaseAltFillColorDefault}"/>
                            <SolidColorBrush x:Key="App.Theme.FileArea.BackgroundBrush" Color="#C0FCFCFC"/>
                            <SolidColorBrush x:Key="App.Theme.IconBaseBrush" Color="{StaticResource TextFillColorPrimary}"/>

                            <!-- TabView overrides - CRITICAL for styling -->
                            <SolidColorBrush x:Key="TabViewItemHeaderBackground" Color="{StaticResource SubtleFillColorTransparent}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="{StaticResource LayerOnMicaBaseAltFillColorDefault}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPressed" Color="{StaticResource SubtleFillColorTertiary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPointerOver" Color="{StaticResource SubtleFillColorSecondary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="{StaticResource TextFillColorSecondary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderForegroundPointerOver" Color="{StaticResource TextFillColorPrimary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderForegroundPressed" Color="{StaticResource TextFillColorPrimary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="{StaticResource TextFillColorPrimary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderForegroundDisabled" Color="{StaticResource TextFillColorDisabled}"/>
                            <SolidColorBrush x:Key="TabViewItemIconForeground" Color="{StaticResource TextFillColorSecondary}"/>
                            <SolidColorBrush x:Key="TabViewItemIconForegroundPointerOver" Color="{StaticResource TextFillColorPrimary}"/>
                            <SolidColorBrush x:Key="TabViewItemIconForegroundPressed" Color="{StaticResource TextFillColorPrimary}"/>
                            <SolidColorBrush x:Key="TabViewItemIconForegroundSelected" Color="{StaticResource TextFillColorPrimary}"/>

                            <!-- Accent -->
                            <Color x:Key="App.Theme.AccentColor">#1DB954</Color>
                            <SolidColorBrush x:Key="App.Theme.AccentBrush" Color="{StaticResource App.Theme.AccentColor}"/>

                            <!-- Baseline home card -->
                            <Color x:Key="HomeBaselineCardOverlayPrimaryTextColor">#FFFFFFFF</Color>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayPrimaryTextBrush" Color="{StaticResource HomeBaselineCardOverlayPrimaryTextColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlaySecondaryTextBrush" Color="#D9FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayTertiaryTextBrush" Color="#B5FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayThumbBackgroundBrush" Color="#20FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayThumbBorderBrush" Color="#30FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayChromeBackgroundBrush" Color="#B81B1B1B"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayChromeBorderBrush" Color="#33FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardDividerBrush" Color="#1AFFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewBadgeBackgroundBrush" Color="#24FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewBadgeBorderBrush" Color="#28FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewSurfaceBackgroundBrush" Color="#38121720"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewSurfaceBorderBrush" Color="#30FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewPlaceholderBackgroundBrush" Color="#14000000"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewPlaceholderStrokeBrush" Color="#EAF7FBFF"/>
                            <Color x:Key="HomeBaselineCardPreviewVisualizerForegroundColor">#FFF7FBFF</Color>
                            <Color x:Key="HomeBaselineCardPreviewVisualizerTrackColor">#00000000</Color>
                            <Color x:Key="HomeBaselineCardHeroHighlightStartColor">#54FFFFFF</Color>
                            <Color x:Key="HomeBaselineCardHeroHighlightMidColor">#10FFFFFF</Color>
                            <Color x:Key="HomeBaselineCardHeroHighlightEndColor">#00FFFFFF</Color>
                            <Color x:Key="HomeBaselineCardHeroShadowTopColor">#26000000</Color>
                            <Color x:Key="HomeBaselineCardHeroShadowMidColor">#09000000</Color>
                            <Color x:Key="HomeBaselineCardHeroShadowBottomColor">#A6000000</Color>
                            <Color x:Key="RightPanelBackgroundHighlightStartColor">#56FFFFFF</Color>
                            <Color x:Key="RightPanelBackgroundHighlightMidColor">#16FFFFFF</Color>
                            <Color x:Key="RightPanelBackgroundHighlightEndColor">#00FFFFFF</Color>
                            <Color x:Key="RightPanelBackgroundShadowTopColor">#18000000</Color>
                            <Color x:Key="RightPanelBackgroundShadowMidColor">#08000000</Color>
                            <Color x:Key="RightPanelBackgroundShadowBottomColor">#B6000000</Color>
                            <SolidColorBrush x:Key="RightPanelBackgroundNonDetailsDimBrush" Color="#300A0C10"/>
                            <Color x:Key="ArtistHeroFallbackGlowStartColor">#30FFFFFF</Color>
                            <Color x:Key="ArtistHeroFallbackGlowMidColor">#141DB954</Color>
                            <Color x:Key="ArtistHeroFallbackGlowEndColor">#001DB954</Color>
                            <Color x:Key="ArtistHeroFallbackShadowTopColor">#00000000</Color>
                            <Color x:Key="ArtistHeroFallbackShadowMidColor">#06000000</Color>
                            <Color x:Key="ArtistHeroFallbackShadowBottomColor">#18000000</Color>
                        </ResourceDictionary>

                        <ResourceDictionary x:Key="Dark">
                            <!-- App backgrounds -->
                            <SolidColorBrush x:Key="App.Theme.BackgroundBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="App.Theme.Sidebar.BackgroundBrush" Color="{StaticResource LayerOnMicaBaseAltFillColorDefault}"/>
                            <SolidColorBrush x:Key="App.Theme.Content.BackgroundBrush" Color="{StaticResource CardBackgroundFillColorDefault}"/>
                            <SolidColorBrush x:Key="App.Theme.Player.BackgroundBrush" Color="{StaticResource CardBackgroundFillColorSecondary}"/>
                            <SolidColorBrush x:Key="App.Theme.AddressBar.BackgroundBrush" Color="{StaticResource LayerOnMicaBaseAltFillColorDefault}"/>
                            <SolidColorBrush x:Key="App.Theme.FileArea.BackgroundBrush" Color="{StaticResource CardBackgroundFillColorDefault}"/>
                            <SolidColorBrush x:Key="App.Theme.IconBaseBrush" Color="{StaticResource TextFillColorPrimary}"/>

                            <!-- TabView overrides - CRITICAL for styling -->
                            <SolidColorBrush x:Key="TabViewItemHeaderBackground" Color="{StaticResource SubtleFillColorTransparent}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="{StaticResource LayerOnMicaBaseAltFillColorDefault}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPressed" Color="{StaticResource SubtleFillColorTertiary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPointerOver" Color="{StaticResource SubtleFillColorSecondary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="{StaticResource TextFillColorSecondary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderForegroundPointerOver" Color="{StaticResource TextFillColorPrimary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderForegroundPressed" Color="{StaticResource TextFillColorPrimary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="{StaticResource TextFillColorPrimary}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderForegroundDisabled" Color="{StaticResource TextFillColorDisabled}"/>
                            <SolidColorBrush x:Key="TabViewItemIconForeground" Color="{StaticResource TextFillColorSecondary}"/>
                            <SolidColorBrush x:Key="TabViewItemIconForegroundPointerOver" Color="{StaticResource TextFillColorPrimary}"/>
                            <SolidColorBrush x:Key="TabViewItemIconForegroundPressed" Color="{StaticResource TextFillColorPrimary}"/>
                            <SolidColorBrush x:Key="TabViewItemIconForegroundSelected" Color="{StaticResource TextFillColorPrimary}"/>

                            <!-- Accent -->
                            <Color x:Key="App.Theme.AccentColor">#1DB954</Color>
                            <SolidColorBrush x:Key="App.Theme.AccentBrush" Color="{StaticResource App.Theme.AccentColor}"/>

                            <!-- Baseline home card -->
                            <Color x:Key="HomeBaselineCardOverlayPrimaryTextColor">#FFFFFFFF</Color>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayPrimaryTextBrush" Color="{StaticResource HomeBaselineCardOverlayPrimaryTextColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlaySecondaryTextBrush" Color="#D9FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayTertiaryTextBrush" Color="#B5FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayThumbBackgroundBrush" Color="#20FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayThumbBorderBrush" Color="#30FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayChromeBackgroundBrush" Color="#B81B1B1B"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayChromeBorderBrush" Color="#33FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardDividerBrush" Color="#1AFFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewBadgeBackgroundBrush" Color="#24FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewBadgeBorderBrush" Color="#28FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewSurfaceBackgroundBrush" Color="#38121720"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewSurfaceBorderBrush" Color="#30FFFFFF"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewPlaceholderBackgroundBrush" Color="#14000000"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewPlaceholderStrokeBrush" Color="#EAF7FBFF"/>
                            <Color x:Key="HomeBaselineCardPreviewVisualizerForegroundColor">#FFF7FBFF</Color>
                            <Color x:Key="HomeBaselineCardPreviewVisualizerTrackColor">#00000000</Color>
                            <Color x:Key="HomeBaselineCardHeroHighlightStartColor">#54FFFFFF</Color>
                            <Color x:Key="HomeBaselineCardHeroHighlightMidColor">#10FFFFFF</Color>
                            <Color x:Key="HomeBaselineCardHeroHighlightEndColor">#00FFFFFF</Color>
                            <Color x:Key="HomeBaselineCardHeroShadowTopColor">#26000000</Color>
                            <Color x:Key="HomeBaselineCardHeroShadowMidColor">#09000000</Color>
                            <Color x:Key="HomeBaselineCardHeroShadowBottomColor">#A6000000</Color>
                            <Color x:Key="RightPanelBackgroundHighlightStartColor">#58FFFFFF</Color>
                            <Color x:Key="RightPanelBackgroundHighlightMidColor">#16FFFFFF</Color>
                            <Color x:Key="RightPanelBackgroundHighlightEndColor">#00FFFFFF</Color>
                            <Color x:Key="RightPanelBackgroundShadowTopColor">#22000000</Color>
                            <Color x:Key="RightPanelBackgroundShadowMidColor">#0A000000</Color>
                            <Color x:Key="RightPanelBackgroundShadowBottomColor">#C4000000</Color>
                            <SolidColorBrush x:Key="RightPanelBackgroundNonDetailsDimBrush" Color="#3A090B11"/>
                            <Color x:Key="ArtistHeroFallbackGlowStartColor">#36FFFFFF</Color>
                            <Color x:Key="ArtistHeroFallbackGlowMidColor">#181DB954</Color>
                            <Color x:Key="ArtistHeroFallbackGlowEndColor">#001DB954</Color>
                            <Color x:Key="ArtistHeroFallbackShadowTopColor">#00000000</Color>
                            <Color x:Key="ArtistHeroFallbackShadowMidColor">#12000000</Color>
                            <Color x:Key="ArtistHeroFallbackShadowBottomColor">#54000000</Color>
                        </ResourceDictionary>

                        <ResourceDictionary x:Key="HighContrast">
                            <!-- App backgrounds -->
                            <SolidColorBrush x:Key="App.Theme.BackgroundBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="App.Theme.Sidebar.BackgroundBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="App.Theme.Content.BackgroundBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="App.Theme.Player.BackgroundBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="App.Theme.AddressBar.BackgroundBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="App.Theme.FileArea.BackgroundBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="App.Theme.IconBaseBrush" Color="{StaticResource SystemColorButtonTextColor}"/>

                            <!-- TabView overrides -->
                            <SolidColorBrush x:Key="TabViewItemHeaderBackground" Color="{StaticResource SystemColorWindowColor}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="{StaticResource SystemColorHighlightColor}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPressed" Color="{StaticResource SystemColorHighlightColor}"/>
                            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundPointerOver" Color="{StaticResource SystemColorHighlightColor}"/>

                            <!-- Accent -->
                            <SolidColorBrush x:Key="App.Theme.AccentBrush" Color="{StaticResource SystemColorHighlightColor}"/>

                            <!-- Baseline home card -->
                            <Color x:Key="HomeBaselineCardOverlayPrimaryTextColor">{StaticResource SystemColorButtonTextColor}</Color>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayPrimaryTextBrush" Color="{StaticResource HomeBaselineCardOverlayPrimaryTextColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlaySecondaryTextBrush" Color="{StaticResource SystemColorButtonTextColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayTertiaryTextBrush" Color="{StaticResource SystemColorButtonTextColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayThumbBackgroundBrush" Color="{StaticResource SystemColorWindowColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayThumbBorderBrush" Color="{StaticResource SystemColorButtonTextColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayChromeBackgroundBrush" Color="{StaticResource SystemColorWindowColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardOverlayChromeBorderBrush" Color="{StaticResource SystemColorButtonTextColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardDividerBrush" Color="{StaticResource SystemColorButtonTextColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewBadgeBackgroundBrush" Color="{StaticResource SystemColorWindowColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewBadgeBorderBrush" Color="{StaticResource SystemColorButtonTextColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewSurfaceBackgroundBrush" Color="{StaticResource SystemColorWindowColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewSurfaceBorderBrush" Color="{StaticResource SystemColorButtonTextColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewPlaceholderBackgroundBrush" Color="{StaticResource SystemColorWindowColor}"/>
                            <SolidColorBrush x:Key="HomeBaselineCardPreviewPlaceholderStrokeBrush" Color="{StaticResource SystemColorButtonTextColor}"/>
                            <Color x:Key="HomeBaselineCardPreviewVisualizerForegroundColor">{StaticResource SystemColorHighlightColor}</Color>
                            <Color x:Key="HomeBaselineCardPreviewVisualizerTrackColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="HomeBaselineCardHeroHighlightStartColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="HomeBaselineCardHeroHighlightMidColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="HomeBaselineCardHeroHighlightEndColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="HomeBaselineCardHeroShadowTopColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="HomeBaselineCardHeroShadowMidColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="HomeBaselineCardHeroShadowBottomColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="RightPanelBackgroundHighlightStartColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="RightPanelBackgroundHighlightMidColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="RightPanelBackgroundHighlightEndColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="RightPanelBackgroundShadowTopColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="RightPanelBackgroundShadowMidColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="RightPanelBackgroundShadowBottomColor">{StaticResource SystemColorWindowColor}</Color>
                            <SolidColorBrush x:Key="RightPanelBackgroundNonDetailsDimBrush" Color="{StaticResource SystemColorWindowColor}"/>
                            <Color x:Key="ArtistHeroFallbackGlowStartColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="ArtistHeroFallbackGlowMidColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="ArtistHeroFallbackGlowEndColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="ArtistHeroFallbackShadowTopColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="ArtistHeroFallbackShadowMidColor">{StaticResource SystemColorWindowColor}</Color>
                            <Color x:Key="ArtistHeroFallbackShadowBottomColor">{StaticResource SystemColorWindowColor}</Color>
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>

            <!-- Workaround for tab shadow issue -->
            <x:Double x:Key="TabViewShadowDepth">0</x:Double>

            <!-- Transparent caption button backgrounds for custom titlebar -->
            <SolidColorBrush x:Key="WindowCaptionBackground" Color="Transparent" />
            <SolidColorBrush x:Key="WindowCaptionBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="TransparentColorBrush" Color="Transparent"/>
            <!-- Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True" />
            <converters:ChipBackgroundConverter x:Key="ChipBackgroundConverter" />
            <converters:ChipForegroundConverter x:Key="ChipForegroundConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True" />
            <converters:BoolToFollowTextConverter x:Key="BoolToFollowTextConverter" />
            <converters:BoolToFollowGlyphConverter x:Key="BoolToFollowGlyphConverter" />
            <converters:BoolToHeartGlyphConverter x:Key="BoolToHeartGlyphConverter" />
            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
            <converters:StringToUpperConverter x:Key="StringToUpperConverter" />
            <converters:GridScaleToSizeConverter x:Key="GridScaleToSizeConverter" />
            <converters:BoolToBackgroundConverter x:Key="BoolToBackgroundConverter" />
            <converters:BoolToBackgroundConverter x:Key="InverseBoolToBackgroundConverter" Invert="True" />
            <converters:SpotifyImageConverter x:Key="SpotifyImageConverter"/>
            <converters:DepthToThicknessConverter x:Key="DepthToThicknessConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
