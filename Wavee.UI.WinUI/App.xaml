    xmlns:local="using:Wavee.UI.WinUI"
    xmlns:converters="using:Wavee.UI.WinUI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />

                <!-- App Styles (non-theme) -->
                <ResourceDictionary Source="ms-appx:///Styles/FontResources.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/TextBlockStyles.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/TabBarStyles.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/ListViewStyles.xaml" />
                <ResourceDictionary Source="ms-appx:///Styles/TabbedCommandBarStyles.xaml" />
                <ResourceDictionary Source="ms-appx:///Controls/Sidebar/SidebarStyles.xaml" />
                <ResourceDictionary Source="ms-appx:///Controls/Omnibar/Omnibar.xaml" />
                <ResourceDictionary Source="ms-appx:///Controls/GridSplitter/GridSplitter.xaml" />
                <ResourceDictionary Source="ms-appx:///Controls/ErrorStateView.xaml" />
                <ResourceDictionary Source="ms-appx:///Controls/Shelf/ShelfStyles.xaml" />
                <ResourceDictionary Source="ms-appx:///Themes/ContextMenu.xaml" />
