<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Wavee.Controls.Lyrics.Controls.NowPlayingCanvas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:converters="using:Wavee.Controls.Lyrics.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Wavee.Controls.Lyrics.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Unloaded="UserControl_Unloaded"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:FPSToTimeSpanConverter x:Key="FPSToTimeSpanConverter" />
    </UserControl.Resources>

    <Grid>
        <canvas:CanvasAnimatedControl
            x:Name="Canvas"
            CreateResources="Canvas_CreateResources"
            Draw="Canvas_Draw"
            TargetElapsedTime="{x:Bind LyricsWindowStatus.FPS, Mode=OneWay, Converter={StaticResource FPSToTimeSpanConverter}}"
            Update="Canvas_Update" />
    </Grid>
</UserControl>
