<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Wavee.Controls.Lyrics.Controls.ImageSwitcher"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:const="using:Wavee.Controls.Lyrics.Constants"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Wavee.Controls.Lyrics.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.OpacityTransition>
            <ScalarTransition Duration="{x:Bind const:Time.AnimationDuration}" />
        </Grid.OpacityTransition>
        <local:ShadowImage
            x:Name="LastAlbumArtImage"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadiusAmount="{x:Bind CornerRadiusAmount, Mode=OneWay}"
            ShadowAmount="{x:Bind ShadowAmount, Mode=OneWay}"
            Stretch="{x:Bind Stretch, Mode=OneWay}" />
        <local:ShadowImage
            x:Name="AlbumArtImage"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadiusAmount="{x:Bind CornerRadiusAmount, Mode=OneWay}"
            ShadowAmount="{x:Bind ShadowAmount, Mode=OneWay}"
            Stretch="{x:Bind Stretch, Mode=OneWay}" />
    </Grid>
</UserControl>
