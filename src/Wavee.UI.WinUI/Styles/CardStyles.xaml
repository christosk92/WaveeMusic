<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Shared card-shaped surfaces used by the detail-pages redesign
        (ArtistPage V4A release tiles, AlbumPage Featured-on / Similar-album
        tiles, merch tiles).

        WinUI 3 doesn't ship the WinUI 2 RevealBrush, so the Fluent "card
        with cursor-following spotlight" look is composed manually:
            - resting state: card background + subtle border
            - pointer-over:  brighter background + slightly thicker accent border

        Pages that want the cursor-following spotlight overlay add a
        composition handler on PointerMoved; this style is just the
        background + border parity layer.
    -->

    <Style x:Key="RevealCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="RevealCardBorderStyle.Compact" TargetType="Border" BasedOn="{StaticResource RevealCardBorderStyle}">
        <Setter Property="CornerRadius" Value="6" />
    </Style>

</ResourceDictionary>
