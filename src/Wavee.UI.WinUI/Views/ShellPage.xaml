<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sidebar="using:Wavee.UI.WinUI.Controls.Sidebar"
    xmlns:tabbar="using:Wavee.UI.WinUI.Controls.TabBar"
    xmlns:navtoolbar="using:Wavee.UI.WinUI.Controls.NavigationToolbar"
    xmlns:playerbar="using:Wavee.UI.WinUI.Controls.PlayerBar"
    xmlns:sidebarplayer="using:Wavee.UI.WinUI.Controls.SidebarPlayer"
    xmlns:rightpanel="using:Wavee.UI.WinUI.Controls.RightPanel"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    xmlns:toolkit="using:CommunityToolkit.WinUI"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    xmlns:notifications="using:Wavee.UI.WinUI.Controls.Notifications"
    xmlns:addtoplaylist="using:Wavee.UI.WinUI.Controls.AddToPlaylist"
    xmlns:minivideo="using:Wavee.UI.WinUI.Controls.MiniVideoPlayer"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
    </Page.Resources>

    <!-- F12 debug shortcut removed — use Settings > Diagnostics instead -->

    <!-- Keyboard shortcuts handled in ProcessKeyboardAccelerators to avoid tooltip flyouts -->

    <controls:ZoomContentControl x:Name="ZoomControl">
    <Grid x:Name="RootLayoutGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: TitleBar with TabBar (full width).
             The outer Grid stays mounted in Theatre / Fullscreen so the
             custom title bar drag region remains addressable; only the tab
             strip itself collapses inside it. -->
        <Grid Grid.Row="0" x:Name="TitleBarGrid">
            <tabbar:TabBar
                x:Name="TabControl"
                TabInstances="{x:Bind ViewModel.Tabs}"
                SelectedIndex="{x:Bind ViewModel.SelectedTabIndex, Mode=TwoWay}"
                Visibility="{x:Bind ViewModel.IsTabBarVisibleInShell, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                TabCloseRequested="TabControl_TabCloseRequested"
                TabSleepToggleRequested="TabControl_TabSleepToggleRequested"
                AddTabRequested="TabControl_AddTabRequested"/>
        </Grid>

        <!-- Row 1: Navigation Toolbar (full width, below tabs) -->
        <navtoolbar:NavigationToolbar
            x:Name="NavToolbar"
            Grid.Row="1"
            Visibility="{x:Bind ViewModel.IsNavToolbarVisibleInShell, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            IsRightPanelOpen="{x:Bind ViewModel.IsRightPanelOpen, Mode=TwoWay}"
            IsFriendsPanelActive="{x:Bind ViewModel.IsFriendsPanelActive, Mode=OneWay}"
            CanGoBack="{x:Bind ViewModel.CanGoBack, Mode=OneWay}"
            CanGoForward="{x:Bind ViewModel.CanGoForward, Mode=OneWay}"
            IsOnHomePage="{x:Bind ViewModel.IsOnHomePage, Mode=OneWay}"
            IsOnProfilePage="{x:Bind ViewModel.IsOnProfilePage, Mode=OneWay}"
            SearchSuggestionsLoading="{x:Bind ViewModel.IsSearchSuggestionsLoading, Mode=OneWay}"
            SearchSuggestionsErrorMessage="{x:Bind ViewModel.SearchSuggestionErrorMessage, Mode=OneWay}"
            BackRequested="NavToolbar_BackRequested"
            ForwardRequested="NavToolbar_ForwardRequested"
            HomeRequested="NavToolbar_HomeRequested"
            SearchQuerySubmitted="NavToolbar_SearchQuerySubmitted"
            SearchTextChanged="NavToolbar_SearchTextChanged"
            SearchSuggestionChosen="NavToolbar_SearchSuggestionChosen"
            SearchRetryRequested="NavToolbar_SearchRetryRequested"
            SearchActionButtonClicked="NavToolbar_SearchActionButtonClicked"
            SearchSuggestions="{x:Bind ViewModel.SearchSuggestions, Mode=OneWay}"
            SuggestionGroups="{x:Bind ViewModel.SuggestionGroups, Mode=OneWay}"
            FriendsRequested="NavToolbar_FriendsRequested"
            SignInRequested="NavToolbar_SignInRequested"/>

        <!-- Shell-level notification bars -->
        <StackPanel Grid.Row="2" Canvas.ZIndex="1">
            <InfoBar x:Uid="Views_ShellPage__InfoBar_1"
                x:Name="ConnectionErrorBar"
                Title="Connection failed"
                Severity="Error"
                IsOpen="False"
                IsClosable="True">
                <InfoBar.ActionButton>
                    <Button x:Uid="Views_ShellPage__Button_2" Content="Retry" Click="RetryConnection_Click"/>
                </InfoBar.ActionButton>
            </InfoBar>
        </StackPanel>

        <!-- Floating Photos-style notification toast — floats above the player bar. -->
        <notifications:NotificationToast
            x:Name="NotificationToastControl"
            Grid.Row="2"
            Canvas.ZIndex="3"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Center"
            Margin="0,0,0,16"
            IsOpen="{x:Bind ViewModel.IsNotificationOpen, Mode=TwoWay}"
            Message="{x:Bind ViewModel.NotificationMessage, Mode=OneWay}"
            Severity="{x:Bind ViewModel.NotificationSeverity, Mode=OneWay}"
            ActionLabel="{x:Bind ViewModel.NotificationActionLabel, Mode=OneWay}"
            IsActionEnabled="{x:Bind ViewModel.IsNotificationActionEnabled, Mode=OneWay}"
            ActionClick="NotificationAction_Click"
            CloseRequested="Notification_CloseRequested"/>

        <!-- App-wide "Adding to playlist…" floating bar. Mounted once at the
             shell level so it survives navigation between Browse, album,
             artist, search etc. while a session is open. Self-managed
             Visibility from IAddToPlaylistSession.IsActive. -->
        <addtoplaylist:AddToPlaylistBar
            x:Name="AddToPlaylistBarControl"
            Grid.Row="2"
            Canvas.ZIndex="4"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Center"
            Margin="0,0,0,16"/>

        <!-- Connection overlay — blocks interaction while disconnected -->
        <Border
            x:Name="ConnectionOverlay"
            Grid.Row="2"
            Canvas.ZIndex="2"
            Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
            Opacity="0.85"
            IsHitTestVisible="True"
            Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressRing x:Name="ReconnectingRing" IsActive="True" Width="36" Height="36"/>
                <TextBlock x:Uid="Views_ShellPage__TextBlock_3" x:Name="ConnectionOverlayText"
                           Text="Reconnecting to Spotify..."
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Row 2: Main content area with sidebar.
             Collapses entirely when the player enters Theatre / Fullscreen —
             the TheatrePlayerHost below takes over the whole window. -->
        <sidebar:SidebarView
            x:Name="SidebarControl"
            Grid.Row="2"
            Visibility="{x:Bind ViewModel.IsSidebarVisibleInShell, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            DisplayMode="{x:Bind ViewModel.SidebarDisplayMode, Mode=TwoWay}"
            IsPaneOpen="{x:Bind ViewModel.IsSidebarPaneOpen, Mode=TwoWay}"
            OpenPaneLength="{x:Bind ViewModel.SidebarWidth, Mode=TwoWay}"
            MenuItemsSource="{x:Bind ViewModel.SidebarItems}"
            SelectedItem="{x:Bind ViewModel.SelectedSidebarItem, Mode=TwoWay}"
            ItemInvoked="SidebarControl_ItemInvoked"
            PinButtonClicked="SidebarControl_PinButtonClicked">

            <!-- Main Content + Right Panel (each with independent shadow) -->
            <sidebar:SidebarView.InnerContent>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Main content card (Files-style: subtle rounded corners + soft shadow) -->
                    <Border Grid.Column="0">
                        <toolkit:Effects.Shadow>
                            <media:AttachedCardShadow BlurRadius="16" Offset="0,2"
                                                      Opacity="0.12" Color="Black" CornerRadius="8"/>
                        </toolkit:Effects.Shadow>
                        <Border Background="{ThemeResource App.Theme.FileArea.BackgroundBrush}"
                                CornerRadius="8">
                            <ContentPresenter
                                x:Name="TabContentPresenter"
                                Content="{x:Bind ViewModel.SelectedTabItem.ContentFrame, Mode=OneWay}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
                        </Border>
                    </Border>

                    <!-- Right panel card. Visibility ANDs IsRightPanelOpen with !IsRightPanelDetached
                         so tearing the panel into a floating window collapses the slot and main content reflows. -->
                    <Border Grid.Column="1"
                            Visibility="{x:Bind ViewModel.IsRightPanelVisibleInShell, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <toolkit:Effects.Shadow>
                            <media:AttachedCardShadow BlurRadius="32" Offset="4,-2"
                                                      Opacity="0.3" Color="Black" CornerRadius="8"/>
                        </toolkit:Effects.Shadow>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8">
                            <rightpanel:RightPanelView
                                x:Name="RightPanelControl"
                                PanelWidth="{x:Bind ViewModel.RightPanelWidth, Mode=TwoWay}"
                                IsOpen="{x:Bind ViewModel.IsRightPanelOpen, Mode=TwoWay}"
                                SelectedMode="{x:Bind ViewModel.RightPanelMode, Mode=TwoWay}"/>
                        </Border>
                    </Border>
                </Grid>
            </sidebar:SidebarView.InnerContent>

            <!-- Sidebar Header — sidebar player widget mount point. Visible only when
                 PlayerLocation == Sidebar AND the player isn't torn off into a floating
                 window. The widget itself only renders when a track is loaded (HasTrack
                 gate inside the control). -->
            <sidebar:SidebarView.Header>
                <sidebarplayer:SidebarPlayerWidget
                    x:Name="SidebarPlayerControl"
                    Visibility="{x:Bind ViewModel.IsSidebarPlayerVisibleInShell, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </sidebar:SidebarView.Header>

            <!-- Sidebar Footer (settings) -->
            <sidebar:SidebarView.Footer>
                <StackPanel>
                    <!-- Expandable Album Art -->
                    <Border
                        x:Name="ExpandedAlbumArtContainer"
                        Margin="0,0,0,0"
                        CornerRadius="0"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        Tapped="ExpandedAlbumArt_Tapped"
                        Visibility="{x:Bind PlayerBarControl.ViewModel.IsAlbumArtExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <animations:Implicit.ShowAnimations>
                            <animations:OpacityAnimation Duration="0:0:0.3" From="0" To="1" />
                            <animations:TranslationAnimation Duration="0:0:0.3" From="0,50,0" To="0" />
                        </animations:Implicit.ShowAnimations>
                        <animations:Implicit.HideAnimations>
                            <animations:OpacityAnimation Duration="0:0:0.2" From="1" To="0" />
                            <animations:TranslationAnimation Duration="0:0:0.2" From="0" To="0,50,0" />
                        </animations:Implicit.HideAnimations>
                        <Image
                            Stretch="UniformToFill"
                            Source="{x:Bind PlayerBarControl.ViewModel.AlbumArtLarge, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=300}"
                            behaviors:ImageFallbackBehavior.HideOnError="True"
                            behaviors:ImageFallbackBehavior.FadeInOnLoad="True" />
                    </Border>
                </StackPanel>
            </sidebar:SidebarView.Footer>
        </sidebar:SidebarView>

        <!-- Player bar (docked at bottom). Detached state also suppresses this slot. -->
        <playerbar:PlayerBar
            x:Name="PlayerBarControl"
            Grid.Row="3"
            HorizontalAlignment="Stretch"
            Visibility="{x:Bind ViewModel.IsBottomPlayerVisibleInShell, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Bottom-right floating video mini-player. Lives outside the
             navigation Frame so the MediaPlayerElement underneath doesn't
             tear down on page navigation — that's the whole point of having
             it: video keeps playing while the user browses other pages. The
             control hides itself via Visibility binding to its VM, so an
             always-mounted instance is cheap when no video is active.
             Also forced-hidden in Theatre / Fullscreen — the expanded surface
             already owns the video, the PiP would be redundant. -->
        <minivideo:MiniVideoPlayer
            x:Name="MiniVideoPlayerControl"
            Grid.Row="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Visibility="{x:Bind ViewModel.IsMiniPlayerVisibleInShell, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            Margin="0,0,16,16"/>

        <!-- Right-edge "tear-off" tab. Surfaces when the user has dismissed
             the floating MiniVideoPlayer (X) but video keeps playing —
             gives them a way to bring playback back into view without
             stopping it. Inner Visibility is self-managed by the control
             from ViewModel.IsGripperVisible; the outer wrapper gate just
             hides it during Theatre / Fullscreen along with the Mini. -->
        <minivideo:VideoGripperView
            x:Name="VideoGripperControl"
            Grid.Row="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Visibility="{x:Bind ViewModel.IsMiniPlayerVisibleInShell, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- Theatre / Fullscreen overlay frame.
             Visible only when Presentation != Normal. RowSpan=4 + Canvas.ZIndex=10
             keep it above the entire shell grid so the player sees the whole
             window real estate. Navigated to VideoPlayerPage in code-behind on
             presentation change so a single source of truth (VideoPlayerPage)
             handles surface acquisition / scrim / dock — no XAML duplication.
             Background is solid black so the Mica backdrop doesn't bleed
             through the letterbox bars. -->
        <Border
            x:Name="TheatreOverlayHost"
            Grid.Row="0"
            Grid.RowSpan="4"
            Canvas.ZIndex="10"
            Background="Black"
            Visibility="{x:Bind ViewModel.IsExpandedPresentation, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Frame x:Name="TheatreFrame" Background="Transparent" />
        </Border>

        <Border
            x:Name="VideoMiniPlayerPromptAnchor"
            Grid.Row="2"
            Width="1"
            Height="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,186,140"
            Opacity="0"
            IsHitTestVisible="False"/>

        <TeachingTip
            x:Name="ShowVideoHereTeachingTip"
            Grid.Row="2"
            Title="Show video here?"
            Subtitle="A video is playing. Show the mini player in this window?"
            Target="{x:Bind VideoMiniPlayerPromptAnchor}"
            PreferredPlacement="TopRight"
            IsLightDismissEnabled="True"
            ActionButtonContent="Yes"
            CloseButtonContent="No"
            ActionButtonClick="ShowVideoHereTeachingTip_ActionButtonClick"
            CloseButtonClick="ShowVideoHereTeachingTip_CloseButtonClick"
            Closed="ShowVideoHereTeachingTip_Closed">
            <CheckBox
                x:Name="DoNotAskShowVideoHereCheckBox"
                Content="Don't ask me again"/>
        </TeachingTip>

    </Grid>
    </controls:ZoomContentControl>
</Page>
