<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.EpisodePage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:ui="using:CommunityToolkit.WinUI.Media"
    xmlns:winUi="using:CommunityToolkit.WinUI"
    xmlns:appControls="using:Wavee.UI.WinUI.Controls"
    xmlns:comments="using:Wavee.UI.WinUI.Controls.Comments"
    xmlns:dtos="using:Wavee.UI.WinUI.Data.DTOs"
    xmlns:rightPanel="using:Wavee.UI.WinUI.Controls.RightPanel"
    xmlns:showEpisode="using:Wavee.UI.WinUI.Controls.ShowEpisode"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True"/>
    </Page.Resources>

    <Grid>
        <!-- Palette wash on top of Mica. Same brush ShowPage uses; null → nothing renders. -->
        <Border IsHitTestVisible="False"
                Background="{x:Bind ViewModel.PaletteBackdropBrush, Mode=OneWay}"/>

        <!-- ══ LOADING SKELETON ════════════════════════════════════════════════
             Mirrors the hero shape so the user perceives layout stability the
             first frame. ScheduleCrossfade fades shimmer→content over ~300 ms. -->
        <Grid x:Name="ShimmerContainer"
              x:Load="{x:Bind ShimmerGate.IsLoaded, Mode=OneWay}"
              IsHitTestVisible="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="20,16,20,0"
                Padding="10,6"
                HorizontalAlignment="Left"
                CornerRadius="18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <controls:Shimmer Width="14" Height="14" CornerRadius="7"/>
                    <controls:Shimmer Width="190" Height="16" CornerRadius="4"/>
                </StackPanel>
            </Border>

            <ScrollView
                Grid.Row="1"
                ContentOrientation="Vertical"
                VerticalScrollMode="Disabled"
                VerticalScrollBarVisibility="Hidden"
                HorizontalScrollMode="Disabled"
                HorizontalScrollBarVisibility="Hidden">
                <StackPanel Spacing="24"
                            Margin="40,16,40,40"
                            MaxWidth="1160"
                            HorizontalAlignment="Stretch">
                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:Shimmer Grid.Column="0" Width="240" Height="240" CornerRadius="10"/>
                        <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <controls:Shimmer Width="88" Height="26" CornerRadius="13"/>
                                <controls:Shimmer Width="64" Height="26" CornerRadius="13"/>
                            </StackPanel>
                            <controls:Shimmer Width="520" Height="34" CornerRadius="6"/>
                            <controls:Shimmer Width="280" Height="17" CornerRadius="4"/>
                            <controls:Shimmer Width="220" Height="14" CornerRadius="4"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                                <controls:Shimmer Width="132" Height="44" CornerRadius="22"/>
                                <controls:Shimmer Width="44" Height="44" CornerRadius="22"/>
                                <controls:Shimmer Width="44" Height="44" CornerRadius="22"/>
                                <controls:Shimmer Width="44" Height="44" CornerRadius="22"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="32" RowSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.15*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="24">
                            <StackPanel Spacing="10">
                                <controls:Shimmer Width="180" Height="24" CornerRadius="6" HorizontalAlignment="Left"/>
                                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="18">
                                    <StackPanel Spacing="8">
                                        <controls:Shimmer Height="14" HorizontalAlignment="Stretch" CornerRadius="3"/>
                                        <controls:Shimmer Height="14" HorizontalAlignment="Stretch" CornerRadius="3" Margin="0,0,48,0"/>
                                        <controls:Shimmer Height="14" HorizontalAlignment="Stretch" CornerRadius="3" Margin="0,0,116,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Spacing="10">
                                <controls:Shimmer Width="128" Height="24" CornerRadius="6" HorizontalAlignment="Left"/>
                                <controls:Shimmer Height="84" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="88"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:Shimmer Grid.Column="0" Width="44" Height="12" CornerRadius="3" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <controls:Shimmer Grid.Column="1" Height="36" CornerRadius="6"/>
                                </Grid>
                                <StackPanel Spacing="12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:Shimmer Grid.Column="0" Width="36" Height="36" CornerRadius="18"/>
                                        <StackPanel Grid.Column="1" Spacing="7">
                                            <controls:Shimmer Width="220" Height="11" CornerRadius="3" HorizontalAlignment="Left"/>
                                            <controls:Shimmer Height="13" CornerRadius="3" HorizontalAlignment="Stretch" Margin="0,0,54,0"/>
                                            <controls:Shimmer Height="13" CornerRadius="3" HorizontalAlignment="Stretch" Margin="0,0,112,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:Shimmer Grid.Column="0" Width="36" Height="36" CornerRadius="18"/>
                                        <StackPanel Grid.Column="1" Spacing="7">
                                            <controls:Shimmer Width="180" Height="11" CornerRadius="3" HorizontalAlignment="Left"/>
                                            <controls:Shimmer Height="13" CornerRadius="3" HorizontalAlignment="Stretch" Margin="0,0,28,0"/>
                                            <controls:Shimmer Height="13" CornerRadius="3" HorizontalAlignment="Stretch" Margin="0,0,154,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="24">
                            <StackPanel Spacing="14">
                                <controls:Shimmer Width="112" Height="24" CornerRadius="6" HorizontalAlignment="Left"/>
                                <StackPanel Spacing="10">
                                    <controls:Shimmer Height="68" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                    <controls:Shimmer Height="68" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                    <controls:Shimmer Height="68" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Spacing="14">
                                <controls:Shimmer Width="170" Height="24" CornerRadius="6" HorizontalAlignment="Left"/>
                                <StackPanel Spacing="10">
                                    <controls:Shimmer Height="76" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                    <controls:Shimmer Height="76" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                    <controls:Shimmer Height="76" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollView>
        </Grid>

        <!-- ══ CONTENT ════════════════════════════════════════════════════════ -->
        <Grid x:Name="ContentContainer">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Breadcrumb sits above the scrolling area so it stays anchored.
                 Items are simple strings; the click handler decides where to go. -->
            <Border
                x:Name="EpisodeBreadcrumbContainer"
                Grid.Row="0"
                Margin="20,16,20,0"
                Padding="10,6"
                HorizontalAlignment="Left"
                CornerRadius="18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xEC05;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <muxc:BreadcrumbBar x:Name="EpisodeBreadcrumb"
                                        ItemsSource="{x:Bind ViewModel.BreadcrumbItems, Mode=OneWay}"
                                        ItemClicked="EpisodeBreadcrumb_ItemClicked"/>
                </StackPanel>
            </Border>

            <ScrollView x:Name="EpisodeScrollViewer"
                        Grid.Row="1"
                        ContentOrientation="Vertical"
                        VerticalScrollMode="Auto"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Disabled"
                        HorizontalScrollBarVisibility="Hidden">
                <StackPanel x:Name="EpisodeContentStack"
                            Spacing="24"
                            Margin="40,16,40,40"
                            MaxWidth="1160"
                            HorizontalAlignment="Stretch"
                            SizeChanged="EpisodeContentStack_SizeChanged">

                    <!-- ── HERO BLOCK ────────────────────────────────────────
                         Cover (240x240 square, shadow-lifted) on the left,
                         identity + CTAs stacked on the right. Min-width on the
                         text column means the hero never collapses awkwardly. -->
                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Cover. Drop shadow lifts it off the palette wash so the
                             episode reads as a tile, not a flat thumbnail. -->
                        <Grid x:Name="EpisodeCoverContainer"
                              Grid.Column="0"
                              Width="240"
                              Height="240"
                              VerticalAlignment="Top">
                            <winUi:Effects.Shadow>
                                <ui:AttachedCardShadow BlurRadius="32" Offset="0,12" Opacity="0.32"
                                                       Color="Black" CornerRadius="10"
                                                       InnerContentClipMode="CompositionMaskBrush"/>
                            </winUi:Effects.Shadow>
                            <Border CornerRadius="10"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Grid>
                                    <FontIcon Glyph="&#xE93E;" FontSize="64" Opacity="0.3"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Visibility="{x:Bind ViewModel.CoverArtUrl, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                    <Image Source="{x:Bind ViewModel.CoverArtUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='240'}"
                                           Stretch="UniformToFill"
                                           Visibility="{x:Bind ViewModel.CoverArtUrl, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Identity + CTAs. -->
                        <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Top">

                            <!-- Eyebrow row: EPISODE pill + optional #N. -->
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border CornerRadius="14"
                                        Padding="10,3,10,5"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                    <TextBlock Text="EPISODE"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                </Border>
                                <Border CornerRadius="14"
                                        Padding="10,3,10,5"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        Visibility="{x:Bind ViewModel.EpisodeNumberTag, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="{x:Bind ViewModel.EpisodeNumberTag, Mode=OneWay}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <!-- Title. Larger than ShowPage's 22pt because this is
                                 a single-item detail surface and the title carries
                                 most of the visual weight. -->
                            <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       LineHeight="34"
                                       TextWrapping="Wrap"
                                       MaxLines="3"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                            <!-- "From {show}" link → ShowPage. Hidden when no parent. -->
                            <HyperlinkButton Padding="0"
                                             Command="{x:Bind ViewModel.OpenShowCommand}"
                                             Visibility="{x:Bind ViewModel.HasParentShow, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="From"
                                               FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.ParentShowTitle, Mode=OneWay}"
                                               FontSize="13"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </HyperlinkButton>

                            <!-- Meta line + flags. -->
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{x:Bind ViewModel.MetaLine, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Border CornerRadius="3"
                                        Padding="4,0,4,1"
                                        Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                        VerticalAlignment="Center"
                                        Visibility="{x:Bind ViewModel.IsExplicit, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="E" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" Spacing="4"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind ViewModel.IsVideo, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <FontIcon Glyph="&#xE714;" FontSize="11"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="VIDEO" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action cluster: primary play CTA + secondaries. -->
                            <controls:WrapPanel Orientation="Horizontal" HorizontalSpacing="8" VerticalSpacing="8" Margin="0,12,0,0">
                                <Button Style="{StaticResource AccentButtonStyle}"
                                        Command="{x:Bind ViewModel.PlayCommand}"
                                        Padding="20,10" CornerRadius="22"
                                        ToolTipService.ToolTip="Play episode">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;" FontSize="14"/>
                                        <TextBlock Text="{x:Bind ViewModel.ListenActionText, Mode=OneWay}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                                <Button Click="LikeButton_Click"
                                        Width="44" Height="44" CornerRadius="22" Padding="0"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderThickness="0"
                                        ToolTipService.ToolTip="Save episode">
                                    <FontIcon Glyph="&#xEB51;" FontSize="14"/>
                                </Button>
                                <Button Click="QueueButton_Click"
                                        Width="44" Height="44" CornerRadius="22" Padding="0"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderThickness="0"
                                        ToolTipService.ToolTip="Add to queue">
                                    <FontIcon Glyph="&#xE823;" FontSize="14"/>
                                </Button>
                                <Button Command="{x:Bind ViewModel.ShareCommand}"
                                        Click="ShareButton_Click"
                                        IsEnabled="{x:Bind ViewModel.CanShare, Mode=OneWay}"
                                        Width="44" Height="44" CornerRadius="22" Padding="0"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderThickness="0"
                                        ToolTipService.ToolTip="Copy link to episode">
                                    <FontIcon Glyph="&#xE72D;" FontSize="14"/>
                                </Button>
                            </controls:WrapPanel>
                        </StackPanel>
                    </Grid>

                    <!-- ── DESCRIPTION ─────────────────────────────────────── -->
                    <Grid x:Name="EpisodeBodyGrid"
                          ColumnSpacing="32"
                          RowSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="EpisodeBodyPrimaryColumn" Width="2*"/>
                            <ColumnDefinition x:Name="EpisodeBodySecondaryColumn" Width="1.15*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel x:Name="EpisodeBodyPrimaryPanel"
                                    Grid.Column="0"
                                    Spacing="24">
                            <StackPanel Spacing="10"
                                        Visibility="{x:Bind ViewModel.HasDescription, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="About this episode"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           FontWeight="Bold"/>
                                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="18">
                                    <appControls:HtmlTextBlock Text="{x:Bind ViewModel.DescriptionHtml, Mode=OneWay}"
                                                               MaxLines="0"
                                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <comments:CommentsList
                                x:Name="EpisodeComments"
                                HeaderText="{x:Bind ViewModel.CommentsCountLabel, Mode=OneWay}"
                                Comments="{x:Bind ViewModel.Comments, Mode=OneWay}"
                                Draft="{x:Bind ViewModel.CommentDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                CharacterCount="{x:Bind ViewModel.CommentCharacterCount, Mode=OneWay}"
                                StatusText="{x:Bind ViewModel.CommentStatus, Mode=OneWay}"
                                IsSubmitEnabled="{x:Bind ViewModel.CanSubmitComment, Mode=OneWay}"
                                HasNoComments="{x:Bind ViewModel.HasNoComments, Mode=OneWay}"
                                IsLoadingMore="{x:Bind ViewModel.IsLoadingMoreComments, Mode=OneWay}"
                                HasMoreComments="{x:Bind ViewModel.HasMoreComments, Mode=OneWay}"
                                LoadMoreCommand="{x:Bind ViewModel.LoadMoreCommentsCommand, Mode=OneWay}"
                                SubmitRequested="EpisodeComments_SubmitRequested"
                                ShowReactionsRequested="EpisodeComments_ShowReactionsRequested"
                                ShowReplyReactionsRequested="EpisodeComments_ShowReplyReactionsRequested"
                                ReplySubmitRequested="EpisodeComments_ReplySubmitRequested"/>
                        </StackPanel>

                        <StackPanel x:Name="EpisodeBodySecondaryPanel"
                                    Grid.Column="1"
                                    Spacing="24">

                    <!-- ── CHAPTERS ─────────────────────────────────────────
                         Same column layout the right panel uses for the
                         playback chapter rail (timestamp + rail + content card),
                         tapping a row seeks the player to chapter start. -->
                    <StackPanel Spacing="14"
                                Visibility="{x:Bind ViewModel.HasChapters, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Chapters"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   FontWeight="Bold"/>
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Chapters, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="2"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:EpisodeChapterVm">
                                    <Button Tag="{x:Bind}"
                                            Click="ChapterButton_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            MinHeight="0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            ToolTipService.ToolTip="Seek to chapter"
                                            AutomationProperties.Name="{x:Bind Title}">
                                        <Grid ColumnSpacing="10" Padding="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind StartTime}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       Opacity="{x:Bind ChromeOpacity, Mode=OneWay}"
                                                       TextAlignment="Right"
                                                       TextWrapping="NoWrap"
                                                       VerticalAlignment="Center"/>
                                            <rightPanel:PodcastChapterTimelineRail Grid.Column="1"
                                                                                  Progress="{x:Bind TimelineCellProgress, Mode=OneWay}"
                                                                                  IsActive="{x:Bind IsActive, Mode=OneWay}"
                                                                                  IsCompleted="{x:Bind IsCompleted, Mode=OneWay}"
                                                                                  IsFirst="{x:Bind IsFirst}"
                                                                                  IsLast="{x:Bind IsLast}"/>
                                            <Border Grid.Column="2"
                                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12,8"
                                                    Opacity="{x:Bind ContentOpacity, Mode=OneWay}">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Text="{x:Bind ChapterLabel}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                               CharacterSpacing="80"/>
                                                    <TextBlock Text="{x:Bind Title}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               MaxLines="2"
                                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                    <TextBlock Text="{x:Bind Subtitle}"
                                                               FontSize="12"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               TextWrapping="Wrap"
                                                               MaxLines="2"
                                                               Visibility="{x:Bind Subtitle, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>

                    <!-- ── MORE FROM THIS SHOW ─────────────────────────────── -->
                    <StackPanel Spacing="14"
                                Visibility="{x:Bind ViewModel.HasMoreFromShow, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="More from this show"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <HyperlinkButton Grid.Column="1"
                                             Command="{x:Bind ViewModel.OpenShowCommand}"
                                             Content="See all"
                                             VerticalAlignment="Center"
                                             Padding="8,4"/>
                        </Grid>
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.MoreFromShow, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="10"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="dtos:ShowEpisodeDto">
                                    <showEpisode:ShowEpisodeRow
                                        Episode="{x:Bind}"
                                        CoverColorBrush="{Binding ElementName=PageRoot, Path=ViewModel.PaletteCoverColorBrush}"
                                        OpenRequested="SiblingEpisode_OpenRequested"
                                        PlayRequested="SiblingEpisode_PlayRequested"
                                        LikeRequested="SiblingEpisode_LikeRequested"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollView>
        </Grid>

        <!-- Error state — same surface as ShowPage. -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Padding="32"
                    Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <FontIcon Glyph="&#xE783;" FontSize="36" Opacity="0.6" HorizontalAlignment="Center"/>
            <TextBlock Text="We couldn't load this episode."
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="400"/>
        </StackPanel>
    </Grid>
</Page>
