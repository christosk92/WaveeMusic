<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.ArtistPage"
    x:Name="ArtistPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ic="using:FluentIcons.WinUI"
    xmlns:fa="using:FontAwesome6.Svg"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:track="using:Wavee.UI.WinUI.Controls.Track"
    xmlns:trackBehaviors="using:Wavee.UI.WinUI.Controls.Track.Behaviors"
    xmlns:hero="using:Wavee.UI.WinUI.Controls.HeroHeader"
    xmlns:layouts="using:Wavee.UI.WinUI.Controls.Layouts"
    xmlns:albumDetail="using:Wavee.UI.WinUI.Controls.AlbumDetailPanel"
    xmlns:controls1="using:Wavee.UI.WinUI.Controls"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:shelf="using:Wavee.UI.WinUI.Controls.Shelf"
    xmlns:transitions="using:CommunityToolkit.WinUI"
    xmlns:waveeHelpers="using:Wavee.UI.WinUI.Helpers"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PinnedItemNormalBackgroundBrush" Color="#66101010"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBackgroundBrush" Color="#88202020"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBackgroundBrush" Color="#AA050505"/>
                    <SolidColorBrush x:Key="PinnedItemNormalBorderBrush" Color="#44FFFFFF"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBorderBrush" Color="#88FFFFFF"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBorderBrush" Color="#BBFFFFFF"/>
                    <SolidColorBrush x:Key="PinnedItemForegroundBrush" Color="White"/>
                    <SolidColorBrush x:Key="PinnedItemAvatarBorderBrush" Color="#66FFFFFF"/>
                    <SolidColorBrush x:Key="ShyHeaderBorderBrush" Color="#66FFFFFF"/>
                    <SolidColorBrush x:Key="WorldRankBadgeBackgroundBrush" Color="#24FFFFFF"/>
                    <SolidColorBrush x:Key="WorldRankBadgeBorderBrush" Color="#45FFFFFF"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <!-- Inverted: bright translucent pill over the now white-scrimmed hero. -->
                    <SolidColorBrush x:Key="PinnedItemNormalBackgroundBrush" Color="#66F4F4F4"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBackgroundBrush" Color="#88EAEAEA"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBackgroundBrush" Color="#AADDDDDD"/>
                    <SolidColorBrush x:Key="PinnedItemNormalBorderBrush" Color="#33000000"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBorderBrush" Color="#66000000"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBorderBrush" Color="#99000000"/>
                    <SolidColorBrush x:Key="PinnedItemForegroundBrush" Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="PinnedItemAvatarBorderBrush" Color="#33000000"/>
                    <SolidColorBrush x:Key="ShyHeaderBorderBrush" Color="#33000000"/>
                    <!-- Bright translucent white pill — matches the Dark variant's
                         shape (#24FFFFFF / #45FFFFFF) since the hero scrim now
                         reads white-tinted in Light mode after the LightTint blend. -->
                    <SolidColorBrush x:Key="WorldRankBadgeBackgroundBrush" Color="#26FFFFFF"/>
                    <SolidColorBrush x:Key="WorldRankBadgeBorderBrush"     Color="#4DFFFFFF"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="PinnedItemNormalBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBackgroundBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBackgroundBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                    <SolidColorBrush x:Key="PinnedItemNormalBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                    <SolidColorBrush x:Key="PinnedItemHoverBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                    <SolidColorBrush x:Key="PinnedItemPressedBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                    <SolidColorBrush x:Key="PinnedItemForegroundBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                    <SolidColorBrush x:Key="PinnedItemAvatarBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                    <SolidColorBrush x:Key="ShyHeaderBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                    <SolidColorBrush x:Key="WorldRankBadgeBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}"/>
                    <SolidColorBrush x:Key="WorldRankBadgeBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True"/>
            <converters:BoolToGridListGlyphConverter x:Key="BoolToGridListGlyphConverter"/>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:NullToForegroundConverter x:Key="NullToForegroundConverter"/>

        <!-- Shy-header morph: hero overlay panel <-> floating compact card.
             Matched ids on inner avatar/name/badge/meta/play/follow elements
             interpolate between the two states. Unpaired chrome (the floating
             card border) fades in via the helper's independent show animation. -->
        <transitions:TransitionHelper x:Key="ArtistShyHeaderTransition"
                                      Duration="0:0:0.36"
                                      ReverseDuration="0:0:0.30"
                                      DefaultEasingMode="EaseInOut"
                                      SourceToggleMethod="ByVisibility"
                                      TargetToggleMethod="ByVisibility"
                                      IndependentElementShowDuration="0:0:0.18"
                                      IndependentElementShowDelay="0:0:0.10"
                                      IndependentElementHideDuration="0:0:0.12"
                                      IsHitTestVisibleWhenAnimating="False">
            <transitions:TransitionConfig Id="card-shell" ScaleMode="Scale"/>
            <transitions:TransitionConfig Id="artist-avatar" ScaleMode="Scale"/>
            <transitions:TransitionConfig Id="artist-name" ScaleMode="Custom">
                <transitions:TransitionConfig.CustomScalingCalculator>
                    <waveeHelpers:TransitionTextScalingCalculator/>
                </transitions:TransitionConfig.CustomScalingCalculator>
            </transitions:TransitionConfig>
            <transitions:TransitionConfig Id="artist-badge" ScaleMode="Scale"/>
            <transitions:TransitionConfig Id="artist-meta" ScaleMode="Custom">
                <transitions:TransitionConfig.CustomScalingCalculator>
                    <waveeHelpers:TransitionTextScalingCalculator/>
                </transitions:TransitionConfig.CustomScalingCalculator>
            </transitions:TransitionConfig>
            <transitions:TransitionConfig Id="artist-play" ScaleMode="Scale"/>
            <transitions:TransitionConfig Id="artist-follow" ScaleMode="Scale"/>
        </transitions:TransitionHelper>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <ScrollView x:Name="PageScrollView">
            <Grid>
            <Grid.RowDefinitions>
                <!-- Window-driven height set in OnSizeChanged (45% of page,
                     min 200). Min/Max preserved as guard rails. -->
                <RowDefinition x:Name="HeroRow" Height="300" MinHeight="280" MaxHeight="700"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page tint wash — gets a LinearGradientBrush derived from HeaderHeroColorHex
                 so the artist's palette color extends past the hero into the content area.
                 Fill is assigned from code-behind whenever the hex changes. -->
            <Rectangle x:Name="PageTintFill"
                       Grid.Row="0"
                       Grid.RowSpan="4"
                       VerticalAlignment="Top"
                       Height="600"
                       IsHitTestVisible="False"/>

            <!-- HERO HEADER -->
            <hero:HeroHeader x:Name="HeroGrid"
                             Grid.Row="0"
                             ImageUrl="{x:Bind ViewModel.HeaderImageUrl, Mode=OneWay}"
                             ColorHex="{x:Bind ViewModel.HeaderHeroColorHex, Mode=OneWay}"
                             MinHeight="280"
                             InitialScale="1.0"
                             FinalScale="1.05"
                             AnimationDuration="0:0:0.8"
                             FadeStart="0.55"
                             FadeEnd="0.95">
                <hero:HeroHeader.OverlayContent>
                    <!-- Grid wrapper hosts the source-side matched-id chrome
                         alongside the visible content. The chrome itself is invisible
                         here (transparent fill, no border) — it exists purely to give
                         TransitionHelper a source bounds to morph the floating card
                         chrome FROM. -->
                    <Grid x:Name="HeroOverlayPanel">
                        <Border transitions:TransitionHelper.Id="card-shell"
                                Background="Transparent"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>

                        <StackPanel Padding="32,0,32,24" Spacing="8"
                                    VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <!-- Avatar wrapper — fixed at 136 (120 avatar + 16 gap). The
                                 avatar is always visible regardless of whether the artist has
                                 a hero header image; they're complementary (banner vs portrait). -->
                            <Grid x:Name="AvatarWrapper" Width="136">
                                <!-- Avatar / Watch Feed Video (connected animation target) -->
                                <Grid x:Name="ArtistImageContainer"
                                      Width="120"
                                      Height="120"
                                      HorizontalAlignment="Left"
                                      transitions:TransitionHelper.Id="artist-avatar">
                                <Border CornerRadius="60" Width="120" Height="120"
                                        BorderBrush="{x:Bind ViewModel.PaletteAccentPillBrush, Mode=OneWay}"
                                        BorderThickness="3">
                                    <Border.Shadow>
                                        <ThemeShadow/>
                                    </Border.Shadow>
                                    <Grid>
                                        <!-- Static artist image (always present, video fades in on top) -->
                                        <Ellipse x:Name="ArtistImageEllipse" Width="120" Height="120">
                                            <Ellipse.Fill>
                                                <ImageBrush
                                                    ImageSource="{x:Bind ViewModel.ArtistImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=120}"
                                                    Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!-- Watch feed video (fades in over artist image when ready) -->
                                        <Grid x:Name="WatchFeedGrid" Opacity="0"/>

                                        <!-- Hover overlay (shows play icon on hover, hidden until video loads) -->
                                        <Border x:Name="WatchFeedHoverOverlay" CornerRadius="60" Opacity="0"
                                                Background="#60000000" Visibility="Collapsed"
                                                PointerEntered="WatchFeedOverlay_PointerEntered"
                                                PointerExited="WatchFeedOverlay_PointerExited"
                                                Tapped="WatchFeedOverlay_Tapped">
                                            <FontIcon Glyph="&#xE768;" FontSize="28" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                </Grid>
                            </Grid>

                            <StackPanel VerticalAlignment="Bottom" Spacing="6">
                                <!-- Eyebrow: "ARTIST · VERIFIED" small caps, secondary
                                     color. Lives above the name as an info ribbon —
                                     more Fluent than a floating circle badge. -->
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,2"
                                            Visibility="{x:Bind ViewModel.ArtistName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Border CornerRadius="12"
                                            Padding="8,3"
                                            Background="{ThemeResource WorldRankBadgeBackgroundBrush}"
                                            BorderBrush="{ThemeResource WorldRankBadgeBorderBrush}"
                                            BorderThickness="1"
                                            Visibility="{x:Bind ViewModel.HasWorldRank, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="WORLD RANK"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       CharacterSpacing="120"
                                                       Foreground="{x:Bind ViewModel.HeaderImageUrl, Mode=OneWay, Converter={StaticResource NullToForegroundConverter}}"
                                                       Opacity=".78"/>
                                            <TextBlock Text="{x:Bind ViewModel.WorldRankNumberText, Mode=OneWay}"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="ARTIST"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               CharacterSpacing="120"
                                               Foreground="{x:Bind ViewModel.HeaderImageUrl, Mode=OneWay, Converter={StaticResource NullToForegroundConverter}}"
                                               Opacity=".75"
                                               Visibility="{x:Bind ViewModel.HasWorldRank, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4"
                                                VerticalAlignment="Center"
                                                Visibility="{x:Bind ViewModel.IsVerified, Mode=OneWay}"
                                                transitions:TransitionHelper.Id="artist-badge">
                                        <TextBlock Text="·"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{x:Bind ViewModel.HeaderImageUrl, Mode=OneWay, Converter={StaticResource NullToForegroundConverter}}"
                                                   Opacity=".55"/>
                                        <FontIcon Glyph="&#xE73E;"
                                                  FontSize="11"
                                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="VERIFIED"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   CharacterSpacing="120"
                                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Name: show text or shimmer -->
                                <Grid>
                                    <TextBlock Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}"
                                               Style="{StaticResource TitleLargeTextBlockStyle}"
                                               FontWeight="Bold"
                                               Foreground="{x:Bind ViewModel.HeaderImageUrl, Mode=OneWay, Converter={StaticResource NullToForegroundConverter}}"
                                               transitions:TransitionHelper.Id="artist-name"
                                               Visibility="{x:Bind ViewModel.ArtistName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <controls:Shimmer Width="280" Height="36" HorizontalAlignment="Left"
                                                      Visibility="{x:Bind ViewModel.ArtistName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                </Grid>

                                <!-- Stats row: monthly · followers, bullet-separated -->
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                Visibility="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                                transitions:TransitionHelper.Id="artist-meta">
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{x:Bind ViewModel.HeaderImageUrl, Mode=OneWay, Converter={StaticResource NullToForegroundConverter}}"
                                                   Opacity=".9">
                                            <Run Text="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay}"/><Run x:Uid="Views_ArtistPage__Run_1" Text=" monthly listeners"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <controls:Shimmer Width="160" Height="16" HorizontalAlignment="Left"
                                                      Visibility="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- Action buttons row — Play (palette-tinted accent) +
                             outline Follow + icon-only Share + More menu. Fluent
                             button hierarchy: one primary, one secondary, two
                             tertiary icons. Less heavy than the previous big
                             frosted-glass Follow chrome. -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0"
                                    VerticalAlignment="Bottom">
                            <Button Style="{StaticResource AccentButtonStyle}"
                                    Background="{x:Bind ViewModel.PaletteAccentPillBrush, Mode=OneWay}"
                                    Foreground="{x:Bind ViewModel.PaletteAccentPillForegroundBrush, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.PlayTopTracksCommand}"
                                    VerticalAlignment="Center"
                                    Padding="20,10" CornerRadius="20"
                                    transitions:TransitionHelper.Id="artist-play">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <playback:PlaybackActionContent IconSize="16"
                                                                   SpinnerSize="16"
                                                                   IsPlaying="{x:Bind ViewModel.IsArtistContextPlaying, Mode=OneWay}"
                                                                   IsPending="{x:Bind ViewModel.IsPlayPending, Mode=OneWay}"
                                                                   ActionForeground="{x:Bind ViewModel.PaletteAccentPillForegroundBrush, Mode=OneWay}"/>
                                    <TextBlock x:Uid="Views_ArtistPage__TextBlock_2"
                                               Text="{x:Bind ViewModel.ArtistPlayButtonText, Mode=OneWay}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{x:Bind ViewModel.ToggleFollowCommand}"
                                    VerticalAlignment="Center"
                                    Padding="16,10" CornerRadius="20"
                                    transitions:TransitionHelper.Id="artist-follow">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="{x:Bind ViewModel.IsFollowing, Mode=OneWay, Converter={StaticResource BoolToFollowGlyphConverter}}" FontSize="14"/>
                                    <TextBlock Text="{x:Bind ViewModel.IsFollowing, Mode=OneWay, Converter={StaticResource BoolToFollowTextConverter}}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SubtleButtonStyle}"
                                    VerticalAlignment="Center"
                                    Width="40" Height="40"
                                    Padding="0"
                                    CornerRadius="20"
                                    ToolTipService.ToolTip="Share"
                                    Click="ShareArtist_Click">
                                <FontIcon Glyph="&#xE72D;" FontSize="14"/>
                            </Button>
                            <Button Style="{StaticResource SubtleButtonStyle}"
                                    VerticalAlignment="Center"
                                    Width="40" Height="40"
                                    Padding="0"
                                    CornerRadius="20"
                                    ToolTipService.ToolTip="More">
                                <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Copy link to artist" Click="CopyArtistLink_Click">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE71B;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="Open in Spotify" Click="OpenInSpotify_Click">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8A7;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                        </StackPanel>
                        </StackPanel>
                    </Grid>
                </hero:HeroHeader.OverlayContent>
            </hero:HeroHeader>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- SHIMMER LOADING SKELETON (sections below hero)  -->
            <!-- ═══════════════════════════════════════════════ -->
            <!-- Shares Row 3 with ContentContainer so the two overlap in the same
                 layout slot. Stacking them in different rows caused content to
                 jump upward when shimmer collapsed. -->
            <StackPanel x:Name="ShimmerContainer"
                        x:Load="{x:Bind ShimmerGate.IsLoaded, Mode=OneWay}"
                        Grid.Row="3" VerticalAlignment="Top">
                <!-- Top tracks shimmer -->
                <StackPanel Padding="32,24,32,0" Spacing="12">
                    <controls:Shimmer Width="140" Height="22" HorizontalAlignment="Left"/>
                    <StackPanel Spacing="4">
                        <Grid Height="56" Padding="8,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="4"/>
                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                <controls:Shimmer Width="200" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="120" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                        <Grid Height="56" Padding="8,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="4"/>
                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                <controls:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="100" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                        <Grid Height="56" Padding="8,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="4"/>
                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                <controls:Shimmer Width="220" Height="14" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="140" Height="12" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
                <!-- Albums shelf shimmer -->
                <StackPanel Padding="32,24,32,0" Spacing="12">
                    <controls:Shimmer Width="120" Height="22" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="60" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="100" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="140" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="70" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="110" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="55" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <!-- Singles shelf shimmer -->
                <StackPanel Padding="32,24,32,0" Spacing="12">
                    <controls:Shimmer Width="100" Height="22" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="130" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="55" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="100" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="65" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <controls:Shimmer Width="160" Height="160" CornerRadius="8"/>
                            <controls:Shimmer Width="140" Height="14" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="60" Height="12" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <!-- Related artists shimmer (circular avatars) -->
                <StackPanel Padding="32,24,32,0" Spacing="12">
                    <controls:Shimmer Width="140" Height="22" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <controls:Shimmer Width="140" Height="140" CornerRadius="70"/>
                            <controls:Shimmer Width="100" Height="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <controls:Shimmer Width="140" Height="140" CornerRadius="70"/>
                            <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <controls:Shimmer Width="140" Height="140" CornerRadius="70"/>
                            <controls:Shimmer Width="90" Height="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <controls:Shimmer Width="140" Height="140" CornerRadius="70"/>
                            <controls:Shimmer Width="110" Height="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <controls:Shimmer Width="140" Height="140" CornerRadius="70"/>
                            <controls:Shimmer Width="130" Height="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <!-- Biography shimmer -->
                <StackPanel Padding="32,24,32,32" Spacing="12">
                    <controls:Shimmer Width="100" Height="22" HorizontalAlignment="Left"/>
                    <StackPanel Spacing="8">
                        <controls:Shimmer Height="14" HorizontalAlignment="Stretch"/>
                        <controls:Shimmer Height="14" HorizontalAlignment="Stretch"/>
                        <controls:Shimmer Width="600" Height="14" HorizontalAlignment="Left"/>
                        <controls:Shimmer Height="14" HorizontalAlignment="Stretch"/>
                        <controls:Shimmer Width="420" Height="14" HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- CONTENT SECTIONS (fades in after shimmer)       -->
            <!-- ═══════════════════════════════════════════════ -->
            <StackPanel x:Name="ContentContainer" Grid.Row="3" Padding="32,24,32,32" Spacing="32">

                <!-- ─── Top Tracks (Apple Music grid style) ───
                     Wrapped in a 2-column Grid so a Pinned item card can sit
                     to the left when the artist has one. When no pinned item
                     the left column collapses (Auto width = 0) and the top
                     tracks stack uses the full width as before. -->
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <!-- Bound to VM so the column resolves to its final width
                             before ContentContainer flips Visible at the start of
                             the crossfade. An x:Load expansion 0→280 mid-fade
                             previously slid the top tracks column sideways. -->
                        <ColumnDefinition Width="{x:Bind ViewModel.PinnedColumnWidth, Mode=OneWay}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Pinned vertical card (left of Top Tracks) ──
                         Same layered chrome as the prior hero card (image +
                         scrim + palette gradient + content + comment bubble),
                         but stacked vertically: image fills the whole card,
                         text/bubble/play button overlay at the bottom. -->
                    <Border Grid.Column="0"
                            x:Name="PinnedTopTracksCard"
                            Width="280"
                            VerticalAlignment="Stretch"
                            CornerRadius="12"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            x:Load="{x:Bind ViewModel.HasPinnedItem, Mode=OneWay}">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <Border CornerRadius="11">
                            <Grid>
                                <!-- Layer 1: backdrop -->
                                <Image Stretch="UniformToFill"
                                       Source="{x:Bind ViewModel.PinnedBackdropImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=480}"/>

                                <!-- Layer 2: vertical scrim — bottom is dark
                                     for text legibility, top fades into the
                                     image so the photo breathes. -->
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#00000000" Offset="0"/>
                                            <GradientStop Color="#60000000" Offset="0.4"/>
                                            <GradientStop Color="#E0000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <!-- Layer 3: palette gradient overlay -->
                                <Border Background="{x:Bind ViewModel.PaletteHeroGradientBrush, Mode=OneWay}"/>

                                <!-- Layer 4: invisible tap target -->
                                <Button Style="{StaticResource SubtleButtonStyle}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Padding="0"
                                        CornerRadius="11"
                                        Background="Transparent"
                                        Click="PinnedItem_Click"
                                        ToolTipService.ToolTip="{x:Bind ViewModel.PinnedItem.Comment, Mode=OneWay}"/>

                                <!-- Layer 5: content overlay anchored bottom -->
                                <StackPanel Padding="14,12,14,12"
                                            VerticalAlignment="Bottom"
                                            Spacing="4"
                                            IsHitTestVisible="False">
                                    <TextBlock FontSize="10"
                                               FontWeight="SemiBold"
                                               CharacterSpacing="120"
                                               Foreground="#B0FFFFFF"
                                               TextTrimming="CharacterEllipsis" MaxLines="1">
                                        <Run Text="PINNED · "/>
                                        <Run Text="{x:Bind ViewModel.PinnedItem.Subtitle, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{x:Bind ViewModel.PinnedItem.Title, Mode=OneWay}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2"
                                               LineHeight="22"/>

                                    <!-- Comment chat bubble — chat-tail corner,
                                         soft white-translucent acrylic, italic. -->
                                    <Border Margin="0,4,0,0"
                                            Padding="10,6,10,7"
                                            CornerRadius="4,12,12,12"
                                            BorderBrush="#33FFFFFF"
                                            BorderThickness="1"
                                            HorizontalAlignment="Left"
                                            Visibility="{x:Bind ViewModel.HasPinnedComment, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Border.Background>
                                            <AcrylicBrush TintColor="White"
                                                          TintOpacity="0.10"
                                                          FallbackColor="#22FFFFFF"/>
                                        </Border.Background>
                                        <TextBlock Text="{x:Bind ViewModel.PinnedItem.Comment, Mode=OneWay}"
                                                   FontSize="11.5"
                                                   FontStyle="Italic"
                                                   Foreground="#F5FFFFFF"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="3"
                                                   LineHeight="15"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- ── Top Tracks (right column when paired with pinned,
                         full-width otherwise) ── -->
                    <StackPanel Grid.Column="1" x:Name="TopTracksSection" Spacing="12" Tapped="TopTracksSection_Tapped">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="3" MinHeight="22" CornerRadius="1.5"
                                        VerticalAlignment="Stretch"
                                        Background="{x:Bind ViewModel.SectionAccentBrush, Mode=OneWay}"/>
                                <TextBlock x:Uid="Views_ArtistPage__TextBlock_3" Text="Top Tracks" FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                                <HyperlinkButton x:Uid="Views_ArtistPage__HyperlinkButton_4" Content="Show all >" Padding="4,0"
                                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                 VerticalAlignment="Center"/>
                            </StackPanel>
                            <PipsPager x:Name="TopTracksPipsPager"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       NumberOfPages="{x:Bind ViewModel.TotalPages, Mode=OneWay}"
                                       SelectedPageIndex="{x:Bind ViewModel.CurrentPage, Mode=TwoWay}"
                                       PreviousButtonVisibility="Visible"
                                       NextButtonVisibility="Visible"/>
                        </Grid>

                        <!-- Top tracks grid (column-first, max 3 rows) -->
                        <ItemsRepeater x:Name="TopTracksRepeater" ItemsSource="{x:Bind ViewModel.PagedTopTracks, Mode=OneWay}"
                                        ElementPrepared="TopTracksRepeater_ElementPrepared">
                            <ItemsRepeater.Layout>
                                <layouts:ColumnsFirstGridLayout x:Name="TopTracksLayout" MaxRows="3" MinItemWidth="280"
                                                                ItemHeight="56" RowSpacing="4" ColumnSpacing="8"
                                                                ColumnCountChanged="TopTracksLayout_ColumnCountChanged"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:LazyTrackItem">
                                    <track:TrackItem
                                        Track="{x:Bind Data, Mode=OneWay}"
                                        IsLoading="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                        IsSelected="{x:Bind IsSelected, Mode=OneWay}"
                                        PlayCommand="{Binding ViewModel.PlayTrackCommand, ElementName=ArtistPageRoot}"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Grid>

                <!-- ─── Albums ─── -->
                <StackPanel x:Name="AlbumsSection"
                            Spacing="12"
                            x:Load="{x:Bind ViewModel.HasAlbums, Mode=OneWay}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="3" MinHeight="22" CornerRadius="1.5"
                                    VerticalAlignment="Stretch"
                                    Background="{x:Bind ViewModel.SectionAccentBrush, Mode=OneWay}"/>
                            <TextBlock FontWeight="Bold" FontSize="20" VerticalAlignment="Center">
                                <Run x:Uid="Views_ArtistPage__Run_5" Text="Albums"/>
                                <Run Text=" · " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Run Text="{x:Bind ViewModel.AlbumsTotalCount, Mode=OneWay}"
                                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6"
                                    ToolTipService.ToolTip="Card size">
                                <FontIcon Glyph="&#xE71E;" FontSize="14"/>
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <StackPanel Width="220" Spacing="6" Padding="8">
                                            <TextBlock Text="Card size"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       FontSize="13"/>
                                            <Slider Minimum="0.7" Maximum="1.6"
                                                    StepFrequency="0.05" SmallChange="0.05"
                                                    LargeChange="0.1" TickFrequency="0.1"
                                                    Value="{x:Bind ViewModel.DiscographyGridScale, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6"
                                    Command="{x:Bind ViewModel.ToggleAlbumsViewCommand}">
                                <FontIcon Glyph="{x:Bind ViewModel.AlbumsGridView, Mode=OneWay, Converter={StaticResource BoolToGridListGlyphConverter}}" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- ── Latest release rich card ── Fluent surface chrome
                         (CardBackgroundFillColorDefaultBrush + 1px stroke, no
                         backdrop image / no scrim — keeps visual language
                         aligned with the SettingsCards used elsewhere). 64×64
                         cover + eyebrow + title on the left, palette-tinted
                         Play + subtle Open buttons on the right. Whole card
                         click → open the album. Collapsed when no release. -->
                    <Border x:Name="LatestReleaseCard"
                            CornerRadius="10"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="12"
                            Visibility="{x:Bind ViewModel.HasLatestRelease, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    Padding="0"
                                    CornerRadius="6"
                                    Click="LatestRelease_Click"
                                    ToolTipService.ToolTip="Open album">
                                <Border Width="64" Height="64"
                                        CornerRadius="6"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <Image Stretch="UniformToFill"
                                           Source="{x:Bind ViewModel.LatestReleaseImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=120}"/>
                                </Border>
                            </Button>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                <!-- Two siblings instead of <Run>s in one TextBlock — Run.Text doesn't
                                     reliably refresh from x:Bind property changes in WinUI 3, which
                                     made this card stay stuck on the previous artist's release. -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               CharacterSpacing="120"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               Text="NEW RELEASE · "/>
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               CharacterSpacing="120"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"
                                               Text="{x:Bind ViewModel.LatestReleaseSubtitle, Mode=OneWay}"/>
                                </StackPanel>
                                <HyperlinkButton Click="LatestRelease_Click"
                                                 Padding="0" Margin="0"
                                                 HorizontalAlignment="Left">
                                    <TextBlock Text="{x:Bind ViewModel.LatestReleaseName, Mode=OneWay}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                </HyperlinkButton>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Button Style="{StaticResource AccentButtonStyle}"
                                        Background="{x:Bind ViewModel.PaletteAccentPillBrush, Mode=OneWay}"
                                        Foreground="{x:Bind ViewModel.PaletteAccentPillForegroundBrush, Mode=OneWay}"
                                        Click="PlayLatestRelease_Click"
                                        Padding="14,8"
                                        CornerRadius="18">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;" FontSize="11"/>
                                        <TextBlock Text="Play"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SubtleButtonStyle}"
                                        Click="LatestRelease_Click"
                                        Width="36" Height="36"
                                        Padding="0"
                                        CornerRadius="18"
                                        ToolTipService.ToolTip="Open album">
                                    <FontIcon Glyph="&#xE8A7;" FontSize="13"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Grid view (wrapping multi-row, click to expand inline) -->
                    <ItemsRepeater x:Name="AlbumsGridRepeater"
                                   ItemsSource="{x:Bind ViewModel.Albums, Mode=OneWay}"
                                   ElementClearing="DiscographyRepeater_ElementClearing"
                                   Visibility="{x:Bind ViewModel.AlbumsGridView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <!-- MinItemWidth/Height come from ViewModel.DiscographyGridScale × base size
                                 via GridScaleToSizeConverter. The size slider in the section header
                                 (next to the grid/list toggle) writes the scale. UniformGridLayout's
                                 properties don't evaluate x:Bind reliably so we use ElementName binding
                                 against the page's named root, ArtistPageRoot. -->
                            <UniformGridLayout
                                MinItemWidth="{Binding ElementName=ArtistPageRoot, Path=ViewModel.DiscographyGridScale, Converter={StaticResource GridScaleToSizeConverter}, ConverterParameter=160}"
                                MinItemHeight="{Binding ElementName=ArtistPageRoot, Path=ViewModel.DiscographyGridScale, Converter={StaticResource GridScaleToSizeConverter}, ConverterParameter=220}"
                                MinRowSpacing="12" MinColumnSpacing="12"
                                ItemsStretch="Uniform"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid>
                                    <cards:ContentCard
                                        Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ImageUrl="{x:Bind Data.ImageUrl, Mode=OneWay}"
                                        Title="{x:Bind Data.Name, Mode=OneWay}"
                                        Subtitle="{x:Bind Data.Year, Mode=OneWay}"
                                        PlaceholderColorHex="{x:Bind Data.ColorHex, Mode=OneWay}"
                                        CardClick="AlbumCard_Click"
                                        CardHover="AlbumCard_Hover"/>
                                    <StackPanel Spacing="8" Padding="8"
                                                Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <controls:Shimmer Height="150" CornerRadius="8"/>
                                        <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                                        <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <!-- List view -->
                    <ItemsRepeater x:Name="AlbumsListRepeater"
                                   ItemsSource="{x:Bind ViewModel.Albums, Mode=OneWay}"
                                   ElementClearing="DiscographyRepeater_ElementClearing"
                                   Visibility="{x:Bind ViewModel.AlbumsGridView, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="2"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid Padding="8,6" ColumnSpacing="12" CornerRadius="4"
                                      Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <Image Source="{x:Bind Data.ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=48}"
                                               Stretch="UniformToFill"
                                               behaviors:ImageFallbackBehavior.HideOnError="True"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Data.Name, Mode=OneWay}" FontWeight="SemiBold" MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" FontSize="13"/>
                                        <TextBlock Text="{x:Bind Data.Year, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind Data.TrackCount, Mode=OneWay}"/>
                                        <Run x:Uid="Views_ArtistPage__Run_6" Text=" tracks"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <controls1:ErrorStateView x:Uid="Views_ArtistPage__ErrorStateView_7"
                        Visibility="{x:Bind ViewModel.HasAlbumsError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Title="Couldn't load all albums"
                        Message="Some albums may be missing"
                        RetryCommand="{x:Bind ViewModel.RetryDiscographyCommand}"
                        HorizontalAlignment="Left"
                        Padding="0,4,0,0"/>
                </StackPanel>

                <!-- ─── Singles ─── -->
                <StackPanel x:Name="SinglesSection"
                            Spacing="12"
                            x:Load="{x:Bind ViewModel.HasSingles, Mode=OneWay}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="3" MinHeight="22" CornerRadius="1.5"
                                    VerticalAlignment="Stretch"
                                    Background="{x:Bind ViewModel.SectionAccentBrush, Mode=OneWay}"/>
                            <TextBlock FontWeight="Bold" FontSize="20" VerticalAlignment="Center">
                                <Run x:Uid="Views_ArtistPage__Run_8" Text="Singles &amp; EPs"/>
                                <Run Text=" · " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Run Text="{x:Bind ViewModel.SinglesTotalCount, Mode=OneWay}"
                                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6"
                                    ToolTipService.ToolTip="Card size">
                                <FontIcon Glyph="&#xE71E;" FontSize="14"/>
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <StackPanel Width="220" Spacing="6" Padding="8">
                                            <TextBlock Text="Card size"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       FontSize="13"/>
                                            <Slider Minimum="0.7" Maximum="1.6"
                                                    StepFrequency="0.05" SmallChange="0.05"
                                                    LargeChange="0.1" TickFrequency="0.1"
                                                    Value="{x:Bind ViewModel.DiscographyGridScale, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="8,6"
                                    Command="{x:Bind ViewModel.ToggleSinglesViewCommand}">
                                <FontIcon Glyph="{x:Bind ViewModel.SinglesGridView, Mode=OneWay, Converter={StaticResource BoolToGridListGlyphConverter}}" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <!-- Grid view (wrapping multi-row, click to expand inline) -->
                    <ItemsRepeater x:Name="SinglesGridRepeater"
                                   ItemsSource="{x:Bind ViewModel.Singles, Mode=OneWay}"
                                   ElementClearing="DiscographyRepeater_ElementClearing"
                                   Visibility="{x:Bind ViewModel.SinglesGridView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <!-- Same scale-driven sizing as Albums; both grids share
                                 ViewModel.DiscographyGridScale so they always move in sync. -->
                            <UniformGridLayout
                                MinItemWidth="{Binding ElementName=ArtistPageRoot, Path=ViewModel.DiscographyGridScale, Converter={StaticResource GridScaleToSizeConverter}, ConverterParameter=160}"
                                MinItemHeight="{Binding ElementName=ArtistPageRoot, Path=ViewModel.DiscographyGridScale, Converter={StaticResource GridScaleToSizeConverter}, ConverterParameter=220}"
                                MinRowSpacing="12" MinColumnSpacing="12"
                                ItemsStretch="Uniform"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid>
                                    <cards:ContentCard
                                        Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ImageUrl="{x:Bind Data.ImageUrl, Mode=OneWay}"
                                        Title="{x:Bind Data.Name, Mode=OneWay}"
                                        Subtitle="{x:Bind Data.Year, Mode=OneWay}"
                                        PlaceholderColorHex="{x:Bind Data.ColorHex, Mode=OneWay}"
                                        CardClick="AlbumCard_Click"
                                        CardHover="AlbumCard_Hover"/>
                                    <StackPanel Spacing="8" Padding="8"
                                                Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <controls:Shimmer Height="150" CornerRadius="8"/>
                                        <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                                        <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <!-- List view -->
                    <ItemsRepeater x:Name="SinglesListRepeater"
                                   ItemsSource="{x:Bind ViewModel.Singles, Mode=OneWay}"
                                   ElementClearing="DiscographyRepeater_ElementClearing"
                                   Visibility="{x:Bind ViewModel.SinglesGridView, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="2"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid Padding="8,6" ColumnSpacing="12" CornerRadius="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <Image Source="{x:Bind Data.ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=48}"
                                               Stretch="UniformToFill"
                                               behaviors:ImageFallbackBehavior.HideOnError="True"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Data.Name, Mode=OneWay}" FontWeight="SemiBold" MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" FontSize="13"/>
                                        <TextBlock Text="{x:Bind Data.Year, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind Data.TrackCount, Mode=OneWay}"/><Run x:Uid="Views_ArtistPage__Run_9" Text=" tracks"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <controls1:ErrorStateView x:Uid="Views_ArtistPage__ErrorStateView_10"
                        Visibility="{x:Bind ViewModel.HasSinglesError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Title="Couldn't load all singles"
                        Message="Some singles may be missing"
                        RetryCommand="{x:Bind ViewModel.RetryDiscographyCommand}"
                        HorizontalAlignment="Left"
                        Padding="0,4,0,0"/>
                </StackPanel>

                <!-- ─── Compilations ─── -->
                <StackPanel x:Name="CompilationsSection"
                            Spacing="12"
                            x:Load="{x:Bind ViewModel.HasCompilations, Mode=OneWay}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Border Width="3" MinHeight="22" CornerRadius="1.5"
                                    VerticalAlignment="Stretch"
                                    Background="{x:Bind ViewModel.SectionAccentBrush, Mode=OneWay}"/>
                            <TextBlock FontWeight="Bold" FontSize="20" VerticalAlignment="Center">
                                <Run x:Uid="Views_ArtistPage__Run_11" Text="Compilations"/>
                                <Run Text=" · " Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Run Text="{x:Bind ViewModel.CompilationsTotalCount, Mode=OneWay}"
                                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </TextBlock>
                            <HyperlinkButton x:Uid="Views_ArtistPage__HyperlinkButton_12" Content="Show all >" Padding="4,0"
                                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                             VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                    Visibility="{x:Bind CompilationsShelf.HasOverflow, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button Style="{StaticResource ShelfChevronButtonStyle}"
                                    Command="{x:Bind CompilationsShelf.PageLeftCommand, Mode=OneTime}">
                                <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                            </Button>
                            <Button Style="{StaticResource ShelfChevronButtonStyle}"
                                    Command="{x:Bind CompilationsShelf.PageRightCommand, Mode=OneTime}">
                                <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <shelf:ShelfScroller x:Name="CompilationsShelf"
                                         ItemsSource="{x:Bind ViewModel.Compilations, Mode=OneWay}"
                                         MinItemWidth="160" MaxItemWidth="200" Spacing="12">
                        <shelf:ShelfScroller.ItemTemplate>
                            <DataTemplate x:DataType="vm:LazyReleaseItem">
                                <Grid Width="160">
                                    <!-- Loaded: real card -->
                                    <cards:ContentCard
                                        Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ImageUrl="{x:Bind Data.ImageUrl, Mode=OneWay}"
                                        Title="{x:Bind Data.Name, Mode=OneWay}"
                                        Subtitle="{x:Bind Data.Year, Mode=OneWay}"
                                        PlaceholderColorHex="{x:Bind Data.ColorHex, Mode=OneWay}"
                                        CardClick="AlbumCard_Click"
                                        CardHover="AlbumCard_Hover"/>
                                    <!-- Loading: shimmer card -->
                                    <StackPanel Spacing="8" Padding="8"
                                                Visibility="{x:Bind IsLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <controls:Shimmer Height="150" CornerRadius="8"/>
                                        <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left"/>
                                        <controls:Shimmer Width="50" Height="12" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </shelf:ShelfScroller.ItemTemplate>
                    </shelf:ShelfScroller>
                    <controls1:ErrorStateView x:Uid="Views_ArtistPage__ErrorStateView_13"
                        Visibility="{x:Bind ViewModel.HasCompilationsError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Title="Couldn't load all compilations"
                        Message="Some compilations may be missing"
                        RetryCommand="{x:Bind ViewModel.RetryDiscographyCommand}"
                        HorizontalAlignment="Left"
                        Padding="0,4,0,0"/>
                </StackPanel>

                <!-- ─── Concerts ─── -->
                <StackPanel x:Name="ConcertsSection"
                            Spacing="12"
                            x:Load="{x:Bind ViewModel.HasConcerts, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="3" MinHeight="22" CornerRadius="1.5"
                                VerticalAlignment="Stretch"
                                Background="{x:Bind ViewModel.SectionAccentBrush, Mode=OneWay}"/>
                        <TextBlock x:Uid="Views_ArtistPage__TextBlock_14" Text="Concerts" FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                        <controls1:LocationButton
                            LocationName="{x:Bind ViewModel.UserLocationName, Mode=TwoWay}"
                            LocationChanged="LocationButton_LocationChanged"/>
                    </StackPanel>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Concerts, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ConcertVm">
                                <Button Click="ConcertCard_Click" Padding="16,12" Width="200"
                                        CornerRadius="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        HorizontalContentAlignment="Left"
                                        Tag="{x:Bind Uri}">
                                    <Grid RowSpacing="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Date badge -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind DateFormatted}" FontWeight="Bold" FontSize="16"
                                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{x:Bind DayOfWeek}" FontSize="12" Opacity="0.6"
                                                       VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                            <Border CornerRadius="4" Padding="6,2" Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                    Visibility="{x:Bind IsNearUser, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Uid="Views_ArtistPage__TextBlock_15" Text="Near you" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Venue -->
                                        <TextBlock Grid.Row="1" Text="{x:Bind Venue}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>

                                        <!-- City -->
                                        <TextBlock Grid.Row="2" Text="{x:Bind City}" FontSize="12" Opacity="0.6"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>

                                        <!-- Title (lineup) -->
                                        <TextBlock Grid.Row="3" Text="{x:Bind Title}" FontSize="11" Opacity="0.5"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1" Margin="0,4,0,0"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- ─── Related Artists ─── -->
                <shelf:SectionShelf x:Name="RelatedArtistsShelf"
                                    x:Uid="Views_ArtistPage__SectionShelf_FansAlsoLike"
                                    Title="Fans Also Like"
                                    ItemsSource="{x:Bind ViewModel.RelatedArtists, Mode=OneWay}"
                                    MinItemWidth="140"
                                    x:Load="{x:Bind ViewModel.HasRelatedArtists, Mode=OneWay}">
                    <shelf:SectionShelf.ItemTemplate>
                        <DataTemplate x:DataType="vm:RelatedArtistVm">
                            <cards:ContentCard
                                Width="140"
                                ImageUrl="{x:Bind ImageUrl}"
                                Title="{x:Bind Name}"
                                Subtitle="Artist"
                                PlaceholderGlyph="&#xE77B;"
                                IsCircularImage="True"
                                CenterText="True"
                                NavigationUri="{x:Bind Uri}"
                                NavigationTitle="{x:Bind Name}"/>
                        </DataTemplate>
                    </shelf:SectionShelf.ItemTemplate>
                </shelf:SectionShelf>

                <!-- ─── About (Fluent SettingsExpander) ─── -->
                <StackPanel x:Name="BiographySection"
                            Spacing="8"
                            x:Load="{x:Bind ViewModel.HasBiography, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="3" MinHeight="22" CornerRadius="1.5"
                                VerticalAlignment="Stretch"
                                Background="{x:Bind ViewModel.SectionAccentBrush, Mode=OneWay}"/>
                        <TextBlock x:Uid="Views_ArtistPage__TextBlock_17" Text="About" FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Bio body — plain wrapping TextBlock with truncation +
                         "Show more" toggle. The expander chrome was overkill
                         for typically short artist blurbs. -->
                    <controls1:HtmlTextBlock x:Name="BiographyBlock"
                                             Text="{x:Bind ViewModel.Biography, Mode=OneWay}"
                                             MaxLines="4"
                                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <HyperlinkButton x:Name="BiographyShowMoreButton"
                                     Content="Show more"
                                     Padding="0,2,0,0"
                                     Click="BiographyShowMore_Click"/>
                </StackPanel>

                <!-- ─── Connect & Markets ─── -->
                <StackPanel x:Name="ConnectSection"
                            Spacing="8"
                            x:Load="{x:Bind ViewModel.HasConnectSection, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="3" MinHeight="22" CornerRadius="1.5"
                                VerticalAlignment="Stretch"
                                Background="{x:Bind ViewModel.SectionAccentBrush, Mode=OneWay}"/>
                        <TextBlock Text="Connect" FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Social links — chip row, opens URL in default browser. -->
                    <ItemsRepeater x:Name="ExternalLinksRepeater"
                                   ItemsSource="{x:Bind ViewModel.ExternalLinks, Mode=OneWay}"
                                   x:Load="{x:Bind ViewModel.HasExternalLinks, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ArtistSocialLinkVm">
                                <Button Padding="12,6"
                                        CornerRadius="16"
                                        MinWidth="0"
                                        Tag="{x:Bind Url}"
                                        Click="SocialLink_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <fa:SvgAwesome Icon="{x:Bind Icon}"
                                                       Width="14" Height="14"
                                                       PrimaryColor="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="{x:Bind Name}" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Top cities — bar chart, listener share normalized to widest bar. -->
                    <StackPanel x:Name="TopCitiesSection"
                                Spacing="6"
                                Margin="0,8,0,0"
                                x:Load="{x:Bind ViewModel.HasTopCities, Mode=OneWay}">
                        <TextBlock Text="Where listeners are"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.TopCities, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="6"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ArtistTopCityVm">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind City}" FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                            <TextBlock Text="{x:Bind Country}" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Width="{x:Bind RelativeWidth}"
                                                Height="6"
                                                CornerRadius="3"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{Binding ElementName=ArtistPageRoot, Path=ViewModel.SectionAccentBrush, Mode=OneWay}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind DisplayCount}" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </StackPanel>

                <!-- ─── Gallery ─── -->
                <StackPanel x:Name="GallerySection"
                            Spacing="12"
                            x:Load="{x:Bind ViewModel.HasGallery, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="3" MinHeight="22" CornerRadius="1.5"
                                VerticalAlignment="Stretch"
                                Background="{x:Bind ViewModel.SectionAccentBrush, Mode=OneWay}"/>
                        <TextBlock Text="Gallery" FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Wrapping uniform grid (Microsoft Photos / Store gallery
                         pattern). Tiles are 160 px square, center-cropped, with
                         8 px gutters and ItemsStretch=Fill so the right edge is
                         flush. ItemsView gives selection + keyboard navigation
                         out of the box. -->
                    <ItemsView x:Name="GalleryItemsView"
                               ItemsSource="{x:Bind ViewModel.GalleryPhotos, Mode=OneWay}"
                               SelectionMode="Single"
                               IsItemInvokedEnabled="True"
                               ItemInvoked="Gallery_ItemInvoked">
                        <ItemsView.Layout>
                            <UniformGridLayout MinItemWidth="160" MinItemHeight="160"
                                               MinColumnSpacing="8" MinRowSpacing="8"
                                               ItemsStretch="Fill"/>
                        </ItemsView.Layout>
                        <ItemsView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <ItemContainer>
                                    <Border CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <Image Stretch="UniformToFill"
                                               Source="{x:Bind Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=320}"
                                               AutomationProperties.Name="Artist photo"/>
                                    </Border>
                                </ItemContainer>
                            </DataTemplate>
                        </ItemsView.ItemTemplate>
                    </ItemsView>
                </StackPanel>

            </StackPanel> <!-- ContentContainer -->

            </Grid>
        </ScrollView>

        <Grid x:Name="ShyHeaderHost"
              Canvas.ZIndex="5"
              VerticalAlignment="Top"
              Margin="16,16,16,0">
            <Grid x:Name="ShyHeaderCard"
                  HorizontalAlignment="Center"
                  MaxWidth="760"
                  MinHeight="68"
                  Visibility="Collapsed">
                <!-- Chrome layer: matched-id "card-shell" pairs with the invisible
                     chrome inside HeroOverlayPanel. TransitionHelper morphs this
                     visible chrome FROM the source chrome bounds (full-width, bottom
                     of hero) TO this floating-card position — translation+scale
                     interpolation gives the chrome itself a true morph instead of
                     just appearing in place. -->
                <Border transitions:TransitionHelper.Id="card-shell"
                        CornerRadius="18"
                        BorderBrush="{ThemeResource ShyHeaderBorderBrush}"
                        BorderThickness="1.5">
                    <Border.Background>
                        <AcrylicBrush TintColor="{ThemeResource SolidBackgroundFillColorBase}"
                                      TintOpacity="0.78"
                                      FallbackColor="{ThemeResource CardBackgroundFillColorDefault}"/>
                    </Border.Background>
                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>
                </Border>

                <Grid Padding="12,10" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="40"
                            Height="40"
                            CornerRadius="20"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            transitions:TransitionHelper.Id="artist-avatar">
                        <Image Source="{x:Bind ViewModel.ArtistImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=64}"
                               Stretch="UniformToFill"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"
                                       transitions:TransitionHelper.Id="artist-name"/>
                            <Border Width="20"
                                    Height="20"
                                    CornerRadius="10"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    Visibility="{x:Bind ViewModel.IsVerified, Mode=OneWay}"
                                    transitions:TransitionHelper.Id="artist-badge">
                                <FontIcon Glyph="&#xE73E;"
                                          FontSize="10"
                                          Foreground="White"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"
                                   Visibility="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                   transitions:TransitionHelper.Id="artist-meta">
                            <Run Text="{x:Bind ViewModel.MonthlyListeners, Mode=OneWay}"/>
                            <Run Text=" monthly listeners"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.PlayTopTracksCommand}"
                                Padding="16,8"
                                CornerRadius="18"
                                MinWidth="92"
                                transitions:TransitionHelper.Id="artist-play">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <playback:PlaybackActionContent IconSize="14"
                                                               SpinnerSize="14"
                                                               IsPlaying="{x:Bind ViewModel.IsArtistContextPlaying, Mode=OneWay}"
                                                               IsPending="{x:Bind ViewModel.IsPlayPending, Mode=OneWay}"
                                                               ActionForeground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.ArtistPlayButtonText, Mode=OneWay}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{x:Bind ViewModel.ToggleFollowCommand}"
                                Padding="14,8"
                                CornerRadius="18"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                transitions:TransitionHelper.Id="artist-follow">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="{x:Bind ViewModel.IsFollowing, Mode=OneWay, Converter={StaticResource BoolToFollowGlyphConverter}}"
                                          FontSize="12"/>
                                <TextBlock Text="{x:Bind ViewModel.IsFollowing, Mode=OneWay, Converter={StaticResource BoolToFollowTextConverter}}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- ─── Gallery lightbox ─── Full-window Popup overlaying the page;
             FlipView for swipe + arrow-key + chevron carousel; PipsPager for
             dot navigation; per-image ScrollViewer with ZoomMode for pan/zoom.
             Uses Popup (not ContentDialog) per WinUI guidance — gives us
             click-on-scrim dismiss and proper full-window sizing. -->
        <Popup x:Name="GalleryLightbox"
               IsLightDismissEnabled="False"
               LightDismissOverlayMode="Off">
            <Grid x:Name="GalleryLightboxRoot"
                  Width="{Binding ActualWidth, ElementName=ArtistPageRoot}"
                  Height="{Binding ActualHeight, ElementName=ArtistPageRoot}"
                  Background="#CC000000"
                  PointerPressed="GalleryLightboxScrim_PointerPressed">

                <FlipView x:Name="GalleryFlipView"
                          ItemsSource="{x:Bind ViewModel.GalleryPhotos, Mode=OneWay}"
                          Background="Transparent"
                          SelectionChanged="GalleryFlipView_SelectionChanged">
                    <FlipView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <ScrollViewer ZoomMode="Enabled"
                                          MinZoomFactor="1" MaxZoomFactor="4"
                                          HorizontalScrollMode="Auto" VerticalScrollMode="Auto"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Background="Transparent">
                                <Image Source="{x:Bind Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=1024}"
                                       Stretch="Uniform"
                                       AutomationProperties.Name="Artist photo"/>
                            </ScrollViewer>
                        </DataTemplate>
                    </FlipView.ItemTemplate>
                </FlipView>

                <!-- Top-right close button -->
                <Button x:Name="GalleryLightboxCloseButton"
                        Style="{StaticResource SubtleButtonStyle}"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="16" Width="40" Height="40" Padding="0"
                        ToolTipService.ToolTip="Close"
                        Click="GalleryLightboxClose_Click">
                    <FontIcon Glyph="&#xE711;" FontSize="14" Foreground="White"/>
                </Button>

                <!-- Bottom: PipsPager + counter overlay -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,32" Spacing="6"
                            Visibility="{x:Bind ViewModel.HasGallery, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <PipsPager NumberOfPages="{x:Bind ViewModel.GalleryPhotos.Count, Mode=OneWay}"
                               SelectedPageIndex="{x:Bind GalleryFlipView.SelectedIndex, Mode=TwoWay}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="GalleryCounterText"
                               HorizontalAlignment="Center"
                               Foreground="White" Opacity="0.85" FontSize="12"/>
                </StackPanel>

                <!-- Escape closes the lightbox. -->
                <Grid.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Escape" Invoked="GalleryLightboxEscape_Invoked"/>
                </Grid.KeyboardAccelerators>
            </Grid>
        </Popup>
    </Grid>
</Page>
