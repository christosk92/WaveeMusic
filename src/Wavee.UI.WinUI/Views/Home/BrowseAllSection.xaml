<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Views.Home.BrowseAllSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:home="using:Wavee.UI.WinUI.ViewModels.Home"
    xmlns:homeViews="using:Wavee.UI.WinUI.Views.Home"
    xmlns:browseControls="using:Wavee.UI.WinUI.Controls.Browse"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <UserControl.Resources>
        <DataTemplate x:Key="BrowseChipTemplate" x:DataType="home:BrowseAllItem">
            <homeViews:BrowseChip Item="{x:Bind}"/>
        </DataTemplate>

        <!-- Per-group template for the loaded state. Caps eyebrow + UniformGridLayout
             of BrowseChip instances. -->
        <DataTemplate x:Key="BrowseGroupTemplate" x:DataType="home:BrowseAllGroup">
            <StackPanel Margin="0,0,0,14">
                <TextBlock
                    Text="{x:Bind Eyebrow}"
                    FontSize="9.5"
                    FontWeight="SemiBold"
                    CharacterSpacing="140"
                    Opacity="0.6"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Margin="0,0,0,6"/>
                <browseControls:BrowseGrid
                    ItemsSource="{x:Bind Items}"
                    ItemTemplate="{StaticResource BrowseChipTemplate}"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel x:Name="Root" Margin="0,4,0,24">
        <!-- "BROWSE ALL" eyebrow + header — always visible, even during shimmer. -->
        <TextBlock
            Text="BROWSE ALL"
            FontSize="10"
            FontWeight="SemiBold"
            CharacterSpacing="160"
            Opacity="0.85"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        <TextBlock
            Text="Discover something new"
            FontSize="22"
            FontWeight="SemiBold"
            Margin="0,2,0,16"
            Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

        <!-- Loading skeleton — 6 stacked group placeholders sized to match the
             populated layout so the swap-in doesn't cause a vertical jump.
             Visibility is driven imperatively from code-behind because x:Bind
             chains through a DP (Adapter) on a UserControl don't always
             re-evaluate reliably when the DP changes after init. -->
        <StackPanel x:Name="ShimmerHost"
                    Spacing="14">
            <!-- Group 1 (TOP, ~4 chips) -->
            <StackPanel>
                <controls:Shimmer Width="44" Height="9" CornerRadius="3" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                </StackPanel>
            </StackPanel>
            <!-- Group 2 (FOR YOU, ~7 chips) -->
            <StackPanel>
                <controls:Shimmer Width="64" Height="9" CornerRadius="3" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                </StackPanel>
            </StackPanel>
            <!-- Group 3 (GENRES, ~14 chips → 2 rows worth) -->
            <StackPanel Spacing="3">
                <controls:Shimmer Width="56" Height="9" CornerRadius="3" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                </StackPanel>
            </StackPanel>
            <!-- Group 4 (MOOD, ~10 chips → ~2 rows) -->
            <StackPanel Spacing="3">
                <controls:Shimmer Width="100" Height="9" CornerRadius="3" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                </StackPanel>
            </StackPanel>
            <!-- Group 5 (CHARTS, ~2 chips) -->
            <StackPanel>
                <controls:Shimmer Width="56" Height="9" CornerRadius="3" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                </StackPanel>
            </StackPanel>
            <!-- Group 6 (MORE, ~8 chips) -->
            <StackPanel>
                <controls:Shimmer Width="40" Height="9" CornerRadius="3" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                    <controls:Shimmer Width="140" Height="28" CornerRadius="5"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Loaded state — real grouped chips. ItemsSource + Visibility set
             imperatively from code-behind once the lazy fetch resolves. -->
        <ItemsRepeater
            x:Name="GroupsRepeater"
            ItemTemplate="{StaticResource BrowseGroupTemplate}"
            Visibility="Collapsed">
            <ItemsRepeater.Layout>
                <StackLayout Orientation="Vertical" Spacing="0"/>
            </ItemsRepeater.Layout>
        </ItemsRepeater>
    </StackPanel>
</UserControl>
