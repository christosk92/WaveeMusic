<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Views.YourEpisodesView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:appcontrols="using:Wavee.UI.WinUI.Controls"
    xmlns:comments="using:Wavee.UI.WinUI.Controls.Comments"
    xmlns:showEpisode="using:Wavee.UI.WinUI.Controls.ShowEpisode"
    xmlns:tdg="using:Wavee.UI.WinUI.Controls.TrackDataGrid"
    xmlns:dto="using:Wavee.UI.WinUI.Data.DTOs"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    mc:Ignorable="d"
    Background="Transparent">

    <UserControl.Resources>
        <DataTemplate x:Key="PodcastShowItemTemplate" x:DataType="dto:LibraryPodcastShowDto">
            <Grid Padding="6" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Width="32"
                    Height="32"
                    CornerRadius="5"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid>
                        <FontIcon
                            Glyph="{x:Bind PlaceholderGlyph}"
                            FontSize="14"
                            Opacity="0.35"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                        <Image
                            Source="{x:Bind ImageUrl, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='64'}"
                            Stretch="UniformToFill"
                            Visibility="{x:Bind ImageUrl, Converter={StaticResource NullToVisibilityConverter}}"
                            behaviors:ImageFallbackBehavior.HideOnError="True"
                            behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                            behaviors:ImageFallbackBehavior.DecodePixelWidth="64"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock
                        Text="{x:Bind Name}"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="1"/>
                    <TextBlock
                        Text="{x:Bind Metadata}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="1"/>
                </StackPanel>

                <Border
                    Grid.Column="2"
                    MinWidth="22"
                    Height="18"
                    Padding="6,0"
                    CornerRadius="9"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind HasSavedEpisodes, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock
                        Text="{x:Bind SavedEpisodeCount}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PodcastEpisodeHeaderTemplate">
            <Grid Padding="8,12,8,6" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    CornerRadius="5"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid>
                        <FontIcon
                            Glyph="&#xEC05;"
                            FontSize="15"
                            Opacity="0.35"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                        <Image
                            Source="{Binding Header.ImageUrl, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='72'}"
                            Stretch="UniformToFill"
                            Visibility="{Binding Header.ImageUrl, Converter={StaticResource NullToVisibilityConverter}}"
                            behaviors:ImageFallbackBehavior.HideOnError="True"
                            behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                            behaviors:ImageFallbackBehavior.DecodePixelWidth="72"/>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock
                        Text="{Binding Header.Title}"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="1"/>
                    <TextBlock
                        Text="{Binding CountText}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="1"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="EpisodeGroupTemplate" x:DataType="vm:PodcastEpisodeGroupViewModel">
            <StackPanel Spacing="8">
                <Button
                    Command="{x:Bind ToggleExpandedCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Visibility="{x:Bind ShowHeader, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border
                        Grid.Column="0"
                        Width="36"
                        Height="36"
                        CornerRadius="5"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Grid>
                                <FontIcon
                                Glyph="&#xEC05;"
                                FontSize="15"
                                Opacity="0.35"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                                <Image
                                Source="{x:Bind ImageUrl, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='72'}"
                                Stretch="UniformToFill"
                                Visibility="{x:Bind ImageUrl, Converter={StaticResource NullToVisibilityConverter}}"
                                behaviors:ImageFallbackBehavior.HideOnError="True"
                                behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                behaviors:ImageFallbackBehavior.DecodePixelWidth="72"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                            <TextBlock
                            Text="{x:Bind Title}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="1"/>
                            <TextBlock
                            Text="{x:Bind Summary}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="1"/>
                        </StackPanel>
                        <FontIcon
                        Grid.Column="2"
                        Glyph="{x:Bind ExpandGlyph, Mode=OneWay}"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <tdg:TrackDataGrid
                    PageKey="podcasts"
                    ShowToolbar="False"
                    UseCardRows="True"
                    AllowHorizontalRowScroll="False"
                    ItemsSource="{x:Bind Episodes}"
                    PlayCommand="{x:Bind PlayEpisodeCommand}"
                    SelectionChangedCommand="{x:Bind SelectEpisodeCommand}"
                    Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    Loaded="EpisodeGroupGrid_Loaded"
                    Unloaded="EpisodeGroupGrid_Unloaded"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="EpisodeDetailPanelTemplate" x:DataType="vm:YourEpisodesViewModel">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <ScrollView Visibility="{x:Bind HasSelectedEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="10" Padding="0,0,2,0">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                x:Name="EpisodeDetailCoverContainer"
                                Width="64"
                                Height="64"
                                CornerRadius="6"
                                VerticalAlignment="Top"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Grid>
                                    <FontIcon
                                        Glyph="&#xEC05;"
                                        FontSize="22"
                                        Opacity="0.35"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                    <Image
                                        Source="{x:Bind SelectedEpisodeImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='128'}"
                                        Stretch="UniformToFill"
                                        Visibility="{x:Bind SelectedEpisodeImageUrl, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                        behaviors:ImageFallbackBehavior.HideOnError="True"
                                        behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                        behaviors:ImageFallbackBehavior.DecodePixelWidth="128"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Top">
                                <TextBlock
                                    Text="{x:Bind SelectedEpisodeTitle, Mode=OneWay}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    TextWrapping="WrapWholeWords"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="2"/>
                                <HyperlinkButton
                                    Content="{x:Bind SelectedEpisodeShowName, Mode=OneWay}"
                                    Command="{x:Bind OpenSelectedEpisodeShowCommand, Mode=OneWay}"
                                    Padding="0"
                                    MinHeight="0"
                                    HorizontalAlignment="Left"
                                    Visibility="{x:Bind HasShowName, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock
                                    Text="{x:Bind SelectedEpisodeMetaLine, Mode=OneWay}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="2"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel
                            Spacing="3"
                            Visibility="{x:Bind HasResumeProgress, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ProgressBar
                                Minimum="0"
                                Maximum="100"
                                Value="{x:Bind ResumeProgressPercent, Mode=OneWay}"
                                Height="3"/>
                            <TextBlock
                                Text="{x:Bind SelectedEpisodeResumeText, Mode=OneWay}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <controls:WrapPanel Orientation="Horizontal" HorizontalSpacing="6" VerticalSpacing="6">
                            <Button
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind PlaySelectedEpisodeCommand, Mode=OneWay}"
                                Padding="10,4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE768;" FontSize="12"/>
                                    <TextBlock Text="Play"/>
                                </StackPanel>
                            </Button>
                            <Button
                                Click="OpenSelectedEpisodeDetails_Click"
                                Padding="10,4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="12"/>
                                    <TextBlock Text="Open"/>
                                </StackPanel>
                            </Button>
                            <Button
                                Command="{x:Bind CopyEpisodeLinkCommand, Mode=OneWay}"
                                Padding="8,4"
                                Visibility="{x:Bind HasShareUrl, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="Copy episode link">
                                <FontIcon Glyph="&#xE71B;" FontSize="12"/>
                            </Button>
                        </controls:WrapPanel>

                        <StackPanel
                            Spacing="4"
                            Visibility="{x:Bind HasSelectedEpisodeDescription, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <appcontrols:HtmlTextBlock
                                Text="{x:Bind SelectedEpisodeDescription, Mode=OneWay}"
                                MaxLines="6"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <HyperlinkButton
                                Content="Show more"
                                Padding="0"
                                MinHeight="0"
                                HorizontalAlignment="Left"
                                Click="OpenSelectedEpisodeDetails_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollView>

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Visibility="{x:Bind HasSelectedEpisode, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <FontIcon Glyph="&#xE8D6;" FontSize="28" Opacity="0.35"/>
                    <TextBlock
                        Text="Select an episode"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid
            x:Name="WideLayoutRoot"
            Loaded="WideLayoutRoot_Loaded"
            SizeChanged="WideLayoutRoot_SizeChanged"
            Visibility="{x:Bind ViewModel.IsWideLayout, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="PodcastShowsColumn" Width="260" MinWidth="220" MaxWidth="340"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="PodcastEpisodesColumn" Width="3*" MinWidth="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="PodcastDetailsColumn" Width="320" MinWidth="280" MaxWidth="360"/>
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Row="0"
                Grid.ColumnSpan="5"
                Canvas.ZIndex="2"
                Margin="0,0,0,12"
                ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="WideBreadcrumbContainer"
                    Grid.Column="0"
                    Padding="10,6"
                    HorizontalAlignment="Left"
                    CornerRadius="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xEC05;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <BreadcrumbBar
                            ItemsSource="{x:Bind ViewModel.BreadcrumbItems, Mode=OneWay}"
                            ItemClicked="BreadcrumbBar_ItemClicked"/>
                    </StackPanel>
                </Border>

                <Button
                    Grid.Column="1"
                    Padding="12,6"
                    HorizontalAlignment="Right"
                    Click="BrowsePodcasts_Click"
                    ToolTipService.ToolTip="Browse podcasts">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE71B;" FontSize="14"/>
                        <TextBlock Text="Browse podcasts"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid
                Grid.Row="1"
                Grid.Column="0"
                Visibility="{x:Bind ViewModel.ShowWidePodcastBrowser, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox
                        Grid.Column="0"
                        PlaceholderText="Filter podcasts..."
                        Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button
                        Grid.Column="1"
                        Padding="10,6"
                        ToolTipService.ToolTip="Sort"
                        Click="SortButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8CB;" FontSize="13"/>
                            <FontIcon Glyph="{x:Bind ViewModel.SortDirectionGlyph, Mode=OneWay}" FontSize="10"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <ListView
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.FilteredShows, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedShow, Mode=TwoWay}"
                    ItemTemplate="{StaticResource PodcastShowItemTemplate}"
                    SelectionMode="Single"
                    HorizontalContentAlignment="Stretch"
                    Visibility="{x:Bind ViewModel.IsInitialLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                <StackPanel
                    Grid.Row="1"
                    Spacing="6"
                    Padding="6,0,6,0"
                    Visibility="{x:Bind ViewModel.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="8" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:Shimmer Grid.Column="0" Width="32" Height="32" CornerRadius="5"/>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <controls:Shimmer Width="160" Height="11" CornerRadius="3" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="100" Height="9" CornerRadius="3" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:Shimmer Grid.Column="0" Width="32" Height="32" CornerRadius="5"/>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <controls:Shimmer Width="140" Height="11" CornerRadius="3" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="80" Height="9" CornerRadius="3" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:Shimmer Grid.Column="0" Width="32" Height="32" CornerRadius="5"/>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <controls:Shimmer Width="180" Height="11" CornerRadius="3" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="120" Height="9" CornerRadius="3" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:Shimmer Grid.Column="0" Width="32" Height="32" CornerRadius="5"/>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <controls:Shimmer Width="120" Height="11" CornerRadius="3" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="90" Height="9" CornerRadius="3" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:Shimmer Grid.Column="0" Width="32" Height="32" CornerRadius="5"/>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <controls:Shimmer Width="150" Height="11" CornerRadius="3" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="100" Height="9" CornerRadius="3" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>

            <appcontrols:GridSplitter
                Grid.Row="1"
                Grid.Column="1"
                Width="12"
                Visibility="{x:Bind ViewModel.ShowWidePodcastBrowser, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                ResizeCompleted="WideColumnSplitter_ResizeCompleted"/>

            <Grid
                Grid.Row="1"
                Grid.Column="2"
                Visibility="{x:Bind ViewModel.ShowWidePodcastBrowser, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Visibility="{x:Bind ViewModel.IsInitialLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <Grid>
                        <Border
                            CornerRadius="8"
                            Background="Transparent"
                            IsHitTestVisible="False"/>
                        <Border
                            CornerRadius="8"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            IsHitTestVisible="False"/>
                        <Border
                            Width="4"
                            HorizontalAlignment="Left"
                            CornerRadius="8,0,0,8"
                            Background="Transparent"
                            IsHitTestVisible="False"/>
                        <Grid Padding="10" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                    <Border
                        x:Name="SelectedShowCoverContainer"
                        Grid.Column="0"
                        Width="48"
                        Height="48"
                        CornerRadius="6"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid>
                            <Border
                                Background="Transparent"
                                IsHitTestVisible="False"/>
                            <FontIcon
                                Glyph="{x:Bind ViewModel.SelectedShowPlaceholderGlyph, Mode=OneWay}"
                                FontSize="20"
                                Opacity="0.35"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                            <Image
                                Source="{x:Bind ViewModel.SelectedShowImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='96'}"
                                Stretch="UniformToFill"
                                Visibility="{x:Bind ViewModel.SelectedShowImageUrl, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                behaviors:ImageFallbackBehavior.HideOnError="True"
                                behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                behaviors:ImageFallbackBehavior.DecodePixelWidth="96"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <TextBlock
                            Text="{x:Bind ViewModel.SelectedShowName, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="1"/>
                        <TextBlock
                            Text="{x:Bind ViewModel.SelectedShowMetadata, Mode=OneWay}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="1"/>

                        <controls:WrapPanel Orientation="Horizontal" HorizontalSpacing="6" VerticalSpacing="6" Margin="0,6,0,0">
                            <Button
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.PlayAllCommand, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.HasEpisodeGroups, Mode=OneWay}"
                                Padding="10,5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE768;" FontSize="13"/>
                                    <TextBlock Text="Play"/>
                                </StackPanel>
                            </Button>
                            <Button
                                Command="{x:Bind ViewModel.ShuffleCommand, Mode=OneWay}"
                                IsEnabled="{x:Bind ViewModel.HasEpisodeGroups, Mode=OneWay}"
                                Padding="10,5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8B1;" FontSize="13"/>
                                    <TextBlock Text="Shuffle"/>
                                </StackPanel>
                            </Button>
                            <Button
                                Click="OpenSelectedShowDetails_Click"
                                Padding="10,5"
                                Visibility="{x:Bind ViewModel.CanOpenSelectedShow, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="13"/>
                                    <TextBlock Text="Open show"/>
                                </StackPanel>
                            </Button>
                            <controls:Segmented
                                x:Name="PodcastEpisodeScopeSelector"
                                SelectedIndex="{x:Bind ViewModel.PodcastEpisodeScopeIndex, Mode=OneWay}"
                                SelectionChanged="PodcastEpisodeScopeSelector_SelectionChanged"
                                Visibility="{x:Bind ViewModel.CanSwitchPodcastEpisodeScope, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <controls:SegmentedItem Content="Saved"/>
                                <controls:SegmentedItem Content="Latest"/>
                            </controls:Segmented>
                        </controls:WrapPanel>
                    </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="10"
                    Visibility="{x:Bind ViewModel.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:Shimmer Grid.Column="0" Width="48" Height="48" CornerRadius="6"/>
                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                            <controls:Shimmer Width="200" Height="13" CornerRadius="3" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="120" Height="10" CornerRadius="3" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                <controls:Shimmer Width="64" Height="22" CornerRadius="4"/>
                                <controls:Shimmer Width="72" Height="22" CornerRadius="4"/>
                                <controls:Shimmer Width="120" Height="22" CornerRadius="4"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <tdg:TrackDataGrid
                        PageKey="podcasts"
                        ShowToolbar="False"
                        UseCardRows="True"
                        AllowHorizontalRowScroll="False"
                        ItemsSource="{x:Bind ViewModel.VisibleEpisodes, Mode=OneWay}"
                        PlayCommand="{x:Bind ViewModel.PlayEpisodeCommand, Mode=OneWay}"
                        SelectionChangedCommand="{x:Bind ViewModel.SelectEpisodeCommand, Mode=OneWay}"
                        IsGrouped="{x:Bind ViewModel.ShowEpisodeGroupHeaders, Mode=OneWay}"
                        GroupKeySelector="{x:Bind ViewModel.PodcastEpisodeGroupKeySelector, Mode=OneWay}"
                        GroupHeaderSelector="{x:Bind ViewModel.PodcastEpisodeGroupHeaderSelector, Mode=OneWay}"
                        GroupCountFormatter="{x:Bind ViewModel.PodcastEpisodeGroupCountFormatter, Mode=OneWay}"
                        GroupHeaderTemplate="{StaticResource PodcastEpisodeHeaderTemplate}"
                        AreStickyGroupHeadersEnabled="False"
                        Loaded="EpisodeGroupGrid_Loaded"
                        Unloaded="EpisodeGroupGrid_Unloaded"
                        Visibility="{x:Bind ViewModel.ShowEpisodesShimmer, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <StackPanel
                        Spacing="12"
                        Padding="0,10,0,0"
                        Visibility="{x:Bind ViewModel.ShowEpisodesShimmer, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:Shimmer Grid.Column="0" Width="36" Height="36" CornerRadius="5"/>
                            <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                                <controls:Shimmer Width="180" Height="14" CornerRadius="4" HorizontalAlignment="Left"/>
                                <controls:Shimmer Width="130" Height="11" CornerRadius="4" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                        <controls:Shimmer Height="66" HorizontalAlignment="Stretch" CornerRadius="8"/>
                        <controls:Shimmer Height="66" HorizontalAlignment="Stretch" CornerRadius="8"/>
                        <controls:Shimmer Height="66" HorizontalAlignment="Stretch" CornerRadius="8"/>
                        <controls:Shimmer Height="66" HorizontalAlignment="Stretch" CornerRadius="8"/>
                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Visibility="{x:Bind ViewModel.ShowEpisodeEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <FontIcon
                            Glyph="&#xEC05;"
                            FontSize="44"
                            Opacity="0.35"/>
                        <TextBlock
                            Text="{x:Bind ViewModel.EpisodeEmptyTitle, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            HorizontalAlignment="Center"/>
                        <TextBlock
                            Text="{x:Bind ViewModel.EpisodeEmptyDescription, Mode=OneWay}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextAlignment="Center"
                            TextWrapping="Wrap"
                            MaxWidth="360"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <appcontrols:GridSplitter
                Grid.Row="1"
                Grid.Column="3"
                Width="12"
                Visibility="{x:Bind ViewModel.ShowWidePodcastBrowser, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                ResizeCompleted="WideColumnSplitter_ResizeCompleted"/>

            <Grid
                Grid.Row="1"
                Grid.Column="4"
                Visibility="{x:Bind ViewModel.ShowWidePodcastBrowser, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ContentControl
                    Content="{x:Bind ViewModel}"
                    ContentTemplate="{StaticResource EpisodeDetailPanelTemplate}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Visibility="{x:Bind ViewModel.IsInitialLoading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                <StackPanel
                    Spacing="10"
                    Padding="0,0,2,0"
                    Visibility="{x:Bind ViewModel.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:Shimmer Grid.Column="0" Width="64" Height="64" CornerRadius="6"/>
                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Top">
                            <controls:Shimmer Width="220" Height="14" CornerRadius="3" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="180" Height="14" CornerRadius="3" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="120" Height="11" CornerRadius="3" HorizontalAlignment="Left"/>
                            <controls:Shimmer Width="160" Height="11" CornerRadius="3" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <controls:Shimmer Width="60" Height="26" CornerRadius="4"/>
                        <controls:Shimmer Width="64" Height="26" CornerRadius="4"/>
                        <controls:Shimmer Width="32" Height="26" CornerRadius="4"/>
                    </StackPanel>
                    <StackPanel Spacing="6" Margin="0,8,0,0">
                        <controls:Shimmer Height="11" HorizontalAlignment="Stretch" CornerRadius="3"/>
                        <controls:Shimmer Height="11" HorizontalAlignment="Stretch" CornerRadius="3"/>
                        <controls:Shimmer Width="220" Height="11" CornerRadius="3" HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid
            Visibility="{x:Bind ViewModel.IsNarrowLayout, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Margin="0,0,0,16"
                ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="NarrowBreadcrumbContainer"
                    Grid.Column="0"
                    Padding="10,6"
                    HorizontalAlignment="Left"
                    CornerRadius="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xEC05;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <BreadcrumbBar
                            ItemsSource="{x:Bind ViewModel.BreadcrumbItems, Mode=OneWay}"
                            ItemClicked="BreadcrumbBar_ItemClicked"/>
                    </StackPanel>
                </Border>

                <Button
                    Grid.Column="1"
                    Padding="10,6"
                    HorizontalAlignment="Right"
                    Click="BrowsePodcasts_Click"
                    ToolTipService.ToolTip="Browse podcasts">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE71B;" FontSize="14"/>
                        <TextBlock Text="Browse"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <Grid
                    Visibility="{x:Bind ViewModel.ShowNarrowShowsStage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        PlaceholderText="Filter podcasts..."
                        Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.FilteredShows, Mode=OneWay}"
                        ItemTemplate="{StaticResource PodcastShowItemTemplate}"
                        SelectionMode="Single"
                        HorizontalContentAlignment="Stretch"
                        SelectionChanged="NarrowShowsList_SelectionChanged"/>
                </Grid>

                <Grid
                    Visibility="{x:Bind ViewModel.ShowNarrowEpisodesStage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <tdg:TrackDataGrid
                        PageKey="podcasts"
                        ShowToolbar="False"
                        UseCardRows="True"
                        AllowHorizontalRowScroll="False"
                        ItemsSource="{x:Bind ViewModel.VisibleEpisodes, Mode=OneWay}"
                        PlayCommand="{x:Bind ViewModel.PlayEpisodeCommand, Mode=OneWay}"
                        SelectionChangedCommand="{x:Bind ViewModel.SelectEpisodeCommand, Mode=OneWay}"
                        IsGrouped="{x:Bind ViewModel.ShowEpisodeGroupHeaders, Mode=OneWay}"
                        GroupKeySelector="{x:Bind ViewModel.PodcastEpisodeGroupKeySelector, Mode=OneWay}"
                        GroupHeaderSelector="{x:Bind ViewModel.PodcastEpisodeGroupHeaderSelector, Mode=OneWay}"
                        GroupCountFormatter="{x:Bind ViewModel.PodcastEpisodeGroupCountFormatter, Mode=OneWay}"
                        GroupHeaderTemplate="{StaticResource PodcastEpisodeHeaderTemplate}"
                        AreStickyGroupHeadersEnabled="False"
                        Loaded="EpisodeGroupGrid_Loaded"
                        Unloaded="EpisodeGroupGrid_Unloaded"/>
                </Grid>

            </Grid>
        </Grid>

        <Border
            Padding="24"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
            Visibility="{x:Bind ViewModel.ShowLoadError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel
                Spacing="12"
                MaxWidth="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <FontIcon
                    Glyph="&#xE783;"
                    FontSize="36"
                    Opacity="0.45"
                    HorizontalAlignment="Center"/>
                <TextBlock
                    Text="Podcasts could not load"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    TextAlignment="Center"
                    HorizontalAlignment="Center"/>
                <TextBlock
                    Text="{x:Bind ViewModel.LoadErrorDescription, Mode=OneWay}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords"
                    HorizontalAlignment="Center"/>
                <Button
                    Command="{x:Bind ViewModel.LoadCommand, Mode=OneWay}"
                    HorizontalAlignment="Center"
                    Padding="14,7">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="13"/>
                        <TextBlock Text="Retry"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
