<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.Local.LocalMusicPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:waveeHelpers="using:Wavee.UI.WinUI.Helpers"
    xmlns:waveeLocal="using:Wavee.Local"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    NavigationCacheMode="Enabled"
    waveeHelpers:PageEntranceFade.Fade="True">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True"/>
    </Page.Resources>

    <Grid Padding="32,24,32,16" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header row: title left, Sync-with-Spotify action right. -->
        <Grid Grid.Row="0">
            <TextBlock Text="Music" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button x:Name="SpotifySyncButton"
                        Click="SpotifySyncButton_Click"
                        ToolTipService.ToolTip="Search Spotify for canonical metadata + cover art for every local track">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="Sync with Spotify"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SpotifyMoreButton"
                        ToolTipService.ToolTip="More">
                    <FontIcon Glyph="&#xE712;" FontSize="14"/>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Force re-sync with Spotify"
                                            Click="SpotifyForceResync_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE72C;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>

        <ToggleSwitch Grid.Row="1" Header="Show only liked"
                      IsOn="{x:Bind ViewModel.ShowOnlyLiked, Mode=TwoWay}"/>

        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <FontIcon Glyph="&#xE8D6;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            <TextBlock Text="No local music yet" Style="{ThemeResource SubtitleTextBlockStyle}" HorizontalAlignment="Center"/>
            <TextBlock Text="Add a folder containing audio files in Settings."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Tracks}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="2"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="waveeLocal:LocalTrackRow">
                        <Grid Padding="6,6" ColumnSpacing="14" Tag="{x:Bind}" Tapped="Track_Tapped" RightTapped="Track_RightTapped">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="4" Background="{ThemeResource SubtleFillColorTertiaryBrush}">
                                <Image Source="{x:Bind EffectiveCoverUri, Converter={StaticResource SpotifyImageConverter}, ConverterParameter=96, Mode=OneTime}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                <TextBlock Text="{x:Bind Artist}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{x:Bind Album}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind DurationDisplay}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
