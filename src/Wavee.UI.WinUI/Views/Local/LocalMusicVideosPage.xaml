<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.Local.LocalMusicVideosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Wavee.Local.Models"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards">

    <Grid Padding="32,24,32,16" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Music videos" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.MusicVideos}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout Orientation="Horizontal"
                                       MinItemWidth="240" MinItemHeight="200"
                                       MinRowSpacing="20" MinColumnSpacing="16"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:LocalMusicVideo">
                        <cards:ContentCard AspectMode="Wide"
                                           PlaceholderGlyph="&#xE714;"
                                           Tag="{x:Bind}"
                                           ImageUrl="{x:Bind ThumbnailUri}"
                                           Title="{x:Bind Title}"
                                           Subtitle="{x:Bind Artist}"
                                           CardClick="Item_CardClick"
                                           CardRightTapped="Item_CardRightTapped"/>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
