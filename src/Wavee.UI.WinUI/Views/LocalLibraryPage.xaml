<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.LocalLibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vmLocal="using:Wavee.UI.WinUI.ViewModels.Local"
    xmlns:models="using:Wavee.Local.Models"
    xmlns:waveeLocal="using:Wavee.Local"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:local="using:Wavee.UI.WinUI.Views"
    NavigationCacheMode="Enabled"
    xmlns:waveeHelpers="using:Wavee.UI.WinUI.Helpers"
    mc:Ignorable="d"
    waveeHelpers:PageEntranceFade.Fade="True">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
    </Page.Resources>

    <Grid Padding="32,24,32,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Local files" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"/>
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{ThemeResource BodyTextBlockStyle}">
                <Run Text="{x:Bind ViewModel.ShowCount, Mode=OneWay}"/>
                <Run Text=" shows · "/>
                <Run Text="{x:Bind ViewModel.MovieCount, Mode=OneWay}"/>
                <Run Text=" movies · "/>
                <Run Text="{x:Bind ViewModel.MusicCount, Mode=OneWay}"/>
                <Run Text=" music · "/>
                <Run Text="{x:Bind ViewModel.MusicVideoCount, Mode=OneWay}"/>
                <Run Text=" music videos · "/>
                <Run Text="{x:Bind ViewModel.OtherCount, Mode=OneWay}"/>
                <Run Text=" other"/>
            </TextBlock>
        </StackPanel>

        <!-- Banner row: TMDB CTA + live enrichment progress. Both InfoBars
             show/hide independently — typically only one is visible at a
             time (CTA before token, progress after a Sync click). -->
        <StackPanel Grid.Row="1" Spacing="8">
            <!-- BYO-token CTA: hidden once a token is set or once the user
                 dismisses it. Drives the explicit-sync onboarding flow. -->
            <InfoBar x:Name="TmdbCtaBar"
                     IsOpen="{x:Bind ViewModel.ShowTmdbCta, Mode=OneWay}"
                     IsClosable="True"
                     Closed="TmdbCtaBar_Closed"
                     Severity="Informational"
                     Title="Get free posters and metadata"
                     Message="Add a TMDB token in Settings to fetch posters and episode info for your local movies and shows.">
                <InfoBar.ActionButton>
                    <Button Content="Set up TMDB" Click="SetUpTmdb_Click"/>
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- Live enrichment progress — only visible while a Sync is
                 actively processing items. -->
            <InfoBar IsOpen="{x:Bind ViewModel.HasEnrichmentProgress, Mode=OneWay}"
                     IsClosable="False"
                     Severity="Informational"
                     Title="Enriching local metadata"
                     Message="{x:Bind ViewModel.EnrichmentRibbon, Mode=OneWay}"/>
        </StackPanel>

        <!-- Empty state -->
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <FontIcon Glyph="&#xE8B7;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            <TextBlock Text="No local files indexed yet" Style="{ThemeResource SubtitleTextBlockStyle}" HorizontalAlignment="Center"/>
            <TextBlock Text="Add a watched folder in Settings → Storage and Network → Local Files."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"/>
        </StackPanel>

        <!-- Rails -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled"
                      Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel Spacing="32">

                <!-- Continue watching/listening -->
                <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.HasContinue, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Continue watching" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                    <ScrollViewer HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Hidden" VerticalScrollMode="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Continue}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="14"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:LocalContinueItem">
                                    <cards:ContentCard Width="220"
                                                       AspectMode="Backdrop"
                                                       PlaceholderGlyph="&#xE714;"
                                                       Tag="{x:Bind}"
                                                       ImageUrl="{x:Bind ArtworkUri}"
                                                       Title="{x:Bind DisplayName}"
                                                       CardClick="ContinueItem_CardClick"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- TV shows -->
                <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.HasShows, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <TextBlock Text="TV shows" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                        <HyperlinkButton Content="See all →" HorizontalAlignment="Right" Click="SeeAllShows_Click"/>
                    </Grid>
                    <ScrollViewer HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Hidden" VerticalScrollMode="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Shows}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="14"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:LocalShow">
                                    <cards:ContentCard Width="160"
                                                       AspectMode="Tall"
                                                       PlaceholderGlyph="&#xE7F4;"
                                                       Tag="{x:Bind Id}"
                                                       ImageUrl="{x:Bind PosterArtworkUri}"
                                                       Title="{x:Bind Name}"
                                                       Subtitle="{x:Bind local:LocalLibraryPage.FormatEpisodes(EpisodeCount)}"
                                                       CardClick="ShowCard_CardClick"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- Movies -->
                <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.HasMovies, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <TextBlock Text="Movies" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                        <HyperlinkButton Content="See all →" HorizontalAlignment="Right" Click="SeeAllMovies_Click"/>
                    </Grid>
                    <ScrollViewer HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Hidden" VerticalScrollMode="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Movies}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="14"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:LocalMovie">
                                    <cards:ContentCard Width="160"
                                                       AspectMode="Tall"
                                                       PlaceholderGlyph="&#xE714;"
                                                       Tag="{x:Bind TrackUri}"
                                                       ImageUrl="{x:Bind PosterUri}"
                                                       Title="{x:Bind Title}"
                                                       Subtitle="{x:Bind local:LocalLibraryPage.FormatYear(Year)}"
                                                       CardClick="MovieCard_CardClick"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- Music videos -->
                <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.HasMusicVideos, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <TextBlock Text="Music videos" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                        <HyperlinkButton Content="See all →" HorizontalAlignment="Right" Click="SeeAllMusicVideos_Click"/>
                    </Grid>
                    <ScrollViewer HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Hidden" VerticalScrollMode="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.MusicVideos}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="14"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:LocalMusicVideo">
                                    <cards:ContentCard Width="220"
                                                       AspectMode="Wide"
                                                       PlaceholderGlyph="&#xE714;"
                                                       Tag="{x:Bind TrackUri}"
                                                       ImageUrl="{x:Bind ThumbnailUri}"
                                                       Title="{x:Bind Title}"
                                                       Subtitle="{x:Bind Artist}"
                                                       CardClick="MusicVideoCard_CardClick"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- Music (recently added) -->
                <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.HasMusic, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <TextBlock Text="Music — recently added" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                        <HyperlinkButton Content="See all →" HorizontalAlignment="Right" Click="SeeAllMusic_Click"/>
                    </Grid>
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.RecentlyAdded}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="4"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="waveeLocal:LocalTrackRow">
                                <Grid Padding="6,4" ColumnSpacing="12" Tag="{x:Bind TrackUri}" Tapped="MusicRow_Tapped">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border CornerRadius="4" Background="{ThemeResource SubtleFillColorTertiaryBrush}">
                                        <Image Source="{x:Bind EffectiveCoverUri, Converter={StaticResource SpotifyImageConverter}, ConverterParameter=80, Mode=OneTime}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="0">
                                        <TextBlock Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                        <TextBlock Text="{x:Bind Artist}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Other -->
                <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.HasOthers, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <TextBlock Text="Other" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                        <HyperlinkButton Content="See all →" HorizontalAlignment="Right" Click="SeeAllOthers_Click"/>
                    </Grid>
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Text="Files we couldn't classify. Right-click an item to set its type."/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
