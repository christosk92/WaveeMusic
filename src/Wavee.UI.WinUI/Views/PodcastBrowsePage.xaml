<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.PodcastBrowsePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hero="using:Wavee.Controls.HeroCarousel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:shelf="using:Wavee.UI.WinUI.Controls.Shelf"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    mc:Ignorable="d"
    Background="Transparent"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <Page.Resources>
        <ResourceDictionary>
            <DataTemplate x:Key="PodcastShowContentCardTemplate" x:DataType="vm:PodcastBrowseItemViewModel">
                <cards:ContentCard
                    Title="{x:Bind Title, Mode=OneWay}"
                    Subtitle="{x:Bind Subtitle, Mode=OneWay}"
                    ImageUrl="{x:Bind ImageUrl, Mode=OneWay}"
                    PlaceholderColorHex="{x:Bind ColorHex, Mode=OneWay}"
                    PlaceholderGlyph="&#xEC05;"
                    NavigationUri="{x:Bind Uri, Mode=OneWay}"
                    NavigationTitle="{x:Bind Title, Mode=OneWay}" />
            </DataTemplate>

            <DataTemplate x:Key="HeroSideCardTemplate" x:DataType="vm:PodcastBrowseItemViewModel">
                <Button
                    MinWidth="0"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="BrowseItem_Click"
                    Tag="{x:Bind}"
                    UseSystemFocusVisuals="True">
                    <Border
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="#202020"
                        CornerRadius="8">
                        <Grid>
                            <Border CornerRadius="8">
                                <Border.Background>
                                    <ImageBrush
                                        ImageSource="{x:Bind ImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='420'}"
                                        Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>

                            <Border CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Offset="0.0" Color="#22000000" />
                                        <GradientStop Offset="0.52" Color="#56000000" />
                                        <GradientStop Offset="1.0" Color="#DE000000" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <Border CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Offset="0.0" Color="#80000000" />
                                        <GradientStop Offset="0.48" Color="#1C000000" />
                                        <GradientStop Offset="1.0" Color="#00000000" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <TextBlock
                                Margin="20,0,20,18"
                                VerticalAlignment="Bottom"
                                Text="{x:Bind Title, Mode=OneWay}"
                                FontSize="19"
                                FontWeight="SemiBold"
                                Foreground="White"
                                MaxLines="2"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Border>
                </Button>
            </DataTemplate>

            <DataTemplate x:Key="EditorialShelfTemplate" x:DataType="vm:PodcastBrowseSectionViewModel">
                <StackPanel Margin="0,0,-32,18" Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock
                                Text="{x:Bind Title}"
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                FontWeight="Bold" />
                            <TextBlock
                                Text="{x:Bind Subtitle}"
                                FontSize="12"
                                CharacterSpacing="80"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextTrimming="CharacterEllipsis"
                                Visibility="{x:Bind Subtitle, Converter={StaticResource NullToVisibilityConverter}}" />
                        </StackPanel>

                        <Button
                            Grid.Column="1"
                            MinWidth="0"
                            Padding="10,4"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="SectionAction_Click"
                            Content="{x:Bind ActionText, Mode=OneWay}"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Tag="{x:Bind}"
                            Visibility="{x:Bind HasAction, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <StackPanel
                            Grid.Column="2"
                            Margin="0,0,32,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <Button
                                Style="{StaticResource ShelfChevronButtonStyle}"
                                Command="{Binding ElementName=PART_Shelf, Path=PageLeftCommand}"
                                Visibility="{Binding ElementName=PART_Shelf, Path=HasOverflow, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FontIcon FontSize="12" Glyph="&#xE76B;" />
                            </Button>
                            <Button
                                Style="{StaticResource ShelfChevronButtonStyle}"
                                Command="{Binding ElementName=PART_Shelf, Path=PageRightCommand}"
                                Visibility="{Binding ElementName=PART_Shelf, Path=HasOverflow, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FontIcon FontSize="12" Glyph="&#xE76C;" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <shelf:ShelfScroller
                            x:Name="PART_Shelf"
                            ItemsSourceIdentity="{x:Bind Uri, Mode=OneWay}"
                            ItemsSource="{x:Bind Items, Mode=OneWay}"
                            ItemTemplate="{StaticResource PodcastShowContentCardTemplate}"
                            MinItemWidth="160"
                            MaxItemWidth="200"
                            Spacing="14" />
                        <Border
                            Width="140"
                            HorizontalAlignment="Right"
                            IsHitTestVisible="False"
                            Background="{ThemeResource ShelfFadeRightBrush}" />
                    </Grid>
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Padding="12,8,12,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="CategorySidebar"
            Grid.Column="0"
            Margin="0,0,16,0"
            Visibility="Collapsed">
            <Grid>
                <ScrollView
                    ContentOrientation="Vertical"
                    HorizontalScrollBarVisibility="Hidden"
                    HorizontalScrollMode="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Auto"
                    Visibility="{x:Bind ViewModel.ShowSidebar, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Padding="0,6,0,28" Spacing="16">
                        <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.AllPodcastCategories, Mode=OneWay}">
                            <muxc:ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:PodcastBrowseSectionViewModel">
                                    <StackPanel Spacing="7">
                                        <TextBlock
                                            Text="{x:Bind Title, Converter={StaticResource StringToUpperConverter}}"
                                            FontSize="11"
                                            CharacterSpacing="180"
                                            FontWeight="SemiBold"
                                            Opacity="0.55"
                                            TextTrimming="CharacterEllipsis" />

                                        <muxc:ItemsRepeater ItemsSource="{x:Bind Items, Mode=OneWay}">
                                            <muxc:ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PodcastBrowseItemViewModel">
                                                    <Button
                                                        MinWidth="0"
                                                        MinHeight="0"
                                                        Padding="8,5"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Stretch"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Click="BrowseItem_Click"
                                                        Tag="{x:Bind}"
                                                        UseSystemFocusVisuals="True">
                                                        <Grid MinHeight="24" ColumnSpacing="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border
                                                                Grid.ColumnSpan="2"
                                                                Margin="-8,-4,-8,-4"
                                                                Background="{x:Bind TileTintBrush}"
                                                                CornerRadius="7"
                                                                Opacity="0.95"
                                                                Visibility="{x:Bind IsSidebarSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                            <Border
                                                                Width="3"
                                                                Height="16"
                                                                VerticalAlignment="Center"
                                                                Background="{x:Bind TileBorderBrush}"
                                                                CornerRadius="2"
                                                                Visibility="{x:Bind IsSidebarSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                            <TextBlock
                                                                Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Text="{x:Bind Title, Converter={StaticResource StringToUpperConverter}}"
                                                                FontSize="11"
                                                                CharacterSpacing="100"
                                                                FontWeight="SemiBold"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </muxc:ItemsRepeater.ItemTemplate>
                                            <muxc:ItemsRepeater.Layout>
                                                <muxc:StackLayout Orientation="Vertical" Spacing="2" />
                                            </muxc:ItemsRepeater.Layout>
                                        </muxc:ItemsRepeater>
                                    </StackPanel>
                                </DataTemplate>
                            </muxc:ItemsRepeater.ItemTemplate>
                            <muxc:ItemsRepeater.Layout>
                                <muxc:StackLayout Orientation="Vertical" Spacing="16" />
                            </muxc:ItemsRepeater.Layout>
                        </muxc:ItemsRepeater>
                    </StackPanel>
                </ScrollView>

                <StackPanel
                    x:Name="CategorySidebarShimmer"
                    Padding="0,6,0,0"
                    IsHitTestVisible="False"
                    Spacing="16"
                    Visibility="{x:Bind ViewModel.ShowSidebarShimmer, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="8">
                        <controls:Shimmer Width="64" Height="11" HorizontalAlignment="Left" CornerRadius="3" Opacity="0.55" />
                        <controls:Shimmer Width="120" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                        <controls:Shimmer Width="96" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                    </StackPanel>
                    <StackPanel Spacing="8">
                        <controls:Shimmer Width="132" Height="11" HorizontalAlignment="Left" CornerRadius="3" Opacity="0.55" />
                        <controls:Shimmer Width="84" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                        <controls:Shimmer Width="108" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                        <controls:Shimmer Width="140" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                        <controls:Shimmer Width="72" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                    </StackPanel>
                    <StackPanel Spacing="8">
                        <controls:Shimmer Width="108" Height="11" HorizontalAlignment="Left" CornerRadius="3" Opacity="0.55" />
                        <controls:Shimmer Width="116" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                        <controls:Shimmer Width="84" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollView
            x:Name="MainScroll"
            Grid.Column="1"
            ContentOrientation="Vertical"
            HorizontalScrollBarVisibility="Hidden"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <StackPanel Spacing="18">
                <Grid Margin="0,6,4,0" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="420" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <muxc:BreadcrumbBar
                            Margin="0,0,0,2"
                            HorizontalAlignment="Left"
                            ItemClicked="BrowseBreadcrumb_ItemClicked"
                            ItemsSource="{x:Bind ViewModel.BreadcrumbItems, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.ShowBreadcrumbs, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                            FontSize="38"
                            FontWeight="Bold"
                            LineHeight="44"
                            MaxLines="2"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                            FontSize="13"
                            CharacterSpacing="20"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            LineHeight="18"
                            MaxLines="1"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{x:Bind ViewModel.Subtitle, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
                    </StackPanel>

                    <TextBox
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        PlaceholderText="{x:Bind ViewModel.SearchPlaceholder, Mode=OneWay}" />
                </Grid>

                <Grid
                    MaxWidth="1420"
                    Margin="0,12,4,0"
                    HorizontalAlignment="Left"
                    ColumnSpacing="12"
                    Visibility="{x:Bind ViewModel.ShowHeroCarousel, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="920" />
                        <ColumnDefinition Width="488" />
                    </Grid.ColumnDefinitions>

                    <hero:HeroCarouselView
                        x:Name="HeroCarousel"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        AutoAdvanceInterval="0:0:6"
                        Background="Transparent"
                        IsAutoAdvanceEnabled="{x:Bind ViewModel.HasHeroShows, Mode=OneWay}"
                        IsLoopingEnabled="True"
                        PauseAutoAdvanceOnInteraction="True"
                        ShowPips="True"
                        UseColorWash="True"
                        UseGlow="True"
                        MaxStageWidth="920"
                        UseShimmerPlaceholder="True"
                        UseSpotlight="True" />

                    <Grid
                        Grid.Column="1"
                        Height="517.5"
                        Margin="0"
                        VerticalAlignment="Top"
                        RowSpacing="12"
                        Visibility="{x:Bind ViewModel.HasHeroSideShows, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ContentControl
                            Grid.Row="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Content="{x:Bind ViewModel.HeroSidePrimary, Mode=OneWay}"
                            ContentTemplate="{StaticResource HeroSideCardTemplate}"
                            Visibility="{x:Bind ViewModel.HasHeroSidePrimary, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ContentControl
                                Grid.Column="0"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Content="{x:Bind ViewModel.HeroSideSecondaryOne, Mode=OneWay}"
                                ContentTemplate="{StaticResource HeroSideCardTemplate}"
                                Visibility="{x:Bind ViewModel.HasHeroSideSecondaryOne, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <ContentControl
                                Grid.Column="1"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Content="{x:Bind ViewModel.HeroSideSecondaryTwo, Mode=OneWay}"
                                ContentTemplate="{StaticResource HeroSideCardTemplate}"
                                Visibility="{x:Bind ViewModel.HasHeroSideSecondaryTwo, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Grid>
                </Grid>

                <Grid x:Name="PodcastBrowseBodyHost" MinHeight="360">
                    <StackPanel
                        x:Name="PodcastBrowseShimmer"
                        x:Load="{x:Bind ShimmerGate.IsLoaded, Mode=OneWay}"
                        IsHitTestVisible="False"
                        Spacing="14"
                        VerticalAlignment="Top">
                        <StackPanel Margin="0,0,-32,20" Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="6" VerticalAlignment="Center">
                                    <controls:Shimmer Width="180" Height="24" HorizontalAlignment="Left" CornerRadius="6" />
                                    <controls:Shimmer Width="240" Height="12" HorizontalAlignment="Left" CornerRadius="4" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,32,0" Orientation="Horizontal" Spacing="4">
                                    <controls:Shimmer Width="32" Height="32" CornerRadius="16" />
                                    <controls:Shimmer Width="32" Height="32" CornerRadius="16" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <StackPanel Width="180" Spacing="8">
                                    <controls:Shimmer Width="180" Height="180" CornerRadius="8" />
                                    <controls:Shimmer Width="150" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                                    <controls:Shimmer Width="96" Height="12" HorizontalAlignment="Left" CornerRadius="4" />
                                </StackPanel>
                                <StackPanel Width="180" Spacing="8">
                                    <controls:Shimmer Width="180" Height="180" CornerRadius="8" />
                                    <controls:Shimmer Width="132" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                                    <controls:Shimmer Width="108" Height="12" HorizontalAlignment="Left" CornerRadius="4" />
                                </StackPanel>
                                <StackPanel Width="180" Spacing="8">
                                    <controls:Shimmer Width="180" Height="180" CornerRadius="8" />
                                    <controls:Shimmer Width="164" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                                    <controls:Shimmer Width="88" Height="12" HorizontalAlignment="Left" CornerRadius="4" />
                                </StackPanel>
                                <StackPanel Width="180" Spacing="8">
                                    <controls:Shimmer Width="180" Height="180" CornerRadius="8" />
                                    <controls:Shimmer Width="128" Height="14" HorizontalAlignment="Left" CornerRadius="4" />
                                    <controls:Shimmer Width="72" Height="12" HorizontalAlignment="Left" CornerRadius="4" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel
                        x:Name="PodcastBrowseContent"
                        Opacity="0"
                        Spacing="20"
                        VerticalAlignment="Top">
                        <InfoBar
                            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                            Severity="Error"
                            Title="Podcast browse failed"
                            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                            IsClosable="False" />

                        <muxc:ItemsRepeater
                            ItemsSource="{x:Bind ViewModel.EditorialShelves, Mode=OneWay}"
                            ItemTemplate="{StaticResource EditorialShelfTemplate}"
                            Visibility="{x:Bind ViewModel.HasEditorialShelves, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <muxc:ItemsRepeater.Layout>
                                <muxc:StackLayout Orientation="Vertical" Spacing="0" />
                            </muxc:ItemsRepeater.Layout>
                        </muxc:ItemsRepeater>

                        <TextBlock
                            HorizontalAlignment="Center"
                            Text="No podcast browse content was returned."
                            Style="{StaticResource BodyTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Visibility="{x:Bind ViewModel.ShowNoContentMessage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
