<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.PlaylistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tdg="using:Wavee.UI.WinUI.Controls.TrackDataGrid"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:controls1="using:Wavee.UI.WinUI.Controls"
    xmlns:browseControls="using:Wavee.UI.WinUI.Controls.Browse"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:ui="using:CommunityToolkit.WinUI.Media"
    xmlns:winUi="using:CommunityToolkit.WinUI"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:home="using:Wavee.UI.WinUI.ViewModels.Home"
    xmlns:homeViews="using:Wavee.UI.WinUI.Views.Home"
    xmlns:sessionTokens="using:Wavee.UI.WinUI.Controls.SessionTokens"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">

    <Page.Resources>
        <DataTemplate x:Key="EmptyPlaylistGenreChipTemplate" x:DataType="home:BrowseAllItem">
            <homeViews:BrowseChip Item="{x:Bind}"/>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="RootGrid" SizeChanged="RootGrid_SizeChanged">
        <!-- Responsive: driven by SizeChanged in code-behind. Loading is bound to
             IsLoading (metadata) for the left panel; the TrackListView has its own
             IsLoadingTracks-driven shimmer because playlist tracks lazy-load
             independently of the metadata. -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState"/>
                <VisualState x:Name="NarrowState">
                    <VisualState.Setters>
                        <!-- NarrowPlaylistHeader.Visibility setters removed: no element
                             with that x:Name exists in this page anymore, so the setter
                             threw XamlUnhandledException on every SizeChanged that flipped
                             between Wide/Narrow. If a narrow-mode header is reintroduced
                             later, re-add matching setters referencing the real name. -->
                        <Setter Target="WidePlaylistPanel.Visibility" Value="Collapsed"/>
                        <Setter Target="WidePlaylistScroller.Visibility" Value="Collapsed"/>
                        <Setter Target="ShimmerContainer.Visibility" Value="Collapsed"/>
                        <Setter Target="PlaylistSplitter.Visibility" Value="Collapsed"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Palette-tinted page wash sitting on top of the window's Mica.
             Mirrors AlbumPage so playlist / album feel like the same surface.
             Opacity is baked into the brush itself; null brush ⇒ nothing renders. -->
        <Border IsHitTestVisible="False"
                Background="{x:Bind ViewModel.PaletteBackdropBrush, Mode=OneWay}"/>

        <Grid x:Name="TwoColumnGrid"
              MaxWidth="2400"
              HorizontalAlignment="Stretch"
              Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <!-- Banner row: 280 px hero band spanning all three columns.
                     Either composition image (HeaderImageUrl present) or a
                     procedural gradient (AnimatedHeroBackground), with the
                     title overlaid at the bottom-left. -->
                <RowDefinition Height="Auto"/>
                <!-- Content row: existing two-column layout (left = metadata
                     sidebar, right = TrackDataGrid). -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="200" MinWidth="200" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ╔══════════════════════════════════════════════════════════
                 ║ HERO BANNER ROW
                 ║ Spans all 3 columns at the top. Two mutually-exclusive
                 ║ background renderers stacked behind the title overlay:
                 ║   1. HeaderBackgroundHost — composition image surface for
                 ║      editorial / radio playlists with header_image_url_desktop.
                 ║      Image + scrim composition visuals attached in code-behind.
                 ║   2. AnimatedHeroBackground — Win2D + MeshGradientShader
                 ║      seeded with palette-extracted BannerPrimaryColor /
                 ║      BannerAccentColor for playlists without a header image.
                 ║ XAML scrim Border on top provides bottom-weighted darken-
                 ║ to-theme-surface so the title text stays legible against
                 ║ either background.
                 ╚══════════════════════════════════════════════════════════ -->
            <Grid x:Name="HeroBannerRow"
                  Grid.Row="0"
                  Grid.ColumnSpan="3"
                  Height="280"
                  Visibility="{x:Bind ViewModel.LayoutMode, Mode=OneWay, Converter={StaticResource PlaylistLayoutModeBannerVisibilityConverter}}">

                <!-- Procedural fallback (BACK layer). Visible only when
                     HeaderImageUrl is null — most user-created playlists, plus
                     the brief shimmer window before the editorial image lands,
                     plus the rare image-decode-failure case (see
                     OnHeroImageLoadCompleted in code-behind which clears
                     HeaderImageUrl on failure). The two color DPs are fed from
                     the cover-extracted AlbumPalette via the VM. -->
                <cards:AnimatedHeroBackground
                    x:Name="HeroBannerFallback"
                    PrimaryColor="{x:Bind ViewModel.BannerPrimaryColor, Mode=OneWay}"
                    AccentColor="{x:Bind ViewModel.BannerAccentColor, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasHeaderImage, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                <!-- Composition image surface (FRONT layer). ALWAYS visible
                     inside the banner row — no per-element Visibility binding.
                     When HeaderImageUrl is null the composition surface is
                     null (renders transparent) and the AnimatedHeroBackground
                     behind shows through. When the URL arrives, the surface
                     loads and the image covers the gradient.
                     Why no Visibility binding: gating Visibility on
                     HasHeaderImage caused intermittent empty banners on cold
                     load — the host was Collapsed (ActualSize=0) when
                     HeaderBackgroundHost_Loaded built the composition tree
                     and ApplyHeaderBackground sized the decode, then the
                     Collapsed→Visible transition didn't reliably re-sync the
                     SpriteVisual's RelativeSizeAdjustment. Always-visible
                     keeps the host at full size from first paint. -->
                <Border x:Name="HeaderBackgroundHost"
                        IsHitTestVisible="False"/>

                <!-- Title + source overlay (bottom-left of the banner). The
                     InlineEditableText keeps owner-rename inline-edit behavior
                     in its new home — click the title to edit (owners only).
                     Title shimmer occupies the same Y position so the swap
                     when PlaylistName arrives is opacity-only, no shift. -->
                <Grid VerticalAlignment="Bottom"
                      Margin="32,0,32,20">
                    <StackPanel Spacing="6" HorizontalAlignment="Stretch">
                        <Grid MinHeight="48" HorizontalAlignment="Stretch">
                            <controls1:InlineEditableText
                                x:Name="BannerTitleEditor"
                                Text="{x:Bind ViewModel.PlaylistName, Mode=OneWay}"
                                IsEditable="{x:Bind ViewModel.CanEditName, Mode=OneWay}"
                                IsBusy="{x:Bind ViewModel.IsRenaming, Mode=OneWay}"
                                MaxLength="100"
                                MaxLines="2"
                                FontSize="40"
                                FontWeight="Bold"
                                TextAlignment="Left"
                                HorizontalContentAlignment="Stretch"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Committed="PlaylistTitleEditor_Committed"
                                Visibility="{x:Bind ViewModel.PlaylistName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <controls:Shimmer Width="480" Height="40" CornerRadius="6" HorizontalAlignment="Left"
                                              Visibility="{x:Bind ViewModel.PlaylistName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.OwnerName, Mode=OneWay}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{x:Bind ViewModel.OwnerName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Shimmer skeleton for left panel (visible while metadata loads).
                 Wrapper Grid keeps the IContentPageHost.ShimmerContainer ref +
                 the narrow VSM Visibility setter pointing at one element.
                 Inside, two skeletons branch by LayoutMode so the shimmer→
                 loaded swap is opacity-only (geometry matches the loaded
                 state for whichever layout mode is active):
                   • Banner mode: owner-row + stats + actions (no cover/title
                     — those live in the banner row above, with their own
                     overlay shimmer).
                   • Cover mode: cover + title + owner-row + stats + actions
                     (matches the pre-redesign skeleton for user playlists). -->
            <Grid x:Name="ShimmerContainer"
                  x:Load="{x:Bind ShimmerGate.IsLoaded, Mode=OneWay}"
                  Grid.Row="1" Grid.Column="0"
                  HorizontalAlignment="Stretch" VerticalAlignment="Top"
                  Padding="32,24,16,24">
                <StackPanel Spacing="14"
                            Visibility="{x:Bind ViewModel.LayoutMode, Mode=OneWay, Converter={StaticResource PlaylistLayoutModeBannerVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <controls:Shimmer Width="24" Height="24" CornerRadius="12"/>
                        <controls:Shimmer Width="120" Height="16" VerticalAlignment="Center"/>
                    </StackPanel>
                    <controls:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <controls:Shimmer Width="86" Height="40" CornerRadius="20"/>
                        <controls:Shimmer Width="40" Height="40" CornerRadius="20"/>
                        <controls:Shimmer Width="40" Height="40" CornerRadius="20"/>
                        <controls:Shimmer Width="40" Height="40" CornerRadius="20"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Spacing="14"
                            Visibility="{x:Bind ViewModel.LayoutMode, Mode=OneWay, Converter={StaticResource PlaylistLayoutModeCoverVisibilityConverter}}">
                    <controls:Shimmer Height="220" CornerRadius="8" HorizontalAlignment="Stretch"/>
                    <controls:Shimmer Width="220" Height="22" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <controls:Shimmer Width="24" Height="24" CornerRadius="12"/>
                        <controls:Shimmer Width="120" Height="16" VerticalAlignment="Center"/>
                    </StackPanel>
                    <controls:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <controls:Shimmer Width="86" Height="40" CornerRadius="20"/>
                        <controls:Shimmer Width="40" Height="40" CornerRadius="20"/>
                        <controls:Shimmer Width="40" Height="40" CornerRadius="20"/>
                        <controls:Shimmer Width="40" Height="40" CornerRadius="20"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Wide left panel: shown once metadata has arrived. The cover Grid
                 + title block at the top are gated on LayoutMode == Cover (user
                 playlists). Banner-mode playlists hide both — their title lives
                 in the banner row's overlay above, and there is no square cover.
                 Wrapped in a ScrollView so long descriptions / session-control
                 chip grids / collaborator lists can scroll vertically when the
                 panel doesn't fit the window height. -->
            <ScrollView x:Name="WidePlaylistScroller" Grid.Row="1" Grid.Column="0"
                        ContentOrientation="Vertical"
                        HorizontalScrollMode="Disabled"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollMode="Auto"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="WidePlaylistPanel"
                        Padding="16,20,8,20" Spacing="14" HorizontalAlignment="Stretch"
                        VerticalAlignment="Top">

                <!-- 1. Cover art (Cover mode only). Square; SizeChanged keeps it
                     square as the panel resizes. Hidden in Banner mode — the
                     hero banner row above carries the visual identity instead.
                     x:Name="CoverHeroBlock" wraps the cover Grid only (the
                     title Grid below has its own name) so the layout-transition
                     fade-in in code-behind can target this surface independent
                     of the rest of WidePlaylistPanel which is already visible. -->
                <Grid x:Name="CoverHeroBlock" HorizontalAlignment="Stretch"
                      Visibility="{x:Bind ViewModel.LayoutMode, Mode=OneWay, Converter={StaticResource PlaylistLayoutModeCoverVisibilityConverter}}">
                    <winUi:Effects.Shadow>
                        <ui:AttachedCardShadow BlurRadius="32" Offset="0,12" Opacity="0.28" Color="Black" CornerRadius="8" InnerContentClipMode="CompositionMaskBrush"/>
                    </winUi:Effects.Shadow>
                    <Border x:Name="PlaylistArtContainer" CornerRadius="8"
                            HorizontalAlignment="Stretch"
                            SizeChanged="PlaylistArtContainer_SizeChanged"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid>
                            <Grid Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <FontIcon Glyph="&#xE93F;"
                                          FontFamily="{StaticResource MediaPlayerIconsFontFamily}"
                                          FontSize="64"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                          Opacity="0.72"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Grid>
                            <Image x:Name="CoverImage"
                                   Source="{x:Bind ViewModel.PlaylistImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='280'}"
                                   Stretch="UniformToFill"
                                   Visibility="{x:Bind ViewModel.PlaylistImageUrl, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                   behaviors:ImageFallbackBehavior.HideOnError="True"
                                   behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                   behaviors:ImageFallbackBehavior.DecodePixelWidth="280"/>

                            <Image x:Name="CoverPreviewImage"
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed"/>

                            <Grid x:Name="CoverEditOverlay"
                                  Background="#80000000"
                                  Opacity="0"
                                  IsHitTestVisible="{x:Bind ViewModel.CanEditPicture, Mode=OneWay}"
                                  PointerEntered="CoverEditOverlay_PointerEntered"
                                  PointerExited="CoverEditOverlay_PointerExited"
                                  Tapped="CoverEditOverlay_Tapped"
                                  RightTapped="CoverEditOverlay_RightTapped">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="6">
                                    <FontIcon Glyph="&#xE722;" FontSize="32"
                                              Foreground="White"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="Change photo"
                                               Foreground="White"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <ProgressRing x:Name="CoverUploadRing"
                                              Width="36" Height="36"
                                              IsActive="False"
                                              Visibility="Collapsed"
                                              Foreground="White"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 2. Title (Cover mode only). InlineEditableText renders as a
                     TextBlock for viewers (IsEditable=false) and swaps to a
                     TextBox in-place for owners on click. Hidden in Banner mode
                     — the banner overlay's BannerTitleEditor handles the title
                     up there. Both wire to the same Committed handler. -->
                <Grid x:Name="CoverTitleBlock" MinHeight="28" HorizontalAlignment="Stretch"
                      Visibility="{x:Bind ViewModel.LayoutMode, Mode=OneWay, Converter={StaticResource PlaylistLayoutModeCoverVisibilityConverter}}">
                    <controls1:InlineEditableText
                        x:Name="PlaylistTitleEditor"
                        Text="{x:Bind ViewModel.PlaylistName, Mode=OneWay}"
                        IsEditable="{x:Bind ViewModel.CanEditName, Mode=OneWay}"
                        IsBusy="{x:Bind ViewModel.IsRenaming, Mode=OneWay}"
                        MaxLength="100"
                        MaxLines="4"
                        FontSize="22"
                        FontWeight="Bold"
                        TextAlignment="Left"
                        HorizontalContentAlignment="Stretch"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        Committed="PlaylistTitleEditor_Committed"
                        Visibility="{x:Bind ViewModel.PlaylistName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <controls:Shimmer Width="220" Height="22" HorizontalAlignment="Left"
                                      Visibility="{x:Bind ViewModel.PlaylistName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                </Grid>

                <!-- 3. Owner row — small avatar + linked name. Clicking the row
                     opens the owner's profile (ProfilePage). PersonPicture handles
                     image / initials / glyph fallback; HyperlinkButton's Command
                     binds to PlaylistViewModel.OpenOwnerProfileCommand which is
                     a no-op when OwnerId is missing. -->
                <HyperlinkButton Padding="0"
                                 Command="{x:Bind ViewModel.OpenOwnerProfileCommand}"
                                 Visibility="{x:Bind ViewModel.OwnerName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <PersonPicture Width="24" Height="24"
                                       DisplayName="{x:Bind ViewModel.OwnerName, Mode=OneWay}"
                                       ProfilePicture="{x:Bind ViewModel.OwnerAvatarUrl, Mode=OneWay, Converter={StaticResource SpotifyImageConverter}, ConverterParameter='48'}"/>
                        <TextBlock Text="{x:Bind ViewModel.OwnerName, Mode=OneWay}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </HyperlinkButton>

                <!-- 4. Inline stats line: "242 songs · 11 hr 18 min · 95K followers".
                     Single TextBlock fed by MetaInlineLine (computed VM property);
                     omits empty segments so the line grows as values resolve. -->
                <TextBlock Text="{x:Bind ViewModel.MetaInlineLine, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>

                <!-- 4b. Chart sub-stat line — only shown for chart-format playlists.
                     "Updated May 1 · 8 new entries". Empty / collapsed otherwise. -->
                <TextBlock Text="{x:Bind ViewModel.ChartHeaderLine, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.IsChart, Mode=OneWay,
                               Converter={StaticResource BoolToVisibilityConverter}}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap"/>

                <!-- 5. Action row — Play (primary accent w/ label) + small icon-only
                     Shuffle / Heart / Share / Overflow. WrapPanel so buttons flow to
                     a second row when the panel is too narrow to fit them inline
                     (small-window / resized-splitter cases). -->
                <controls:WrapPanel Orientation="Horizontal" HorizontalSpacing="8" VerticalSpacing="8" Margin="0,8,0,0">
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.PlayAllCommand}"
                            Padding="18,10" CornerRadius="20"
                            ToolTipService.ToolTip="Play">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE768;" FontSize="14"/>
                            <TextBlock Text="Play" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.ShuffleCommand}"
                            Width="40" Height="40" CornerRadius="20" Padding="0"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Shuffle play">
                        <FontIcon Glyph="&#xE8B1;" FontSize="14"/>
                    </Button>
                    <!-- Heart: hidden on owned playlists (owners are inherently
                         followers of their own playlists; the affordance there is
                         "delete" instead — see the trash button next door). -->
                    <Button Command="{x:Bind ViewModel.ToggleFollowCommand}"
                            Width="40" Height="40" CornerRadius="20" Padding="0"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Save to your library"
                            Visibility="{x:Bind ViewModel.IsOwner, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <FontIcon Glyph="{x:Bind ViewModel.IsFollowed, Mode=OneWay, Converter={StaticResource BoolToHeartGlyphConverter}}"
                                  FontSize="14"/>
                    </Button>
                    <!-- Delete: shown only on owned playlists. Click handler reuses
                         the existing ConfirmAndDeletePlaylistAsync dialog. -->
                    <Button Click="HeroDeleteButton_Click"
                            Width="40" Height="40" CornerRadius="20" Padding="0"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Delete playlist"
                            Visibility="{x:Bind ViewModel.IsOwner, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <FontIcon Glyph="&#xE74D;" FontSize="14"
                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    </Button>
                    <Button Command="{x:Bind ViewModel.SharePlaylistCommand}"
                            Width="40" Height="40" CornerRadius="20" Padding="0"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Copy link to playlist">
                        <FontIcon Glyph="&#xE72D;" FontSize="14"/>
                    </Button>

                    <!-- Owner overflow: collaborative toggle + delete. Hidden for
                         viewers and contributors. Flyout built per-open in
                         code-behind. -->
                    <Button x:Name="OwnerOverflowButton"
                            Width="40" Height="40" CornerRadius="20" Padding="0"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            BorderThickness="0"
                            ToolTipService.ToolTip="More"
                            Click="OwnerOverflowButton_Click"
                            Visibility="{x:Bind ViewModel.HasOverflowItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <FontIcon Glyph="&#xE712;" FontSize="14"/>
                    </Button>
                </controls:WrapPanel>

                <!-- 6a. Description (viewer / non-owner branch). Plain text, no card
                     chrome — flows naturally beneath the action row like the album
                     page's release/copyright block. -->
                <StackPanel Spacing="4"
                            Margin="0,4,0,0"
                            Visibility="{x:Bind ViewModel.IsDescriptionViewerCardVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <RichTextBlock x:Name="DescriptionRichText"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextAlignment="Left"
                                   MaxLines="3"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap"
                                   IsTextTrimmedChanged="DescriptionRichText_IsTextTrimmedChanged"/>

                    <HyperlinkButton x:Name="DescriptionMoreButton"
                                     HorizontalAlignment="Left"
                                     Padding="4,2"
                                     FontSize="12"
                                     Visibility="Collapsed"
                                     Click="DescriptionMoreButton_Click">
                        <TextBlock x:Name="DescriptionMoreLabel" Text="More..."/>
                    </HyperlinkButton>
                </StackPanel>

                <!-- 6b. Description (owner branch). Editable in-place; "Edit description..."
                     placeholder when empty. No surrounding card. -->
                <controls1:InlineEditableText
                    x:Name="PlaylistDescriptionEditor"
                    Text="{x:Bind ViewModel.PlaylistDescription, Mode=OneWay}"
                    IsEditable="{x:Bind ViewModel.CanEditDescription, Mode=OneWay}"
                    IsBusy="{x:Bind ViewModel.IsUpdatingDescription, Mode=OneWay}"
                    AcceptsReturn="True"
                    MaxLength="300"
                    MaxLines="6"
                    FontSize="12"
                    Margin="0,4,0,0"
                    TextAlignment="Left"
                    HorizontalContentAlignment="Stretch"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Placeholder="Edit description..."
                    Committed="PlaylistDescriptionEditor_Committed"
                    x:Load="{x:Bind ViewModel.CanEditDescription, Mode=OneWay}"/>

                <!-- 7. Session control chips: editorial / algorithmic playlists ship
                     a session_control_display group; chip row re-personalises the
                     playlist on click. Now left-aligned to match panel direction. -->
                <Grid HorizontalAlignment="Left" Margin="0,8,0,0"
                      x:Name="TokenViewPanel"
                      x:Load="{x:Bind ViewModel.HasSessionControlChips, Mode=OneWay}">
                    <sessionTokens:SessionTokenView
                        IsWrapped="True"
                        CanRemoveTokens="False"
                        ItemsSource="{x:Bind ViewModel.SessionControlChips, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedSessionControlChip, Mode=TwoWay}">
                        <sessionTokens:SessionTokenView.ItemTemplate>
                            <DataTemplate x:DataType="vm:SessionControlChipViewModel">
                                <TextBlock Text="{x:Bind Label}" FontSize="13"/>
                            </DataTemplate>
                        </sessionTokens:SessionTokenView.ItemTemplate>
                    </sessionTokens:SessionTokenView>
                </Grid>

                <!-- 8. Collaborator row — overlapping ringed avatars + "{N} collaborators"
                     label + trailing chevron. Wrapped in a Border so we can paint a
                     hover-pill background (toggled in code-behind via PointerEntered/
                     Exited) and the cursor swaps to a hand on hover — the previous
                     bare StackPanel had no clickability affordance. -->
                <controls1:ClickableBorder x:Name="CollaboratorStackHostFrame"
                                           HorizontalAlignment="Left"
                                           Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                           BorderThickness="1"
                                           CornerRadius="{ThemeResource OverlayCornerRadius}"
                                           Padding="8,6,12,6"
                                           Margin="0,6,0,0"
                                           Tapped="CollaboratorStackHost_Tapped"
                                           PointerEntered="CollaboratorStackHostFrame_PointerEntered"
                                           PointerExited="CollaboratorStackHostFrame_PointerExited"
                                           Visibility="{x:Bind ViewModel.HasCollaborators, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel x:Name="CollaboratorStackHost"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="8"/>
                </controls1:ClickableBorder>
            </StackPanel>
            </ScrollView>

            <controls1:GridSplitter
                x:Name="PlaylistSplitter"
                Grid.Row="1" Grid.Column="1"
                Width="12"
                ResizeCompleted="PlaylistSplitter_ResizeCompleted"/>

            <!-- Track grid in column 2. IsLoading is driven by IsLoadingTracks so
                 the grid can show lightweight skeleton rows while playlist tracks
                 lazy-load independently of metadata. Rewrite swapped
                 TrackListView for TrackDataGrid — filter/sort/columns live inside the
                 grid's toolbar now; the page-level hero + narrow-mode header that used
                 to nest inside TrackListView.HeaderContent still render above the grid. -->
            <tdg:TrackDataGrid
                x:Name="TrackGrid"
                Grid.Row="1" Grid.Column="2"
                VerticalAlignment="Stretch"
                Margin="0,0,0,0"
                PageKey="playlist"
                UseItemsViewRows="True"
                IsLoading="{x:Bind ViewModel.IsLoadingTracks, Mode=OneWay}"
                LoadingRowCount="{x:Bind ViewModel.TotalTracks, Mode=OneWay}"
                AddedByVisible="{x:Bind ViewModel.ShouldShowAddedByColumn, Mode=OneWay}"
                ItemsSource="{x:Bind ViewModel.FilteredTracks, Mode=OneWay}"
                PlayCommand="{x:Bind ViewModel.PlayTrackCommand}">
                <tdg:TrackDataGrid.FilterBarContent>
                    <ToggleButton
                        MinHeight="32"
                        Padding="10,4"
                        CornerRadius="16"
                        IsChecked="{x:Bind ViewModel.ShowOnlyVideoTracks, Mode=TwoWay}"
                        Visibility="{x:Bind ViewModel.HasVideoTracks, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Show only tracks with music videos">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon
                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                FontSize="13"
                                Glyph="&#xE714;" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.VideoTrackFilterLabel, Mode=OneWay}" />
                        </StackPanel>
                    </ToggleButton>
                </tdg:TrackDataGrid.FilterBarContent>
            </tdg:TrackDataGrid>

            <Grid
                x:Name="EmptyPlaylistState"
                Grid.Row="1" Grid.Column="2"
                Margin="24,104,24,24"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Visibility="{x:Bind ViewModel.ShowEmptyPlaylistState, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel
                    MaxWidth="640"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <Border
                        Width="72"
                        Height="72"
                        HorizontalAlignment="Center"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="36">
                        <FontIcon
                            Glyph="&#xE8FD;"
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="30"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Opacity="0.85"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock
                        Text="This playlist is empty"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        TextAlignment="Center"
                        HorizontalAlignment="Center"/>
                    <TextBlock
                        Text="Explore a genre below, then add songs from search to start building it."
                        Style="{StaticResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"/>
                    <browseControls:BrowseGrid
                        ItemsSource="{x:Bind ViewModel.EmptyPlaylistGenreItems, Mode=OneWay}"
                        ItemTemplate="{StaticResource EmptyPlaylistGenreChipTemplate}"
                        MinItemWidth="120"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Stretch"
                        Visibility="{x:Bind ViewModel.ShowEmptyPlaylistGenreGrid, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>

        </Grid>

        <!-- Error overlay: shown when detail fetch or track fetch fails.
             Retry re-invalidates the PlaylistStore and resets track-load state. -->
        <controls1:ErrorStateView
            Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            RetryCommand="{x:Bind ViewModel.RetryCommand}"/>
    </Grid>
</Page>
