<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.PlaylistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tdg="using:Wavee.UI.WinUI.Controls.TrackDataGrid"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:controls1="using:Wavee.UI.WinUI.Controls"
    xmlns:helpers="using:Wavee.UI.WinUI.Helpers"
    xmlns:browseControls="using:Wavee.UI.WinUI.Controls.Browse"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:ui="using:CommunityToolkit.WinUI.Media"
    xmlns:winUi="using:CommunityToolkit.WinUI"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:home="using:Wavee.UI.WinUI.ViewModels.Home"
    xmlns:homeViews="using:Wavee.UI.WinUI.Views.Home"
    xmlns:contracts="using:Wavee.UI.WinUI.Data.Contracts"
    xmlns:sessionTokens="using:Wavee.UI.WinUI.Controls.SessionTokens"
    xmlns:track="using:Wavee.UI.WinUI.Controls.Track"
    xmlns:playlist="using:Wavee.UI.WinUI.Controls.Playlist"
    xmlns:transitions="using:CommunityToolkit.WinUI"
    x:Name="PageRoot"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent">

    <Page.Resources>
        <DataTemplate x:Key="EmptyPlaylistGenreChipTemplate" x:DataType="home:BrowseAllItem">
            <homeViews:BrowseChip Item="{x:Bind}"/>
        </DataTemplate>

        <!-- Shy-header morph: banner overlay -> floating compact pill. Matched
             ids on the title + owner-name elements interpolate between the two
             states; card-shell on the outer pill Border drives the chrome
             morph. Cover thumb + Play button on the pill have no matched
             source in the banner overlay, so they fade in via the Independent*
             show window. Mirrors ArtistShyHeaderTransition. -->
        <transitions:TransitionHelper x:Key="PlaylistShyHeaderTransition"
                                      Duration="0:0:0.36"
                                      ReverseDuration="0:0:0.30"
                                      DefaultEasingMode="EaseInOut"
                                      SourceToggleMethod="ByVisibility"
                                      TargetToggleMethod="ByVisibility"
                                      IndependentElementShowDuration="0:0:0.18"
                                      IndependentElementShowDelay="0:0:0.10"
                                      IndependentElementHideDuration="0:0:0.12"
                                      IsHitTestVisibleWhenAnimating="False">
            <transitions:TransitionConfig Id="card-shell" ScaleMode="Scale"/>
            <transitions:TransitionConfig Id="playlist-name" ScaleMode="Custom">
                <transitions:TransitionConfig.CustomScalingCalculator>
                    <helpers:TransitionTextScalingCalculator/>
                </transitions:TransitionConfig.CustomScalingCalculator>
            </transitions:TransitionConfig>
            <transitions:TransitionConfig Id="playlist-owner" ScaleMode="Custom">
                <transitions:TransitionConfig.CustomScalingCalculator>
                    <helpers:TransitionTextScalingCalculator/>
                </transitions:TransitionConfig.CustomScalingCalculator>
            </transitions:TransitionConfig>
        </transitions:TransitionHelper>
    </Page.Resources>

    <Grid x:Name="RootGrid" SizeChanged="RootGrid_SizeChanged">
        <!-- Responsive: driven by SizeChanged in code-behind. Loading is bound to
             IsLoading (metadata) for the left panel; the TrackListView has its own
             IsLoadingTracks-driven shimmer because playlist tracks lazy-load
             independently of the metadata. -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState"/>
                <VisualState x:Name="NarrowState">
                    <VisualState.Setters>
                        <!-- NarrowPlaylistHeader.Visibility setters removed: no element
                             with that x:Name exists in this page anymore, so the setter
                             threw XamlUnhandledException on every SizeChanged that flipped
                             between Wide/Narrow. If a narrow-mode header is reintroduced
                             later, re-add matching setters referencing the real name. -->
                        <Setter Target="LeftColumnHost.Visibility" Value="Collapsed"/>
                        <Setter Target="ShimmerContainer.Visibility" Value="Collapsed"/>
                        <Setter Target="PlaylistSplitter.Visibility" Value="Collapsed"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Palette-tinted page wash sitting on top of the window's Mica.
             Mirrors AlbumPage so playlist / album feel like the same surface.
             Opacity is baked into the brush itself; null brush ⇒ nothing renders. -->
        <Border IsHitTestVisible="False"
                Background="{x:Bind ViewModel.PaletteBackdropBrush, Mode=OneWay}"/>

        <!-- Unified page-level scroller. Wraps the banner row + the two-column
             content so the banner, left sidebar, and track table all scroll
             together as a single document. The left sidebar's composition
             Translation is bound to this scroller's ExpressionAnimationSources
             in code-behind so it locks in place once the user scrolls past the
             banner ("sticky left column"). The TrackDataGrid's
             IsParentScrolling=true disables its internal ItemsView scroll so
             it measures to natural height inside this scroller. -->
        <ScrollView x:Name="PageScrollView"
                    VerticalScrollMode="Auto"
                    HorizontalScrollMode="Disabled"
                    ZoomMode="Disabled"
                    ContentOrientation="Vertical"
                    Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
        <Grid x:Name="TwoColumnGrid"
              MaxWidth="2400"
              HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <!-- Banner row: 280 px hero band spanning all three columns.
                     Either composition image (HeaderImageUrl present) or a
                     procedural gradient (AnimatedHeroBackground), with the
                     title overlaid at the bottom-left. -->
                <RowDefinition Height="Auto"/>
                <!-- Content row: was Height="*" when the page had a fixed
                     viewport; now Auto so the row measures to natural content
                     height (sidebar + track table + footer) and the outer
                     PageScrollView handles all vertical motion. -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="200" MinWidth="200" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ╔══════════════════════════════════════════════════════════
                 ║ HERO BANNER ROW
                 ║ Spans all 3 columns at the top. Two mutually-exclusive
                 ║ background renderers stacked behind the title overlay:
                 ║   1. HeaderBackgroundHost — composition image surface for
                 ║      editorial / radio playlists with header_image_url_desktop.
                 ║      Image + scrim composition visuals attached in code-behind.
                 ║   2. AnimatedHeroBackground — Win2D + MeshGradientShader
                 ║      seeded with palette-extracted BannerPrimaryColor /
                 ║      BannerAccentColor for playlists without a header image.
                 ║ XAML scrim Border on top provides bottom-weighted darken-
                 ║ to-theme-surface so the title text stays legible against
                 ║ either background.
                 ╚══════════════════════════════════════════════════════════ -->
            <Grid x:Name="HeroBannerRow"
                  Grid.Row="0"
                  Grid.ColumnSpan="3"
                  Height="280"
                  Visibility="{x:Bind ViewModel.LayoutMode, Mode=OneWay, Converter={StaticResource PlaylistLayoutModeBannerVisibilityConverter}}">

                <!-- Procedural fallback (BACK layer). Visible only when
                     HeaderImageUrl is null — most user-created playlists, plus
                     the brief shimmer window before the editorial image lands,
                     plus the rare image-decode-failure case (see
                     OnHeroImageLoadCompleted in code-behind which clears
                     HeaderImageUrl on failure). The two color DPs are fed from
                     the cover-extracted AlbumPalette via the VM. -->
                <cards:AnimatedHeroBackground
                    x:Name="HeroBannerFallback"
                    PrimaryColor="{x:Bind ViewModel.BannerPrimaryColor, Mode=OneWay}"
                    AccentColor="{x:Bind ViewModel.BannerAccentColor, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasHeaderImage, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                <!-- Composition image surface (FRONT layer). ALWAYS visible
                     inside the banner row — no per-element Visibility binding.
                     When HeaderImageUrl is null the composition surface is
                     null (renders transparent) and the AnimatedHeroBackground
                     behind shows through. When the URL arrives, the surface
                     loads and the image covers the gradient.
                     Why no Visibility binding: gating Visibility on
                     HasHeaderImage caused intermittent empty banners on cold
                     load — the host was Collapsed (ActualSize=0) when
                     HeaderBackgroundHost_Loaded built the composition tree
                     and ApplyHeaderBackground sized the decode, then the
                     Collapsed→Visible transition didn't reliably re-sync the
                     SpriteVisual's RelativeSizeAdjustment. Always-visible
                     keeps the host at full size from first paint. -->
                <Border x:Name="HeaderBackgroundHost"
                        IsHitTestVisible="False"/>

                <!-- Title + source overlay (bottom-left of the banner). The
                     InlineEditableText keeps owner-rename inline-edit behavior
                     in its new home — click the title to edit (owners only).
                     Title shimmer occupies the same Y position so the swap
                     when PlaylistName arrives is opacity-only, no shift.
                     BannerOverlayPanel is the ShyHeaderController's `source`
                     element; matched-IDs (card-shell, playlist-name,
                     playlist-owner) interpolate with the PlaylistShyPill. -->
                <Grid x:Name="BannerOverlayPanel"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">
                    <!-- Invisible card-shell anchor — gives the TransitionHelper
                         a source rectangle to morph the pill's outer Border in
                         from. Mirrors ArtistPage's HeroOverlayPanel pattern. -->
                    <Border transitions:TransitionHelper.Id="card-shell"
                            Background="Transparent"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>
                    <Grid VerticalAlignment="Bottom"
                          Margin="32,0,32,20">
                        <StackPanel Spacing="6" HorizontalAlignment="Stretch">
                            <Grid MinHeight="48" HorizontalAlignment="Stretch">
                                <controls1:InlineEditableText
                                    x:Name="BannerTitleEditor"
                                    Text="{x:Bind ViewModel.PlaylistName, Mode=OneWay}"
                                    ToolTipService.ToolTip="{x:Bind ViewModel.PlaylistName, Mode=OneWay}"
                                    IsEditable="{x:Bind ViewModel.CanEditName, Mode=OneWay}"
                                    IsBusy="{x:Bind ViewModel.IsRenaming, Mode=OneWay}"
                                    MaxLength="100"
                                    MaxLines="2"
                                    FontSize="{x:Bind helpers:TitleFontSizer.Hero(ViewModel.PlaylistName), Mode=OneWay}"
                                    FontWeight="Bold"
                                    TextAlignment="Left"
                                    HorizontalContentAlignment="Stretch"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                    Committed="PlaylistTitleEditor_Committed"
                                    Visibility="{x:Bind ViewModel.PlaylistName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                    transitions:TransitionHelper.Id="playlist-name"/>
                                <controls:Shimmer Width="480" Height="40" CornerRadius="6" HorizontalAlignment="Left"
                                                  Visibility="{x:Bind ViewModel.PlaylistName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.OwnerName, Mode=OneWay}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind ViewModel.OwnerName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                       transitions:TransitionHelper.Id="playlist-owner"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Shimmer skeleton for left panel (visible while metadata loads).
                 Wrapper Grid keeps the IContentPageHost.ShimmerContainer ref +
                 the narrow VSM Visibility setter pointing at one element.
                 Inside, two skeletons branch by LayoutMode so the shimmer→
                 loaded swap is opacity-only (geometry matches the loaded
                 state for whichever layout mode is active):
                   • Banner mode: owner-row + stats + actions (no cover/title
                     — those live in the banner row above, with their own
                     overlay shimmer).
                   • Cover mode: cover + title + owner-row + stats + actions
                     (matches the pre-redesign skeleton for user playlists). -->
            <Grid x:Name="ShimmerContainer"
                  x:Load="{x:Bind ShimmerGate.IsLoaded, Mode=OneWay}"
                  Grid.Row="1" Grid.Column="0"
                  HorizontalAlignment="Stretch" VerticalAlignment="Top"
                  Padding="32,24,16,24">
                <!-- Banner-mode skeleton (no cover/title — those live in the
                     banner row above). Owner + stats + Play/Shuffle + 5-pill
                     cluster shimmer. Geometry mirrors the loaded layout exactly. -->
                <StackPanel Spacing="14"
                            Visibility="{x:Bind ViewModel.LayoutMode, Mode=OneWay, Converter={StaticResource PlaylistLayoutModeBannerVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <controls:Shimmer Width="24" Height="24" CornerRadius="12"/>
                        <controls:Shimmer Width="120" Height="16" VerticalAlignment="Center"/>
                    </StackPanel>
                    <controls:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                    <!-- Play + Shuffle -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <controls:Shimmer Width="86" Height="40" CornerRadius="20"/>
                        <controls:Shimmer Width="40" Height="40" CornerRadius="20"/>
                    </StackPanel>
                    <!-- 5-pill cluster -->
                    <controls:WrapPanel Orientation="Horizontal"
                                        HorizontalSpacing="6" VerticalSpacing="6"
                                        Margin="0,4,0,0">
                        <controls:Shimmer Width="74"  Height="36" CornerRadius="18"/>
                        <controls:Shimmer Width="80"  Height="36" CornerRadius="18"/>
                        <controls:Shimmer Width="136" Height="36" CornerRadius="18"/>
                        <controls:Shimmer Width="128" Height="36" CornerRadius="18"/>
                        <controls:Shimmer Width="108" Height="36" CornerRadius="18"/>
                    </controls:WrapPanel>
                </StackPanel>
                <!-- Cover-mode skeleton: cover + hero-scale title + owner row +
                     stats + Play/Shuffle + 5-pill cluster. Matches the loaded
                     state so the swap is opacity-only. -->
                <StackPanel Spacing="14"
                            Visibility="{x:Bind ViewModel.LayoutMode, Mode=OneWay, Converter={StaticResource PlaylistLayoutModeCoverVisibilityConverter}}">
                    <controls:Shimmer Height="220" CornerRadius="8" HorizontalAlignment="Stretch"/>
                    <!-- Hero-scale title bar -->
                    <controls:Shimmer Width="260" Height="44" HorizontalAlignment="Left" CornerRadius="6"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <controls:Shimmer Width="24" Height="24" CornerRadius="12"/>
                        <controls:Shimmer Width="120" Height="16" VerticalAlignment="Center"/>
                    </StackPanel>
                    <controls:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <controls:Shimmer Width="86" Height="40" CornerRadius="20"/>
                        <controls:Shimmer Width="40" Height="40" CornerRadius="20"/>
                    </StackPanel>
                    <controls:WrapPanel Orientation="Horizontal"
                                        HorizontalSpacing="6" VerticalSpacing="6"
                                        Margin="0,4,0,0">
                        <controls:Shimmer Width="74"  Height="36" CornerRadius="18"/>
                        <controls:Shimmer Width="80"  Height="36" CornerRadius="18"/>
                        <controls:Shimmer Width="136" Height="36" CornerRadius="18"/>
                        <controls:Shimmer Width="128" Height="36" CornerRadius="18"/>
                        <controls:Shimmer Width="108" Height="36" CornerRadius="18"/>
                    </controls:WrapPanel>
                </StackPanel>
            </Grid>

            <!-- Wide left panel: shown once metadata has arrived. The cover Grid
                 + title block at the top are gated on LayoutMode == Cover (user
                 playlists). Banner-mode playlists hide both — their title lives
                 in the banner row's overlay above, and there is no square cover.
                 Previously wrapped in its own ScrollView (WidePlaylistScroller);
                 now a direct Grid child so the page-level PageScrollView is the
                 single scroll source. LeftColumnHost is the composition target —
                 code-behind binds its Translation to PageScrollView's
                 ExpressionAnimationSources to make it pin once the banner has
                 scrolled past. -->
            <StackPanel x:Name="LeftColumnHost"
                        Grid.Row="1" Grid.Column="0"
                        Padding="16,20,8,20" Spacing="14" HorizontalAlignment="Stretch"
                        VerticalAlignment="Top">

                <!-- 1. Cover art (Cover mode only). Square; SizeChanged keeps it
                     square as the panel resizes. Hidden in Banner mode — the
                     hero banner row above carries the visual identity instead.
                     x:Name="CoverHeroBlock" wraps the cover Grid only (the
                     title Grid below has its own name) so the layout-transition
                     fade-in in code-behind can target this surface independent
                     of the rest of WidePlaylistPanel which is already visible. -->
                <Grid x:Name="CoverHeroBlock" HorizontalAlignment="Stretch"
                      Visibility="{x:Bind ViewModel.LayoutMode, Mode=OneWay, Converter={StaticResource PlaylistLayoutModeCoverVisibilityConverter}}">
                    <winUi:Effects.Shadow>
                        <ui:AttachedCardShadow BlurRadius="32" Offset="0,12" Opacity="0.28" Color="Black" CornerRadius="8" InnerContentClipMode="CompositionMaskBrush"/>
                    </winUi:Effects.Shadow>
                    <Border x:Name="PlaylistArtContainer" CornerRadius="8"
                            HorizontalAlignment="Stretch"
                            SizeChanged="PlaylistArtContainer_SizeChanged"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid>
                            <Grid Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <FontIcon Glyph="&#xE93F;"
                                          FontFamily="{StaticResource MediaPlayerIconsFontFamily}"
                                          FontSize="64"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                          Opacity="0.72"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Grid>
                            <Image x:Name="CoverImage"
                                   Source="{x:Bind ViewModel.PlaylistImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter='280'}"
                                   Stretch="UniformToFill"
                                   Visibility="{x:Bind ViewModel.PlaylistImageUrl, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                   behaviors:ImageFallbackBehavior.HideOnError="True"
                                   behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                   behaviors:ImageFallbackBehavior.DecodePixelWidth="280"/>

                            <Image x:Name="CoverPreviewImage"
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed"/>

                            <Grid x:Name="CoverEditOverlay"
                                  Background="#80000000"
                                  Opacity="0"
                                  IsHitTestVisible="{x:Bind ViewModel.CanEditPicture, Mode=OneWay}"
                                  PointerEntered="CoverEditOverlay_PointerEntered"
                                  PointerExited="CoverEditOverlay_PointerExited"
                                  Tapped="CoverEditOverlay_Tapped"
                                  RightTapped="CoverEditOverlay_RightTapped">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="6">
                                    <FontIcon Glyph="&#xE722;" FontSize="32"
                                              Foreground="White"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="Change photo"
                                               Foreground="White"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <ProgressRing x:Name="CoverUploadRing"
                                              Width="36" Height="36"
                                              IsActive="False"
                                              Visibility="Collapsed"
                                              Foreground="White"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 2. Title (Cover mode only). Hero-scale to match AlbumPage:
                     FontSize=40 / FontWeight=Black. InlineEditableText still
                     swaps to a TextBox for owners on click; the inner text view
                     inherits the FontSize / FontWeight DPs. Hidden in Banner
                     mode — the banner overlay's BannerTitleEditor handles the
                     title up there. Both wire to the same Committed handler. -->
                <Grid x:Name="CoverTitleBlock" MinHeight="44" HorizontalAlignment="Stretch"
                      Visibility="{x:Bind ViewModel.LayoutMode, Mode=OneWay, Converter={StaticResource PlaylistLayoutModeCoverVisibilityConverter}}">
                    <controls1:InlineEditableText
                        x:Name="PlaylistTitleEditor"
                        Text="{x:Bind ViewModel.PlaylistName, Mode=OneWay}"
                        ToolTipService.ToolTip="{x:Bind ViewModel.PlaylistName, Mode=OneWay}"
                        IsEditable="{x:Bind ViewModel.CanEditName, Mode=OneWay}"
                        IsBusy="{x:Bind ViewModel.IsRenaming, Mode=OneWay}"
                        MaxLength="100"
                        MaxLines="3"
                        FontSize="{x:Bind helpers:TitleFontSizer.Hero(ViewModel.PlaylistName), Mode=OneWay}"
                        FontWeight="Black"
                        TextAlignment="Left"
                        HorizontalContentAlignment="Stretch"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        Committed="PlaylistTitleEditor_Committed"
                        Visibility="{x:Bind ViewModel.PlaylistName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <controls:Shimmer Width="260" Height="44" HorizontalAlignment="Left" CornerRadius="6"
                                      Visibility="{x:Bind ViewModel.PlaylistName, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                </Grid>

                <!-- 3. Owner row — small avatar + linked name. Clicking the row
                     opens the owner's profile (ProfilePage). PersonPicture handles
                     image / initials / glyph fallback; HyperlinkButton's Command
                     binds to PlaylistViewModel.OpenOwnerProfileCommand which is
                     a no-op when OwnerId is missing. -->
                <HyperlinkButton Padding="0"
                                 Command="{x:Bind ViewModel.OpenOwnerProfileCommand}"
                                 Visibility="{x:Bind ViewModel.OwnerName, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <PersonPicture Width="24" Height="24"
                                       DisplayName="{x:Bind ViewModel.OwnerName, Mode=OneWay}"
                                       ProfilePicture="{x:Bind ViewModel.OwnerAvatarUrl, Mode=OneWay, Converter={StaticResource SpotifyImageConverter}, ConverterParameter='48'}"/>
                        <TextBlock Text="{x:Bind ViewModel.OwnerName, Mode=OneWay}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </HyperlinkButton>

                <!-- 4. Inline stats line: "242 songs · 11 hr 18 min · 95K followers".
                     Single TextBlock fed by MetaInlineLine (computed VM property);
                     omits empty segments so the line grows as values resolve. -->
                <TextBlock Text="{x:Bind ViewModel.MetaInlineLine, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>

                <!-- 4b. Chart sub-stat line — only shown for chart-format playlists.
                     "Updated May 1 · 8 new entries". Empty / collapsed otherwise. -->
                <TextBlock Text="{x:Bind ViewModel.ChartHeaderLine, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.IsChart, Mode=OneWay,
                               Converter={StaticResource BoolToVisibilityConverter}}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap"/>

                <!-- 5a. Primary CTAs — Play (big accent) + Shuffle / Save / Share (icon row).
                     Save (HeartButton) is hidden for owners — owners get the Delete pill in
                     the secondary cluster instead. Share mirrors HeartButton's transparent
                     32×32 style so the three secondary actions read as a coherent cluster. -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" VerticalAlignment="Center">
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.PlayAllCommand}"
                            Padding="18,10" CornerRadius="20"
                            ToolTipService.ToolTip="Play">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE768;" FontSize="14"/>
                            <TextBlock Text="Play" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.ShuffleCommand}"
                            Width="40" Height="40" CornerRadius="20" Padding="0"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Shuffle play">
                        <FontIcon Glyph="&#xE8B1;" FontSize="14"/>
                    </Button>
                    <controls1:HeartButton IsLiked="{x:Bind ViewModel.IsFollowed, Mode=OneWay}"
                                           Command="{x:Bind ViewModel.ToggleFollowCommand}"
                                           VerticalAlignment="Center"
                                           Visibility="{x:Bind ViewModel.IsOwner, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <Button Command="{x:Bind ViewModel.SharePlaylistCommand}"
                            Width="32" Height="32" CornerRadius="16" Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Copy link to playlist">
                        <FontIcon Glyph="&#xE72D;" FontSize="14"/>
                    </Button>
                </StackPanel>

                <!-- 5b. Secondary action cluster — labeled pill buttons mirroring
                     AlbumPage's `.action-cluster`. WrapPanel so the row spills to a
                     second line on narrow column widths. Save + Share live in the
                     icon row above; Delete is owners-only and stays here. -->
                <controls:WrapPanel Orientation="Horizontal"
                                    HorizontalSpacing="6" VerticalSpacing="6"
                                    Margin="0,4,0,0">
                    <!-- Add to playlist (flyout — picks the destination from the
                         user's playlists, then copies all tracks of THIS playlist). -->
                    <Button x:Name="AddPlaylistToPlaylistPillButton"
                            Height="36" Padding="14,0" CornerRadius="18"
                            Background="Transparent"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            ToolTipService.ToolTip="Copy all tracks to another playlist">
                        <Button.Flyout>
                            <MenuFlyout x:Name="AddPlaylistToPlaylistMenuFlyout"
                                        Placement="Bottom"
                                        Opening="AddPlaylistToPlaylistMenuFlyout_Opening"/>
                        </Button.Flyout>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                            <TextBlock Text="Add to playlist" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <!-- Add to queue -->
                    <Button Command="{x:Bind ViewModel.AddPlaylistToQueueCommand}"
                            Height="36" Padding="14,0" CornerRadius="18"
                            Background="Transparent"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            ToolTipService.ToolTip="Add every track to the queue">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8FD;" FontSize="12"/>
                            <TextBlock Text="Add to queue" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <!-- Start radio -->
                    <Button Command="{x:Bind ViewModel.StartPlaylistRadioCommand}"
                            Height="36" Padding="14,0" CornerRadius="18"
                            Background="Transparent"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            ToolTipService.ToolTip="Start a radio seeded from this playlist">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE9E9;" FontSize="12"/>
                            <TextBlock Text="Start radio" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <!-- Delete: owners only. Reuses the existing
                         ConfirmAndDeletePlaylistAsync dialog via HeroDeleteButton_Click. -->
                    <Button Click="HeroDeleteButton_Click"
                            Height="36" Padding="14,0" CornerRadius="18"
                            Background="Transparent"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            ToolTipService.ToolTip="Delete playlist"
                            Visibility="{x:Bind ViewModel.IsOwner, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE74D;" FontSize="12"
                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            <TextBlock Text="Delete" FontSize="13"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        </StackPanel>
                    </Button>
                    <!-- Owner overflow (collaborative toggle, etc). Same flyout as before. -->
                    <Button x:Name="OwnerOverflowButton"
                            Height="36" Width="36" Padding="0" CornerRadius="18"
                            Background="Transparent"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            ToolTipService.ToolTip="More"
                            Click="OwnerOverflowButton_Click"
                            Visibility="{x:Bind ViewModel.HasOverflowItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <FontIcon Glyph="&#xE712;" FontSize="12"/>
                    </Button>
                </controls:WrapPanel>

                <!-- 6a. Description (viewer / non-owner branch). Plain text, no card
                     chrome — flows naturally beneath the action row like the album
                     page's release/copyright block. -->
                <StackPanel Spacing="4"
                            Margin="0,4,0,0"
                            Visibility="{x:Bind ViewModel.IsDescriptionViewerCardVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <RichTextBlock x:Name="DescriptionRichText"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextAlignment="Left"
                                   MaxLines="3"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap"
                                   IsTextTrimmedChanged="DescriptionRichText_IsTextTrimmedChanged"/>

                    <HyperlinkButton x:Name="DescriptionMoreButton"
                                     HorizontalAlignment="Left"
                                     Padding="4,2"
                                     FontSize="12"
                                     Visibility="Collapsed"
                                     Click="DescriptionMoreButton_Click">
                        <TextBlock x:Name="DescriptionMoreLabel" Text="More..."/>
                    </HyperlinkButton>
                </StackPanel>

                <!-- 6b. Description (owner branch). Editable in-place; "Edit description..."
                     placeholder when empty. No surrounding card. -->
                <controls1:InlineEditableText
                    x:Name="PlaylistDescriptionEditor"
                    Text="{x:Bind ViewModel.PlaylistDescription, Mode=OneWay}"
                    IsEditable="{x:Bind ViewModel.CanEditDescription, Mode=OneWay}"
                    IsBusy="{x:Bind ViewModel.IsUpdatingDescription, Mode=OneWay}"
                    AcceptsReturn="True"
                    MaxLength="300"
                    MaxLines="6"
                    FontSize="12"
                    Margin="0,4,0,0"
                    TextAlignment="Left"
                    HorizontalContentAlignment="Stretch"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Placeholder="Edit description..."
                    Committed="PlaylistDescriptionEditor_Committed"
                    x:Load="{x:Bind ViewModel.CanEditDescription, Mode=OneWay}"/>

                <!-- 7. Session control chips: editorial / algorithmic playlists ship
                     a session_control_display group; chip row re-personalises the
                     playlist on click. Now left-aligned to match panel direction. -->
                <Grid HorizontalAlignment="Left" Margin="0,8,0,0"
                      x:Name="TokenViewPanel"
                      x:Load="{x:Bind ViewModel.HasSessionControlChips, Mode=OneWay}">
                    <sessionTokens:SessionTokenView
                        IsWrapped="True"
                        CanRemoveTokens="False"
                        ItemsSource="{x:Bind ViewModel.SessionControlChips, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedSessionControlChip, Mode=TwoWay}">
                        <sessionTokens:SessionTokenView.ItemTemplate>
                            <DataTemplate x:DataType="vm:SessionControlChipViewModel">
                                <TextBlock Text="{x:Bind Label}" FontSize="13"/>
                            </DataTemplate>
                        </sessionTokens:SessionTokenView.ItemTemplate>
                    </sessionTokens:SessionTokenView>
                </Grid>

                <!-- 8. Collaborator row — overlapping ringed avatars + "{N} collaborators"
                     label + trailing chevron. Wrapped in a Border so we can paint a
                     hover-pill background (toggled in code-behind via PointerEntered/
                     Exited) and the cursor swaps to a hand on hover — the previous
                     bare StackPanel had no clickability affordance. -->
                <controls1:ClickableBorder x:Name="CollaboratorStackHostFrame"
                                           HorizontalAlignment="Left"
                                           Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                           BorderThickness="1"
                                           CornerRadius="{ThemeResource OverlayCornerRadius}"
                                           Padding="8,6,12,6"
                                           Margin="0,6,0,0"
                                           Tapped="CollaboratorStackHost_Tapped"
                                           PointerEntered="CollaboratorStackHostFrame_PointerEntered"
                                           PointerExited="CollaboratorStackHostFrame_PointerExited"
                                           Visibility="{x:Bind ViewModel.HasCollaborators, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel x:Name="CollaboratorStackHost"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="8"/>
                </controls1:ClickableBorder>
            </StackPanel>

            <controls1:GridSplitter
                x:Name="PlaylistSplitter"
                Grid.Row="1" Grid.Column="1"
                Width="12"
                ResizeCompleted="PlaylistSplitter_ResizeCompleted"/>

            <!-- Track grid in column 2. IsLoading is driven by IsLoadingTracks so
                 the grid can show lightweight skeleton rows while playlist tracks
                 lazy-load independently of metadata. Rewrite swapped
                 TrackListView for TrackDataGrid — filter/sort/columns live inside the
                 grid's toolbar now; the page-level hero + narrow-mode header that used
                 to nest inside TrackListView.HeaderContent still render above the grid. -->
            <tdg:TrackDataGrid
                x:Name="TrackGrid"
                Grid.Row="1" Grid.Column="2"
                VerticalAlignment="Stretch"
                Margin="0,0,0,0"
                PageKey="playlist"
                UseItemsViewRows="True"
                IsParentScrolling="True"
                IsLoading="{x:Bind ViewModel.IsLoadingTracks, Mode=OneWay}"
                LoadingRowCount="{x:Bind ViewModel.TotalTracks, Mode=OneWay}"
                AddedByVisible="{x:Bind ViewModel.ShouldShowAddedByColumn, Mode=OneWay}"
                ContextUri="{x:Bind ViewModel.PlaylistId, Mode=OneWay}"
                CanReorder="{x:Bind ViewModel.CanReorderTracks, Mode=OneWay}"
                TracksReorderRequested="TrackGrid_TracksReorderRequested"
                ItemsSource="{x:Bind ViewModel.FilteredTracks, Mode=OneWay}"
                PlayCommand="{x:Bind ViewModel.PlayTrackCommand}">
                <tdg:TrackDataGrid.FilterBarContent>
                    <ToggleButton
                        MinHeight="32"
                        Padding="10,4"
                        CornerRadius="16"
                        IsChecked="{x:Bind ViewModel.ShowOnlyVideoTracks, Mode=TwoWay}"
                        Visibility="{x:Bind ViewModel.HasVideoTracks, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ToolTipService.ToolTip="Show only tracks with music videos">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon
                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                FontSize="13"
                                Glyph="&#xE714;" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.VideoTrackFilterLabel, Mode=OneWay}" />
                        </StackPanel>
                    </ToggleButton>
                </tdg:TrackDataGrid.FilterBarContent>

                <!-- "Recommended Songs" footer — Spotify's Enhance / Recommended
                     Songs surface. Gated on CanShowRecommendations (owner +
                     ≥1 track): the recommender uses the existing tracks as
                     seed, so an empty playlist has nothing to recommend
                     against. Fetch is auto-triggered by the VM the first
                     time both conditions hold; the populated state swaps in
                     an ItemsControl of recommendation cards. The
                     DataTemplate routes Add/Dismiss back to the VM via
                     PageRoot.ViewModel bindings — DataTemplate's local
                     DataContext is the RecommendedTrackResult itself, not
                     the page, so we cross-reference via ElementName=PageRoot. -->
                <tdg:TrackDataGrid.FooterContent>
                    <!-- Visibility (not x:Load) on the root: FooterContent is
                         typed as `object`, and the XAML compile-time deferred-
                         load infrastructure can't attach x:Load on the direct
                         child of a custom-control property setter — assignment
                         throws XamlParseException at parse time. -->
                    <StackPanel Padding="16,24,16,32"
                                x:Name="FooterTracks"
                                Spacing="16"
                                Visibility="{x:Bind ViewModel.CanShowRecommendations, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Recommended Songs"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <!-- "Find more songs" entry — opens the app-wide
                                 add-to-playlist session targeted at this playlist
                                 and lands the user in Search so they can shop.
                                 Code-behind handler mirrors the empty-state CTA. -->
                            <Button x:Name="FindMoreSongsChip"
                                    Grid.Column="1"
                                    Click="FindMoreSongsChip_Click"
                                    Margin="0,0,8,0"
                                    Height="32" Padding="12,0" CornerRadius="16"
                                    Background="Transparent"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    ToolTipService.ToolTip="Browse the app and add tracks to this playlist">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE721;" FontSize="12"/>
                                    <TextBlock Text="Find more songs" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <!-- Refresh chip is always reachable (no Visibility binding) so
                                 the user can swap the batch with a single click whenever
                                 they don't like the current set. -->
                            <Button Grid.Column="2"
                                    Command="{x:Bind ViewModel.FindRecommendedTracksCommand}"
                                    Height="32" Padding="12,0" CornerRadius="16"
                                    Background="Transparent"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    ToolTipService.ToolTip="Get a new batch of recommendations">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                                    <TextBlock Text="Refresh" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Error state — shown when the last fetch attempt failed.
                             Independent of HasRecommendedTracks so a refresh failure
                             after an earlier successful load shows the error card
                             alongside the existing rows (recovery doesn't lose work). -->
                        <Border Visibility="{x:Bind ViewModel.RecommendationsLoadFailed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE783;"
                                          FontSize="18"
                                          VerticalAlignment="Center"
                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Couldn't load recommendations"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               FontSize="13"/>
                                    <TextBlock Text="Check your connection and try again."
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Command="{x:Bind ViewModel.FindRecommendedTracksCommand}"
                                        Height="32" Padding="12,0" CornerRadius="16"
                                        Background="Transparent"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                                        <TextBlock Text="Retry" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Populated state — canonical TrackItem rows so each
                             recommendation gets the global now-playing equalizer
                             (via TrackStateBehavior) and the standard hover heart
                             affordance for free. A trailing "+" button on the
                             right adds the track directly to THIS playlist. The
                             template-local DataContext is the RecommendedTrackResult
                             itself, so the page commands route via ElementName=PageRoot. -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.RecommendedTracks, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.HasRecommendedTracks, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="2"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="contracts:RecommendedTrackResult">
                                    <Grid ColumnSpacing="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- TrackItem in Row mode to match the playlist's main
                                             track table styling exactly. Album / date / added-by
                                             / play-count / index columns are hidden — recs are
                                             unordered and don't belong to the playlist yet, so
                                             those table fields don't apply. -->
                                        <track:TrackItem Grid.Column="0"
                                                         Mode="Row"
                                                         Track="{x:Bind}"
                                                         ShowAlbumArt="True"
                                                         ShowArtistColumn="True"
                                                         ShowAlbumColumn="False"
                                                         ShowDateAdded="False"
                                                         ShowAddedByColumn="False"
                                                         ShowPlayCount="False"
                                                         PreserveImageOnUnload="True"
                                                         PlayCommand="{Binding ElementName=PageRoot, Path=ViewModel.PlayTrackCommand}"/>

                                        <Button Grid.Column="1"
                                                Width="32" Height="32" CornerRadius="16" Padding="0"
                                                Background="Transparent"
                                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0"
                                                Command="{Binding ElementName=PageRoot, Path=ViewModel.AddRecommendationCommand}"
                                                CommandParameter="{x:Bind}"
                                                ToolTipService.ToolTip="Add to this playlist">
                                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </tdg:TrackDataGrid.FooterContent>
            </tdg:TrackDataGrid>

            <Grid
                x:Name="EmptyPlaylistState"
                Grid.Row="1" Grid.Column="2"
                Margin="24,104,24,24"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Visibility="{x:Bind ViewModel.ShowEmptyPlaylistState, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel
                    MaxWidth="640"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <Border
                        Width="72"
                        Height="72"
                        HorizontalAlignment="Center"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="36">
                        <FontIcon
                            Glyph="&#xE8FD;"
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="30"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Opacity="0.85"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock
                        Text="This playlist is empty"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        TextAlignment="Center"
                        HorizontalAlignment="Center"/>
                    <TextBlock
                        Text="Find songs to add — anything you tap with + lands here."
                        Style="{StaticResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"/>
                    <!-- Primary "Find songs to add" CTA. Enters app-wide add-to-playlist
                         mode (IAddToPlaylistSession.Begin) and navigates to Search so the
                         user can shop. Genre chips below also enter the same mode. -->
                    <Button x:Name="EmptyStateFindSongsButton"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Center"
                            MinWidth="220"
                            Padding="16,10" CornerRadius="20"
                            Margin="0,4,0,0"
                            Click="EmptyStateFindSongsButton_Click"
                            Visibility="{x:Bind ViewModel.CanEditItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE721;" FontSize="14"/>
                            <TextBlock Text="Find songs to add" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <TextBlock
                        Text="Or browse by genre"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        TextAlignment="Center"
                        Margin="0,8,0,0"
                        Visibility="{x:Bind ViewModel.ShowEmptyPlaylistGenreGrid, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <browseControls:BrowseGrid
                        x:Name="EmptyStateBrowseGrid"
                        ItemsSource="{x:Bind ViewModel.EmptyPlaylistGenreItems, Mode=OneWay}"
                        ItemTemplate="{StaticResource EmptyPlaylistGenreChipTemplate}"
                        MinItemWidth="120"
                        Margin="0,4,0,0"
                        HorizontalAlignment="Stretch"
                        Tapped="EmptyStateBrowseGrid_Tapped"
                        Visibility="{x:Bind ViewModel.ShowEmptyPlaylistGenreGrid, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>

        </Grid>
        </ScrollView>

        <!-- Error overlay: shown when detail fetch or track fetch fails.
             Retry re-invalidates the PlaylistStore and resets track-load state. -->
        <controls1:ErrorStateView
            Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            RetryCommand="{x:Bind ViewModel.RetryCommand}"/>

        <!-- Floating shy pill — pinned at top-center of the page, outside the
             PageScrollView so it doesn't scroll. ShyHeaderController flips it
             Visible once the user scrolls past ~190 px (banner pin offset)
             and morphs the matched-ID leaves with the banner overlay above. -->
        <playlist:PlaylistShyPill
            x:Name="PlaylistShyPill"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,12,0,0"
            Visibility="Collapsed"
            PlaylistImageUrl="{x:Bind ViewModel.PlaylistImageUrl, Mode=OneWay}"
            PlaylistName="{x:Bind ViewModel.PlaylistName, Mode=OneWay}"
            OwnerName="{x:Bind ViewModel.OwnerName, Mode=OneWay}"
            PaletteAccentPillBrush="{x:Bind ViewModel.PaletteAccentPillBrush, Mode=OneWay}"
            PaletteAccentPillForegroundBrush="{x:Bind ViewModel.PaletteAccentPillForegroundBrush, Mode=OneWay}"
            PlayCommand="{x:Bind ViewModel.PlayAllCommand}"/>
    </Grid>
</Page>
