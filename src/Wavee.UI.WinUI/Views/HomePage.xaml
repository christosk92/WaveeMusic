<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:layouts="using:Wavee.UI.WinUI.Controls.Layouts"
    xmlns:models="using:Wavee.UI.WinUI.Data.Models"
    xmlns:local="using:Wavee.UI.WinUI.Views"
    xmlns:controls1="using:Wavee.UI.WinUI.Controls"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:shelf="using:Wavee.UI.WinUI.Controls.Shelf"
    xmlns:hero="using:Klankhuis.Hero.Controls"
    xmlns:home="using:Wavee.UI.WinUI.ViewModels.Home"
    xmlns:homeViews="using:Wavee.UI.WinUI.Views.Home"
    xmlns:shared="using:Wavee.UI.WinUI.Views.Shared"
    xmlns:waveeHelpers="using:Wavee.UI.WinUI.Helpers"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="Transparent"
    waveeHelpers:PageEntranceFade.Fade="True">

    <Page.Resources>
        <ResourceDictionary>
            <converters:NullToVisibilityConverter x:Key="NullToCollapsedConverter"/>

            <Style x:Key="HomeSectionDebugButtonStyle" TargetType="Button">
                <Setter Property="Content" Value="&#xEBE8;"/>
                <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}"/>
                <Setter Property="ToolTipService.ToolTip" Value="Show section debug JSON"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
                <Setter Property="Padding" Value="6"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Opacity" Value="0.5"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <!-- ════════════════════════════════════════════════════════════
             ITEM-LEVEL TEMPLATES (used inside generic sections)
             ════════════════════════════════════════════════════════════ -->

            <!-- Playlist / Album / Podcast card: square image.
             NOTE: x:Phase was attempted here to enable progressive rendering, but
             x:Phase only applies to ListView/GridView container-recycling scenarios,
             NOT to ItemsRepeater which uses a different virtualization model. The
             analogous win for ItemsRepeater comes from virtualizing the inner layout
             (see step A in the plan — rewriting SingleRowLayout) and from batching
             the outer collection population (already landed via PopulateSectionsChunkedAsync). -->
            <!-- Mode=OneWay is required: HomeFeedCache.ApplyDiff mutates item Title/ImageUrl
             in-place after a refresh (see UpdateItemInPlace). Default x:Bind mode is OneTime,
             which captures only the value at template instantiation — so cached items that
             later get enriched (e.g., Title arriving via fresh fetch, ImageUrl changing from
             a stale URL) would keep rendering their original placeholder (null title =
             empty "Unknown"-looking card, stale image, etc.). -->
            <DataTemplate x:Key="PlaylistCardTemplate" x:DataType="vm:HomeSectionItem">
                <cards:ContentCard
                ImageUrl="{x:Bind BestMediumImageUrl, Mode=OneWay}"
                Title="{x:Bind Title, Mode=OneWay}"
                Subtitle="{x:Bind Subtitle, Mode=OneWay}"
                PlaceholderColorHex="{x:Bind ColorHex, Mode=OneWay}"
                IsCircularImage="False"
                NavigationUri="{x:Bind Uri, Mode=OneWay}"
                NavigationTitle="{x:Bind Title, Mode=OneWay}"/>
            </DataTemplate>

            <!-- Artist card: circular image, centered text -->
            <DataTemplate x:Key="ArtistCardTemplate" x:DataType="vm:HomeSectionItem">
                <cards:ContentCard
                ImageUrl="{x:Bind BestMediumImageUrl, Mode=OneWay}"
                Title="{x:Bind Title, Mode=OneWay}"
                Subtitle="{x:Bind Subtitle, Mode=OneWay}"
                PlaceholderColorHex="{x:Bind ColorHex, Mode=OneWay}"
                PlaceholderGlyph="&#xE77B;"
                IsCircularImage="True"
                CenterText="True"
                NavigationUri="{x:Bind Uri, Mode=OneWay}"
                NavigationTitle="{x:Bind Title, Mode=OneWay}"/>
            </DataTemplate>

            <!-- Liked Songs (Recents-saved variant): foreground purple-heart tile
             with up to 3 fanned thumbnails, "{N} songs added" + green check.
             Picked by HomeItemTemplateSelector when the item carries
             IsRecentlySaved + spotify:collection URI (parsed from
             formatListAttributes.group_metadata in HomeResponseParserV2). -->
            <DataTemplate x:Key="LikedSongsRecentTemplate" x:DataType="vm:HomeSectionItem">
                <cards:LikedSongsRecentCard
                Title="{x:Bind Title, Mode=OneWay}"
                AddedCount="{x:Bind RecentlyAddedCount, Mode=OneWay}"
                AddedItemNoun="{x:Bind RecentlyAddedItemNoun, Mode=OneWay}"
                Thumbnail1ImageUrl="{x:Bind RecentlyAddedThumbnail1Url, Mode=OneWay}"
                Thumbnail2ImageUrl="{x:Bind RecentlyAddedThumbnail2Url, Mode=OneWay}"
                Thumbnail3ImageUrl="{x:Bind RecentlyAddedThumbnail3Url, Mode=OneWay}"
                NavigationUri="{x:Bind Uri, Mode=OneWay}"/>
            </DataTemplate>

            <!-- Episode card: cover + title + publisher + played-state row.
             Picked by HomeItemTemplateSelector when ContentType == Episode. -->
            <DataTemplate x:Key="EpisodeCardTemplate" x:DataType="vm:HomeSectionItem">
                <cards:EpisodeCard/>
            </DataTemplate>

            <!-- Item template selector for mixed-type sections -->
            <local:HomeItemTemplateSelector x:Key="HomeItemSelector"
            ArtistTemplate="{StaticResource ArtistCardTemplate}"
            DefaultTemplate="{StaticResource PlaylistCardTemplate}"
            LikedSongsRecentTemplate="{StaticResource LikedSongsRecentTemplate}"
            EpisodeTemplate="{StaticResource EpisodeCardTemplate}"/>

            <!-- ════════════════════════════════════════════════════════════
             SECTION-LEVEL TEMPLATES
             ════════════════════════════════════════════════════════════ -->

            <!-- Shorts section: adaptive 2-row grid of pills -->
            <DataTemplate x:Key="ShortsSectionTemplate" x:DataType="vm:HomeSection">
                <Grid Margin="0,0,0,24">
                    <ItemsRepeater ItemsSource="{x:Bind Items}">
                        <ItemsRepeater.Layout>
                            <layouts:ShortcutsGridLayout
                            ItemHeight="56"
                            ColumnSpacing="8"
                            RowSpacing="8"
                            RowCount="2"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:HomeSectionItem">
                                <cards:ShortsPill
                                ImageUrl="{x:Bind BestSmallImageUrl, Mode=OneWay}"
                                Title="{x:Bind Title, Mode=OneWay}"
                                Item="{x:Bind}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <Button
                    Style="{StaticResource HomeSectionDebugButtonStyle}"
                    Tag="{x:Bind}"
                    Click="HomeSectionDebugButton_Click"
                    Visibility="{x:Bind IsDebugVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </DataTemplate>

            <!-- Generic section: title + horizontal card row with per-item templates.
             The card-frame Border was dropped in the region redesign — section
             chrome now comes from the parent HomeRegionView's mica band, and
             individual sections sit naked inside the band as 16 px-titled rows. -->
            <DataTemplate x:Key="GenericSectionTemplate" x:DataType="vm:HomeSection">
                <StackPanel Margin="0,0,0,8">
                        <!-- Header row. Vertical-bar accent on the left of the title
                         (Settings sub-categories pattern, user explicitly likes
                         this). Bound to AccentLineBrush, derived from the
                         section's first item's extracted dark color. Null brush
                         → invisible 3 px gap. -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Header entity avatar (e.g. "More like X" sections) -->
                            <PersonPicture
                            Grid.Column="0"
                            Width="36" Height="36"
                            Margin="0,0,10,0"
                            ProfilePicture="{x:Bind HeaderEntityImageUrl, Converter={StaticResource SpotifyImageConverter}, ConverterParameter=80}"
                            Visibility="{x:Bind HeaderEntityImageUrl, Converter={StaticResource NullToCollapsedConverter}}"/>

                            <Grid Grid.Column="1" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                    Width="3"
                                    MinHeight="22"
                                    CornerRadius="1.5"
                                    VerticalAlignment="Stretch"
                                    Margin="0,4,0,4"
                                    Background="{x:Bind AccentLineBrush, Mode=OneWay}"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <!-- Subtitle above title (e.g. "More like") -->
                                    <TextBlock
                                    Text="{x:Bind Subtitle}"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Visibility="{x:Bind Subtitle, Converter={StaticResource NullToCollapsedConverter}}"/>
                                    <TextBlock
                                    Text="{x:Bind Title}"
                                    Style="{StaticResource BaseTextBlockStyle}"
                                    FontSize="16"/>
                                </StackPanel>
                            </Grid>

                            <Button Grid.Column="2"
                                Content="View all"
                                Tag="{x:Bind ViewAllUri}"
                                Click="HomeSectionViewAll_Click"
                                Visibility="{x:Bind HasViewAll, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                VerticalAlignment="Center"
                                MinWidth="0"
                                MinHeight="0"
                                Padding="8,2"
                                FontSize="12"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <Button
                            Grid.Column="3"
                            Style="{StaticResource HomeSectionDebugButtonStyle}"
                            Tag="{x:Bind}"
                            Click="HomeSectionDebugButton_Click"
                            Visibility="{x:Bind IsDebugVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>

                        <shelf:ShelfScroller
                        x:Name="GenericSectionShelf"
                        ItemsSourceIdentity="{x:Bind SectionUri, Mode=OneWay}"
                        ItemsSource="{x:Bind Items, Mode=OneWay}"
                        ItemTemplateSelector="{StaticResource HomeItemSelector}"
                        MinItemWidth="220" MaxItemWidth="260" Spacing="16"/>
                </StackPanel>
            </DataTemplate>

            <!-- Baseline section: grouped Spotify-style cards enriched in the background.
             Card-frame Border dropped — region band carries the chrome. -->
            <DataTemplate x:Key="BaselineSectionTemplate" x:DataType="vm:HomeSection">
                <StackPanel Margin="0,0,0,8" Spacing="12">
                        <Grid MinHeight="1" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                Width="3"
                                MinHeight="22"
                                CornerRadius="1.5"
                                VerticalAlignment="Stretch"
                                Margin="0,4,0,4"
                                Background="{x:Bind AccentLineBrush, Mode=OneWay}"/>

                            <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind Title}"
                            Style="{StaticResource BaseTextBlockStyle}"
                            FontSize="16"
                            VerticalAlignment="Center"/>

                            <Button
                            Grid.Column="2"
                            Style="{StaticResource HomeSectionDebugButtonStyle}"
                            Tag="{x:Bind}"
                            Click="HomeSectionDebugButton_Click"
                            Visibility="{x:Bind IsDebugVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>

                        <ItemsRepeater ItemsSource="{x:Bind Items}">
                            <ItemsRepeater.Layout>
                                <!-- RealizeAllItems flipped from True to False (Phase 7.2). With
                             True, every BaselineHomeCard in a section materialized on
                             first paint regardless of scroll position — even cards
                             below the fold paid for their full visual tree + image
                             decode. The layout supports row-range virtualization via
                             GetRealizedRowRange (see SafeUniformGridLayout.cs:164);
                             switching to False activates it. Saves ~5–8 MB on first
                             Home paint with no UX regression on standard scroll. -->
                                <layouts:SafeUniformGridLayout
                            MinItemWidth="290"
                            MaxItemWidth="360"
                            MinItemHeight="380"
                            MinColumnSpacing="16"
                            MinRowSpacing="20"
                            RealizationBufferRows="2"
                            RealizeAllItems="False"
                            ItemAspectRatio="0.6764705882352941"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:HomeSectionItem">
                                    <cards:BaselineHomeCard Item="{x:Bind}"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                </StackPanel>
            </DataTemplate>

            <!-- Section template selector — moved from code-behind into XAML so
                 each HomeRegionView's inner ItemsRepeater can bind to it via the
                 SectionTemplateSelector DP. The shorts template stays referenced
                 even though the side rail owns Shorts now (defensive: the
                 classifier still hands Shorts back to the selector if it ever
                 leaks into a region). -->
            <local:HomeSectionTemplateSelector x:Key="HomeSectionTemplateSelector"
                ShortsTemplate="{StaticResource ShortsSectionTemplate}"
                GenericTemplate="{StaticResource GenericSectionTemplate}"
                BaselineTemplate="{StaticResource BaselineSectionTemplate}"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hero-band responsive states.
             Originally split across two inline VSMs (HeroBand + StackedShortcuts) and
             triggered by `AdaptiveTrigger MinWindowWidth=…` which reads *window* width.
             With the Queue panel open the HomePage area shrinks well below the
             window's reported width, so the wide-state trigger stayed active and the
             side rail never collapsed beneath the hero. Switched to code-behind in
             HomePage.HeroBand_SizeChanged: states are driven off HeroBand.ActualWidth
             so the layout responds to the actual content rectangle. -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="HeroBandStates">
                <VisualState x:Name="HeroBandWideState"/>
                <VisualState x:Name="HeroBandStackedMediumState">
                    <VisualState.Setters>
                        <Setter Target="HomeHero.(Grid.ColumnSpan)" Value="2"/>
                        <Setter Target="HaloBackdrop.(Grid.ColumnSpan)" Value="2"/>
                        <Setter Target="WideSideRail.Visibility" Value="Collapsed"/>
                        <Setter Target="StackedShortcuts.Visibility" Value="Visible"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="HeroBandStackedNarrowState">
                    <VisualState.Setters>
                        <Setter Target="HomeHero.(Grid.ColumnSpan)" Value="2"/>
                        <Setter Target="HaloBackdrop.(Grid.ColumnSpan)" Value="2"/>
                        <Setter Target="WideSideRail.Visibility" Value="Collapsed"/>
                        <Setter Target="StackedShortcuts.Visibility" Value="Visible"/>
                        <Setter Target="StackedCard0.(Grid.ColumnSpan)" Value="6"/>
                        <Setter Target="StackedCard0.(Grid.RowSpan)" Value="1"/>
                        <Setter Target="StackedCard1.(Grid.Row)" Value="1"/>
                        <Setter Target="StackedCard1.(Grid.Column)" Value="0"/>
                        <Setter Target="StackedCard1.(Grid.ColumnSpan)" Value="3"/>
                        <Setter Target="StackedCard2.(Grid.Row)" Value="1"/>
                        <Setter Target="StackedCard2.(Grid.Column)" Value="3"/>
                        <Setter Target="StackedCard2.(Grid.ColumnSpan)" Value="3"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Loading: shimmer skeleton (crossfades to content) -->
        <ScrollView
            x:Name="ShimmerContainer"
            Margin="0,0,-24,0"
            Padding="0,0,24,0"
            VerticalScrollBarVisibility="Hidden"
            IsHitTestVisible="False">
            <!-- Mirrors the real homepage tree (greeting + 480 px hero band
                 with the same wide/stacked VSM + region bands with mixed
                 shelves and one baseline grid) so the shimmer → content
                 crossfade has minimal reflow. Released after first crossfade
                 via ShimmerContainer.Content = null. -->
            <shared:HomePageShimmer/>
        </ScrollView>

        <!-- Error -->
        <controls1:ErrorStateView

            Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            RetryCommand="{x:Bind ViewModel.RetryCommand}"/>

        <!-- Content (starts invisible via composition, crossfades in when loaded) -->
        <ScrollView x:Name="ContentContainer" VerticalScrollBarVisibility="Auto"
                    Margin="0,0,-28,0"
                    Padding="0,0,0,0"
                    Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <StackPanel Padding="32,24,32,24" Spacing="20">
                <!-- Greeting band: avatar + greeting/subtitle + chips on the left,
                     refresh button on the right. Sits in flow with the rest of
                     the feed — scrolls away naturally, no shy/sticky variant. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="14" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <PersonPicture
                                Width="40" Height="40"
                                DisplayName="{x:Bind ViewModel.CurrentUserName, Mode=OneWay}"
                                ProfilePicture="{x:Bind ViewModel.CurrentUserAvatarUrl, Mode=OneWay, Converter={StaticResource SpotifyImageConverter}, ConverterParameter=80}"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock
                                    Text="{x:Bind ViewModel.Greeting, Mode=OneWay}"
                                    Style="{StaticResource TitleTextBlockStyle}"
                                    FontWeight="SemiBold"/>
                                <TextBlock
                                    Text="{x:Bind ViewModel.GreetingSubtitle, Mode=OneWay}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Filter chips. Custom chip styling kept (the morph
                             behaviour for parent → sub-chips doesn't fit the
                             native Segmented control). -->
                        <ItemsRepeater
                            ItemsSource="{x:Bind ViewModel.DisplayedChips, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="8"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:HomeChipViewModel">
                                    <Button
                                        Click="Chip_Click"
                                        Padding="14,6"
                                        CornerRadius="16"
                                        MinWidth="0"
                                        FontSize="13" Tag="{x:Bind }"
                                        BorderThickness="0"
                                        Background="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource ChipBackgroundConverter}}"
                                        Foreground="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource ChipForegroundConverter}}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon
                                                Glyph="&#xE711;"
                                                FontSize="11"
                                                Visibility="{x:Bind IsBackChip, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <TextBlock Text="{x:Bind Label}"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- Visual-identity accent line under the chips. Same
                             shape as the section-header accent bars (3 px tall,
                             1.5 corner) so the page reads as one visual family. -->
                        <Border Height="3"
                                Width="120"
                                HorizontalAlignment="Left"
                                CornerRadius="1.5"
                                Margin="0,4,0,0"
                                Background="{x:Bind ViewModel.HeroAccentLineBrushOrFallback, Mode=OneWay}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Uid="Views_HomePage__Button_1"
                            ToolTipService.ToolTip="Refresh"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8"
                            VerticalAlignment="Top"
                            Margin="0,4,0,0"
                            Command="{x:Bind ViewModel.RefreshCommand}">
                        <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                    </Button>
                </Grid>

                <!-- Hero band — three responsive layouts:
                       Wide   ≥1500 px : original layout — HeroCarousel left
                                         (full Row 0 height) + WideSideRail
                                         right (3 cards stacked vertically,
                                         2*/1*/1* row weights). The hero gets
                                         the room Klankhuis was designed for
                                         (≥1100 px text-column slack), so the
                                         title renders without char-by-char
                                         wrapping.
                       Medium ≥900 px  : hero spans the full row 0; below it,
                                         StackedShortcuts shows the 1-big +
                                         2-stacked layout (Image 5 reference).
                       Narrow <900 px  : hero spans the full row 0; below it,
                                         StackedShortcuts collapses Card0 to
                                         a full-width banner with Card1 +
                                         Card2 side-by-side underneath
                                         (Image 6 reference).
                     The two rail variants (WideSideRail vs StackedShortcuts)
                     coexist in markup; the outer VSM swaps Visibility +
                     spans Hero across both columns when collapsing. The
                     duplicated SideCard markup is intentional — both sets
                     bind to the same SideCard0/1/2 view-model properties so
                     data stays single-source. -->
                <Grid x:Name="HeroBand" Margin="0,4,0,12"
                      Visibility="{x:Bind ViewModel.IsLocalChipActive, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                      SizeChanged="HeroBand_SizeChanged">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="480"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid x:Name="HaloBackdrop"
                          Grid.Row="0"
                          Grid.Column="0"
                          Background="Transparent"
                          IsHitTestVisible="False"
                          hero:HeroHalo.BlurRadius="120"
                          hero:HeroHalo.CornerRadius="14"
                          hero:HeroHalo.Intensity="0.45"/>

                    <hero:HeroCarousel x:Name="HomeHero"
                        Grid.Row="0"
                        Grid.Column="0"
                        VerticalAlignment="Stretch"
                        Autoplay="True"
                        AutoplayInterval="0:0:7"
                        ItemsSource="{x:Bind ViewModel.HeroAdapter.HeroSlides, Mode=OneWay}"/>

                    <!-- Wide-only side rail: original 320 px, 3 cards
                         stacked vertically next to the hero. -->
                    <Grid x:Name="WideSideRail"
                          Grid.Row="0"
                          Grid.Column="1"
                          Width="320"
                          Margin="20,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <hero:SideCard Grid.Row="0" Big="True" Margin="0,0,0,6"
                                       Label="{x:Bind ViewModel.HeroAdapter.SideCard0.Label, Mode=OneWay}"
                                       Eyebrow="{x:Bind ViewModel.HeroAdapter.SideCard0.Eyebrow, Mode=OneWay}"
                                       Accent="{x:Bind ViewModel.HeroAdapter.SideCard0.Accent, Mode=OneWay}"
                                       ImageUri="{x:Bind ViewModel.HeroAdapter.SideCard0.ImageUri, Mode=OneWay}"/>
                        <hero:SideCard Grid.Row="1" Margin="0,6,0,6" MinHeight="0"
                                       Label="{x:Bind ViewModel.HeroAdapter.SideCard1.Label, Mode=OneWay}"
                                       Eyebrow="{x:Bind ViewModel.HeroAdapter.SideCard1.Eyebrow, Mode=OneWay}"
                                       Accent="{x:Bind ViewModel.HeroAdapter.SideCard1.Accent, Mode=OneWay}"
                                       ImageUri="{x:Bind ViewModel.HeroAdapter.SideCard1.ImageUri, Mode=OneWay}"/>
                        <hero:SideCard Grid.Row="2" Margin="0,6,0,0" MinHeight="0"
                                       Label="{x:Bind ViewModel.HeroAdapter.SideCard2.Label, Mode=OneWay}"
                                       Eyebrow="{x:Bind ViewModel.HeroAdapter.SideCard2.Eyebrow, Mode=OneWay}"
                                       Accent="{x:Bind ViewModel.HeroAdapter.SideCard2.Accent, Mode=OneWay}"
                                       ImageUri="{x:Bind ViewModel.HeroAdapter.SideCard2.ImageUri, Mode=OneWay}"/>
                    </Grid>

                    <!-- Below-hero shortcuts (Medium + Narrow). 6 columns of
                         equal weight; cards' Grid.Row / Grid.Column /
                         Grid.ColumnSpan / Grid.RowSpan flip per inner VSM.
                         Default markup matches Medium (1 big left + 2 stacked
                         right with 4/2 column split). Narrow state collapses
                         to Card0 banner + Card1/Card2 horizontal.
                         Visible only in Medium/Narrow (set by outer VSM). -->
                    <Grid x:Name="StackedShortcuts"
                          Grid.Row="1"
                          Grid.Column="0"
                          Grid.ColumnSpan="2"
                          Margin="0,12,0,0"
                          Visibility="Collapsed"
                          RowSpacing="12"
                          ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="140"/>
                            <RowDefinition Height="140"/>
                        </Grid.RowDefinitions>

                        <hero:SideCard x:Name="StackedCard0"
                                       Grid.Row="0" Grid.Column="0"
                                       Grid.ColumnSpan="4" Grid.RowSpan="2"
                                       Big="True"
                                       Label="{x:Bind ViewModel.HeroAdapter.SideCard0.Label, Mode=OneWay}"
                                       Eyebrow="{x:Bind ViewModel.HeroAdapter.SideCard0.Eyebrow, Mode=OneWay}"
                                       Accent="{x:Bind ViewModel.HeroAdapter.SideCard0.Accent, Mode=OneWay}"
                                       ImageUri="{x:Bind ViewModel.HeroAdapter.SideCard0.ImageUri, Mode=OneWay}"/>
                        <hero:SideCard x:Name="StackedCard1"
                                       Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2"
                                       MinHeight="0"
                                       Label="{x:Bind ViewModel.HeroAdapter.SideCard1.Label, Mode=OneWay}"
                                       Eyebrow="{x:Bind ViewModel.HeroAdapter.SideCard1.Eyebrow, Mode=OneWay}"
                                       Accent="{x:Bind ViewModel.HeroAdapter.SideCard1.Accent, Mode=OneWay}"
                                       ImageUri="{x:Bind ViewModel.HeroAdapter.SideCard1.ImageUri, Mode=OneWay}"/>
                        <hero:SideCard x:Name="StackedCard2"
                                       Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2"
                                       MinHeight="0"
                                       Label="{x:Bind ViewModel.HeroAdapter.SideCard2.Label, Mode=OneWay}"
                                       Eyebrow="{x:Bind ViewModel.HeroAdapter.SideCard2.Eyebrow, Mode=OneWay}"
                                       Accent="{x:Bind ViewModel.HeroAdapter.SideCard2.Accent, Mode=OneWay}"
                                       ImageUri="{x:Bind ViewModel.HeroAdapter.SideCard2.ImageUri, Mode=OneWay}"/>

                    </Grid>
                </Grid>

                <!-- Outer virtualizing repeater of regions (4 chapters). Each
                     region hosts its own inner ItemsRepeater of sections —
                     don't nest a second SectionStackLayout there. -->
                <ItemsRepeater
                    x:Name="RegionsRepeater"
                    ItemsSource="{x:Bind ViewModel.HeroAdapter.Regions, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <layouts:SectionStackLayout Spacing="0"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="home:HomeRegion">
                            <homeViews:HomeRegionView
                                Region="{x:Bind}"
                                SectionTemplateSelector="{StaticResource HomeSectionTemplateSelector}"/>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Browse All — text-first genre selector at the bottom of home.
                     Lazy-fetched: BrowseAllSection's EffectiveViewportChanged
                     triggers HeroAdapter.LoadBrowseAsync only when the section
                     enters within ~one viewport. Shimmer skeleton until then.
                     Hidden under the Local files chip filter — it's Spotify-
                     sourced and has no place in a local-only view. -->
                <homeViews:BrowseAllSection
                    Visibility="{x:Bind ViewModel.IsLocalChipActive, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                    Adapter="{x:Bind ViewModel.HeroAdapter, Mode=OneWay}"/>
            </StackPanel>
        </ScrollView>

    </Grid>
</Page>
