<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.VideoPlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sidebarplayer="using:Wavee.UI.WinUI.Controls.SidebarPlayer"
    NavigationCacheMode="Disabled"
    Background="Transparent"
    mc:Ignorable="d">

    <!--
        Thin host for the same ExpandedPlayerView the popout (PlayerFloatingWindow)
        uses. All bespoke YouTube-style chrome was removed; surface ownership and
        Mode persistence (Lyrics / Queue / None) are coordinated in code-behind,
        mirroring PlayerFloatingWindow.xaml.cs.
    -->
    <Grid>
        <sidebarplayer:ExpandedPlayerView x:Name="ExpandedHost"/>
    </Grid>
</Page>
