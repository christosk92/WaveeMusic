<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wavee.UI.WinUI.Views.VideoPlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:local="using:Wavee.UI.WinUI.Controls.Local"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:mini="using:Wavee.UI.WinUI.Controls.MiniVideoPlayer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Disabled"
    Background="Black"
    RequestedTheme="Dark"
    xmlns:waveeHelpers="using:Wavee.UI.WinUI.Helpers"
    mc:Ignorable="d"
    waveeHelpers:PageEntranceFade.Fade="True">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <!--
        Cinematic, video-first now-playing page. Replaces the previous wrapper
        around ExpandedPlayerView, which had a surface-ownership gate that left
        the page showing a poster image instead of the live video frame.

        RequestedTheme=Dark forces all child controls to use the dark-theme
        Fluent palette regardless of the user's system theme — important
        because the page sits over a video frame and needs light foreground
        on every chrome element to stay readable. Removes the need for
        custom button templates: the default Fluent SubtleFillColor* tokens
        already render correctly under a forced-dark theme.

        Layout:
          full-bleed video frame (Stretch=Uniform)
          top gradient + quick actions (heart, audio)
          bottom gradient + meta + seek + transport

        Queue, lyrics, and details remain owned by the shell right panel.
        The video page intentionally does not host an inline right dock.
    -->
    <Grid x:Name="StageGrid"
          Background="Black"
          AllowDrop="True"
          DragEnter="StageGrid_DragOver"
          DragOver="StageGrid_DragOver"
          DragLeave="StageGrid_DragLeave"
          Drop="StageGrid_Drop">
        <!-- ============== VIDEO COLUMN ============== -->
        <Grid x:Name="VideoColumn"
              Background="Black">

            <!--
                VideoSurfaceHost provides the album-art / blurred-poster /
                video-frame crossfade pipeline. Code-behind mounts the
                MediaPlayerElement or WebView2 into its VideoMountPoint
                when IActiveVideoSurfaceService awards us the surface.
                No status overlay — the crossfade IS the loading affordance.
            -->
            <mini:VideoSurfaceHost x:Name="SurfaceHost"
                                   AlbumArtUrl="{x:Bind ViewModel.AlbumArtLarge, Mode=OneWay}"
                                   PosterUrl="{x:Bind ViewModel.AlbumArtLarge, Mode=OneWay}" />

            <!-- ============== SCRIM ==============
                 Fades together as one unit when the pointer goes idle for
                 ScrimIdleHideMs ms. PointerMove on the page re-shows it;
                 pointer entering the scrim itself pins it visible (so a
                 user hovering the transport doesn't have the chrome
                 evaporate under their cursor).
            -->
            <Grid x:Name="Scrim"
                  IsHitTestVisible="True">

                <!-- Top gradient — light shade so quick-action buttons read
                     cleanly against a bright video frame. -->
                <Rectangle VerticalAlignment="Top"
                           Height="220"
                           IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0"   Color="#8C000000" />
                            <GradientStop Offset="0.6" Color="#1F000000" />
                            <GradientStop Offset="1"   Color="#00000000" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Top-right quick actions: heart + "Listen as audio".
                     Share intentionally omitted in v1 — no existing share-
                     track plumbing in the app. Add when the rest of the
                     app grows that affordance. -->
                <StackPanel HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Orientation="Horizontal"
                            Spacing="10"
                            Margin="0,28,32,0">

                    <Border CornerRadius="20"
                            Background="#59000000"
                            BorderBrush="#1FFFFFFF"
                            BorderThickness="1"
                            Padding="0">
                        <controls:HeartButton x:Name="HeartButtonCtrl"
                                              Width="40" Height="40" />
                    </Border>

                    <Button x:Name="ListenAsAudioButton"
                            Height="40"
                            Padding="14,0"
                            CornerRadius="20"
                            BorderThickness="1"
                            BorderBrush="#1FFFFFFF"
                            Background="#59000000"
                            Foreground="White"
                            Command="{x:Bind ViewModel.SwitchToAudioCommand}"
                            Visibility="{x:Bind ViewModel.IsCurrentTrackAudioCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <FontIcon Glyph="&#xE8D6;" FontSize="13" />
                            <TextBlock Text="Listen as audio"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Bottom gradient — tall + soft so it never seams hard
                     against a vivid frame. -->
                <Rectangle VerticalAlignment="Bottom"
                           Height="320"
                           IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                            <GradientStop Offset="0"   Color="#D9000000" />
                            <GradientStop Offset="0.38" Color="#8C000000" />
                            <GradientStop Offset="0.72" Color="#2E000000" />
                            <GradientStop Offset="1"   Color="#00000000" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Bottom chrome: title + artist + seek + transport.
                     Spacing matches the HTML prototype. -->
                <StackPanel VerticalAlignment="Bottom"
                            Spacing="14"
                            Margin="56,0,56,32">

                    <StackPanel Spacing="4">
                        <HyperlinkButton Padding="0"
                                         MinWidth="0"
                                         MinHeight="0"
                                         HorizontalAlignment="Left"
                                         HorizontalContentAlignment="Left"
                                         Foreground="White"
                                         Click="TrackTitle_Click"
                                         ToolTipService.ToolTip="Open details">
                            <TextBlock x:Name="TrackTitleText"
                                       Text="{x:Bind ViewModel.TrackTitle, Mode=OneWay}"
                                       FontSize="32"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       MaxLines="2"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="Wrap" />
                        </HyperlinkButton>
                        <HyperlinkButton Padding="0"
                                         MinWidth="0"
                                         MinHeight="0"
                                         HorizontalAlignment="Left"
                                         HorizontalContentAlignment="Left"
                                         Foreground="#B8FFFFFF"
                                         Click="ArtistLine_Click"
                                         ToolTipService.ToolTip="Open details">
                            <TextBlock x:Name="ArtistText"
                                       Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}"
                                       FontSize="15"
                                       Foreground="#B8FFFFFF"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </HyperlinkButton>
                    </StackPanel>

                    <!-- YouTube-style transport: compact icon row + progress
                         bar above. All transport state, track menu, expand
                         flyout, and presentation-mode wiring live inside the
                         reusable VideoTransportBar UserControl so this page
                         and the popout's ExpandedNowPlayingLayout share one
                         set of controls. -->
                    <playback:VideoTransportBar x:Name="TransportBar"
                                                Surface="Main" />
                </StackPanel>
            </Grid>

            <!--
                Up-Next overlay (Netflix-style "Next episode" card). Sits
                ABOVE the auto-fading Scrim so the chrome hide-on-idle
                doesn't drag the card with it. Top-right, pushed below the
                heart / "Listen as audio" chip row (~28+40+16). Visibility
                + animation + binding all driven by
                UpNextEpisodeOverlayViewModel; the page wires the VM only
                when the current item is a local TV episode.
            -->
            <local:UpNextEpisodeOverlay x:Name="UpNextOverlay"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,84,32,0"/>
        </Grid>

        <!-- Subtitle drop overlay. Visible only while a valid drag is over
             the page (.srt / .vtt / .ass / .ssa / .sub). Spans both columns
             so the user can drop anywhere over the player surface. -->
        <Border x:Name="SubtitleDropOverlay"
                Visibility="Collapsed"
                Background="#A0000000"
                IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="14">
                <FontIcon Glyph="&#xE7C3;" FontSize="48" Foreground="White" />
                <TextBlock Text="Drop subtitle file"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center" />
                <TextBlock Text=".srt · .vtt · .ass · .ssa · .sub"
                           FontSize="12"
                           Foreground="#B8FFFFFF"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

    </Grid>
</Page>
