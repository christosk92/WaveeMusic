<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.FollowButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Button x:Name="InternalButton"
            Click="OnClick"
            Height="44"
            Padding="18,0"
            CornerRadius="22"
            HorizontalAlignment="Stretch">
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <FontIcon x:Name="FollowIcon" Glyph="&#xEB51;" FontSize="13"/>
            <TextBlock x:Uid="Controls_FollowButton__TextBlock_1"
                       x:Name="FollowText"
                       Text="Follow"
                       FontSize="13"
                       FontWeight="SemiBold"/>
        </StackPanel>
    </Button>
</UserControl>
