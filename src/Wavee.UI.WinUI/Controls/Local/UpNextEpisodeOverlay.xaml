<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Local.UpNextEpisodeOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    IsTabStop="False"
    IsHitTestVisible="True">

    <!--
        Netflix-style "Up Next" card. Anchored top-right of the video host
        on VideoPlayerPage. Sits ABOVE the auto-fading scrim so the chrome
        hide-on-idle doesn't make the card disappear underneath.

        Visibility, countdown, and bound metadata are driven by
        UpNextEpisodeOverlayViewModel via x:Bind. The host page hooks the
        Click events through to the VM (WatchNow / Cancel) and the
        PointerEntered / PointerExited events on CardRoot for hover-pause.

        Slide-in animation lives in code-behind (RenderTransform +
        Storyboard) — XAML's VisualStateManager isn't a great fit because
        IsVisible flips between false→true with state we want to animate
        even when the control re-mounts.
    -->
    <Grid x:Name="Root"
          Visibility="Collapsed">
        <Border x:Name="CardRoot"
                Width="380"
                MinHeight="120"
                CornerRadius="12"
                Background="#E6101010"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                Padding="14"
                PointerEntered="CardRoot_PointerEntered"
                PointerExited="CardRoot_PointerExited">
            <Border.RenderTransform>
                <TranslateTransform x:Name="RootTranslate" X="0" Y="0"/>
            </Border.RenderTransform>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 16:9 poster on the left. Self-rounded so we never depend
                     on parent clipping (see WinUI3 rounded-clipping note). -->
                <Border Grid.Column="0"
                        Width="120"
                        Height="68"
                        CornerRadius="6"
                        Background="#22FFFFFF">
                    <Border CornerRadius="6">
                        <Border.Background>
                            <ImageBrush x:Name="PosterBrush"
                                        Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                </Border>

                <!-- Right column: label + title + countdown row + buttons. -->
                <Grid Grid.Column="1" RowSpacing="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header strip: "UP NEXT" label + dismiss × on the right. -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="UP NEXT"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="200"
                                   Foreground="#B8FFFFFF"/>
                        <Button Grid.Column="1"
                                x:Name="CancelButton"
                                Width="22"
                                Height="22"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="CancelButton_Click"
                                ToolTipService.ToolTip="Dismiss">
                            <FontIcon Glyph="&#xE894;"
                                      FontSize="11"
                                      Foreground="#B8FFFFFF"/>
                        </Button>
                    </Grid>

                    <!-- "S2 · E5" -->
                    <TextBlock Grid.Row="1"
                               x:Name="SeasonEpisodeText"
                               Text="{x:Bind ViewModel.NextEpisodeSeasonEpisodeLabel, Mode=OneWay}"
                               FontSize="11"
                               Foreground="#A0FFFFFF"/>

                    <!-- Episode title — main line. -->
                    <TextBlock Grid.Row="2"
                               x:Name="EpisodeTitleText"
                               Text="{x:Bind ViewModel.NextEpisodeTitle, Mode=OneWay}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="Wrap"
                               MaxLines="2"
                               VerticalAlignment="Center"/>

                    <!-- Countdown + Watch now. -->
                    <Grid Grid.Row="3"
                          Margin="0,8,0,0"
                          ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Countdown ring with seconds number centered. -->
                        <Grid Grid.Column="0"
                              Width="32" Height="32"
                              VerticalAlignment="Center">
                            <ProgressRing IsIndeterminate="False"
                                          Maximum="100"
                                          Value="{x:Bind ViewModel.CountdownProgress, Mode=OneWay}"
                                          Width="32"
                                          Height="32"
                                          Foreground="White"/>
                            <TextBlock Text="{x:Bind ViewModel.CountdownSeconds, Mode=OneWay}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Grid.Column="1"
                                   Text="Playing next…"
                                   FontSize="11"
                                   Foreground="#A0FFFFFF"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="2"
                                x:Name="WatchNowButton"
                                Click="WatchNowButton_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                CornerRadius="14"
                                Padding="12,4">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE768;" FontSize="11"/>
                                <TextBlock Text="Watch now"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
