<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Local.LocalEpisodeCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Wrapped in a Button so Click is the canonical signal — same pattern
         ContentCard uses. Grid-with-Tapped works in most layouts, but Button
         is bullet-proof inside ItemsRepeater + UniformGridLayout and gives
         us focus / keyboard handling for free. The Button's chrome is
         neutralised (transparent background, no padding/border) so all the
         visual styling comes from the inner CardRoot Grid. -->
    <Button x:Name="CardButton"
            Padding="0"
            Background="Transparent"
            BorderThickness="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Click="CardButton_Click"
            RightTapped="CardButton_RightTapped">
    <Grid x:Name="CardRoot"
          CornerRadius="8"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
          BorderThickness="1"
          Padding="0,0,0,12"
          PointerEntered="CardRoot_PointerEntered"
          PointerExited="CardRoot_PointerExited">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 16:9 thumb with overlays. Height is driven from the container's
             ActualWidth via SizeChanged (see LocalEpisodeCard.xaml.cs) so the
             thumb stays at 16:9 regardless of the host grid's MinItemWidth. -->
        <Grid Grid.Row="0"
              x:Name="ThumbContainer"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              CornerRadius="8,8,0,0"
              SizeChanged="ThumbContainer_SizeChanged">
            <FontIcon x:Name="ThumbPlaceholderIcon"
                      Glyph="&#xE786;"
                      FontSize="32"
                      Opacity="0.4"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>

            <Image x:Name="ThumbImage"
                   Stretch="UniformToFill"
                   Opacity="0"
                   ImageOpened="ThumbImage_ImageOpened"/>

            <!-- Bottom-edge resume-position bar. Width is fraction-driven. -->
            <Grid x:Name="ResumeBar"
                  Visibility="Collapsed"
                  Height="3"
                  VerticalAlignment="Bottom">
                <Border Background="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Border x:Name="ResumeFill"
                        HorizontalAlignment="Left"
                        Width="0"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"/>
            </Grid>

            <!-- Hover play overlay. Glyph swaps to pause when this episode
                 is the active playing item, matching TrackItem behaviour. -->
            <Button x:Name="PlayOverlay"
                    Opacity="0"
                    Width="44" Height="44"
                    CornerRadius="22"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource AccentButtonStyle}"
                    IsHitTestVisible="False">
                <FontIcon x:Name="PlayOverlayGlyph"
                          Glyph="&#xE768;" FontSize="16"
                          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
            </Button>

            <!-- Playing-state equalizer. Visible when this episode is the
                 active item AND the card isn't hovered (the play / pause
                 button takes over on hover). Animated when playing; static
                 at lower opacity when paused. Same control used by
                 ContentCard / TrackItem so visuals stay consistent. -->
            <Border x:Name="PlayingEqualizerBadge"
                    Visibility="Collapsed"
                    Width="44" Height="44"
                    CornerRadius="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#A0000000"
                    IsHitTestVisible="False">
                <cards:LottieEqualizer x:Name="PlayingEqualizer"
                                       IconSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
            </Border>

            <!-- "Not in library" badge — top-left, shown when the episode
                 exists in the TMDB roster but not on disk. -->
            <Border x:Name="NotInLibraryBadge"
                    Visibility="Collapsed"
                    Margin="8,8,0,0"
                    Padding="6,2,6,3"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    CornerRadius="4"
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}">
                <TextBlock Text="Not in library"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
            </Border>

            <!-- Watched checkmark — top-right. -->
            <Border x:Name="WatchedBadge"
                    Visibility="Collapsed"
                    Margin="0,8,8,0"
                    Width="24" Height="24"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    CornerRadius="12"
                    Background="{ThemeResource AccentFillColorDefaultBrush}">
                <FontIcon Glyph="&#xE73E;"
                          FontSize="12"
                          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Title row: "S1 E1 · Pilot" + duration on the right. -->
        <Grid Grid.Row="1" Padding="12,10,12,2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       x:Name="TitleText"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       x:Name="DurationText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Synopsis. -->
        <TextBlock Grid.Row="2"
                   x:Name="OverviewText"
                   Padding="12,0,12,0"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextWrapping="Wrap"
                   TextTrimming="CharacterEllipsis"
                   MaxLines="2"/>
    </Grid>
    </Button>
</UserControl>
