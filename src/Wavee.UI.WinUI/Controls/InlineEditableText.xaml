<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.InlineEditableText"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid x:Name="Root"
          Background="Transparent"
          PointerEntered="Root_PointerEntered"
          PointerExited="Root_PointerExited">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- HoverFrame wraps the text/textbox and carries the editable affordance.
             Background + BorderBrush flip in code-behind on pointer enter/exit
             (tracked at the Root level so moving from text → pencil doesn't
             collapse the affordance). CornerRadius/Padding keep the chrome
             unobtrusive. -->
        <Border x:Name="HoverFrame"
                Grid.Column="0"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6,2"
                Tapped="Frame_Tapped">
            <Grid>
                <TextBlock x:Name="DisplayText"
                           Text="{x:Bind Text, Mode=OneWay}"
                           TextWrapping="WrapWholeWords"
                           TextTrimming="CharacterEllipsis"
                           FontSize="{x:Bind FontSize, Mode=OneWay}"
                           FontWeight="{x:Bind FontWeight, Mode=OneWay}"
                           Foreground="{x:Bind Foreground, Mode=OneWay}"
                           HorizontalAlignment="{x:Bind HorizontalContentAlignment, Mode=OneWay}"
                           TextAlignment="{x:Bind TextAlignment, Mode=OneWay}"
                           MaxLines="{x:Bind MaxLines, Mode=OneWay}"/>

                <!-- Empty-state CTA (only when IsEditable AND Text is empty) -->
                <TextBlock x:Name="PlaceholderText"
                           Text="{x:Bind Placeholder, Mode=OneWay}"
                           Visibility="Collapsed"
                           FontSize="{x:Bind FontSize, Mode=OneWay}"
                           FontStyle="Italic"
                           Opacity="0.6"
                           Foreground="{x:Bind Foreground, Mode=OneWay}"
                           HorizontalAlignment="{x:Bind HorizontalContentAlignment, Mode=OneWay}"
                           TextAlignment="{x:Bind TextAlignment, Mode=OneWay}"/>

                <!-- Edit host. Two complete subtrees: SingleLineHost is used when
                     AcceptsReturn=false (title); MultiLineHost when true (description).
                     EnterEditMode picks one and collapses the other. Each subtree owns
                     its own TextBox + Save/Cancel buttons so re-parenting at runtime
                     isn't needed. -->
                <StackPanel x:Name="EditStack"
                            Visibility="Collapsed">
                    <!-- ── Single-line: buttons inline to the right of the TextBox ── -->
                    <Grid x:Name="SingleLineHost" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="EditBoxSingle"
                                 Grid.Column="0"
                                 FontSize="{x:Bind FontSize, Mode=OneWay}"
                                 FontWeight="{x:Bind FontWeight, Mode=OneWay}"
                                 Foreground="{x:Bind Foreground, Mode=OneWay}"
                                 Background="Transparent"
                                 BorderBrush="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 Margin="-2,0,-2,0"
                                 VerticalAlignment="Center"
                                 TextAlignment="{x:Bind TextAlignment, Mode=OneWay}"
                                 AcceptsReturn="False"
                                 MaxLength="{x:Bind MaxLength, Mode=OneWay}"
                                 TextWrapping="NoWrap"
                                 KeyDown="EditBox_KeyDown"
                                 LostFocus="EditBox_LostFocus"/>
                        <Button x:Name="SaveButtonSingle"
                                Grid.Column="1"
                                Width="28" Height="28"
                                MinWidth="28" MinHeight="28"
                                CornerRadius="14"
                                Padding="0"
                                VerticalAlignment="Center"
                                Style="{StaticResource AccentButtonStyle}"
                                ToolTipService.ToolTip="Save (Enter)"
                                Click="SaveButton_Click">
                            <FontIcon Glyph="&#xE73E;" FontSize="12"
                                      Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                        </Button>
                        <Button x:Name="CancelButtonSingle"
                                Grid.Column="2"
                                Width="28" Height="28"
                                MinWidth="28" MinHeight="28"
                                CornerRadius="14"
                                Padding="0"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="Cancel (Esc)"
                                PointerPressed="CancelButton_PointerPressed"
                                Click="CancelButton_Click">
                            <FontIcon Glyph="&#xE711;" FontSize="12"/>
                        </Button>
                    </Grid>

                    <!-- ── Multi-line: TextBox on its own row; buttons in a right-
                           aligned row below. Cancel left, Save right (matches the
                           dialog primary-action convention). ── -->
                    <StackPanel x:Name="MultiLineHost"
                                Visibility="Collapsed"
                                Spacing="6">
                        <TextBox x:Name="EditBoxMulti"
                                 FontSize="{x:Bind FontSize, Mode=OneWay}"
                                 FontWeight="{x:Bind FontWeight, Mode=OneWay}"
                                 Foreground="{x:Bind Foreground, Mode=OneWay}"
                                 Background="Transparent"
                                 BorderBrush="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 Margin="-2,0,-2,0"
                                 TextAlignment="{x:Bind TextAlignment, Mode=OneWay}"
                                 AcceptsReturn="True"
                                 MaxLength="{x:Bind MaxLength, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 KeyDown="EditBox_KeyDown"
                                 LostFocus="EditBox_LostFocus"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="6">
                            <Button x:Name="CancelButtonMulti"
                                    Width="28" Height="28"
                                    MinWidth="28" MinHeight="28"
                                    CornerRadius="14"
                                    Padding="0"
                                    ToolTipService.ToolTip="Cancel (Esc)"
                                    PointerPressed="CancelButton_PointerPressed"
                                    Click="CancelButton_Click">
                                <FontIcon Glyph="&#xE711;" FontSize="12"/>
                            </Button>
                            <Button x:Name="SaveButtonMulti"
                                    Width="28" Height="28"
                                    MinWidth="28" MinHeight="28"
                                    CornerRadius="14"
                                    Padding="0"
                                    Style="{StaticResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="Save (Ctrl+Enter)"
                                    Click="SaveButton_Click">
                                <FontIcon Glyph="&#xE73E;" FontSize="12"
                                          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Persistent pencil hint — visible when IsEditable && not editing && not busy.
             Click also enters edit mode (in addition to the hover-frame Tapped). -->
        <Button x:Name="EditAffordanceButton"
                Grid.Column="1"
                Width="24" Height="24"
                MinWidth="24" MinHeight="24"
                CornerRadius="12"
                Padding="0"
                Margin="6,0,0,0"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Visibility="Collapsed"
                ToolTipService.ToolTip="Edit"
                Click="EditAffordanceButton_Click">
            <FontIcon Glyph="&#xE70F;" FontSize="12"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Button>

        <!-- Inline busy spinner (driven by IsBusy from the consumer). -->
        <ProgressRing x:Name="BusyRing"
                      Grid.Column="2"
                      Width="14"
                      Height="14"
                      Margin="6,0,0,0"
                      IsActive="False"
                      Visibility="Collapsed"/>
    </Grid>
</UserControl>
