<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Search.SearchResultHeroCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:addtoplaylist="using:Wavee.UI.WinUI.Controls.AddToPlaylist"
    mc:Ignorable="d">

    <Grid>
        <!-- ColorBackground (was inside RootBorder): solid extracted colour layer for
             non-bleed cases, set via the ColorHex DP. -->
        <Border x:Name="ColorBackground"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="26"/>

        <!-- Bleed layer: a composition SpriteVisual is attached to BleedSurfaceHost
             (LoadedImageSurface + CompositionSurfaceBrush, set in code-behind). The
             ink + palette overlays sit as XAML siblings of that host so they render
             ABOVE the composition visual (composition children always top their host's
             own XAML descendants, hence the dedicated empty host). BleedImageArea's
             CornerRadius=26 clips the whole stack to the rounded chrome shape. -->
        <Border x:Name="BleedImageArea"
                CornerRadius="26">
            <Grid>
                <!-- Empty host that owns the bleed SpriteVisual. -->
                <Border x:Name="BleedSurfaceHost"/>
                <!-- Ink gradient: darkens the left ~65% so the title stays readable
                     over the hero image. Collapsed unless we've resolved a hero image. -->
                <Border x:Name="HeroInkOverlay"
                        Visibility="Collapsed">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#E0000000" Offset="0"/>
                            <GradientStop Color="#80000000" Offset="0.4"/>
                            <GradientStop Color="#00000000" Offset="0.8"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <!-- Palette-tinted gradient (Spotify's extractedColorSet), layered over
                     the black ink so the wash picks up artist colour. Background is
                     assigned from code-behind when palette + theme resolve. -->
                <Border x:Name="PaletteHeroOverlay"/>
            </Grid>
        </Border>

        <!-- Chrome stroke + padding wrapper. Background stays Transparent so the bleed
             layer behind shows through. -->
        <Border x:Name="RootBorder"
                Background="Transparent"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="26"
                Padding="22">
            <Grid x:Name="ContentRow"
                  ColumnSpacing="20"
                  VerticalAlignment="Bottom">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hero artwork (square clip with overlays for tracks/albums/playlists; PersonPicture for artists) -->
                    <Grid Width="140" Height="140">
                        <Border x:Name="ArtworkClip"
                            Width="140" Height="140"
                            CornerRadius="26"
                            Background="{ThemeResource CardBackgroundFillColorTertiaryBrush}">
                            <Grid>
                                <FontIcon x:Name="ArtworkPlaceholderIcon"
                                      FontSize="28"
                                      Opacity="0.4"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                                <Image x:Name="ArtworkImage"
                                   Stretch="UniformToFill"
                                   behaviors:ImageFallbackBehavior.HideOnError="True"
                                   behaviors:ImageFallbackBehavior.FadeInOnLoad="True"/>

                                <!-- Now-playing equalizer overlay -->
                                <Border x:Name="NowPlayingOverlay"
                                    Background="#D9000000"
                                    Visibility="Collapsed">
                                    <cards:LottieEqualizer x:Name="NowPlayingEqualizer"
                                                       IconSize="40"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                </Border>

                                <!-- Buffering progress ring -->
                                <ProgressRing x:Name="BufferingRing"
                                          Width="40" Height="40"
                                          IsActive="False"
                                          Visibility="Collapsed"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Circular avatar — used for artists -->
                        <PersonPicture x:Name="ArtistAvatar"
                                   Width="140" Height="140"
                                   Visibility="Collapsed"/>
                    </Grid>

                    <!-- Title block -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="10">
                        <Border Background="{ThemeResource CardBackgroundFillColorTertiaryBrush}"
                            CornerRadius="12"
                            Padding="9,4"
                            HorizontalAlignment="Left">
                            <TextBlock x:Name="TypeTagText"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Border>

                        <TextBlock x:Name="TitleText"
                               FontSize="38"
                               FontWeight="Bold"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                        <TextBlock x:Name="SubtitleText"
                               FontSize="17"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Round accent play button (purely visual; click bubbles to host) -->
                    <Border x:Name="PlayActionButton"
                        Grid.Column="2"
                        Width="64" Height="64"
                        CornerRadius="32"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False">
                        <playback:PlaybackActionContent x:Name="PlayActionContent"
                                                       IconSize="22"
                                                       ActionForeground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                    </Border>
                </Grid>
        </Border>

        <cards:PendingBorderBeam x:Name="PlaybackPendingBeam"
                                 x:Load="False"
                                 Canvas.ZIndex="10"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 CornerRadius="26"
                                 BeamThickness="2"/>

        <!-- App-wide "Add to playlist" chip — top-right badge while an
             IAddToPlaylistSession is active and the hero represents a track.
             The chip's own session-watch controls visibility; this just
             positions it. -->
        <addtoplaylist:AddToPlaylistChip x:Name="AddChip"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,14,14,0"
                                         Canvas.ZIndex="11"/>
    </Grid>
</UserControl>
