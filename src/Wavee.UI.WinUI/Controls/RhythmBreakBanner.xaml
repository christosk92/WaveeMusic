<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.RhythmBreakBanner"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Full-width "On Tour Now" rhythm-break banner used between dense
          music-data sections on the V4A artist page. Acrylic backdrop +
          accent gradient sheen overlay + dual-ring pulse dot + CTA. -->
    <Button x:Name="CardButton"
            HorizontalContentAlignment="Stretch"
            HorizontalAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            CornerRadius="16"
            Click="CardButton_Click">
        <Border CornerRadius="16"
                MinHeight="118"
                Padding="28,18"
                Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource AccentControlElevationBorderBrush}"
                BorderThickness="1">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <!-- Dual-ring pulse dot -->
                        <Grid x:Name="PulseDotHost" Width="14" Height="14">
                            <Ellipse x:Name="PulseRingOuter"
                                     Width="14" Height="14"
                                     Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                     Opacity="0.32"/>
                            <Ellipse x:Name="PulseDot"
                                     Width="8" Height="8"
                                     Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="EyebrowText"
                                   Text="ON TOUR NOW"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   CharacterSpacing="160"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    </StackPanel>
                    <TextBlock x:Name="HeadlineText"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2"/>
                    <TextBlock x:Name="SublineText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"/>
                </StackPanel>

                <HyperlinkButton Grid.Column="1"
                                 x:Name="CtaLink"
                                 Content="See dates &amp; tickets ›"
                                 VerticalAlignment="Center"
                                 FontWeight="SemiBold"
                                 Padding="12,8"/>
            </Grid>
        </Border>
    </Button>
</UserControl>
