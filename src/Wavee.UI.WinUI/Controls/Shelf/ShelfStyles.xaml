<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shelf="using:Wavee.UI.WinUI.Controls.Shelf"
    xmlns:cfx="using:Wavee.UI.WinUI.Helpers.Composition">

    <!-- ShelfFadeRightBrush retired. Consumer pages now use the composition-
         based attached property at
         Wavee.UI.WinUI.Helpers.Composition.ShelfFadeMask.FadeRight, which
         renders a backdrop sample of the underlying visuals through an alpha
         gradient mask. That adapts to the page's palette-tinted backdrop and
         Mica instead of painting a hardcoded brush over them. -->

    <!-- Chevron button style used by shelf headers (SectionShelf + any page
         that wires its own header to a ShelfScroller). Matches the Fluent card
         surface; greyed out automatically via ICommand.CanExecute. -->
    <Style x:Key="ShelfChevronButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="UseSystemFocusVisuals" Value="True"/>
    </Style>

    <Style TargetType="shelf:ShelfScroller">
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="shelf:ShelfScroller">
                    <!-- Wrapper Grid hosts the scrolling items AND a baked-in
                         right-edge fade overlay. The fade Border is gated on
                         the templated parent's CanPageRight so it only shows
                         when there's overflow to the right (short shelves
                         that fit completely don't get the fade). The fade
                         uses the composition-based ShelfFadeMask attached
                         property — backdrop sample + Gaussian blur + alpha
                         gradient — so it adapts to whatever's underneath
                         instead of painting a hardcoded slab. Width=96
                         matches the previous per-page Border so every
                         existing layout keeps the same proportions. -->
                    <Grid>
                        <ScrollView x:Name="PART_Scroll"
                                    IgnoredInputKinds="All"
                                    ContentOrientation="Horizontal"
                                    HorizontalScrollBarVisibility="Hidden"
                                    VerticalScrollBarVisibility="Hidden"
                                    VerticalScrollMode="Disabled"
                                    ZoomMode="Disabled"
                                    VerticalAlignment="Top">
                            <ItemsRepeater x:Name="PART_Repeater"
                                           VerticalAlignment="Top">
                                <ItemsRepeater.Layout>
                                    <shelf:ShelfLayout/>
                                </ItemsRepeater.Layout>
                            </ItemsRepeater>
                        </ScrollView>
                        <Border HorizontalAlignment="Right"
                                Width="96"
                                IsHitTestVisible="False"
                                cfx:ShelfFadeMask.FadeRight="True"
                                Visibility="{Binding CanPageRight, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
