<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Shelf.SectionShelf"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shelf="using:Wavee.UI.WinUI.Controls.Shelf"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <StackPanel Spacing="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                           FontWeight="Bold" FontSize="20" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}"
                           Visibility="{x:Bind Subtitle, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <HyperlinkButton Content="{x:Bind ShowAllText, Mode=OneWay}"
                                 Command="{x:Bind ShowAllCommand, Mode=OneWay}"
                                 Visibility="{x:Bind ShowAllCommand, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                 Padding="4,0"
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                 VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                        Visibility="{x:Bind PART_Shelf.HasOverflow, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button Style="{StaticResource ShelfChevronButtonStyle}"
                        Command="{x:Bind PART_Shelf.PageLeftCommand, Mode=OneTime}">
                    <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                </Button>
                <Button Style="{StaticResource ShelfChevronButtonStyle}"
                        Command="{x:Bind PART_Shelf.PageRightCommand, Mode=OneTime}">
                    <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <shelf:ShelfScroller x:Name="PART_Shelf"
                             MinItemWidth="{x:Bind MinItemWidth, Mode=OneWay}"
                             MaxItemWidth="{x:Bind MaxItemWidth, Mode=OneWay}"
                             Spacing="{x:Bind Spacing, Mode=OneWay}"
                             OverlapCards="{x:Bind OverlapCards, Mode=OneWay}"/>
    </StackPanel>
</UserControl>
