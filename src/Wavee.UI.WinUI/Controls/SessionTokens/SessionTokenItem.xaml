            <StaticResource x:Key="SessionTokenItemBorderBrushSelected"
                            ResourceKey="AccentFillColorDefaultBrush" />
            <StaticResource x:Key="SessionTokenItemBorderBrushPointerOverSelected"
                            ResourceKey="AccentFillColorSecondaryBrush" />
            <StaticResource x:Key="SessionTokenItemBorderBrushPressedSelected"
