            <StaticResource x:Key="SessionTokenItemBackgroundPointerOverSelected"
                            ResourceKey="AccentFillColorSecondaryBrush" />
            <StaticResource x:Key="SessionTokenItemBackgroundPressedSelected"
                            ResourceKey="AccentFillColorTertiaryBrush" />
            <StaticResource x:Key="SessionTokenItemBorderBrush"
                            ResourceKey="ControlStrokeColorDefaultBrush" />
            <StaticResource x:Key="SessionTokenItemBorderBrushPointerOver"
