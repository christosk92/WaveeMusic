<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Wavee.UI.WinUI.Controls.SpotifyConnectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:branding="using:Wavee.UI.WinUI.Controls.Branding"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    DefaultButton="None"
    Style="{StaticResource DefaultContentDialogStyle}">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">800</x:Double>
    </ContentDialog.Resources>

    <Grid Width="720" MinHeight="420">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step 1: Authenticate (two-column layout with OR separator).
             Visible only while CurrentStep == Authenticate. -->
        <Grid x:Name="AuthPanel" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Browser login -->
            <StackPanel Grid.Column="0" Padding="32" Spacing="16" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE8D6;" FontSize="32" Foreground="#1DB954"/>
                    <TextBlock x:Uid="Controls_SpotifyConnectDialog__TextBlock_1" Text="Spotify" FontSize="24" FontWeight="Bold" Foreground="#1DB954"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">
                    <Run>Sign in with your Spotify</Run><Run>&#xAE;</Run>
                    <Run> account on the Spotify</Run><Run>&#xAE;</Run>
                    <Run> website</Run>
                </TextBlock>

                <Button Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch" Padding="12"
                        Command="{x:Bind ViewModel.ConnectWithBrowserCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <TextBlock x:Uid="Controls_SpotifyConnectDialog__TextBlock_2" Text="Log in" FontWeight="SemiBold"/>
                        <FontIcon Glyph="&#xE8A7;" FontSize="12"/>
                    </StackPanel>
                </Button>

                <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                    <Run FontWeight="SemiBold">Disclaimer:</Run>
                    <Run> Spotify&#xAE; and the Spotify logo are registered trademarks of Spotify AB. All trademarks, logos, and brand names are the property of their respective owners. Their use in this application is for identification purposes only and does not imply any endorsement or affiliation.</Run>
                </TextBlock>
            </StackPanel>

            <!-- OR separator -->
            <Grid Grid.Column="1" VerticalAlignment="Stretch" Margin="0,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Width="1" HorizontalAlignment="Center"
                        Background="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Border Grid.Row="1" CornerRadius="14" Padding="8,4"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <TextBlock x:Uid="Controls_SpotifyConnectDialog__TextBlock_3" Text="OR" FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </Border>
                <Border Grid.Row="2" Width="1" HorizontalAlignment="Center"
                        Background="{ThemeResource CardStrokeColorDefaultBrush}"/>
            </Grid>

            <!-- Right: QR code + pairing code -->
            <StackPanel Grid.Column="2" Padding="24,32" Spacing="10"
                        HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- QR Code with Spotify icon overlay -->
                <Border CornerRadius="12"
                        HorizontalAlignment="Center" Padding="12"
                        Background="White">
                    <Grid Width="160" Height="160">
                        <ProgressRing x:Name="QrLoadingRing" IsActive="True"
                                      Width="32" Height="32"/>
                        <Image x:Name="QrImage" Width="160" Height="160"
                               Source="{x:Bind ViewModel.QrCodeImage, Mode=OneWay}"
                               Visibility="Collapsed"/>
                        <Border x:Name="QrOverlayIcon" Background="White" CornerRadius="8" Padding="6"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <FontIcon Glyph="&#xE8D6;" FontSize="18" Foreground="#1DB954"/>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock x:Uid="Controls_SpotifyConnectDialog__TextBlock_4" Text="Scan QR code to log in" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" Spacing="4"
                            HorizontalAlignment="Center">
                    <TextBlock x:Uid="Controls_SpotifyConnectDialog__TextBlock_5" Text="Or go to"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <HyperlinkButton x:Uid="Controls_SpotifyConnectDialog__HyperlinkButton_6" Content="spotify.com/pair" Padding="4,0"
                                     NavigateUri="https://spotify.com/pair"
                                     VerticalAlignment="Center"/>
                    <TextBlock x:Uid="Controls_SpotifyConnectDialog__TextBlock_7" Text="and enter code:"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Pairing code + copy button -->
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.UserCode, Mode=OneWay}"
                               FontSize="28" FontWeight="Bold" CharacterSpacing="150"
                               IsTextSelectionEnabled="True" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                    <Button x:Uid="Controls_SpotifyConnectDialog__Button_8" x:Name="CopyCodeButton" Click="CopyCode_Click"
                            Width="32" Height="32" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Copy code">
                        <FontIcon x:Name="CopyIcon" Glyph="&#xE8C8;" FontSize="14"/>
                    </Button>
                </StackPanel>

                <!-- Status text (device-code state, not phase progress) -->
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Step 2: Live progress panel — single bound layout that shows the
             current phase as MainText, the live sub-text per phase, and an
             overall weighted progress bar. Real signals only — no Task.Delay.
             Visible while CurrentStep == Progress. -->
        <Grid x:Name="ProgressPanel" Grid.Row="0" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="20" MaxWidth="480" Padding="24">
                <branding:WaveeLogo Width="96" Height="96"
                                    HorizontalAlignment="Center"/>

                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <ProgressRing IsActive="True" Width="32" Height="32"
                                  HorizontalAlignment="Center"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.MainText, Mode=OneWay}"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.SubText, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Error -->
        <StackPanel x:Name="ErrorPanel" Grid.Row="0" Visibility="Collapsed"
                    Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
            <FontIcon Glyph="&#xEA39;" FontSize="48"
                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                       MaxWidth="400"/>
            <Button x:Uid="Controls_SpotifyConnectDialog__Button_12" Content="Try Again" Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Center"
                    Command="{x:Bind ViewModel.RetryCommand}"/>
        </StackPanel>

        <!-- Bottom bar: progress bar bound to OverallProgress + close button.
             Visible during all states (Auth shows it at 0; Progress drives it
             to 100; Error stays where it left off). -->
        <Grid Grid.Row="1" Padding="32,12" BorderThickness="0,1,0,0"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" VerticalAlignment="Center"
                         Value="{x:Bind ViewModel.OverallProgress, Mode=OneWay}"
                         Maximum="100"
                         Height="4" CornerRadius="2"/>
            <Button x:Uid="Controls_SpotifyConnectDialog__Button_14" x:Name="CloseButton" Grid.Column="1" Content="Close"
                    MinWidth="120" Margin="24,0,0,0"
                    Command="{x:Bind ViewModel.CancelCommand}"/>
        </Grid>
    </Grid>
</ContentDialog>
