<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Library.LibrarySortViewPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <UserControl.Resources>

        <!-- Sort option row: flat, full-width, hover tint, active row shows green check + direction chevron. -->
        <Style x:Key="SortOptionRowStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorTransparentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="UseSystemFocusVisuals" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid"
                              Background="{TemplateBinding Background}"
                              CornerRadius="{TemplateBinding CornerRadius}"
                              Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- View-mode icon toggle: 40×36, rounded, accent fill when checked. -->
        <Style x:Key="ViewModeToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorTransparentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="UseSystemFocusVisuals" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid x:Name="RootGrid"
                              Background="{TemplateBinding Background}"
                              CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource AccentFillColorDefaultBrush}"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource AccentFillColorSecondaryBrush}"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootGrid.Background" Value="{ThemeResource AccentFillColorTertiaryBrush}"/>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Data template for a sort option row content: label left, check+direction right. -->
        <DataTemplate x:Key="SortRowContentTemplate">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <!-- Trigger: ghost DropDownButton that reflects current sort + direction + view. -->
    <DropDownButton
        x:Name="TriggerButton"
        Padding="10,6"
        MinWidth="0"
        CornerRadius="6"
        Background="{ThemeResource SubtleFillColorTransparentBrush}"
        BorderThickness="0"
        ToolTipService.ToolTip="Sort and view options">

        <DropDownButton.Content>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8CB;" FontSize="13"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="TriggerSortLabel"
                           Text="Recents"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <FontIcon x:Name="TriggerDirectionGlyph"
                          Glyph="&#xE74B;"
                          FontSize="10"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Border Width="1" Height="12" Margin="4,0"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                <FontIcon x:Name="TriggerViewGlyph"
                          Glyph="&#xF0E2;"
                          FontSize="13"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </DropDownButton.Content>

        <DropDownButton.Flyout>
            <Flyout Placement="BottomEdgeAlignedLeft"
                    ShouldConstrainToRootBounds="True">
                <Flyout.FlyoutPresenterStyle>
                    <Style TargetType="FlyoutPresenter">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinWidth" Value="0"/>
                        <Setter Property="MaxWidth" Value="360"/>
                        <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}"/>
                        <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled"/>
                        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>
                    </Style>
                </Flyout.FlyoutPresenterStyle>

                <StackPanel MinWidth="260" Padding="8">

                    <!-- Sort by section -->
                    <TextBlock Text="Sort by"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               FontSize="14"
                               Padding="8,6,8,6"/>

                    <StackPanel x:Name="SortOptionsPanel" Spacing="2">
                        <Button x:Name="SortRecents" Style="{StaticResource SortOptionRowStyle}" Click="SortOption_Click" Tag="Recents">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Recents" VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" x:Name="SortRecentsCheck" Glyph="&#xE73E;" FontSize="14"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Visibility="Collapsed"/>
                                <FontIcon Grid.Column="2" x:Name="SortRecentsDir" Glyph="&#xE74B;" FontSize="12"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                        <Button x:Name="SortRecentlyAdded" Style="{StaticResource SortOptionRowStyle}" Click="SortOption_Click" Tag="RecentlyAdded">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Recently added" VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" x:Name="SortRecentlyAddedCheck" Glyph="&#xE73E;" FontSize="14"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Visibility="Collapsed"/>
                                <FontIcon Grid.Column="2" x:Name="SortRecentlyAddedDir" Glyph="&#xE74B;" FontSize="12"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                        <Button x:Name="SortAlphabetical" Style="{StaticResource SortOptionRowStyle}" Click="SortOption_Click" Tag="Alphabetical">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Alphabetical" VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" x:Name="SortAlphabeticalCheck" Glyph="&#xE73E;" FontSize="14"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Visibility="Collapsed"/>
                                <FontIcon Grid.Column="2" x:Name="SortAlphabeticalDir" Glyph="&#xE74B;" FontSize="12"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                        <Button x:Name="SortCreator" Style="{StaticResource SortOptionRowStyle}" Click="SortOption_Click" Tag="Creator">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Creator" VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" x:Name="SortCreatorCheck" Glyph="&#xE73E;" FontSize="14"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Visibility="Collapsed"/>
                                <FontIcon Grid.Column="2" x:Name="SortCreatorDir" Glyph="&#xE74B;" FontSize="12"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                        <Button x:Name="SortReleaseDate" Style="{StaticResource SortOptionRowStyle}" Click="SortOption_Click" Tag="ReleaseDate">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Release date" VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1" x:Name="SortReleaseDateCheck" Glyph="&#xE73E;" FontSize="14"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Visibility="Collapsed"/>
                                <FontIcon Grid.Column="2" x:Name="SortReleaseDateDir" Glyph="&#xE74B;" FontSize="12"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <MenuFlyoutSeparator Margin="0,6"/>

                    <!-- View as section -->
                    <TextBlock Text="View as"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               FontSize="14"
                               Padding="8,6,8,6"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="4" Padding="8,4,8,8">
                        <ToggleButton x:Name="ViewCompactList"
                                      Style="{StaticResource ViewModeToggleStyle}"
                                      Click="ViewToggle_Click"
                                      ToolTipService.ToolTip="Compact list">
                            <FontIcon Glyph="&#xE8FD;" FontSize="14"/>
                        </ToggleButton>
                        <ToggleButton x:Name="ViewDefaultList"
                                      Style="{StaticResource ViewModeToggleStyle}"
                                      Click="ViewToggle_Click"
                                      ToolTipService.ToolTip="List">
                            <FontIcon Glyph="&#xE14C;" FontSize="14"/>
                        </ToggleButton>
                        <ToggleButton x:Name="ViewCompactGrid"
                                      Style="{StaticResource ViewModeToggleStyle}"
                                      Click="ViewToggle_Click"
                                      ToolTipService.ToolTip="Compact grid">
                            <FontIcon Glyph="&#xE80A;" FontSize="14"/>
                        </ToggleButton>
                        <ToggleButton x:Name="ViewDefaultGrid"
                                      Style="{StaticResource ViewModeToggleStyle}"
                                      Click="ViewToggle_Click"
                                      ToolTipService.ToolTip="Grid">
                            <FontIcon Glyph="&#xF0E2;" FontSize="14"/>
                        </ToggleButton>
                    </StackPanel>

                    <!-- Grid size slider: visible only when a grid view mode is selected and
                         ShowGridScale is true (set by the consuming page). -->
                    <StackPanel x:Name="GridScaleSection" Spacing="4" Padding="8,0,8,8" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Size"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <FontIcon Grid.Column="1" Glyph="&#xE71E;" FontSize="12"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                        <Slider x:Name="GridScaleSlider"
                                Minimum="0.7"
                                Maximum="1.6"
                                StepFrequency="0.05"
                                SmallChange="0.05"
                                LargeChange="0.1"
                                TickFrequency="0.1"
                                Value="{x:Bind GridScale, Mode=TwoWay}"/>
                    </StackPanel>

                </StackPanel>
            </Flyout>
        </DropDownButton.Flyout>
    </DropDownButton>
</UserControl>
