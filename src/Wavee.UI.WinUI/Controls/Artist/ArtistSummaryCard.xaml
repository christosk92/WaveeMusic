<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Artist.ArtistSummaryCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.microsoft.com/markup-compatibility/2006"
    xmlns:ic="using:FluentIcons.WinUI"
    xmlns:waveeControls="using:Wavee.UI.WinUI.Controls"
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch">

    <!--
        Reusable "About the artist" summary card. Self-contained:
          - avatar + eyebrow + name + verified ★ + bio + Follow pill
          - optional on-device AI bio fallback (✨ sparkle when the Spotify
            bio is empty and Phi Silica is enabled in settings)
          - card surface (avatar + text area) is clickable → routes to
            ArtistPage. Hover state lightens the surface background.
          - AdditionalContent slot for page-specific extras (stats line,
            ticket pill, etc.) — collapsed by default
        Visuals + AI flow live in the code-behind so consumers just bind
        data DPs and a follow command.
    -->
    <Border x:Name="CardSurface"
            HorizontalAlignment="Stretch"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="14,12"
            PointerEntered="CardSurface_PointerEntered"
            PointerExited="CardSurface_PointerExited"
            Tapped="CardSurface_Tapped">
        <Grid ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <PersonPicture Grid.Column="0" Grid.RowSpan="2"
                           x:Name="AvatarPicture"
                           Width="56" Height="56"
                           VerticalAlignment="Top"/>

            <StackPanel Grid.Column="1" Grid.Row="0"
                        Spacing="2"
                        VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock x:Name="EyebrowTextBlock"
                               Text="ABOUT THE ARTIST"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               FontWeight="SemiBold"
                               CharacterSpacing="120"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <!-- Sparkle is only visible when the bio shown is the
                         on-device AI summary (Spotify's bio was empty and
                         Phi Silica filled in). Tooltip explains it. -->
                    <ic:SymbolIcon x:Name="AiSparkle"
                                   Symbol="Sparkle"
                                   IconVariant="Filled"
                                   FontSize="11"
                                   ToolTipService.ToolTip="Summary generated on-device by AI"
                                   Visibility="Collapsed"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock x:Name="NameTextBlock"
                               FontSize="15"
                               FontWeight="ExtraBold"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"/>
                    <FontIcon x:Name="VerifiedGlyph"
                              Glyph="&#xE73E;"
                              FontSize="11"
                              Visibility="Collapsed"/>
                </StackPanel>
                <!-- HtmlTextBlock decodes HTML entities (Spotify ships
                     biographies with &#39;, &#x1f90d;, etc.) and renders any
                     embedded Spotify URI links as in-app navigations. -->
                <waveeControls:HtmlTextBlock x:Name="BioTextBlock"
                                             MaxLines="2"
                                             Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                             FontSize="12"/>
            </StackPanel>

            <Button Grid.Column="2" Grid.Row="0"
                    x:Name="FollowButton"
                    Height="36" Padding="14,0" CornerRadius="18"
                    Background="Transparent"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Center"
                    Click="FollowButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <FontIcon x:Name="FollowGlyph" FontSize="12"/>
                    <TextBlock x:Name="FollowLabel" FontSize="13"/>
                </StackPanel>
            </Button>

            <!-- Page-specific extras live here (stats caption, ticket pill,
                 etc.). Collapsed automatically when AdditionalContent is null. -->
            <ContentControl Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                            x:Name="AdditionalContentHost"
                            Margin="0,8,0,0"
                            HorizontalContentAlignment="Stretch"
                            Visibility="Collapsed"/>
        </Grid>
    </Border>
</UserControl>
