<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.PlayerBar.PlayerBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    xmlns:toolkit="using:CommunityToolkit.WinUI"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Styles/PlayerBarStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:RepeatModeToGlyphConverter x:Key="RepeatGlyphConverter" />
            <converters:RepeatModeToCheckedConverter x:Key="RepeatCheckedConverter" />
            <converters:RepeatModeToSymbolConverter x:Key="RepeatSymbolConverter" />
            <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Invert="True" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" Invert="True" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="LayoutStates">
            <VisualState x:Name="Wide">
                <VisualState.Setters>
                    <Setter Target="WideLayoutRoot.Visibility" Value="Visible" />
                    <Setter Target="NarrowLayoutRoot.Visibility" Value="Collapsed" />
                    <Setter Target="InlinePanelGroup.Visibility" Value="Visible" />
                    <Setter Target="InlineModeGroup.Visibility" Value="Visible" />
                    <Setter Target="InlineVolumeGroup.Visibility" Value="Visible" />
                    <Setter Target="OverflowButton.Visibility" Value="Collapsed" />
                    <Setter Target="WideLayoutRoot.Height" Value="56" />
                    <Setter Target="PlayerBarLayoutRoot.MinHeight" Value="56" />
                </VisualState.Setters>
            </VisualState>

            <VisualState x:Name="Compact">
                <VisualState.Setters>
                    <Setter Target="WideLayoutRoot.Visibility" Value="Visible" />
                    <Setter Target="NarrowLayoutRoot.Visibility" Value="Collapsed" />
                    <Setter Target="InlinePanelGroup.Visibility" Value="Visible" />
                    <Setter Target="InlineModeGroup.Visibility" Value="Visible" />
                    <Setter Target="InlineVolumeGroup.Visibility" Value="Collapsed" />
                    <Setter Target="OverflowButton.Visibility" Value="Visible" />
                    <Setter Target="WideLayoutRoot.Height" Value="56" />
                    <Setter Target="PlayerBarLayoutRoot.MinHeight" Value="56" />
                </VisualState.Setters>
            </VisualState>

            <VisualState x:Name="Narrow">
                <VisualState.Setters>
                    <Setter Target="WideLayoutRoot.Visibility" Value="Visible" />
                    <Setter Target="NarrowLayoutRoot.Visibility" Value="Collapsed" />
                    <Setter Target="InlinePanelGroup.Visibility" Value="Collapsed" />
                    <Setter Target="InlineModeGroup.Visibility" Value="Visible" />
                    <Setter Target="InlineVolumeGroup.Visibility" Value="Collapsed" />
                    <Setter Target="OverflowButton.Visibility" Value="Visible" />
                    <Setter Target="WideLayoutRoot.Height" Value="56" />
                    <Setter Target="PlayerBarLayoutRoot.MinHeight" Value="56" />
                </VisualState.Setters>
            </VisualState>

            <VisualState x:Name="VeryNarrow">
                <VisualState.Setters>
                    <Setter Target="WideLayoutRoot.Visibility" Value="Collapsed" />
                    <Setter Target="NarrowLayoutRoot.Visibility" Value="Visible" />
                    <Setter Target="NarrowRemoteDeviceHost.Visibility" Value="Collapsed" />
                    <Setter Target="NarrowInlineModeGroup.Visibility" Value="Collapsed" />
                    <Setter Target="NarrowVolumeButton.Visibility" Value="Visible" />
                    <Setter Target="NarrowTrackMetadataHost.Margin" Value="8,0,0,0" />
                    <Setter Target="PlayerBarLayoutRoot.MinHeight" Value="76" />
                </VisualState.Setters>
            </VisualState>
        </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <StackPanel Orientation="Vertical" Spacing="0">
        <!-- Compact end-of-context hint. Sits above the PlayerBar so it
             doesn't interfere with the track/metadata layout. Visibility is
             driven by IsAtEndOfContext; auto-clears on resume, or user
             dismisses manually via the X button. -->
        <Grid
            x:Name="EndOfContextBar"
            MinHeight="32"
            Padding="16,6"
            Background="{ThemeResource InfoBarInformationalSeverityBackgroundBrush}"
            BorderBrush="{ThemeResource InfoBarBorderBrush}"
            BorderThickness="0,0,0,1"
            Visibility="{x:Bind ViewModel.IsAtEndOfContext, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon
                Grid.Column="0"
                Glyph="&#xE946;"
                FontSize="14"
                Margin="0,0,10,0"
                VerticalAlignment="Center"
                Foreground="{ThemeResource InfoBarInformationalSeverityIconBackground}" />

            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontSize="12"
                TextTrimming="CharacterEllipsis"
                Text="You've reached the end of this queue — click Play to restart." />

            <Button
                Grid.Column="2"
                x:Name="EndOfContextDismissButton"
                Background="Transparent"
                BorderThickness="0"
                Padding="4"
                MinWidth="28"
                MinHeight="28"
                Click="EndOfContextDismiss_Click"
                ToolTipService.ToolTip="Dismiss">
                <FontIcon Glyph="&#xE711;" FontSize="11" />
            </Button>
        </Grid>

        <TeachingTip
            x:Name="VideoPopoutTeachingTip"
            Title="Video is playing in the popout player"
            Subtitle="Playback was routed to the detached player window."
            Target="{x:Bind PlayerBarLayoutRoot}"
            PreferredPlacement="TopRight"
            IsLightDismissEnabled="True"
            ActionButtonContent="Focus player"
            CloseButtonContent="Dismiss"
            ActionButtonClick="VideoPopoutTeachingTip_ActionButtonClick"
            Closed="VideoPopoutTeachingTip_Closed" />

        <TeachingTip
            x:Name="PodcastResumeTeachingTip"
            Title="Resume episode?"
            Subtitle="{x:Bind ViewModel.PodcastResumePromptText, Mode=OneWay}"
            Target="{x:Bind PlayerBarLayoutRoot}"
            PreferredPlacement="Top"
            IsLightDismissEnabled="True"
            IsOpen="{x:Bind ViewModel.IsPodcastResumePromptVisible, Mode=TwoWay}"
            ActionButtonContent="{x:Bind ViewModel.PodcastResumeActionText, Mode=OneWay}"
            CloseButtonContent="Keep from start"
            ActionButtonClick="PodcastResumeTeachingTip_ActionButtonClick"
            CloseButtonClick="PodcastResumeTeachingTip_CloseButtonClick"
            Closed="PodcastResumeTeachingTip_Closed" />

    <Border
        AllowDrop="True"
        DragOver="PlayerBarRoot_DragOver"
        DragLeave="PlayerBarRoot_DragLeave"
        Drop="PlayerBarRoot_Drop"
        Visibility="{x:Bind ViewModel.HasTrack, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
        <toolkit:Effects.Shadow>
            <media:AttachedCardShadow BlurRadius="32" Offset="0,-2" Opacity="0.4" Color="Black" CornerRadius="8" />
        </toolkit:Effects.Shadow>

        <Border
            CornerRadius="4"
            BorderThickness="0">
            <Border.Background>
                <AcrylicBrush
                    x:Name="PlayerBarTintBrush"
                    TintColor="#C05040"
                    TintOpacity="0.88"
                    TintLuminosityOpacity="0.25"
                    FallbackColor="{ThemeResource SolidBackgroundFillColorBase}" />
            </Border.Background>

            <Grid x:Name="PlayerBarLayoutRoot" MinHeight="56" Padding="0,0,8,0">
                <Grid x:Name="WideLayoutRoot" Height="56">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        x:Name="TrackGroup"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        MinWidth="200"
                        MaxWidth="320">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            x:Name="AlbumArtHost"
                            Width="48"
                            Height="48"
                            Margin="4"
                            CornerRadius="4"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Tapped="AlbumArt_Tapped"
                            RightTapped="NowPlaying_RightTapped"
                            Visibility="{x:Bind ViewModel.IsAlbumArtExpanded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <animations:Implicit.ShowAnimations>
                                <animations:OpacityAnimation Duration="0:0:0.2" From="0" To="1" />
                                <animations:ScaleAnimation Duration="0:0:0.2" From="0.8,0.8,1" To="1,1,1" />
                            </animations:Implicit.ShowAnimations>
                            <animations:Implicit.HideAnimations>
                                <animations:OpacityAnimation Duration="0:0:0.15" From="1" To="0" />
                                <animations:ScaleAnimation Duration="0:0:0.15" From="1,1,1" To="0.8,0.8,1" />
                            </animations:Implicit.HideAnimations>
                            <Image
                                Width="48"
                                Height="48"
                                IsHitTestVisible="False"
                                Source="{x:Bind ViewModel.AlbumArt, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=48}"
                                Stretch="UniformToFill"
                                behaviors:ImageFallbackBehavior.HideOnError="True"
                                behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                behaviors:ImageFallbackBehavior.DecodePixelWidth="96" />
                            <FontIcon
                                Glyph="&#xE8D6;"
                                FontSize="18"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind ViewModel.AlbumArt, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}" />
                        </Grid>

                        <StackPanel
                            x:Name="TrackMetadataHost"
                            Grid.Column="1"
                            Margin="8,0,12,0"
                            VerticalAlignment="Center"
                            Spacing="0">
                            <HyperlinkButton
                                Padding="0"
                                MinHeight="0"
                                MinWidth="0"
                                Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                                Click="TrackTitle_Click"
                                RightTapped="NowPlaying_RightTapped">
                                <TextBlock
                                    Text="{x:Bind ViewModel.TrackTitle, Mode=OneWay}"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    MaxLines="1"
                                    TextWrapping="WrapWholeWords"
                                    TextTrimming="CharacterEllipsis" />
                            </HyperlinkButton>
                            <ctk:MetadataControl
                                Items="{x:Bind ViewModel.ArtistMetadataItems, Mode=OneWay}"
                                Separator=", ">
                                <ctk:MetadataControl.TextBlockStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="Opacity" Value="0.6" />
                                        <Setter Property="Foreground" Value="{ThemeResource ApplicationForegroundThemeBrush}" />
                                        <Setter Property="MaxLines" Value="1" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    </Style>
                                </ctk:MetadataControl.TextBlockStyle>
                            </ctk:MetadataControl>
                            <StackPanel
                                x:Name="RemoteDeviceHost"
                                Orientation="Horizontal"
                                Spacing="4"
                                Visibility="{x:Bind ViewModel.IsPlayingRemotely, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FontIcon Glyph="&#xE703;" FontSize="9" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.ActiveDeviceName, Mode=OneWay, FallbackValue='Remote device'}"
                                    FontSize="10"
                                    Opacity="0.7"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <Grid
                            x:Name="HeartHost"
                            Grid.Column="2"
                            VerticalAlignment="Center">
                            <controls:HeartButton
                                x:Name="PlayerHeartButton"
                                Width="28"
                                Height="28"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Grid>

                    <StackPanel
                        x:Name="TransportGroup"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="0"
                        Margin="0,0,12,0">
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="34"
                            Height="32"
                            Padding="0"
                            Command="{x:Bind ViewModel.SkipBackwardCommand}"
                            Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTipService.ToolTip="Back 15 seconds">
                            <TextBlock Text="-15" FontSize="11" FontWeight="SemiBold" />
                        </Button>
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Command="{x:Bind ViewModel.PreviousCommand}"
                            ToolTipService.ToolTip="Previous">
                            <FontIcon Glyph="&#xF8AC;" FontSize="14" />
                        </Button>
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="36"
                            Height="36"
                            Padding="0"
                            Command="{x:Bind ViewModel.PlayPauseCommand}"
                            ToolTipService.ToolTip="Play/Pause">
                            <playback:PlaybackActionContent IconSize="18"
                                                           SpinnerSize="20"
                                                           IsPlaying="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                                                           IsPending="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
                                                           ActionForeground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Command="{x:Bind ViewModel.NextCommand}"
                            ToolTipService.ToolTip="Next">
                            <FontIcon Glyph="&#xF8AD;" FontSize="14" />
                        </Button>
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="34"
                            Height="32"
                            Padding="0"
                            Command="{x:Bind ViewModel.SkipForwardCommand}"
                            Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTipService.ToolTip="Forward 15 seconds">
                            <TextBlock Text="+15" FontSize="11" FontWeight="SemiBold" />
                        </Button>
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="42"
                            Height="32"
                            Padding="0"
                            Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTipService.ToolTip="Playback speed">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="0.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="0.5" />
                                    <MenuFlyoutItem Text="0.75x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="0.75" />
                                    <MenuFlyoutItem Text="1x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1" />
                                    <MenuFlyoutItem Text="1.25x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.25" />
                                    <MenuFlyoutItem Text="1.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.5" />
                                    <MenuFlyoutItem Text="1.75x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.75" />
                                    <MenuFlyoutItem Text="2x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="2" />
                                    <MenuFlyoutItem Text="2.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="2.5" />
                                    <MenuFlyoutItem Text="3x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="3" />
                                </MenuFlyout>
                            </Button.Flyout>
                            <TextBlock Text="{x:Bind ViewModel.PlaybackSpeedText, Mode=OneWay}" FontSize="11" FontWeight="SemiBold" />
                        </Button>
                    </StackPanel>

                    <TextBlock
                        x:Name="TimeStartText"
                        Grid.Column="2"
                        Text="{x:Bind ViewModel.PositionText, Mode=OneWay}"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Margin="4,0,8,0" />

                    <Grid
                        x:Name="ProgressGroup"
                        Grid.Column="3"
                        VerticalAlignment="Center">
                        <playback:CompositionProgressBar
                            x:Name="WideProgressSlider"
                            VerticalAlignment="Center"
                            PositionMs="{x:Bind ViewModel.AnchorPositionMs, Mode=OneWay}"
                            DurationMs="{x:Bind ViewModel.Duration, Mode=OneWay}"
                            IsPlaying="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                            IsBuffering="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
                            Segments="{x:Bind ViewModel.Chapters, Mode=OneWay}"
                            SeekStarted="ProgressBar_SeekStarted"
                            SeekCommitted="ProgressBar_SeekCommitted" />
                    </Grid>

                    <TextBlock
                        x:Name="TimeEndText"
                        Grid.Column="4"
                        Text="{x:Bind ViewModel.DurationText, Mode=OneWay}"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Opacity="0.6"
                        Margin="8,0,12,0" />

                    <StackPanel
                        Grid.Column="5"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="0">
                        <StackPanel
                            x:Name="InlineModeGroup"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="0">
                            <ToggleButton
                                Style="{StaticResource SubtleToggleButtonStyle}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                IsChecked="{x:Bind ViewModel.IsShuffle, Mode=OneWay}"
                                Command="{x:Bind ViewModel.ToggleShuffleCommand}"
                                ToolTipService.ToolTip="Shuffle">
                                <FontIcon Glyph="&#xE8B1;" FontSize="14" />
                            </ToggleButton>

                            <ToggleButton
                                Style="{StaticResource SubtleToggleButtonStyle}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                IsChecked="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatCheckedConverter}}"
                                Command="{x:Bind ViewModel.ToggleRepeatCommand}"
                                ToolTipService.ToolTip="Repeat">
                                <FontIcon
                                    Glyph="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatGlyphConverter}}"
                                    FontSize="14" />
                            </ToggleButton>
                        </StackPanel>

                        <playback:AudioOutputPicker
                            x:Name="InlineVolumeGroup"
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            CompactIconOnly="True"
                            CompactMaxWidth="32"
                            CompactFlyoutPlacement="TopEdgeAlignedRight" />

                        <playback:AudioOutputPicker
                            x:Name="CollapsedVolumeButton"
                            Width="32"
                            Height="32"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"
                            CompactIconOnly="True"
                            CompactMaxWidth="32"
                            CompactFlyoutPlacement="TopEdgeAlignedRight" />

                        <StackPanel
                            x:Name="InlinePanelGroup"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="0">
                            <ToggleButton
                                Style="{StaticResource SubtleToggleButtonStyle}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                IsChecked="{x:Bind ViewModel.IsQueuePanelActive, Mode=OneWay}"
                                Command="{x:Bind ViewModel.ToggleQueuePanelCommand}"
                                ToolTipService.ToolTip="Queue">
                                <FontIcon Glyph="&#xE142;" FontSize="14" />
                            </ToggleButton>

                            <ToggleButton
                                Style="{StaticResource SubtleToggleButtonStyle}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                IsChecked="{x:Bind ViewModel.IsDetailsPanelActive, Mode=OneWay}"
                                Command="{x:Bind ViewModel.ToggleDetailsPanelCommand}"
                                Visibility="{x:Bind ViewModel.IsMusicOnlyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="Details">
                                <FontIcon Glyph="&#xE946;" FontSize="14" />
                            </ToggleButton>

                            <ToggleButton
                                Style="{StaticResource SubtleToggleButtonStyle}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                IsChecked="{x:Bind ViewModel.IsLyricsPanelActive, Mode=OneWay}"
                                Command="{x:Bind ViewModel.ToggleLyricsPanelCommand}"
                                Visibility="{x:Bind ViewModel.IsMusicOnlyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="Lyrics">
                                <FontIcon Glyph="&#xED1E;" FontSize="14" />
                            </ToggleButton>

                            <ToggleButton
                                Style="{StaticResource SubtleToggleButtonStyle}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                IsChecked="{x:Bind ViewModel.IsFriendsPanelActive, Mode=OneWay}"
                                Command="{x:Bind ViewModel.ToggleFriendsPanelCommand}"
                                Visibility="{x:Bind ViewModel.IsMusicOnlyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="Friends Activity">
                                <FontIcon Glyph="&#xE716;" FontSize="14" />
                            </ToggleButton>

                            <playback:WatchVideoButton ButtonSize="32" IconSize="16" />

                            <Button
                                Style="{StaticResource TransparentButtonStyle}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Command="{x:Bind ViewModel.SwitchToAudioCommand}"
                                IsEnabled="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                Visibility="{x:Bind ViewModel.IsCurrentTrackAudioCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="Listen as audio">
                                <Grid Width="16" Height="16">
                                    <FontIcon
                                        Glyph="&#xE8D6;"
                                        FontSize="14"
                                        Visibility="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                    <ProgressRing
                                        Width="16"
                                        Height="16"
                                        IsActive="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay}"
                                        Visibility="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </Button>

                            <!-- Standalone Pop-Out — first-class only for music / podcast
                                 content. For video, Pop-Out moves inside the
                                 "Expand player" DropDownButton below so the bar has
                                 a single expand affordance. -->
                            <Button
                                Style="{StaticResource TransparentButtonStyle}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Click="PopOutToWindow_Click"
                                Visibility="{x:Bind ViewModel.IsMusicOnlyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="Pop out player">
                                <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                            </Button>

                            <!-- Expand player (video only). One DropDownButton replaces
                                 Theatre + Fullscreen + Pop-Out so the three near-identical
                                 expand glyphs don't read as the same button to the user.
                                 Each menu item has its own glyph + label, so the choice
                                 is unambiguous. -->
                            <DropDownButton
                                x:Name="ExpandPlayerDropDown"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Visibility="{x:Bind ViewModel.IsVideoContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTipService.ToolTip="Expand player">
                                <FontIcon Glyph="&#xE740;" FontSize="14" />
                                <DropDownButton.Flyout>
                                    <MenuFlyout Placement="TopEdgeAlignedRight">
                                        <MenuFlyoutItem
                                            Text="Theatre mode"
                                            Command="{x:Bind ViewModel.EnterTheatreCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE73F;" FontSize="14" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            Text="Fullscreen"
                                            Command="{x:Bind ViewModel.EnterFullscreenCommand}"
                                            KeyboardAcceleratorTextOverride="F11">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE740;" FontSize="14" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            Text="Pop out to window"
                                            Click="PopOutToWindow_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </StackPanel>

                        <Button
                            x:Name="OverflowButton"
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Visibility="Collapsed"
                            ToolTipService.ToolTip="More">
                            <Button.Flyout>
                                <MenuFlyout Opening="OverflowFlyout_Opening">
                                    <MenuFlyoutItem
                                        x:Name="WideLikeMenuItem"
                                        Tag="like"
                                        Text="Like track"
                                        Click="LikeOverflowMenuItem_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xEB52;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Queue"
                                        IsChecked="{x:Bind ViewModel.IsQueuePanelActive, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleQueuePanelCommand}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE142;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Lyrics"
                                        IsChecked="{x:Bind ViewModel.IsLyricsPanelActive, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleLyricsPanelCommand}"
                                        Visibility="{x:Bind ViewModel.IsMusicOnlyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xED1E;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Details"
                                        IsChecked="{x:Bind ViewModel.IsDetailsPanelActive, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleDetailsPanelCommand}"
                                        Visibility="{x:Bind ViewModel.IsMusicOnlyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE946;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Friends Activity"
                                        IsChecked="{x:Bind ViewModel.IsFriendsPanelActive, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleFriendsPanelCommand}"
                                        Visibility="{x:Bind ViewModel.IsMusicOnlyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE716;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Theatre mode"
                                        Command="{x:Bind ViewModel.EnterTheatreCommand}"
                                        Visibility="{x:Bind ViewModel.IsVideoContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE73F;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Fullscreen"
                                        Command="{x:Bind ViewModel.EnterFullscreenCommand}"
                                        Visibility="{x:Bind ViewModel.IsVideoContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        KeyboardAcceleratorTextOverride="F11">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE740;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Watch Video"
                                        Command="{x:Bind ViewModel.SwitchToVideoCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsResolvingVideo, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                        Visibility="{x:Bind ViewModel.IsCurrentTrackVideoCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE714;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Listen as audio"
                                        Command="{x:Bind ViewModel.SwitchToAudioCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                        Visibility="{x:Bind ViewModel.IsCurrentTrackAudioCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8D6;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Show mini player"
                                        Click="ShowMiniVideoPlayer_Click"
                                        Visibility="{x:Bind ViewModel.IsCurrentTrackAudioCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE740;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Auto play videos this session"
                                        IsChecked="{x:Bind ViewModel.PreferVideoPlaybackInSession, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleVideoPlaybackPreferenceCommand}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE714;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <ToggleMenuFlyoutItem
                                        Text="Shuffle"
                                        IsChecked="{x:Bind ViewModel.IsShuffle, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleShuffleCommand}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8B1;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Repeat"
                                        IsChecked="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatCheckedConverter}}"
                                        Command="{x:Bind ViewModel.ToggleRepeatCommand}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon
                                                Glyph="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatGlyphConverter}}"
                                                FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem
                                        Text="Pop out to window"
                                        Click="PopOutToWindow_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Show in sidebar"
                                        Click="ShowInSidebar_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE759;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                            <FontIcon Glyph="&#xE712;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid x:Name="NarrowLayoutRoot" Visibility="Collapsed" Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            x:Name="NarrowAlbumArtHost"
                            Width="40"
                            Height="40"
                            Margin="4"
                            CornerRadius="4"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Tapped="AlbumArt_Tapped"
                            RightTapped="NowPlaying_RightTapped"
                            Visibility="{x:Bind ViewModel.IsAlbumArtExpanded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <Image
                                Width="40"
                                Height="40"
                                IsHitTestVisible="False"
                                Source="{x:Bind ViewModel.AlbumArt, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=48}"
                                Stretch="UniformToFill"
                                behaviors:ImageFallbackBehavior.HideOnError="True"
                                behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                behaviors:ImageFallbackBehavior.DecodePixelWidth="96" />
                            <FontIcon
                                Glyph="&#xE8D6;"
                                FontSize="16"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind ViewModel.AlbumArt, Mode=OneWay, Converter={StaticResource InverseNullToVisibilityConverter}}" />
                        </Grid>

                        <StackPanel
                            x:Name="NarrowTrackMetadataHost"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Spacing="0">
                            <HyperlinkButton
                                Padding="0"
                                MinHeight="0"
                                MinWidth="0"
                                Foreground="{ThemeResource ApplicationForegroundThemeBrush}"
                                Click="TrackTitle_Click"
                                RightTapped="NowPlaying_RightTapped">
                                <TextBlock
                                    Text="{x:Bind ViewModel.TrackTitle, Mode=OneWay}"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    MaxLines="1"
                                    TextTrimming="CharacterEllipsis" />
                            </HyperlinkButton>
                            <ctk:MetadataControl
                                Items="{x:Bind ViewModel.ArtistMetadataItems, Mode=OneWay}"
                                Separator=", ">
                                <ctk:MetadataControl.TextBlockStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="12" />
                                        <Setter Property="Opacity" Value="0.6" />
                                        <Setter Property="Foreground" Value="{ThemeResource ApplicationForegroundThemeBrush}" />
                                        <Setter Property="MaxLines" Value="1" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    </Style>
                                </ctk:MetadataControl.TextBlockStyle>
                            </ctk:MetadataControl>
                            <StackPanel
                                x:Name="NarrowRemoteDeviceHost"
                                Orientation="Horizontal"
                                Spacing="4"
                                Visibility="{x:Bind ViewModel.IsPlayingRemotely, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FontIcon Glyph="&#xE703;" FontSize="9" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.ActiveDeviceName, Mode=OneWay, FallbackValue='Remote device'}"
                                    FontSize="10"
                                    Opacity="0.7"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="0"
                        Margin="0,0,4,0">
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="30"
                            Height="32"
                            Padding="0"
                            Command="{x:Bind ViewModel.SkipBackwardCommand}"
                            Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTipService.ToolTip="Back 15 seconds">
                            <TextBlock Text="-15" FontSize="10" FontWeight="SemiBold" />
                        </Button>
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Command="{x:Bind ViewModel.PreviousCommand}"
                            ToolTipService.ToolTip="Previous">
                            <FontIcon Glyph="&#xF8AC;" FontSize="14" />
                        </Button>
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="36"
                            Height="36"
                            Padding="0"
                            Command="{x:Bind ViewModel.PlayPauseCommand}"
                            ToolTipService.ToolTip="Play/Pause">
                            <playback:PlaybackActionContent IconSize="18"
                                                           SpinnerSize="20"
                                                           IsPlaying="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                                                           IsPending="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
                                                           ActionForeground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Command="{x:Bind ViewModel.NextCommand}"
                            ToolTipService.ToolTip="Next">
                            <FontIcon Glyph="&#xF8AD;" FontSize="14" />
                        </Button>
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="30"
                            Height="32"
                            Padding="0"
                            Command="{x:Bind ViewModel.SkipForwardCommand}"
                            Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTipService.ToolTip="Forward 15 seconds">
                            <TextBlock Text="+15" FontSize="10" FontWeight="SemiBold" />
                        </Button>
                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="38"
                            Height="32"
                            Padding="0"
                            Visibility="{x:Bind ViewModel.IsCurrentItemEpisode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTipService.ToolTip="Playback speed">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="0.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="0.5" />
                                    <MenuFlyoutItem Text="0.75x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="0.75" />
                                    <MenuFlyoutItem Text="1x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1" />
                                    <MenuFlyoutItem Text="1.25x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.25" />
                                    <MenuFlyoutItem Text="1.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.5" />
                                    <MenuFlyoutItem Text="1.75x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="1.75" />
                                    <MenuFlyoutItem Text="2x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="2" />
                                    <MenuFlyoutItem Text="2.5x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="2.5" />
                                    <MenuFlyoutItem Text="3x" Command="{x:Bind ViewModel.SetPlaybackSpeedCommand}" CommandParameter="3" />
                                </MenuFlyout>
                            </Button.Flyout>
                            <TextBlock Text="{x:Bind ViewModel.PlaybackSpeedText, Mode=OneWay}" FontSize="10" FontWeight="SemiBold" />
                        </Button>
                    </StackPanel>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="3"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="0">
                        <StackPanel
                            x:Name="NarrowInlineModeGroup"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="0">
                            <ToggleButton
                                Style="{StaticResource SubtleToggleButtonStyle}"
                                Width="30"
                                Height="30"
                                Padding="0"
                                IsChecked="{x:Bind ViewModel.IsShuffle, Mode=OneWay}"
                                Command="{x:Bind ViewModel.ToggleShuffleCommand}"
                                ToolTipService.ToolTip="Shuffle">
                                <FontIcon Glyph="&#xE8B1;" FontSize="13" />
                            </ToggleButton>

                            <ToggleButton
                                Style="{StaticResource SubtleToggleButtonStyle}"
                                Width="30"
                                Height="30"
                                Padding="0"
                                IsChecked="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatCheckedConverter}}"
                                Command="{x:Bind ViewModel.ToggleRepeatCommand}"
                                ToolTipService.ToolTip="Repeat">
                                <FontIcon
                                    Glyph="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatGlyphConverter}}"
                                    FontSize="13" />
                            </ToggleButton>
                        </StackPanel>

                        <playback:AudioOutputPicker
                            x:Name="NarrowVolumeButton"
                            Width="32"
                            Height="32"
                            VerticalAlignment="Center"
                            CompactIconOnly="True"
                            CompactMaxWidth="32"
                            CompactFlyoutPlacement="TopEdgeAlignedRight" />

                        <Button
                            x:Name="NarrowOverflowButton"
                            Style="{StaticResource TransparentButtonStyle}"
                            Width="32"
                            Height="32"
                            Padding="0"
                            ToolTipService.ToolTip="More">
                            <Button.Flyout>
                                <MenuFlyout Opening="OverflowFlyout_Opening">
                                    <MenuFlyoutItem
                                        x:Name="NarrowLikeMenuItem"
                                        Tag="like"
                                        Text="Like track"
                                        Click="LikeOverflowMenuItem_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xEB52;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Queue"
                                        IsChecked="{x:Bind ViewModel.IsQueuePanelActive, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleQueuePanelCommand}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE142;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Lyrics"
                                        IsChecked="{x:Bind ViewModel.IsLyricsPanelActive, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleLyricsPanelCommand}"
                                        Visibility="{x:Bind ViewModel.IsMusicOnlyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xED1E;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Details"
                                        IsChecked="{x:Bind ViewModel.IsDetailsPanelActive, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleDetailsPanelCommand}"
                                        Visibility="{x:Bind ViewModel.IsMusicOnlyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE946;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Friends Activity"
                                        IsChecked="{x:Bind ViewModel.IsFriendsPanelActive, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleFriendsPanelCommand}"
                                        Visibility="{x:Bind ViewModel.IsMusicOnlyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE716;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Theatre mode"
                                        Command="{x:Bind ViewModel.EnterTheatreCommand}"
                                        Visibility="{x:Bind ViewModel.IsVideoContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE73F;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Fullscreen"
                                        Command="{x:Bind ViewModel.EnterFullscreenCommand}"
                                        Visibility="{x:Bind ViewModel.IsVideoContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        KeyboardAcceleratorTextOverride="F11">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE740;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Watch Video"
                                        Command="{x:Bind ViewModel.SwitchToVideoCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsResolvingVideo, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                        Visibility="{x:Bind ViewModel.IsCurrentTrackVideoCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE714;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Listen as audio"
                                        Command="{x:Bind ViewModel.SwitchToAudioCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsSwitchingToAudio, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                        Visibility="{x:Bind ViewModel.IsCurrentTrackAudioCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8D6;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Show mini player"
                                        Click="ShowMiniVideoPlayer_Click"
                                        Visibility="{x:Bind ViewModel.IsCurrentTrackAudioCapable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE740;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Auto play videos this session"
                                        IsChecked="{x:Bind ViewModel.PreferVideoPlaybackInSession, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleVideoPlaybackPreferenceCommand}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE714;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <ToggleMenuFlyoutItem
                                        Text="Shuffle"
                                        IsChecked="{x:Bind ViewModel.IsShuffle, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleShuffleCommand}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8B1;" FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <ToggleMenuFlyoutItem
                                        Text="Repeat"
                                        IsChecked="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatCheckedConverter}}"
                                        Command="{x:Bind ViewModel.ToggleRepeatCommand}">
                                        <ToggleMenuFlyoutItem.Icon>
                                            <FontIcon
                                                Glyph="{x:Bind ViewModel.RepeatMode, Mode=OneWay, Converter={StaticResource RepeatGlyphConverter}}"
                                                FontSize="14" />
                                        </ToggleMenuFlyoutItem.Icon>
                                    </ToggleMenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem
                                        Text="Pop out to window"
                                        Click="PopOutToWindow_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem
                                        Text="Show in sidebar"
                                        Click="ShowInSidebar_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE759;" FontSize="14" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                            <FontIcon Glyph="&#xE712;" FontSize="14" />
                        </Button>
                    </StackPanel>

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Text="{x:Bind ViewModel.PositionText, Mode=OneWay}"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Margin="8,0,8,4" />

                    <playback:CompositionProgressBar
                        x:Name="CompactProgressSlider"
                        Grid.Row="1"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        VerticalAlignment="Center"
                        Margin="0,0,8,4"
                        PositionMs="{x:Bind ViewModel.AnchorPositionMs, Mode=OneWay}"
                        DurationMs="{x:Bind ViewModel.Duration, Mode=OneWay}"
                        IsPlaying="{x:Bind ViewModel.IsPlaying, Mode=OneWay}"
                        IsBuffering="{x:Bind ViewModel.IsBuffering, Mode=OneWay}"
                        Segments="{x:Bind ViewModel.Chapters, Mode=OneWay}"
                        SeekStarted="ProgressBar_SeekStarted"
                        SeekCommitted="ProgressBar_SeekCommitted" />

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="3"
                        Text="{x:Bind ViewModel.DurationText, Mode=OneWay}"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Opacity="0.6"
                        Margin="0,0,4,4" />
                </Grid>
            </Grid>
        </Border>
    </Border>
    </StackPanel>
</UserControl>
