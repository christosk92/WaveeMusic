<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Gallery.MarqueeGalleryStrip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid x:Name="HostGrid"
          Background="Transparent"
          PointerEntered="HostGrid_PointerEntered"
          PointerExited="HostGrid_PointerExited"
          PointerCaptureLost="HostGrid_PointerExited">

        <Grid x:Name="ClipHost" Background="Transparent">
            <Grid.Clip>
                <RectangleGeometry x:Name="ClipGeometry"/>
            </Grid.Clip>
            <StackPanel x:Name="Rail"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"/>
        </Grid>

        <Rectangle x:Name="LeftFade"
                   HorizontalAlignment="Left"
                   IsHitTestVisible="False"/>
        <Rectangle x:Name="RightFade"
                   HorizontalAlignment="Right"
                   IsHitTestVisible="False"/>
    </Grid>
</UserControl>
