<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.HeroHeader.ArtistShyPill"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:waveePlayback="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:transitions="using:CommunityToolkit.WinUI"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- Border colour per theme; background is now the system
                     Acrylic brush so the pill reads as a solid glass card
                     over the page-tint gradient without translucency flicker. -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ShyHeaderBorderBrush" Color="#66FFFFFF"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ShyHeaderBorderBrush" Color="#33000000"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="ShyHeaderBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
            <converters:BoolToFollowGlyphConverter x:Key="BoolToFollowGlyphConverter"/>
            <converters:BoolToFollowTextConverter x:Key="BoolToFollowTextConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Compact "shy" pill that morphs in from the hero overlay on scroll.
         Matched-ID leaves (artist-avatar / artist-name / artist-meta /
         artist-play / artist-follow + card-shell on the outer Border) drive
         the TransitionHelper morph between this control and the hero overlay
         on the host page. -->
    <Border x:Name="PillBorder"
            Padding="16,8"
            MinWidth="420"
            MaxWidth="760"
            CornerRadius="28"
            Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
            BorderBrush="{ThemeResource ShyHeaderBorderBrush}"
            BorderThickness="1"
            transitions:TransitionHelper.Id="card-shell">
        <Border.Shadow>
            <ThemeShadow/>
        </Border.Shadow>
        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <Ellipse Width="36" Height="36"
                     transitions:TransitionHelper.Id="artist-avatar">
                <Ellipse.Fill>
                    <ImageBrush
                        ImageSource="{x:Bind ArtistImageUrl, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=72}"
                        Stretch="UniformToFill"/>
                </Ellipse.Fill>
            </Ellipse>
            <StackPanel VerticalAlignment="Center" Spacing="-1">
                <TextBlock Text="{x:Bind ArtistName, Mode=OneWay}"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           transitions:TransitionHelper.Id="artist-name"/>
                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           transitions:TransitionHelper.Id="artist-meta">
                    <Run Text="{x:Bind MonthlyListenersText, Mode=OneWay}"/>
                    <Run Text=" monthly listeners"/>
                </TextBlock>
            </StackPanel>
            <Button x:Name="PlayBtn"
                    Style="{StaticResource AccentButtonStyle}"
                    Background="{x:Bind PaletteAccentPillBrush, Mode=OneWay}"
                    Foreground="{x:Bind PaletteAccentPillForegroundBrush, Mode=OneWay}"
                    Command="{x:Bind PlayCommand, Mode=OneWay}"
                    Height="36"
                    Padding="14,0"
                    CornerRadius="18"
                    Margin="6,0,0,0"
                    transitions:TransitionHelper.Id="artist-play">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <waveePlayback:PlaybackActionContent IconSize="13"
                                                         SpinnerSize="13"
                                                         IsPlaying="{x:Bind IsArtistContextPlaying, Mode=OneWay}"
                                                         IsPending="{x:Bind IsPlayPending, Mode=OneWay}"/>
                    <TextBlock Text="{x:Bind ArtistPlayButtonText, Mode=OneWay}" FontSize="13"/>
                </StackPanel>
            </Button>
            <Button x:Name="FollowBtn"
                    Command="{x:Bind ToggleFollowCommand, Mode=OneWay}"
                    Height="36"
                    Padding="12,0"
                    CornerRadius="18"
                    transitions:TransitionHelper.Id="artist-follow">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <FontIcon Glyph="{x:Bind IsFollowing, Mode=OneWay, Converter={StaticResource BoolToFollowGlyphConverter}}" FontSize="12"/>
                    <TextBlock Text="{x:Bind IsFollowing, Mode=OneWay, Converter={StaticResource BoolToFollowTextConverter}}" FontSize="13"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
