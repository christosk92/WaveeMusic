<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Wavee.UI.WinUI.Controls">

    <Style TargetType="controls:ErrorStateView">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ErrorStateView">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        Padding="24">
                        <FontIcon
                            Glyph="{TemplateBinding Glyph}"
                            FontSize="48"
                            Opacity="0.4"
                            HorizontalAlignment="Center"/>
                        <TextBlock
                            Text="{TemplateBinding Title}"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            HorizontalAlignment="Center"/>
                        <TextBlock
                            Text="{TemplateBinding Message}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Opacity="0.6"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            MaxWidth="400"
                            TextWrapping="Wrap"/>
                        <Button
                            Content="{TemplateBinding RetryButtonText}"
                            Command="{TemplateBinding RetryCommand}"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
