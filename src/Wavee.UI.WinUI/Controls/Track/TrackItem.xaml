<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Track.TrackItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls1="using:CommunityToolkit.WinUI.Controls"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    xmlns:media="using:CommunityToolkit.WinUI.Media"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:controls="using:Wavee.UI.WinUI.Controls"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Inline metadata glyphs: a flat camera icon, no Border/box. The previous
             box-frame look made the badge feel like a clickable button on rows
             without album art (album page); a standalone glyph reads as metadata. -->
        <Style x:Key="VideoAvailabilityBadgeIconStyle" TargetType="FontIcon">
            <Setter Property="Glyph" Value="&#xE714;"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ExplicitContentBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="MinWidth" Value="13"/>
            <Setter Property="Height" Value="13"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ExplicitContentBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ═══════════════ COMPACT MODE (grid cells: artist top tracks, search) ═══════════════ -->
        <Border x:Name="CompactBorder" Visibility="Visible"
                CornerRadius="6" BorderThickness="0" Background="Transparent">
        <Grid>
        <Grid x:Name="CompactRoot"
              Padding="8,4" ColumnSpacing="12" Height="56">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Album art stack (art + now-playing overlay + hover play button) -->
            <Grid Grid.Column="0" Width="48" Height="48">
                <Border x:Name="CompactAlbumArtBorder" CornerRadius="4"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid>
                        <FontIcon x:Name="CompactArtPlaceholder"
                                  Glyph="&#xE8D6;" FontSize="18" Opacity="0.35"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image x:Name="CompactAlbumArt" Stretch="UniformToFill"
                               behaviors:ImageFallbackBehavior.HideOnError="True"
                               behaviors:ImageFallbackBehavior.FadeInOnLoad="True"/>
                    </Grid>
                </Border>

                <Border x:Name="CompactNowPlaying" CornerRadius="4"
                        Background="#D9000000" Visibility="Collapsed">
                    <cards:LottieEqualizer x:Name="CompactNowPlayingEqualizer"
                                           x:Load="False"
                                           IconSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                </Border>

                <ProgressRing x:Name="CompactBufferingRing"
                              Width="24" Height="24"
                              IsActive="False" Visibility="Collapsed"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Button x:Name="CompactPlayButton"
                        Visibility="Collapsed" Opacity="0"
                        Width="48" Height="48" CornerRadius="4"
                        Padding="0" Background="#CC000000" BorderThickness="0"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <playback:PlaybackActionContent x:Name="CompactPlayContent"
                                                   IconSize="20"
                                                   ActionForeground="White"/>
                </Button>

                <controls1:Shimmer x:Name="CompactArtShimmer" Width="48" Height="48"
                                   CornerRadius="4" Visibility="Collapsed"/>
            </Grid>

            <StackPanel x:Name="CompactInfoPanel" Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                <Grid ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CompactTitle" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" MaxLines="1" FontSize="13"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="5"
                                VerticalAlignment="Center">
                        <FontIcon x:Name="CompactLocalBadge" Visibility="Collapsed"
                                  Glyph="&#xE8B7;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  ToolTipService.ToolTip="On this PC"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <Border x:Name="CompactExplicit"
                            Style="{StaticResource ExplicitContentBadgeStyle}"
                            Visibility="Collapsed"
                            ToolTipService.ToolTip="Explicit">
                        <TextBlock Text="E" Style="{StaticResource ExplicitContentBadgeTextStyle}"/>
                    </Border>
                    <FontIcon x:Name="CompactVideoBadge"
                              Style="{StaticResource VideoAvailabilityBadgeIconStyle}"
                              Visibility="Collapsed"
                              ToolTipService.ToolTip="Music video available"/>
                    <TextBlock x:Name="CompactVideoSeparator"
                               Text="&#x00B7;"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="CompactSubtitle"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"/>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="CompactInfoShimmer" Grid.Column="1" VerticalAlignment="Center"
                        Spacing="6" Visibility="Collapsed">
                <controls1:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                <controls1:Shimmer Width="110" Height="12" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Heart button (left of duration) -->
            <controls:HeartButton x:Name="CompactHeartButton" Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Width="28" Height="28" Visibility="Collapsed"/>

            <TextBlock x:Name="CompactDuration" Grid.Column="3"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center" Padding="6,0"/>
        </Grid>
        <!-- Selection indicator: left-edge accent bar, shown when IsSelected=true.
             Declared last so it paints ON TOP of CompactRoot's 48-px album art. -->
        <Border x:Name="CompactSelectionIndicator"
                Width="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Margin="0,10"
                CornerRadius="2"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                Opacity="0"
                IsHitTestVisible="False"/>
        </Grid>
        </Border>

        <!-- ═══════════════ ROW MODE (table rows: playlists, albums, liked songs) ═══════════════ -->
        <Border x:Name="RowRoot" Visibility="Collapsed"
                Padding="8,8" CornerRadius="6"
                Background="Transparent">
            <Grid>
                <Grid x:Name="RowContentGrid" ColumnSpacing="0">
                    <!--
                        Artist is rendered as a subline under the Title (column 3) rather
                        than occupying its own grid column. Saves ~180 px per row and
                        matches the Spotify/Apple Music row layout.
                    -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="RowIndexColDef" Width="52"/>
                        <ColumnDefinition x:Name="RowHeartColDef" Width="32"/>
                        <ColumnDefinition x:Name="RowArtColDef" Width="42"/>
                        <ColumnDefinition Width="*" MinWidth="120" MaxWidth="640"/>
                        <ColumnDefinition x:Name="RowAlbumColDef" Width="180"/>
                        <ColumnDefinition x:Name="RowAddedByColDef" Width="0"/>
                        <ColumnDefinition x:Name="RowDateColDef" Width="120"/>
                        <ColumnDefinition x:Name="RowPlayCountColDef" Width="0"/>
                        <ColumnDefinition x:Name="RowDurationColDef" Width="60"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row number / Now Playing icon / Play button area -->
                    <Grid Grid.Column="0">
                        <FontIcon x:Name="RowPopularityBadge"
                                  Glyph="&#xE735;"
                                  Width="10"
                                  FontSize="10"
                                  Foreground="{ThemeResource AccentTextFillColorSecondaryBrush}"
                                  Opacity="0.8"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Margin="2,0,0,0"
                                  IsHitTestVisible="False"
                                  Visibility="Collapsed"
                                  ToolTipService.ToolTip="Popular track"/>
                        <TextBlock x:Name="RowIndexText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <cards:LottieEqualizer x:Name="RowNowPlayingEqualizer"
                                               x:Load="False"
                                               IconSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                        <ProgressRing x:Name="RowBufferingRing"
                                      Width="16" Height="16"
                                      IsActive="False" Visibility="Collapsed"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button x:Name="RowPlayButton"
                                Visibility="Collapsed"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <playback:PlaybackActionContent x:Name="RowPlayContent"
                                                           IconSize="14"
                                                           ActionForeground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Heart button -->
                    <controls:HeartButton x:Name="RowHeartButton" Grid.Column="1"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Width="28" Height="28" Visibility="Collapsed"/>

                    <!-- Album thumbnail (34x34) -->
                    <Border x:Name="RowAlbumArtBorder" Grid.Column="2" Width="34" Height="34" CornerRadius="4"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid>
                            <FontIcon x:Name="RowArtPlaceholder" Glyph="&#xE8D6;" FontSize="16" Opacity="0.3"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="RowAlbumArt" Stretch="UniformToFill"
                                   behaviors:ImageFallbackBehavior.HideOnError="True"
                                   behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                   behaviors:ImageFallbackBehavior.DecodePixelWidth="68"/>
                        </Grid>
                    </Border>

                    <!-- Title stacked over Artist subline -->
                    <StackPanel Grid.Column="3" Orientation="Vertical" Spacing="0"
                                Margin="12,0,8,0" VerticalAlignment="Center">
                        <!-- 2-column Grid (not StackPanel) so RowTitle actually
                             gets a bounded measure width and TextTrimming kicks
                             in. Horizontal StackPanel hands children infinite
                             width and the title bleeds into the Album column. -->
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="RowTitle"
                                       Grid.Column="0"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="5"
                                        VerticalAlignment="Center">
                                <!-- Inline badge slots: used when the artist subline
                                     is hidden (album page) so badges sit beside the
                                     title instead of floating on an empty subline. -->
                                <Border x:Name="RowExplicitInline"
                                        Style="{StaticResource ExplicitContentBadgeStyle}"
                                        Visibility="Collapsed"
                                        ToolTipService.ToolTip="Explicit">
                                    <TextBlock Text="E" Style="{StaticResource ExplicitContentBadgeTextStyle}"/>
                                </Border>
                                <FontIcon x:Name="RowVideoBadgeInline"
                                          Style="{StaticResource VideoAvailabilityBadgeIconStyle}"
                                          Visibility="Collapsed"
                                          ToolTipService.ToolTip="Music video available"/>
                                <FontIcon x:Name="RowLocalBadge" Visibility="Collapsed"
                                          Glyph="&#xE8B7;" FontSize="12"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                          ToolTipService.ToolTip="On this PC"/>
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="RowProgressCell"
                              Margin="0,3,0,0"
                              ColumnSpacing="8"
                              VerticalAlignment="Center"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="RowProgressExplicit"
                                    Grid.Column="0"
                                    Style="{StaticResource ExplicitContentBadgeStyle}"
                                    Visibility="Collapsed"
                                    ToolTipService.ToolTip="Explicit">
                                <TextBlock Text="E" Style="{StaticResource ExplicitContentBadgeTextStyle}"/>
                            </Border>
                            <ProgressBar x:Name="RowProgressBar"
                                         Grid.Column="1"
                                         Minimum="0"
                                         Maximum="100"
                                         Height="3"
                                         VerticalAlignment="Center"/>
                            <StackPanel x:Name="RowPlayedIndicator"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Border Width="14"
                                        Height="14"
                                        CornerRadius="7"
                                        BorderThickness="1.5"
                                        BorderBrush="{ThemeResource AccentTextFillColorPrimaryBrush}">
                                    <FontIcon Glyph="&#xE73E;"
                                              FontSize="8"
                                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="RowPlayedText"
                                           Text="Played"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="RowProgressText"
                                       Grid.Column="2"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="4"
                                    Margin="0,-2,0,0"
                                    VerticalAlignment="Center">
                            <Border x:Name="RowExplicit"
                                    Style="{StaticResource ExplicitContentBadgeStyle}"
                                    Visibility="Collapsed"
                                    ToolTipService.ToolTip="Explicit">
                                <TextBlock Text="E" Style="{StaticResource ExplicitContentBadgeTextStyle}"/>
                            </Border>
                            <FontIcon x:Name="RowVideoBadge"
                                      Style="{StaticResource VideoAvailabilityBadgeIconStyle}"
                                      Visibility="Collapsed"
                                      ToolTipService.ToolTip="Music video available"/>
                            <TextBlock x:Name="RowVideoSeparator"
                                       Text="&#x00B7;"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       Visibility="Collapsed"
                                       VerticalAlignment="Center"/>
                            <!-- Per-artist hyperlinks. Children are built imperatively in
                                 TrackItem.xaml.cs#RebuildArtistsSubline so each artist on a
                                 multi-artist track is its own clickable link with comma
                                 separators between them. Single-artist tracks render exactly
                                 one HyperlinkButton — same visual as the previous design. -->
                            <StackPanel x:Name="RowArtistsHost"
                                        Orientation="Horizontal"
                                        Spacing="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Album (clickable) -->
                    <HyperlinkButton x:Name="RowAlbumLink" Grid.Column="4"
                                     Padding="0" VerticalAlignment="Center">
                        <HyperlinkButton.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1"/>
                            </DataTemplate>
                        </HyperlinkButton.ContentTemplate>
                    </HyperlinkButton>

                    <!-- Added By: PersonPicture + display name. Visible on
                         collaborative playlists and viewer-mode playlists
                         (TrackDataGrid sets ShowAddedByColumn). PersonPicture
                         handles every fallback automatically: image when set,
                         initials from DisplayName when no image, generic
                         person glyph when neither — same component used on
                         the hero collab stack. -->
                    <Grid x:Name="RowAddedByCell" Grid.Column="5"
                          ColumnSpacing="6"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <PersonPicture x:Name="RowAddedByAvatar"
                                       Grid.Column="0"
                                       Width="20" Height="20"/>
                        <TextBlock x:Name="RowAddedByText"
                                   Grid.Column="1"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Date Added -->
                    <TextBlock x:Name="RowDateAdded" Grid.Column="6"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Play count (album page) -->
                    <TextBlock x:Name="RowPlayCount" Grid.Column="7"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>

                    <!-- Duration -->
                    <TextBlock x:Name="RowDuration" Grid.Column="8"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Shimmer overlay for lazy/loading rows. Mirrors RowContentGrid's 8 columns
                     so individual shimmer rectangles align under the column headers. The
                     conditional column widths are kept in sync with the real row in
                     ApplyShowFlags (TrackItem.xaml.cs). -->
                <Grid x:Name="RowShimmerOverlay" VerticalAlignment="Center"
                      Visibility="Collapsed"
                      ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition x:Name="ShimHeartColDef" Width="32"/>
                        <ColumnDefinition x:Name="ShimArtColDef" Width="42"/>
                        <ColumnDefinition Width="*" MinWidth="120" MaxWidth="640"/>
                        <ColumnDefinition x:Name="ShimAlbumColDef" Width="180"/>
                        <ColumnDefinition x:Name="ShimAddedByColDef" Width="0"/>
                        <ColumnDefinition x:Name="ShimDateColDef" Width="120"/>
                        <ColumnDefinition x:Name="ShimPlayCountColDef" Width="0"/>
                        <ColumnDefinition x:Name="ShimDurationColDef" Width="60"/>
                    </Grid.ColumnDefinitions>
                    <controls1:Shimmer Grid.Column="2" Width="34" Height="34" CornerRadius="4" HorizontalAlignment="Left"/>
                    <StackPanel Grid.Column="3" Spacing="6" VerticalAlignment="Center" Margin="12,0,8,0">
                        <controls1:Shimmer Width="180" Height="14" HorizontalAlignment="Left"/>
                        <controls1:Shimmer Width="100" Height="10" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <controls1:Shimmer Grid.Column="4" Width="120" Height="12" HorizontalAlignment="Left"/>
                    <controls1:Shimmer Grid.Column="6" Width="80" Height="12" HorizontalAlignment="Left"/>
                    <controls1:Shimmer Grid.Column="8" Width="36" Height="12" HorizontalAlignment="Right"/>
                </Grid>
                <Border x:Name="RowSelectionIndicator"
                        Width="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Margin="0,10"
                        CornerRadius="2"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        Opacity="0"
                        IsHitTestVisible="False"/>
            </Grid>
        </Border>
        <cards:PendingBorderBeam x:Name="PlaybackPendingBeam"
                                 x:Load="False"
                                 Canvas.ZIndex="10"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 CornerRadius="6"
                                 BeamThickness="2"/>
    </Grid>

</UserControl>
