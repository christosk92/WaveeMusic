<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Imaging.CompositionImage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    IsHitTestVisible="False">

    <!-- Two layers: an optional placeholder underneath (visible until the
         image surface reports LoadCompleted), and the host Grid that owns
         the SpriteVisual carrying the actual surface brush. Host is set as
         the visual parent via ElementCompositionPreview.SetElementChildVisual. -->
    <Grid x:Name="RootGrid">
        <Border x:Name="PlaceholderHost"
                Background="{x:Bind PlaceholderBrush, Mode=OneWay}"
                CornerRadius="{x:Bind CornerRadius, Mode=OneWay}"/>
        <Grid x:Name="SurfaceHost"/>
    </Grid>
</UserControl>
