<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Imaging.CrossFadeImage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:imaging="using:Wavee.UI.WinUI.Controls.Imaging"
    mc:Ignorable="d">

    <!-- Two stacked CompositionImage layers + a palette-aware placeholder.
         The host Grid honors the consumer's Width/Height and rounded corners
         so layout footprint is stable regardless of which layer is currently
         visible. Layer opacities are driven by Composition animations from
         code-behind. -->
    <Grid x:Name="HostGrid"
          CornerRadius="{x:Bind CornerRadius, Mode=OneWay}">
        <Border x:Name="PlaceholderLayer"
                Background="{x:Bind PlaceholderBrush, Mode=OneWay}"
                CornerRadius="{x:Bind CornerRadius, Mode=OneWay}"/>
        <imaging:CompositionImage x:Name="LayerA"
                                  Stretch="{x:Bind Stretch, Mode=OneWay}"
                                  CornerRadius="{x:Bind CornerRadius, Mode=OneWay}"
                                  Opacity="0"
                                  IsHitTestVisible="False"/>
        <imaging:CompositionImage x:Name="LayerB"
                                  Stretch="{x:Bind Stretch, Mode=OneWay}"
                                  CornerRadius="{x:Bind CornerRadius, Mode=OneWay}"
                                  Opacity="0"
                                  IsHitTestVisible="False"/>
    </Grid>
</UserControl>
