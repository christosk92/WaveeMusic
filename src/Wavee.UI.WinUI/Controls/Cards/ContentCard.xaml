<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Cards.ContentCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI.Media"
    xmlns:winUi="using:CommunityToolkit.WinUI"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:local="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    mc:Ignorable="d"
    Background="Transparent"
    PointerEntered="Card_PointerEntered"
    PointerExited="Card_PointerExited"
    PointerPressed="Card_PointerPressed"
    PointerReleased="Card_PointerReleased">

    <Button
        x:Name="CardButton"
        Padding="0"
        Background="Transparent"
        BorderThickness="0"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
        Click="CardButton_Click"
        PointerPressed="CardButton_PointerPressed"
        RightTapped="CardButton_RightTapped">
        <Grid>
        <!-- Card root: a single Grid carries background, rounded corners, stroke, padding, and
             the drop shadow. Previously wrapped by a <Border>, but Grid has built-in border
             properties (BorderBrush/BorderThickness/CornerRadius/Padding/Background) per the
             "Optimize your XAML layout" WinUI doc. Eliminates ~310 framework elements from the
             HomePage first-paint burst (one Border per card). AttachedCardShadow attaches to any
             FrameworkElement, so the shadow still works unchanged. -->
        <Grid x:Name="CardRoot"
              CornerRadius="{ThemeResource ControlCornerRadius}"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              Padding="8,8,8,12">
            <!-- Shimmer overlay — instantiated lazily only when a card is in the IsLoading
                 state (passive/placeholder mode). Skipping creation cuts ~3 framework elements
                 × ~310 cards = ~930 elements from the HomePage realization burst. -->
            <StackPanel x:Name="ShimmerOverlay" Spacing="8"
                        x:Load="{x:Bind IsLoading, Mode=OneWay}">
                <controls:Shimmer Height="120" HorizontalAlignment="Stretch" CornerRadius="4"/>
                <controls:Shimmer Height="16" HorizontalAlignment="Left" Width="100"/>
                <controls:Shimmer Height="14" HorizontalAlignment="Left" Width="70"/>
            </StackPanel>

            <StackPanel x:Name="ContentPanel" Spacing="8">
                <!-- Square image mode -->
                <Grid x:Name="SquareImageContainer"
                      CornerRadius="4"
                      HorizontalAlignment="Stretch"
                      Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                      SizeChanged="SquareImageContainer_SizeChanged">
                    <FontIcon x:Name="SquarePlaceholderIcon"
                              Glyph="&#xE8D6;"
                              FontSize="36"
                              Opacity="0.4"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    <Image x:Name="SquareImage"
                           Stretch="UniformToFill"
                           Opacity="0"
                           ImageOpened="SquareImage_ImageOpened"
                           ImageFailed="SquareImage_ImageFailed"/>

                    <!-- Play button overlay (shown on hover) -->
                    <Button x:Name="SquarePlayButton"
                            x:Load="False"
                            Visibility="Collapsed"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,8,8"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Padding="0"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="PlayButton_Click">
                        <playback:PlaybackActionContent x:Name="SquarePlayAction"
                                                       IconSize="16"
                                                       SpinnerSize="18"
                                                       ActionForeground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                    </Button>

                    <!-- "Open in browser" overlay for IsExternal cards (e.g. merch).
                         Mutually exclusive with the play button — see UpdatePlayingState
                         and the IsExternal branches in EnsurePlayOverlayRealized. -->
                    <Button x:Name="SquareExternalButton"
                            x:Load="False"
                            Visibility="Collapsed"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,8,8"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Padding="0"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="ExternalButton_Click"
                            ToolTipService.ToolTip="Open in browser">
                        <FontIcon Glyph="&#xE8A7;" FontSize="14"
                                  Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                    </Button>

                    <!-- Playing indicator (shown when IsPlaying) -->
                    <Border x:Name="SquarePlayingIndicator"
                            x:Load="False"
                            Visibility="Collapsed"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="6,0,0,6"
                            Padding="4,2"
                            CornerRadius="4"
                            Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}">
                        <local:LottieEqualizer x:Name="SquarePlayingEqualizer"
                                               IconSize="20"/>
                    </Border>
                </Grid>

                <!-- Circular image mode — deferred via x:Load="False". Realized on demand
                     by EnsureCircleRealized() in code-behind whenever a circle-mode access
                     is needed (image load, hover, playing-state change, placeholder color/glyph
                     re-apply). Square cards never realize this subtree. -->
                <Grid x:Name="CircleImageContainer"
                      x:Load="False"
                      HorizontalAlignment="Stretch"
                      Visibility="Collapsed">
                    <Ellipse x:Name="CirclePlaceholder"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="Transparent"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <FontIcon x:Name="CirclePlaceholderIcon"
                              Glyph="&#xE77B;"
                              FontSize="36"
                              Opacity="0.4"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    <Ellipse x:Name="CircleImage"
                             Opacity="0.85"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <ImageBrush x:Name="CircleImageBrush"
                                        Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Play button overlay for circle cards -->
                    <Button x:Name="CirclePlayButton"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,4"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Padding="0"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="PlayButton_Click">
                        <playback:PlaybackActionContent x:Name="CirclePlayAction"
                                                       IconSize="16"
                                                       SpinnerSize="18"
                                                       ActionForeground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                    </Button>

                    <!-- Playing indicator for circle cards -->
                    <Border x:Name="CirclePlayingIndicator"
                            Visibility="Collapsed"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="6,0,0,6"
                            Padding="4,2"
                            CornerRadius="4"
                            Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}">
                        <local:LottieEqualizer x:Name="CirclePlayingEqualizer"
                                               IconSize="20"/>
                    </Border>
                </Grid>

                <!-- Title -->
                <TextBlock x:Name="TitleText"
                           MaxLines="1"
                           TextTrimming="CharacterEllipsis"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           FontSize="13"/>

                <!-- Subtitle -->
                <TextBlock x:Name="SubtitleText"
                           MaxLines="2"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="12"/>

                <!-- Optional accent badge (e.g. "Played 3h ago" for library Recents sort). Lives
                     inside the card so the card sizes to include it — no parent-level height
                     magic required. Collapsed by default; consumer sets BadgeText to reveal. -->
                <TextBlock x:Name="BadgeText"
                           Visibility="Collapsed"
                           MaxLines="1"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           FontSize="11"/>
            </StackPanel>
        </Grid>
            <local:PendingBorderBeam x:Name="PendingBeam"
                                     x:Load="False"
                                     Canvas.ZIndex="10"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     CornerRadius="{ThemeResource ControlCornerRadius}"
                                     BeamThickness="2"/>
        </Grid>
    </Button>
</UserControl>
