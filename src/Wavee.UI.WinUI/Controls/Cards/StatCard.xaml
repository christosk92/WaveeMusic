<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Cards.StatCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Profile-facts tile used in the V4A About & Links section.
          Big accent number + small secondary caption, mirror of the prototype's
          .stat-card grid. Keeps the same chrome as info-panel children so it
          drops cleanly into a UniformGridLayout. -->
    <Border x:Name="RootBorder"
            CornerRadius="12"
            Padding="16,14"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
            BorderThickness="1">
        <StackPanel Spacing="2">
            <TextBlock x:Name="NumberText"
                       Style="{StaticResource TitleTextBlockStyle}"
                       FontWeight="Bold"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1" />
            <TextBlock x:Name="LabelText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="2" />
        </StackPanel>
    </Border>
</UserControl>
