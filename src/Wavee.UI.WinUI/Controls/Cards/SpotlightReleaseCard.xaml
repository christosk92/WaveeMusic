<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Cards.SpotlightReleaseCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:imaging="using:Wavee.UI.WinUI.Controls.Imaging"
    mc:Ignorable="d">

    <!-- Hero-rail spotlight card. Three modes (Pinned, LatestRelease,
         PopularRelease) driven by the Mode DP; the code-behind toggles the
         leading affordance (pulse dot / pin glyph / star glyph), Comment vs
         Subtitle visibility, and Save/Share visibility. -->
    <Border x:Name="RootBorder"
            CornerRadius="8"
            MaxWidth="440"
            Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
            BorderBrush="{ThemeResource SurfaceStrokeColorFlyoutBrush}"
            BorderThickness="1"
            BackgroundSizing="InnerBorderEdge">

        <Grid x:Name="CardSurface"
              Padding="16"
              Background="Transparent"
              RowSpacing="12"
              Tapped="CardSurface_Tapped">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header strip: mode-aware leading affordance + tag label.
                 ApplyModeVisuals() makes exactly one of PulseDot / PinGlyph /
                 StarGlyph visible per mode. -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse x:Name="PulseDot"
                         Width="8"
                         Height="8"
                         Fill="{ThemeResource AccentFillColorDefaultBrush}"
                         VerticalAlignment="Center"
                         Visibility="Collapsed"/>
                <FontIcon x:Name="PinGlyph"
                          Glyph="&#xE718;"
                          FontSize="12"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          VerticalAlignment="Center"
                          Visibility="Collapsed"/>
                <FontIcon x:Name="StarGlyph"
                          Glyph="&#xE735;"
                          FontSize="12"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          VerticalAlignment="Center"
                          Visibility="Collapsed"/>
                <TextBlock x:Name="TagTextBlock"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontWeight="SemiBold"
                           CharacterSpacing="80"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Body: cover + text + buttons -->
            <Grid Grid.Row="1" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        x:Name="CoverBorder"
                        Width="96"
                        Height="96"
                        CornerRadius="6"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <imaging:CompositionImage x:Name="CoverImage"
                                              Stretch="UniformToFill"
                                              DecodePixelSize="192"
                                              CornerRadius="6"/>
                </Border>

                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                    <TextBlock x:Name="EyebrowTextBlock"
                               Text="Latest release"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"/>
                    <TextBlock x:Name="TitleTextBlock"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2"/>
                    <TextBlock x:Name="SubtitleTextBlock"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"/>

                    <!-- Quoted-comment block: 3px accent left bar + body text.
                         The bar adopts AccentBrush when the artist palette is
                         supplied, falling back to TextFillColorTertiaryBrush
                         otherwise. Replaces the previous italic-accent body
                         text, which read as web-streaming flourish. -->
                    <Border x:Name="CommentBlock"
                            BorderThickness="3,0,0,0"
                            BorderBrush="{ThemeResource TextFillColorTertiaryBrush}"
                            Padding="10,0,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="CommentTextBlock"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="2"/>
                    </Border>

                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,8,0,0">
                        <Button x:Name="PlayButton"
                                Style="{StaticResource AccentButtonStyle}"
                                Height="30"
                                Padding="11,0"
                                Tapped="InlineAction_Tapped"
                                Click="PlayButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE768;" FontSize="11"/>
                                <TextBlock Text="Play"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="SaveButton"
                                Style="{StaticResource SubtleButtonStyle}"
                                Width="30"
                                Height="30"
                                Padding="0"
                                ToolTipService.ToolTip="Save"
                                Tapped="InlineAction_Tapped"
                                Click="SaveButton_Click">
                            <FontIcon Glyph="&#xEB51;" FontSize="14"/>
                        </Button>
                        <Button x:Name="ShareButton"
                                Style="{StaticResource SubtleButtonStyle}"
                                Width="30"
                                Height="30"
                                Padding="0"
                                ToolTipService.ToolTip="Share"
                                Tapped="InlineAction_Tapped"
                                Click="ShareButton_Click">
                            <FontIcon Glyph="&#xE72D;" FontSize="14"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
