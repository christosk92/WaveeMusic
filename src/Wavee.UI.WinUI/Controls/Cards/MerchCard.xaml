<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Cards.MerchCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Merch tile for the V4A "Tour & Merch" right column. Square image
          with a price chip overlay, title + meta + Buy below. Rounded
          container border explicitly contains the Image — per the WinUI 3
          rounded-clipping rule (composition clips don't reliably clip
          Image children), we set Image into a Border that is itself
          intrinsically rounded. -->
    <Button x:Name="CardButton"
            Padding="0"
            Background="Transparent"
            BorderThickness="0"
            HorizontalContentAlignment="Stretch"
            Width="180"
            Click="CardButton_Click">
        <StackPanel Spacing="8">
            <!-- Image with price chip overlay -->
            <Grid>
                <Border x:Name="ImageBorder"
                        Width="180" Height="180"
                        CornerRadius="12">
                    <Border.Background>
                        <ImageBrush x:Name="MerchImageBrush" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
                <Border x:Name="PriceChip"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        Padding="10,4"
                        CornerRadius="14"
                        Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="PriceText"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               FontSize="13"/>
                </Border>
            </Grid>

            <!-- Title -->
            <TextBlock x:Name="TitleText"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="2"/>

            <!-- Subtitle -->
            <TextBlock x:Name="SubtitleText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="1"/>

            <!-- Buy -->
            <HyperlinkButton x:Name="BuyLink"
                             Content="Buy ›"
                             FontWeight="SemiBold"
                             Padding="0,4"
                             HorizontalAlignment="Left"
                             Click="BuyLink_Click"/>
        </StackPanel>
    </Button>
</UserControl>
