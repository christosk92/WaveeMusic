<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Cards.EditorialHeroCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI.Media"
    xmlns:winUi="using:CommunityToolkit.WinUI"
    xmlns:imaging="using:Wavee.UI.WinUI.Controls.Imaging"
    mc:Ignorable="d"
    Background="Transparent">

    <!-- Editorial hero: full-width anchor tile that lives at the top of the home
         feed. The backdrop is a baked CompositionDrawingSurface (blurred cover +
         radial accent + diagonal accent + procedural noise + vignette), painted
         once per item by EditorialBackdropRenderer and attached to BackdropHost
         as a SpriteVisual child. The cover itself floats on the right with a
         subtle drop shadow, matching the Klankhuis reference design. -->
    <Button x:Name="HeroButton"
            Padding="0"
            Background="Transparent"
            BorderThickness="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Click="HeroButton_Click">
        <Grid x:Name="HeroRoot"
              Height="180"
              CornerRadius="{ThemeResource OverlayCornerRadius}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1">

            <!-- Backdrop host. The actual paint comes from a SpriteVisual hosted
                 here via ElementCompositionPreview.SetElementChildVisual; this
                 Border just clips it to the rounded corners + provides a fallback
                 dark fill while the bake is in flight. -->
            <Border x:Name="BackdropHost"
                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                    Background="#1A1420"/>

            <Grid Padding="20,16,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Right column — pill + title + subtitle, vertically centered. -->
                <StackPanel Grid.Column="1"
                            Spacing="6"
                            VerticalAlignment="Center"
                            MaxWidth="640"
                            Margin="20,0,0,0">
                    <Border x:Name="FeaturedPill"
                            HorizontalAlignment="Left"
                            Padding="10,3,10,4"
                            CornerRadius="6"
                            Background="#33000000"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1">
                        <TextBlock x:Name="PillText"
                                   Text="Continue where you left off"
                                   Foreground="White"
                                   Opacity="0.9"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock x:Name="TitleText"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"
                               LineHeight="26"
                               TextWrapping="Wrap"
                               MaxLines="2"
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock x:Name="SubtitleText"
                               Foreground="White"
                               Opacity="0.75"
                               Style="{StaticResource BodyTextBlockStyle}"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Left column — floating square cover with drop shadow. The
                     ShadowGrid hosts the AttachedCardShadow; the inner Border
                     provides the rounded clip the shadow follows. -->
                <Grid Grid.Column="0"
                      x:Name="CoverShadowHost"
                      Width="140" Height="140"
                      VerticalAlignment="Center">
                    <winUi:Effects.Shadow>
                        <ui:AttachedCardShadow BlurRadius="32"
                                               Opacity="0.45"
                                               Offset="0,8"
                                               CornerRadius="12"/>
                    </winUi:Effects.Shadow>
                    <Border x:Name="CoverContainer"
                            CornerRadius="12"
                            Background="#22000000">
                        <imaging:CompositionImage x:Name="HeroImage"
                                                  Stretch="UniformToFill"
                                                  DecodePixelSize="256"
                                                  CornerRadius="12"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Button>
</UserControl>
