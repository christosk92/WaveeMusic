<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Cards.PopularReleaseRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Single row in the V4A "Popular Releases" list (right side of the
          paired Top-Tracks band). Cover + meta + rank badge. Row 0 carries a
          "Popular now" accent chip. Hover spotlight is attached by the page. -->
    <Border x:Name="RootBorder"
            HorizontalAlignment="Stretch"
            CornerRadius="8"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0">
        <Button x:Name="CardButton"
                Padding="10,10"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="8"
                Click="CardButton_Click">
            <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Cover -->
            <Border Grid.Column="0"
                    Width="64" Height="64"
                    CornerRadius="6"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <Image x:Name="CoverImage" Stretch="UniformToFill"/>
            </Border>

            <!-- Meta -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                <Border x:Name="PopularNowChip"
                        Visibility="Collapsed"
                        CornerRadius="5"
                        Padding="7,1"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource AccentFillColorTertiaryBrush}">
                    <TextBlock Text="POPULAR NOW"
                               FontSize="9"
                               FontWeight="Bold"
                               CharacterSpacing="120"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </Border>
                <TextBlock x:Name="TitleText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"/>
                <TextBlock x:Name="MetaText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"/>
            </StackPanel>

            <TextBlock x:Name="RankText"
                       Grid.Column="2"
                       FontWeight="Bold"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
            </Grid>
        </Button>
    </Border>
</UserControl>
