<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Cards.BaselineHomeCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:ui="using:CommunityToolkit.WinUI.Media"
    xmlns:winUi="using:CommunityToolkit.WinUI"
    mc:Ignorable="d"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Top"
    Loaded="Card_Loaded"
    Unloaded="Card_Unloaded">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <!-- Subtle light overlay so the preview visualizer reads on a
                         light card without darkening the album art beneath. -->
                    <LinearGradientBrush x:Key="HomeBaselineCardPreviewOverlayBrush"
                                         StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00F4F4F4" Offset="0"/>
                        <GradientStop Color="#22F4F4F4" Offset="0.34"/>
                        <GradientStop Color="#5AF4F4F4" Offset="1"/>
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <LinearGradientBrush x:Key="HomeBaselineCardPreviewOverlayBrush"
                                         StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00101010" Offset="0"/>
                        <GradientStop Color="#22101010" Offset="0.34"/>
                        <GradientStop Color="#5A101010" Offset="1"/>
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Viewbox
        Stretch="Uniform"
        StretchDirection="Both"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">
        <Grid
            x:Name="CardRoot"
            Width="230"
            Height="340"
            CornerRadius="14"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            PointerEntered="Card_PointerEntered"
            PointerExited="Card_PointerExited"
            PointerCanceled="Card_PointerCanceled"
            PointerMoved="Card_PointerMoved"
            PointerPressed="CardRoot_PointerPressed"
            RightTapped="CardRoot_RightTapped"
            Tapped="CardRoot_Tapped">
            <winUi:Effects.Shadow>
                <ui:AttachedCardShadow
                    BlurRadius="26"
                    CornerRadius="14"
                    Offset="0,8"
                    Opacity="0.22"/>
            </winUi:Effects.Shadow>

        <Grid.RowDefinitions>
            <RowDefinition Height="84*"/>
            <RowDefinition Height="36*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="ImageStage" Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid x:Name="HeroMotionHost">
                <Image
                    x:Name="HeroImage"
                    Stretch="UniformToFill"
                    Opacity="0.94"/>

                <Grid
                    x:Name="CanvasPreviewHost"
                    x:Load="False"
                    IsHitTestVisible="False"
                    Opacity="0"
                    Visibility="Collapsed"/>

                <Border x:Name="ColorWash" Opacity="0.24"/>
            </Grid>

            <Border>
                <Border.Background>
                    <RadialGradientBrush Center="0.16,0.08" GradientOrigin="0.16,0.08" RadiusX="1.18" RadiusY="0.96">
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroHighlightStartColor}" Offset="0"/>
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroHighlightMidColor}" Offset="0.46"/>
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroHighlightEndColor}" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroShadowTopColor}" Offset="0"/>
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroShadowMidColor}" Offset="0.42"/>
                        <GradientStop Color="{ThemeResource HomeBaselineCardHeroShadowBottomColor}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid
                x:Name="PreviewOverlayRoot"
                x:Load="False"
                Margin="0"
                HorizontalAlignment="Stretch"
                Height="78"
                VerticalAlignment="Bottom"
                Opacity="1"
                Visibility="Collapsed"
                IsHitTestVisible="False">
                <Border VerticalAlignment="Stretch"
                        Background="{ThemeResource HomeBaselineCardPreviewOverlayBrush}"/>
                <cards:PreviewAudioVisualizer
                    x:Name="PreviewVisualizer"
                    Visibility="Collapsed"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    BarColor="{ThemeResource HomeBaselineCardPreviewVisualizerForegroundColor}"
                    TrackColor="{ThemeResource HomeBaselineCardPreviewVisualizerTrackColor}"/>
            </Grid>

            <Border
                x:Name="HeroToBottomBlendOverlay"
                Height="92"
                VerticalAlignment="Bottom"
                IsHitTestVisible="False"/>

            <Grid
                Margin="16"
                RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border
                    x:Name="CoverThumbBorder"
                    Grid.Row="0"
                    Width="58"
                    Height="58"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    CornerRadius="10"
                    Background="{ThemeResource HomeBaselineCardOverlayThumbBackgroundBrush}"
                    BorderBrush="{ThemeResource HomeBaselineCardOverlayThumbBorderBrush}"
                    BorderThickness="1">
                    <winUi:Effects.Shadow>
                        <ui:AttachedCardShadow
                            BlurRadius="18"
                            CornerRadius="10"
                            Offset="0,6"
                            Opacity="0.18"/>
                    </winUi:Effects.Shadow>
                    <Grid>
                        <Image
                            x:Name="CoverThumbImage"
                            Stretch="UniformToFill"/>
                        <FontIcon
                            x:Name="CoverThumbPlaceholder"
                            Glyph="&#xE8D6;"
                            FontSize="20"
                            Foreground="{ThemeResource HomeBaselineCardOverlaySecondaryTextBrush}"
                            Opacity="0.45"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <StackPanel
                    x:Name="TitleOverlay"
                    Grid.Row="1"
                    VerticalAlignment="Bottom"
                    Spacing="4">
                    <TextBlock
                        x:Name="TitleText"
                        TextWrapping="Wrap"
                        FontSize="26"
                        FontWeight="Black"
                        Foreground="{ThemeResource HomeBaselineCardOverlayPrimaryTextBrush}"
                        MaxLines="2"
                        TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Uid="Controls_Cards_BaselineHomeCard__TextBlock_1"
                        x:Name="TypeText"
                        Text="Playlist"
                        FontSize="11"
                        FontWeight="SemiBold"
                        CharacterSpacing="120"
                        Foreground="{ThemeResource HomeBaselineCardOverlaySecondaryTextBrush}"
                        MaxLines="1"
                        TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Border
                        x:Name="PlayingIndicator"
                        x:Load="False"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Padding="6,3"
                        CornerRadius="6"
                        Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
                        Visibility="Collapsed">
                        <cards:LottieEqualizer
                            x:Name="PlayingEqualizer"
                            IconSize="22"/>
                    </Border>

                    <Button
                        x:Name="ContextPlayButton"
                        x:Load="False"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Width="42"
                        Height="42"
                        CornerRadius="21"
                        Padding="0"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="ContextPlayButton_Click"
                        Visibility="Collapsed">
                        <playback:PlaybackActionContent x:Name="ContextPlayButtonContent"
                                                       IconSize="18"
                                                       SpinnerSize="20"
                                                       ActionForeground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                    </Button>
                </Grid>
            </Grid>

            <Grid
                x:Name="HoverChrome"
                x:Load="False"
                Margin="14"
                Opacity="0"
                Visibility="Collapsed"
                VerticalAlignment="Top">
                <ProgressBar
                    x:Name="PreviewPendingProgressBar"
                    Height="2"
                    Margin="-18,-14,-18,10"
                    Minimum="0"
                    Maximum="100"
                    Value="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Foreground="{ThemeResource HomeBaselineCardOverlayPrimaryTextBrush}"
                    Background="{ThemeResource HomeBaselineCardOverlayChromeBorderBrush}"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"/>
                <Button
                    x:Name="TrackPlayButton"
                    HorizontalAlignment="Right"
                    Width="36"
                    Height="36"
                    Padding="0"
                    CornerRadius="10"
                    Background="{ThemeResource HomeBaselineCardOverlayChromeBackgroundBrush}"
                    BorderBrush="{ThemeResource HomeBaselineCardOverlayChromeBorderBrush}"
                    BorderThickness="1"
                    Click="TrackPlayButton_Click"
                    Visibility="Collapsed">
                    <playback:PlaybackActionContent x:Name="TrackPlayButtonContent"
                                                   IconSize="15"
                                                   SpinnerSize="16"
                                                   ActionForeground="{ThemeResource HomeBaselineCardOverlayPrimaryTextBrush}"/>
                </Button>
            </Grid>

            <Button
                x:Name="PreviousPreviewTrackButton"
                x:Load="False"
                Width="34"
                Height="34"
                Margin="10,0,0,18"
                Padding="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{ThemeResource HomeBaselineCardOverlayChromeBackgroundBrush}"
                BorderBrush="{ThemeResource HomeBaselineCardOverlayChromeBorderBrush}"
                BorderThickness="1"
                CornerRadius="17"
                Click="PreviousPreviewTrackButton_Click"
                Visibility="Collapsed">
                <FontIcon
                    Glyph="&#xE76B;"
                    FontSize="13"
                    Foreground="{ThemeResource HomeBaselineCardOverlayPrimaryTextBrush}"/>
            </Button>

            <Button
                x:Name="NextPreviewTrackButton"
                x:Load="False"
                Width="34"
                Height="34"
                Margin="0,0,10,18"
                Padding="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Background="{ThemeResource HomeBaselineCardOverlayChromeBackgroundBrush}"
                BorderBrush="{ThemeResource HomeBaselineCardOverlayChromeBorderBrush}"
                BorderThickness="1"
                CornerRadius="17"
                Click="NextPreviewTrackButton_Click"
                Visibility="Collapsed">
                <FontIcon
                    Glyph="&#xE76C;"
                    FontSize="13"
                    Foreground="{ThemeResource HomeBaselineCardOverlayPrimaryTextBrush}"/>
            </Button>

        </Grid>

        <Border
            x:Name="BottomPanel"
            Grid.Row="1"
            Padding="12,0,12,0"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid x:Name="BottomContentMotionHost">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <TextBlock x:Uid="Controls_Cards_BaselineHomeCard__TextBlock_2"
                        x:Name="PreviewEyebrowText"
                        Grid.Row="1"
                        Text="FEATURING"
                        FontSize="11"
                        FontWeight="SemiBold"
                        CharacterSpacing="180"
                        Foreground="{ThemeResource HomeBaselineCardOverlayTertiaryTextBrush}"
                        MaxLines="1"
                        TextTrimming="CharacterEllipsis"
                        Visibility="Collapsed"/>

                    <TextBlock
                        x:Name="PreviewTrackText"
                        Grid.Row="2"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{ThemeResource HomeBaselineCardOverlayPrimaryTextBrush}"
                        MaxLines="2"
                        TextWrapping="Wrap"
                        TextTrimming="CharacterEllipsis"
                        Visibility="Collapsed"/>

                    <TextBlock
                        x:Name="SubtitleText"
                        Grid.Row="3"
                        Margin="0,6,0,0"
                        FontSize="13"
                        Foreground="{ThemeResource HomeBaselineCardOverlaySecondaryTextBrush}"
                        MaxLines="2"
                        TextWrapping="Wrap"
                        TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Grid>
        </Border>

            <cards:PendingBorderBeam
                x:Name="PendingBeam"
                x:Load="False"
                Grid.RowSpan="2"
                Canvas.ZIndex="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                CornerRadius="14"
                BeamThickness="2"/>

            <Grid
                x:Name="ShimmerOverlay"
                x:Load="False"
                Grid.RowSpan="2"
                Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="72*"/>
                    <RowDefinition Height="28*"/>
                </Grid.RowDefinitions>
                <controls:Shimmer
                    Grid.Row="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    CornerRadius="6"/>
                <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Spacing="10">
                    <controls:Shimmer Height="18" Width="220" HorizontalAlignment="Left" CornerRadius="4"/>
                    <controls:Shimmer Height="14" Width="300" HorizontalAlignment="Left" CornerRadius="4"/>
                    <controls:Shimmer Height="14" Width="240" HorizontalAlignment="Left" CornerRadius="4"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Viewbox>
</UserControl>
