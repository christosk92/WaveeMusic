<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.TrackDataGrid.TrackDataGridColumnHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Wavee.UI.WinUI.Controls.TrackDataGrid">

    <UserControl.Resources>
        <!--  Button template: transparent background with subtle hover/pressed states, no border.  -->
        <Style x:Key="TrackDataGridColumnHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <!--
                Default 0 padding — each header cell picks up its start-padding from
                TrackDataGridColumn.LeftPadding (applied by RebuildHeader) so header
                labels line up with row-cell text.
            -->
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                AutomationProperties.AccessibilityView="Raw"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="ContentPresenter.Opacity" Value="0.5" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Button
            x:Name="HeaderButton"
            Command="{x:Bind Command, Mode=OneWay}"
            CommandParameter="{x:Bind CommandParameter, Mode=OneWay}"
            IsEnabled="{x:Bind CanBeSorted, Mode=OneWay}"
            Padding="{x:Bind LabelPadding, Mode=OneWay}"
            Style="{StaticResource TrackDataGridColumnHeaderButtonStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LabelColumn" Width="*" />
                    <ColumnDefinition x:Name="ArrowColumn" Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="HeaderText"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="{x:Bind HorizontalContentAlignment, Mode=OneWay}"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind Header, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />

                <FontIcon
                    x:Name="SortArrow"
                    Grid.Column="1"
                    Margin="6,0,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Glyph="&#xEDDB;"
                    RenderTransformOrigin="0.5,0.5"
                    Visibility="Collapsed">
                    <FontIcon.RenderTransform>
                        <RotateTransform x:Name="SortArrowRotate" Angle="0" />
                    </FontIcon.RenderTransform>
                </FontIcon>
            </Grid>
        </Button>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="SortStates">
                <VisualState x:Name="Unsorted">
                    <VisualState.Setters>
                        <Setter Target="SortArrow.Visibility" Value="Collapsed" />
                        <Setter Target="HeaderText.(Grid.ColumnSpan)" Value="2" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="SortAscending">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SortArrow" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="Visible" />
                        </ObjectAnimationUsingKeyFrames>
                        <DoubleAnimation
                            Duration="0:0:0.2"
                            Storyboard.TargetName="SortArrowRotate"
                            Storyboard.TargetProperty="Angle"
                            To="0" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="SortDescending">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SortArrow" Storyboard.TargetProperty="Visibility">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="Visible" />
                        </ObjectAnimationUsingKeyFrames>
                        <DoubleAnimation
                            Duration="0:0:0.2"
                            Storyboard.TargetName="SortArrowRotate"
                            Storyboard.TargetProperty="Angle"
                            To="-180" />
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>
