<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Diagnostics.IpcLineChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Stats bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,4">
            <TextBlock x:Name="LatestText" FontFamily="Consolas" FontSize="20" FontWeight="SemiBold"
                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Bottom" Margin="0,0,0,2">
                <TextBlock x:Name="MinText" FontFamily="Consolas" FontSize="11"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                <TextBlock x:Name="AvgText" FontFamily="Consolas" FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="MaxText" FontFamily="Consolas" FontSize="11"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- Chart area -->
        <Border Grid.Row="1" CornerRadius="6"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                MinHeight="120">
            <Canvas x:Name="ChartCanvas"/>
        </Border>
    </Grid>
</UserControl>
