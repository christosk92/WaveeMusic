<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Playback.VideoTransportBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Dark">

    <!--
        YouTube-style transport bar for video surfaces.
        Single horizontal row of compact icon buttons with a progress bar above.
        Reused by VideoPlayerPage and the popout's ExpandedNowPlayingLayout video overlay
        so the cinematic + floating surfaces share one set of controls and one code path.

        Resolves PlayerBarViewModel + INowPlayingPresentationService from Ioc; the host
        page only needs to set the `Surface` DP to pick "Main" (the cinematic page hosted
        in this app's window) or "Popout" (the floating PlayerFloatingWindow) so the
        Mini-player / Pop-out flyout entries route correctly.
    -->
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Progress / seek bar — sits flush above the transport row. -->
        <playback:CompositionProgressBar x:Name="ProgressBar"
                                         Grid.Row="0"
                                         Height="20"
                                         Margin="6,0,6,2"
                                         SeekStarted="ProgressBar_SeekStarted"
                                         SeekCommitted="ProgressBar_SeekCommitted" />

        <!-- Transport row. Two clusters separated by a flexible spacer. -->
        <Grid Grid.Row="1"
              Padding="6,2,6,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left cluster: play / prev / skip-back / skip-forward / next / volume / time -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="2"
                        VerticalAlignment="Center">

                <Button x:Name="PlayPauseButton"
                        Width="36" Height="36"
                        Padding="0"
                        CornerRadius="18"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Play / pause (Space)"
                        Click="PlayPauseButton_Click">
                    <playback:PlaybackActionContent x:Name="PlayPauseGlyph"
                                                    IconSize="18"
                                                    SpinnerSize="20"
                                                    IdleGlyph="&#xE768;"
                                                    ActiveGlyph="&#xE769;"
                                                    ActionForeground="White" />
                </Button>

                <Button x:Name="PrevButton"
                        Width="36" Height="36"
                        Padding="0"
                        CornerRadius="18"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Previous"
                        Click="PrevButton_Click">
                    <FontIcon Glyph="&#xE892;" FontSize="14" />
                </Button>

                <Button x:Name="SkipBack10Button"
                        Width="36" Height="36"
                        Padding="0"
                        CornerRadius="18"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Back 10 seconds (Shift+←)"
                        Click="SkipBack10Button_Click">
                    <FontIcon Glyph="&#xED3C;" FontSize="16" />
                </Button>

                <Button x:Name="SkipForward30Button"
                        Width="36" Height="36"
                        Padding="0"
                        CornerRadius="18"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Forward 30 seconds (Shift+→)"
                        Click="SkipForward30Button_Click">
                    <FontIcon Glyph="&#xED3D;" FontSize="16" />
                </Button>

                <Button x:Name="NextButton"
                        Width="36" Height="36"
                        Padding="0"
                        CornerRadius="18"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Next"
                        Click="NextButton_Click">
                    <FontIcon Glyph="&#xE893;" FontSize="14" />
                </Button>

                <!-- Volume icon + slider in a flyout — mirrors YouTube's
                     hover-expand pattern but uses a click-flyout for predictability. -->
                <Button x:Name="VolumeButton"
                        Width="36" Height="36"
                        Padding="0"
                        CornerRadius="18"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Volume"
                        Click="VolumeButton_Click">
                    <FontIcon x:Name="VolumeGlyph" Glyph="&#xE767;" FontSize="14" />
                    <Button.Flyout>
                        <Flyout Placement="Top">
                            <Slider x:Name="VolumeSlider"
                                    Width="160"
                                    Minimum="0"
                                    Maximum="100"
                                    StepFrequency="1"
                                    ValueChanged="VolumeSlider_ValueChanged" />
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <TextBlock x:Name="TimeText"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontSize="12"
                           Foreground="#E0FFFFFF" />
            </StackPanel>

            <!-- Right cluster: tracks gear | expand DropDownButton -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="2"
                        VerticalAlignment="Center">

                <!-- Tracks (audio / video / subtitle) — same MediaTracksMenuBuilder
                     the popout and cinematic page already share. -->
                <Button x:Name="TracksButton"
                        Width="36" Height="36"
                        Padding="0"
                        CornerRadius="18"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Audio · Video · Subtitles">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                    <Button.Flyout>
                        <MenuFlyout x:Name="TracksFlyout"
                                    Placement="TopEdgeAlignedRight"
                                    Opening="TracksFlyout_Opening" />
                    </Button.Flyout>
                </Button>

                <!-- Expand player — Theatre / Fullscreen / Mini player.
                     Glyph swaps on the active mode so the user can see at a glance
                     whether they can enter or exit. -->
                <DropDownButton x:Name="ExpandPlayerDropDown"
                                Width="36"
                                Height="36"
                                Padding="0"
                                CornerRadius="18"
                                Background="Transparent"
                                BorderThickness="0"
                                ToolTipService.ToolTip="Expand player">
                    <FontIcon x:Name="ExpandPlayerGlyph"
                              Glyph="&#xE740;" FontSize="14" />
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="TopEdgeAlignedRight">
                            <ToggleMenuFlyoutItem x:Name="TheatreMenuItem"
                                                  Text="Theatre mode"
                                                  Click="TheatreMenuItem_Click">
                                <ToggleMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE73F;" FontSize="14" />
                                </ToggleMenuFlyoutItem.Icon>
                            </ToggleMenuFlyoutItem>
                            <ToggleMenuFlyoutItem x:Name="FullscreenMenuItem"
                                                  Text="Fullscreen"
                                                  Click="FullscreenMenuItem_Click"
                                                  KeyboardAcceleratorTextOverride="F11">
                                <ToggleMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE740;" FontSize="14" />
                                </ToggleMenuFlyoutItem.Icon>
                            </ToggleMenuFlyoutItem>
                            <MenuFlyoutSeparator x:Name="TheatreMiniSeparator" />
                            <MenuFlyoutItem x:Name="MiniPlayerMenuItem"
                                            Text="Mini player"
                                            Click="MiniPlayerMenuItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEE49;" FontSize="14" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
