<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.RecentlyPlayedSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:layouts="using:Wavee.UI.WinUI.Controls.Layouts"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="DefaultCardTemplate" x:DataType="vm:HomeSectionItem">
            <cards:ContentCard
                ImageUrl="{x:Bind ImageUrl}"
                Title="{x:Bind Title}"
                Subtitle="{x:Bind Subtitle}"
                PlaceholderColorHex="{x:Bind ColorHex}"
                PlaceholderGlyph="{x:Bind PlaceholderGlyph}"
                IsCircularImage="False"
                NavigationUri="{x:Bind Uri}"
                NavigationTitle="{x:Bind Title}"/>
        </DataTemplate>

        <DataTemplate x:Key="ArtistCardTemplate" x:DataType="vm:HomeSectionItem">
            <cards:ContentCard
                ImageUrl="{x:Bind ImageUrl}"
                Title="{x:Bind Title}"
                Subtitle="{x:Bind Subtitle}"
                PlaceholderColorHex="{x:Bind ColorHex}"
                PlaceholderGlyph="&#xE77B;"
                IsCircularImage="True"
                CenterText="True"
                NavigationUri="{x:Bind Uri}"
                NavigationTitle="{x:Bind Title}"/>
        </DataTemplate>

        <!-- Liked Songs (Recents-saved variant): foreground heart tile with up
             to 3 cover thumbnails fanned out behind it, "{N} songs added"
             subtitle + green-check glyph. Mirrors Spotify desktop's Recents
             render for spotify:collection:tracks when recent_type_saved is set. -->
        <DataTemplate x:Key="LikedSongsRecentTemplate" x:DataType="vm:HomeSectionItem">
            <cards:LikedSongsRecentCard
                Title="{x:Bind Title, Mode=OneWay}"
                AddedCount="{x:Bind RecentlyAddedCount, Mode=OneWay}"
                AddedItemNoun="{x:Bind RecentlyAddedItemNoun, Mode=OneWay}"
                Thumbnail1ImageUrl="{x:Bind RecentlyAddedThumbnail1Url, Mode=OneWay}"
                Thumbnail2ImageUrl="{x:Bind RecentlyAddedThumbnail2Url, Mode=OneWay}"
                Thumbnail3ImageUrl="{x:Bind RecentlyAddedThumbnail3Url, Mode=OneWay}"
                NavigationUri="{x:Bind Uri}"/>
        </DataTemplate>

        <!-- Episode card mirror: Episodes aren't in Recents in the response we
             have today, but if Spotify ever surfaces them here they need the
             same template the Home shelf uses. -->
        <DataTemplate x:Key="EpisodeCardTemplate" x:DataType="vm:HomeSectionItem">
            <cards:EpisodeCard/>
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel x:Name="RootPanel" Visibility="Collapsed">
        <TextBlock x:Uid="Controls_RecentlyPlayedSection__TextBlock_1"
            Text="Recently Played"
            Style="{StaticResource SubtitleTextBlockStyle}"
            FontWeight="Bold"
            Margin="0,0,0,16"/>

        <ItemsRepeater x:Name="ItemsHost">
            <ItemsRepeater.Layout>
                <layouts:SingleRowLayout MinItemWidth="160" MaxItemWidth="200" Spacing="12"/>
            </ItemsRepeater.Layout>
        </ItemsRepeater>
    </StackPanel>
</UserControl>
