<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Settings.GeneralSettingsSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:settings="using:Wavee.UI.WinUI.Controls.Settings"
    mc:Ignorable="d">

    <ScrollView>
        <StackPanel x:Name="SettingsGroupsRoot" Spacing="6" Padding="0,12,0,24">
            <settings:SettingsGroupHeader Title="Appearance"
                                          Description="Choose how Wavee follows your Windows theme."
                                          IconGlyph="&#xE790;"
                                          Tag="appearance"/>
            <controls:SettingsCard x:Uid="Controls_Settings_GeneralSettingsSection__SettingsCard_2" Header="Theme"
                                   Description="Choose light, dark, or match your system"
                                   Tag="appearance">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE790;"/>
                </controls:SettingsCard.HeaderIcon>
                <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
                          MinWidth="140">
                    <ComboBoxItem x:Uid="Controls_Settings_GeneralSettingsSection__ComboBoxItem_3" Content="Light"/>
                    <ComboBoxItem x:Uid="Controls_Settings_GeneralSettingsSection__ComboBoxItem_4" Content="Dark"/>
                    <ComboBoxItem x:Uid="Controls_Settings_GeneralSettingsSection__ComboBoxItem_5" Content="System"/>
                </ComboBox>
            </controls:SettingsCard>

            <settings:SettingsGroupHeader Title="Language &amp; metadata"
                                          Description="Control the app language and the language used for Spotify catalog text."
                                          IconGlyph="&#xE774;"
                                          Tag="language"/>

            <controls:SettingsCard x:Uid="Settings_General_LanguageCard"
                                   Tag="language">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE774;"/>
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Spacing="8">
                    <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedLanguageIndex, Mode=TwoWay}"
                              MinWidth="180">
                        <ComboBoxItem x:Uid="Settings_General_LanguageSystemItem"/>
                        <ComboBoxItem x:Uid="Settings_General_LanguageEnglishItem"/>
                        <ComboBoxItem x:Uid="Settings_General_LanguageKoreanItem"/>
                    </ComboBox>
                </StackPanel>
            </controls:SettingsCard>

            <controls:SettingsCard x:Uid="Settings_General_SpotifyLanguageCard"
                                   Tag="language">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE189;"/>
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Spacing="8">
                    <CheckBox x:Uid="Settings_General_SpotifyLanguageSameAsAppCheckBox"
                              IsChecked="{x:Bind ViewModel.IsSpotifyMetadataSameAsApp, Mode=TwoWay}"/>
                    <StackPanel Spacing="8"
                                Visibility="{x:Bind ViewModel.IsSpotifyMetadataCustomCodeVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBox x:Uid="Settings_General_SpotifyLanguageCodeTextBox"
                                 Text="{x:Bind ViewModel.SpotifyMetadataCustomLanguageCode, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 MaxLength="2"
                                 MinWidth="120"/>
                        <TextBlock x:Uid="Settings_General_SpotifyLanguageHintText"
                                   Style="{StaticResource BodyTextBlockStyle}"/>
                    </StackPanel>
                </StackPanel>
            </controls:SettingsCard>

            <settings:SettingsGroupHeader Title="Display scale"
                                          Description="Tune density and zoom for track lists, library shelves, and settings controls."
                                          IconGlyph="&#xE8A3;"
                                          Tag="display"/>

            <Grid ColumnSpacing="12" Margin="0,0,0,12" Tag="display">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="8" Padding="16,12" Height="88"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <StackPanel Spacing="2">
                            <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1" Height="2" HorizontalAlignment="Left" Width="56"/>
                            <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1" Height="2" HorizontalAlignment="Left" Width="44"/>
                            <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1" Height="2" HorizontalAlignment="Left" Width="52"/>
                            <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1" Height="2" HorizontalAlignment="Left" Width="36"/>
                        </StackPanel>
                        <TextBlock x:Uid="Controls_Settings_GeneralSettingsSection__TextBlock_7" Text="Compact" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="8" Padding="16,12" Height="88"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <StackPanel Spacing="4">
                            <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1.5" Height="3" HorizontalAlignment="Left" Width="56"/>
                            <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1.5" Height="3" HorizontalAlignment="Left" Width="44"/>
                            <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="1.5" Height="3" HorizontalAlignment="Left" Width="52"/>
                        </StackPanel>
                        <TextBlock x:Uid="Controls_Settings_GeneralSettingsSection__TextBlock_8" Text="Default" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="8" Padding="16,12" Height="88"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <StackPanel Spacing="6">
                            <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="2" Height="4" HorizontalAlignment="Left" Width="56"/>
                            <Border Background="{ThemeResource TextFillColorDisabledBrush}" CornerRadius="2" Height="4" HorizontalAlignment="Left" Width="44"/>
                        </StackPanel>
                        <TextBlock x:Uid="Controls_Settings_GeneralSettingsSection__TextBlock_9" Text="Spacious" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <controls:SettingsCard x:Uid="Controls_Settings_GeneralSettingsSection__SettingsCard_10" Header="Zoom level"
                                   Description="{x:Bind ViewModel.ZoomPreviewLabel, Mode=OneWay}"
                                   Tag="display">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8A3;"/>
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.ZoomLevelDisplay, Mode=OneWay}"
                               FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="36"/>
                    <Button x:Uid="Controls_Settings_GeneralSettingsSection__Button_11" Content="Reset" Command="{x:Bind ViewModel.ResetZoomCommand}"/>
                </StackPanel>
            </controls:SettingsCard>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,4,16,8"
                    Tag="display">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="A" FontSize="11" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <Slider Grid.Column="1"
                            Value="{x:Bind ViewModel.ZoomLevelIndex, Mode=TwoWay}"
                            Minimum="0" Maximum="6" StepFrequency="1" SnapsTo="StepValues"
                            Margin="12,0"/>
                    <TextBlock Grid.Column="2" Text="A" FontSize="18" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollView>
</UserControl>
