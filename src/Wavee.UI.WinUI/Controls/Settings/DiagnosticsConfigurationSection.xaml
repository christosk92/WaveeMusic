<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Settings.DiagnosticsConfigurationSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:diag="using:Wavee.UI.WinUI.Controls.Diagnostics"
    xmlns:settings="using:Wavee.UI.WinUI.Controls.Settings"
    mc:Ignorable="d">

    <ScrollView VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Hidden">
        <StackPanel x:Name="ConfigurationGroupsRoot" Spacing="0" Padding="0,4,0,24">
            <controls:SettingsCard Margin="0,0,0,12"
                                   Header="Memory diagnostics panel"
                                   Tag="health"
                                   Description="Reveal the live memory + cache breakdown panel below. Off by default - sampling is only active while this is on.">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE950;"/>
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch IsOn="{x:Bind ViewModel.MemoryDiagnosticsEnabled, Mode=TwoWay}"/>
            </controls:SettingsCard>

            <settings:MemoryDiagnosticsCard
                Visibility="{x:Bind ViewModel.MemoryDiagnosticsEnabled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                Tag="health"/>

            <controls:SettingsExpander x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsExpander_1" Margin="0,0,0,12"
                                       Header="Audio Pipeline"
                                       Tag="health"
                                       Description="{x:Bind ViewModel.AudioPipelineMode, Mode=OneWay}">
                <controls:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE767;"/>
                </controls:SettingsExpander.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ViewModel.AudioPipelineStatus, Mode=OneWay}"/>
                </StackPanel>
                <controls:SettingsExpander.Items>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_2" Header="Process ID"
                                           Description="PID of the audio engine process (0 = in-process)">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE943;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioPipelinePid, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_3" Header="Restart Count"
                                           Description="Number of auto-restarts this session">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE72C;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioRestartCount, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_4" Header="Audio Underruns"
                                           Description="PortAudio buffer underflows (causes audible glitches)">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7BA;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioUnderrunCount, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_5" Header="GC Collections"
                                           Description="Garbage collection counts (Gen2 causes audio freezes)">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE74D;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioGcStats, Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_6" Header="Slowest UI Operations"
                                           Description="Profiled operations that block the UI thread">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE916;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioProfilerTop, Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="11"
                                   MaxWidth="300" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_7" Header="IPC Throughput"
                                           Description="Messages sent/received over the Named Pipe">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8AB;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioThroughput, Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_8" Header="State Freshness"
                                           Description="Time since last state update from audio process">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE2AD;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Text="{x:Bind ViewModel.AudioStateFreshness, Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

            <Border Margin="0,0,0,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12"
                    Tag="health">
                <diag:IpcLineChart x:Name="RttChart" Height="180"/>
            </Border>

            <controls:SettingsCard Margin="0,0,0,12"
                                   Header="Navigation Health Report"
                                   Tag="health"
                                   Description="Copies a snapshot of recent navigation timings, GC counts, working-set deltas, page faults, and the last MemoryReleaseHelper event. Paste into a bug report after reproducing the stall-then-BOOM hang.">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7C3;"/>
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.NavigationReportStatus, Mode=OneWay}"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <Button Content="Copy report"
                            Command="{x:Bind ViewModel.CopyNavigationHealthReportCommand}"/>
                </StackPanel>
            </controls:SettingsCard>

            <controls:SettingsExpander x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsExpander_9" Margin="0,0,0,12"
                                       Header="Clock Synchronization"
                                       Tag="clock"
                                       Description="NTP-style sync with Spotify's server clock">
                <controls:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE121;"/>
                </controls:SettingsExpander.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="{x:Bind ViewModel.ClockOffsetMs, Mode=OneWay}"/>
                        <Run x:Uid="Controls_Settings_DiagnosticsSettingsSection__Run_10" Text="ms offset"/>
                    </TextBlock>
                    <FontIcon Glyph="&#xE73E;" FontSize="12"
                              Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                              Visibility="{x:Bind ViewModel.ClockIsSynced, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
                <controls:SettingsExpander.Items>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_11" Header="Network round-trip"
                                           Description="Latency of the best sync sample">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE968;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.ClockLastRttMs, Mode=OneWay}"/>
                            <Run x:Uid="Controls_Settings_DiagnosticsSettingsSection__Run_12" Text="ms"/>
                        </TextBlock>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_13" Header="Sync interval"
                                           Description="How often to re-synchronize">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE916;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox SelectedIndex="{x:Bind ViewModel.ClockSyncIntervalIndex, Mode=TwoWay}"
                                  MinWidth="140">
                            <ComboBoxItem x:Uid="Controls_Settings_DiagnosticsSettingsSection__ComboBoxItem_14" Content="5 minutes"/>
                            <ComboBoxItem x:Uid="Controls_Settings_DiagnosticsSettingsSection__ComboBoxItem_15" Content="10 minutes"/>
                            <ComboBoxItem x:Uid="Controls_Settings_DiagnosticsSettingsSection__ComboBoxItem_16" Content="15 minutes"/>
                            <ComboBoxItem x:Uid="Controls_Settings_DiagnosticsSettingsSection__ComboBoxItem_17" Content="30 minutes"/>
                        </ComboBox>
                    </controls:SettingsCard>
                    <controls:SettingsCard x:Uid="Controls_Settings_DiagnosticsSettingsSection__SettingsCard_18" Header="Last sync"
                                           Description="{x:Bind ViewModel.ClockLastSyncDisplay, Mode=OneWay}">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE895;"/>
                        </controls:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel VerticalAlignment="Center" Spacing="0">
                                <TextBlock x:Uid="Controls_Settings_DiagnosticsSettingsSection__TextBlock_19" Text="Next sync in"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.ClockNextSyncCountdown, Mode=OneWay}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button x:Uid="Controls_Settings_DiagnosticsSettingsSection__Button_20" Content="Sync now" Command="{x:Bind ViewModel.RefreshClockCommand}"/>
                        </StackPanel>
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>
        </StackPanel>
    </ScrollView>
</UserControl>
