<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Settings.PlaybackSettingsSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:settings="using:Wavee.UI.WinUI.Controls.Settings"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    mc:Ignorable="d">

    <ScrollView>
        <StackPanel x:Name="SettingsGroupsRoot" Spacing="6" Padding="0,12,0,24">
            <settings:SettingsGroupHeader Title="Track interaction"
                                          Description="Choose how track rows respond when clicked."
                                          IconGlyph="&#xE8B0;"
                                          Tag="interaction"/>
            <controls:SettingsCard x:Uid="Controls_Settings_PlaybackSettingsSection__SettingsCard_2" Header="Track click behavior"
                                   Description="How clicking a track starts playback"
                                   Tag="interaction">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8B0;"/>
                </controls:SettingsCard.HeaderIcon>
                <ComboBox SelectedIndex="{x:Bind ViewModel.TrackClickIndex, Mode=TwoWay}"
                          MinWidth="140">
                    <ComboBoxItem x:Uid="Controls_Settings_PlaybackSettingsSection__ComboBoxItem_3" Content="Single tap"/>
                    <ComboBoxItem x:Uid="Controls_Settings_PlaybackSettingsSection__ComboBoxItem_4" Content="Double tap"/>
                </ComboBox>
            </controls:SettingsCard>

            <settings:SettingsGroupHeader Title="Queue behavior"
                                          Description="Set what Wavee does with the current queue when playback starts."
                                          IconGlyph="&#xE8FD;"
                                          Tag="queue"/>
            <controls:SettingsCard x:Uid="Controls_Settings_PlaybackSettingsSection__SettingsCard_6" Header="Default play action"
                                   Description="What happens when you start a track"
                                   Tag="queue">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8FD;"/>
                </controls:SettingsCard.HeaderIcon>
                <ComboBox SelectedIndex="{x:Bind ViewModel.DefaultPlayActionIndex, Mode=TwoWay}"
                          MinWidth="180">
                    <ComboBoxItem x:Uid="Controls_Settings_PlaybackSettingsSection__ComboBoxItem_7" Content="Play and clear queue"/>
                    <ComboBoxItem x:Uid="Controls_Settings_PlaybackSettingsSection__ComboBoxItem_8" Content="Play next"/>
                    <ComboBoxItem x:Uid="Controls_Settings_PlaybackSettingsSection__ComboBoxItem_9" Content="Play later"/>
                </ComboBox>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="Controls_Settings_PlaybackSettingsSection__SettingsCard_10" Header="Ask before playing"
                                   Description="Show a prompt before replacing the current queue"
                                   Tag="queue">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE9CE;"/>
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch IsOn="{x:Bind ViewModel.AskPlayAction, Mode=TwoWay}"
                              OnContent="" OffContent=""/>
            </controls:SettingsCard>
            <controls:SettingsCard Header="Autoplay"
                                   Description="Keep playing similar songs when a playlist, album, or artist ends"
                                   Tag="queue">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xEC4A;"/>
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch IsOn="{x:Bind ViewModel.AutoplayEnabled, Mode=TwoWay}"
                              OnContent="" OffContent=""/>
            </controls:SettingsCard>

            <settings:SettingsGroupHeader Title="Player"
                                          Description="Control how the persistent player behaves while another player view is open."
                                          IconGlyph="&#xE8A7;"
                                          Tag="player"/>
            <controls:SettingsCard Header="Keep docked player visible"
                                   Description="Show the bottom or sidebar player while the player is popped out"
                                   Tag="player">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8A7;"/>
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch IsOn="{x:Bind ViewModel.ShowDockedPlayerWithFloatingPlayer, Mode=TwoWay}"
                              OnContent="" OffContent=""/>
            </controls:SettingsCard>

            <settings:SettingsGroupHeader Title="Streaming audio"
                                          Description="Choose network quality and loudness handling for streamed tracks."
                                          IconGlyph="&#xE8D6;"
                                          Tag="audio"/>
            <controls:SettingsCard x:Uid="Controls_Settings_PlaybackSettingsSection__SettingsCard_12" Header="Streaming quality"
                                   Description="Higher quality uses more bandwidth and storage"
                                   Tag="audio">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8D6;"/>
                </controls:SettingsCard.HeaderIcon>
                <ComboBox SelectedIndex="{x:Bind ViewModel.AudioQualityIndex, Mode=TwoWay}"
                          MinWidth="160">
                    <ComboBoxItem x:Uid="Controls_Settings_PlaybackSettingsSection__ComboBoxItem_13" Content="Normal (96 kbps)"/>
                    <ComboBoxItem x:Uid="Controls_Settings_PlaybackSettingsSection__ComboBoxItem_14" Content="High (160 kbps)"/>
                    <ComboBoxItem x:Uid="Controls_Settings_PlaybackSettingsSection__ComboBoxItem_15" Content="Very High (320 kbps)"/>
                </ComboBox>
            </controls:SettingsCard>
            <controls:SettingsCard x:Uid="Controls_Settings_PlaybackSettingsSection__SettingsCard_16" Header="Normalize volume"
                                   Description="{x:Bind ViewModel.NormalizationDescription, Mode=OneWay}"
                                   Tag="audio">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE767;"/>
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch IsOn="{x:Bind ViewModel.NormalizationEnabled, Mode=TwoWay}"
                              OnContent="" OffContent=""/>
            </controls:SettingsCard>

            <settings:SettingsGroupHeader Title="Lyrics sources"
                                          Description="Enable providers and order them by preference when multiple sources match."
                                          IconGlyph="&#xE8D2;"
                                          Tag="lyrics"/>
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.LyricsSources}"
                      AllowDrop="True"
                      Tag="lyrics">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:LyricsSourceItem">
                        <Grid Padding="0,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind Description}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </ScrollView>
</UserControl>
