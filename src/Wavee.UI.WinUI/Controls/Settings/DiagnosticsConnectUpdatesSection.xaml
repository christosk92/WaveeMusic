<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Settings.DiagnosticsConnectUpdatesSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="using:Wavee.UI.WinUI.Controls.Settings"
    mc:Ignorable="d">

    <Grid x:Name="ConnectUpdatesGroupsRoot"
          RowSpacing="12"
          Margin="0,4,0,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <settings:SettingsGroupHeader Grid.Row="0"
                                      Title="Connect Updates"
                                      Description="Live log of cluster updates, dealer commands, and PUT state requests for the local device."
                                      IconGlyph="&#xE703;"
                                      Tag="connect-events"/>
        <ContentControl x:Name="ConnectEventsHost"
                        Grid.Row="1"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        MinHeight="360"
                        Tag="connect-events"/>
    </Grid>
</UserControl>
