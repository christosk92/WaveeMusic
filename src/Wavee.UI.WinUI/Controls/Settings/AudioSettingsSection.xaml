<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Settings.AudioSettingsSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:eq="using:Wavee.UI.WinUI.Controls.Equalizer"
    mc:Ignorable="d">

    <Grid x:Name="SettingsGroupsRoot" Padding="0,16,0,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8" Tag="equalizer">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Uid="Controls_Settings_AudioSettingsSection__ComboBox_1" Grid.Column="0" Header="Preset"
                      SelectedIndex="{x:Bind ViewModel.SelectedEqPresetIndex, Mode=TwoWay}"
                      MinWidth="160">
                <ComboBoxItem x:Uid="Controls_Settings_AudioSettingsSection__ComboBoxItem_2" Content="Flat"/>
                <ComboBoxItem x:Uid="Controls_Settings_AudioSettingsSection__ComboBoxItem_3" Content="Bass Boost"/>
                <ComboBoxItem x:Uid="Controls_Settings_AudioSettingsSection__ComboBoxItem_4" Content="Treble Boost"/>
                <ComboBoxItem x:Uid="Controls_Settings_AudioSettingsSection__ComboBoxItem_5" Content="Vocal"/>
                <ComboBoxItem x:Uid="Controls_Settings_AudioSettingsSection__ComboBoxItem_6" Content="Radio"/>
                <ComboBoxItem Content="EQ Proof"/>
            </ComboBox>

            <ToggleSwitch x:Uid="Controls_Settings_AudioSettingsSection__ToggleSwitch_7" Grid.Column="2" Header="Equalizer"
                          IsOn="{x:Bind ViewModel.IsEqualizerEnabled, Mode=TwoWay}"
                          OnContent="On" OffContent="Off"
                          Margin="0,0,16,0"/>

            <Button x:Uid="Controls_Settings_AudioSettingsSection__Button_8" Grid.Column="3" Content="Reset" VerticalAlignment="Bottom"
                    Command="{x:Bind ViewModel.ResetEqCommand}"/>
        </Grid>

        <TextBlock Grid.Row="1"
                   Text="{x:Bind ViewModel.EqPresetDescription, Mode=OneWay}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   FontSize="12" Margin="0,0,0,12"
                   Tag="equalizer"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,0,0,12"
                    VerticalAlignment="Center"
                    Tag="equalizer">
            <ProgressRing Width="14"
                          Height="14"
                          IsActive="{x:Bind ViewModel.IsEqualizerApplying, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.IsEqualizerApplying, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <FontIcon FontFamily="Segoe MDL2 Assets"
                      Glyph="&#xE73E;"
                      FontSize="12"
                      Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                      Visibility="{x:Bind ViewModel.EqualizerApplySucceeded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <TextBlock Text="{x:Bind ViewModel.EqualizerApplyStatus, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12"/>
        </StackPanel>

        <eq:EqualizerCurveControl Grid.Row="3"
                                  Bands="{x:Bind ViewModel.EqBands, Mode=OneWay}"
                                  MinHeight="250" MaxHeight="400"
                                  Tag="equalizer"/>
    </Grid>
</UserControl>
