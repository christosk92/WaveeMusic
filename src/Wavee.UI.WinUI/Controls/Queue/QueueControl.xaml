<UserControl
    x:Class="Wavee.UI.WinUI.Controls.Queue.QueueControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Wavee.UI.WinUI.Controls.Queue"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:converters="using:Wavee.UI.WinUI.Converters"
    xmlns:shimmer="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:SpotifyImageConverter x:Key="SpotifyImageConverter"/>

        <!-- Shared track row template with always-visible drag handle on the right. -->
        <DataTemplate x:Key="TrackTemplate" x:DataType="local:QueueDisplayItem">
            <Grid x:Name="TrackRoot"
                  Padding="6,6"
                  ColumnSpacing="12"
                  Height="52"
                  CornerRadius="4"
                  Background="Transparent"
                  Opacity="{x:Bind VisualOpacity, Mode=OneTime}"
                  PointerEntered="TrackRow_PointerEntered"
                  PointerExited="TrackRow_PointerExited">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid>
                        <Border CornerRadius="4"
                                Background="{x:Bind ArtworkTintBrush, Mode=OneWay}"
                                Visibility="{x:Bind ArtworkTintVisibility, Mode=OneWay}"/>
                        <!-- Music-note placeholder sits behind the image; the image covers
                             it once it loads. When ImageUrl is null (queue track wasn't
                             enriched), this is what the user sees instead of an empty tile. -->
                        <FontIcon Glyph="&#xE8D6;"
                                  FontSize="18"
                                  Opacity="0.4"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Visibility="{x:Bind IsLoaded, Mode=OneTime}"/>
                        <Image Stretch="UniformToFill"
                               Visibility="{x:Bind IsLoaded, Mode=OneTime}"
                               Source="{x:Bind ImageUrl, Mode=OneTime, Converter={StaticResource SpotifyImageConverter}, ConverterParameter=40}"/>
                    </Grid>
                </Border>
                <shimmer:Shimmer Grid.Column="0" Width="40" Height="40"
                                 Visibility="{x:Bind IsShimmer, Mode=OneTime}"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2"
                            Visibility="{x:Bind IsLoaded, Mode=OneTime}">
                    <TextBlock Text="{x:Bind Title, Mode=OneTime}"
                               FontSize="13"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{x:Bind Subtitle, Mode=OneTime}"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4"
                            Visibility="{x:Bind IsShimmer, Mode=OneTime}">
                    <shimmer:Shimmer Width="160" Height="12" HorizontalAlignment="Left"/>
                    <shimmer:Shimmer Width="110" Height="10" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Hamburger drag handle — always visible, hand cursor on hover (set in code-behind via Loaded). -->
                <FontIcon x:Name="DragHandle"
                          Grid.Column="2"
                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          Glyph="&#xE700;"
                          FontSize="14"
                          Margin="4,0,4,0"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          VerticalAlignment="Center"
                          Loaded="DragHandle_Loaded"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Pinned controls row — default ToggleButton chrome with a pill corner radius. -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="6"
                    Margin="0,10,0,12">
            <ToggleButton x:Name="ShuffleButton"
                          Width="42" Height="34"
                          MinWidth="42" MinHeight="34"
                          Padding="0"
                          CornerRadius="17"
                          ToolTipService.ToolTip="Shuffle"
                          Click="ShuffleButton_Click">
                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          Glyph="&#xE8B1;" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="RepeatButton"
                          Width="42" Height="34"
                          MinWidth="42" MinHeight="34"
                          Padding="0"
                          CornerRadius="17"
                          ToolTipService.ToolTip="Repeat"
                          Click="RepeatButton_Click">
                <FontIcon x:Name="RepeatGlyph"
                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          Glyph="&#xE8EE;" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="InfiniteButton"
                          Width="42" Height="34"
                          MinWidth="42" MinHeight="34"
                          Padding="0"
                          CornerRadius="17"
                          ToolTipService.ToolTip="Autoplay"
                          Click="InfiniteButton_Click">
                <TextBlock Text="&#x221E;"
                           FontSize="18"
                           FontWeight="SemiBold"
                           LineHeight="18"
                           VerticalAlignment="Center"
                           Margin="0,-3,0,0"/>
            </ToggleButton>

            <ToggleButton x:Name="CrossfadeButton"
                          Width="42" Height="34"
                          MinWidth="42" MinHeight="34"
                          Padding="0"
                          CornerRadius="17"
                          ToolTipService.ToolTip="Crossfade"
                          Click="CrossfadeButton_Click">
                <TextBlock Text="&#x21CC;"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </ToggleButton>
        </StackPanel>

        <!-- Scrolling content -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" Padding="0,0,0,160">

                <!-- Playing-from breadcrumb. Borderless / fill-less single line; the
                     visual contrast against the bordered NowPlayingCard below is what
                     differentiates "what we're playing from" from "what's playing now". -->
                <Button x:Name="ContextCard"
                        Visibility="Collapsed"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Margin="0,0,0,8"
                        Padding="6,6"
                        CornerRadius="2"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Open playback context"
                        Click="ContextCard_Click">
                    <Grid ColumnSpacing="10" MinHeight="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="20" Height="20" CornerRadius="3"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Image x:Name="ContextArt" Stretch="UniformToFill"/>
                        </Border>

                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   MaxLines="1"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="Playing from "
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Run x:Name="ContextTitle"
                                 FontWeight="SemiBold"/>
                        </TextBlock>

                        <FontIcon Grid.Column="2"
                                  Glyph="&#xE8A7;"
                                  FontSize="12"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  VerticalAlignment="Center"
                                  Margin="2,0,2,0"/>
                    </Grid>
                </Button>

                <!-- Now Playing card -->
                <Border x:Name="NowPlayingCard"
                        Visibility="Collapsed"
                        CornerRadius="4"
                        Margin="0,0,0,12"
                        Padding="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid ColumnSpacing="12" MinHeight="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Image x:Name="NowPlayingArt" Stretch="UniformToFill"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Name="NowPlayingTitle"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       FontSize="14"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="NowPlayingArtist"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <cards:LottieEqualizer Grid.Column="2"
                                               x:Name="NowPlayingEqualizer"
                                               IsActive="True"
                                               IconSize="16"
                                               VerticalAlignment="Center"
                                               Margin="4,0,4,0"/>
                    </Grid>
                </Border>

                <!-- User queue section -->
                <StackPanel x:Name="UserQueueSection" Visibility="Collapsed" Spacing="0">
                    <Grid Margin="2,8,2,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="UserQueueHeaderLabel"
                                   Text="Queue"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                        <HyperlinkButton Grid.Column="1"
                                         x:Name="ClearQueueButton"
                                         Content="Clear"
                                         FontSize="12"
                                         Padding="6,2"
                                         Click="ClearQueueButton_Click"/>
                    </Grid>
                    <ItemsRepeater x:Name="UserQueueRepeater"
                                   ItemTemplate="{StaticResource TrackTemplate}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="0"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Next up section -->
                <StackPanel x:Name="NextUpSection" Visibility="Collapsed" Spacing="0">
                    <TextBlock x:Name="NextUpHeader"
                               Text="Next up"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="2,14,2,4"/>
                    <ItemsRepeater x:Name="NextUpRepeater"
                                   ItemTemplate="{StaticResource TrackTemplate}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="0"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Queued later (post-context bucket — "Add to Queue" items
                     that play after the context exhausts, before autoplay) -->
                <StackPanel x:Name="PostContextSection" Visibility="Collapsed" Spacing="0">
                    <StackPanel Margin="2,14,2,4" Spacing="1">
                        <TextBlock x:Name="PostContextHeader"
                                   Text="Queued later"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="Plays after this context finishes"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                    <ItemsRepeater x:Name="PostContextRepeater"
                                   ItemTemplate="{StaticResource TrackTemplate}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="0"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Autoplay section (progressively dimmed) -->
                <StackPanel x:Name="AutoPlaySection" Visibility="Collapsed" Spacing="0">
                    <StackPanel x:Name="AutoPlayHeader" Margin="2,14,2,4" Spacing="1">
                        <TextBlock Text="Autoplay"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="Similar music will keep playing"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                    <ItemsRepeater x:Name="AutoPlayRepeater"
                                   ItemTemplate="{StaticResource TrackTemplate}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="0"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Delimiter -->
                <StackPanel x:Name="DelimiterSection" Visibility="Collapsed"
                            HorizontalAlignment="Center" Spacing="4" Margin="0,16,0,4">
                    <FontIcon Glyph="&#xE71A;" FontSize="16"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="DelimiterText" FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ScrollView>

        <!-- Empty state -->
        <TextBlock x:Uid="Controls_Queue_QueueControl__TextBlock_2" x:Name="EmptyState"
                   Text="Your queue is empty. Play something to see it here."
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextWrapping="WrapWholeWords"
                   FontSize="13"
                   Visibility="Collapsed"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Grid.RowSpan="2"
                   Margin="16"/>
    </Grid>
</UserControl>
