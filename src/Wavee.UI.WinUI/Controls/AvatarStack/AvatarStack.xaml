<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.AvatarStack.AvatarStack"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Stacked-avatar strip. The control is intentionally dumb: avatars +
         optional "+N" overflow badge, no flyout / no label. Consumers wrap
         it (or attach a Flyout / handle Tapped) to drive interaction. The
         visual specs match the playlist contributors row exactly so both
         pages share the same look. -->
    <StackPanel x:Name="HostStack"
                Orientation="Horizontal"
                VerticalAlignment="Center"/>
</UserControl>
