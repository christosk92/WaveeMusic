<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Wavee.UI.WinUI.Controls.RightPanel.RightPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:lyrics="using:Wavee.Controls.Lyrics.Controls"
    xmlns:queue="using:Wavee.UI.WinUI.Controls.Queue"
    xmlns:cards="using:Wavee.UI.WinUI.Controls.Cards"
    xmlns:comments="using:Wavee.UI.WinUI.Controls.Comments"
    xmlns:local="using:Wavee.UI.WinUI.Controls.RightPanel"
    xmlns:playback="using:Wavee.UI.WinUI.Controls.Playback"
    xmlns:sidebarplayer="using:Wavee.UI.WinUI.Controls.SidebarPlayer"
    xmlns:ic="using:FluentIcons.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Wavee.UI.WinUI.ViewModels"
    xmlns:behaviors="using:Wavee.UI.WinUI.Behaviors"
    mc:Ignorable="d"
    MinWidth="200"
    MaxWidth="500"
    Loaded="RightPanelView_Loaded"
    Unloaded="RightPanelView_Unloaded"
>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///CommunityToolkit.WinUI.Controls.Segmented/Segmented/Segmented.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <AcrylicBrush x:Key="DetailsCardBrush"

                                  TintColor="#F7F7F7"
                                  TintOpacity="0.42"
                                  TintLuminosityOpacity="0.88"
                                  FallbackColor="#EEF4F7FA"/>
                    <SolidColorBrush x:Key="RightPanelTabRailBackgroundBrush" Color="#55F2F5F8"/>
                    <SolidColorBrush x:Key="RightPanelTabRailBorderBrush" Color="#220F1720"/>
                    <SolidColorBrush x:Key="RightPanelTabActivePillBrush" Color="#FFFFFFFF"/>
                    <SolidColorBrush x:Key="RightPanelTabActiveBorderBrush" Color="#22000000"/>
                    <SolidColorBrush x:Key="RightPanelTabActiveForegroundBrush" Color="#FF08131A"/>
                    <SolidColorBrush x:Key="RightPanelTabInactiveForegroundBrush" Color="#9E31424D"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <AcrylicBrush x:Key="DetailsCardBrush"
                                  TintColor="#10161C"
                                  TintOpacity="0.38"
                                  TintLuminosityOpacity="0.76"
                                  FallbackColor="#CC10161C"/>
                    <SolidColorBrush x:Key="RightPanelTabRailBackgroundBrush" Color="#4D1C2330"/>
                    <SolidColorBrush x:Key="RightPanelTabRailBorderBrush" Color="#16FFFFFF"/>
                    <SolidColorBrush x:Key="RightPanelTabActivePillBrush" Color="#FF2E3D4A"/>
                    <SolidColorBrush x:Key="RightPanelTabActiveBorderBrush" Color="#1CFFFFFF"/>
                    <SolidColorBrush x:Key="RightPanelTabActiveForegroundBrush" Color="#FFF3F7FA"/>
                    <SolidColorBrush x:Key="RightPanelTabInactiveForegroundBrush" Color="#AFC7D3DB"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <Style x:Key="RightPanelTabButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{ThemeResource RightPanelTabInactiveForegroundBrush}"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="MinHeight" Value="34"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <!-- Output Device row template — used by both local audio and Spotify Connect ItemsRepeaters -->
        </ResourceDictionary>
    </UserControl.Resources>

    <animations:Implicit.ShowAnimations>
        <animations:OpacityAnimation Duration="0:0:0.25" From="0" To="1" />
        <animations:TranslationAnimation Duration="0:0:0.25" From="40,0,0" To="0" />
    </animations:Implicit.ShowAnimations>
    <animations:Implicit.HideAnimations>
        <animations:OpacityAnimation Duration="0:0:0.2" From="1" To="0" />
        <animations:TranslationAnimation Duration="0:0:0.2" From="0" To="40,0,0" />
    </animations:Implicit.HideAnimations>

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>  <!-- Resize gripper -->
            <ColumnDefinition Width="*"/>     <!-- Panel content -->
        </Grid.ColumnDefinitions>

        <!-- Win2D canvas as full-panel background (swap chain can't blend with XAML, so it owns the background) -->
        <lyrics:NowPlayingCanvas x:Name="NowPlayingCanvas"
                                 Grid.ColumnSpan="2"
                                 Visibility="Collapsed"/>

        <!-- Canvas video background (frame server mode + Win2D → standard Image) -->
        <Image x:Name="DetailsCanvasImage"
               Grid.ColumnSpan="2"
               Stretch="UniformToFill"
               Visibility="Collapsed"/>

        <!-- Shared media chrome for all right-panel tabs (composition visual injected in code-behind) -->
        <Grid x:Name="BackgroundOverlayHost"
              Grid.ColumnSpan="2"
              Visibility="Collapsed"
              IsHitTestVisible="False"/>

        <!-- Lyrics overlay on canvas — composition-backed text surface -->
        <Grid x:Name="CanvasLyricsOverlay"
              Grid.Column="1"
              VerticalAlignment="Top"
              HorizontalAlignment="Stretch"
              Margin="20,56,20,0"
              Visibility="Collapsed"
              IsHitTestVisible="False">
            <Grid x:Name="CanvasLyricLineHost"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Top"
                  Height="64"
                  SizeChanged="CanvasLyricLineHost_SizeChanged"/>
        </Grid>

        <Button x:Name="DetailsCanvasSyncBadge"
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,56,14,0"
                Padding="10,6"
                CornerRadius="16"
                Click="DetailsCanvasSyncBadge_Click"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE895;" FontSize="12"/>
                <TextBlock Text="New canvas" FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
        </Button>

        <!-- Resize gripper -->
        <Border
            x:Name="PanelResizer"
            Grid.Column="0"
            MinWidth="4"
            Margin="0,60,0,40"
            HorizontalAlignment="Left"
            Background="Transparent"
            BorderBrush="Transparent"
            Canvas.ZIndex="100"
            CornerRadius="2"
            ManipulationMode="TranslateX"
            ManipulationStarted="Resizer_ManipulationStarted"
            ManipulationDelta="Resizer_ManipulationDelta"
            ManipulationCompleted="Resizer_ManipulationCompleted"
            PointerEntered="Resizer_PointerEntered"
            PointerExited="Resizer_PointerExited"
            DoubleTapped="Resizer_DoubleTapped"/>

        <!-- Panel content -->
            <Grid x:Name="PanelContentGrid" Grid.Column="1" Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Tab header -->
                    <RowDefinition Height="*"/>     <!-- Content -->
                </Grid.RowDefinitions>

                <!-- Tab header rail. Wrapped in a 3-column Grid so chevron pager
                     buttons can flank a horizontally-scrollable ScrollViewer.
                     Edge-fade overlays sit on top of the scroll viewport to
                     soften the cutoff when tab labels overflow (e.g. long
                     localized strings like Korean "세부 정보"). -->
                <Grid x:Name="TabHeaderRow"
                      Grid.Row="0"
                      Margin="6,10,6,6"
                      behaviors:DragToDetachBehavior.Panel="RightPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left pager — only visible when there's content scrolled off the left. -->
                    <Button x:Name="TabPagerLeftButton"
                            Grid.Column="0"
                            Visibility="Collapsed"
                            Click="TabPagerLeft_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="2"
                            Width="22" Height="28"
                            MinWidth="0" MinHeight="0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Scroll tabs left">
                        <FontIcon Glyph="&#xE76B;" FontSize="11"/>
                    </Button>

                    <Grid Grid.Column="1">
                        <ScrollViewer x:Name="TabHeaderScroller"
                                      HorizontalScrollMode="Enabled"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollMode="Disabled"
                                      VerticalScrollBarVisibility="Disabled"
                                      ViewChanged="TabHeaderScroller_ViewChanged"
                                      SizeChanged="TabHeaderScroller_SizeChanged">
                            <controls:Segmented
                                x:Name="TabHeader"
                                HorizontalAlignment="Left"
                                SelectedIndex="0"
                                Style="{StaticResource PivotSegmentedStyle}"
                                SelectionChanged="TabHeader_SelectionChanged">
                                <controls:SegmentedItem x:Uid="Controls_RightPanel_RightPanelView__SegmentedItem_1"
                                                        x:Name="QueueTabItem"
                                                        Content="Queue"
                                                        Tag="Queue"/>
                                <controls:SegmentedItem x:Uid="Controls_RightPanel_RightPanelView__SegmentedItem_2"
                                                        x:Name="LyricsTabItem"
                                                        Content="Lyrics"
                                                        Tag="Lyrics"/>
                                <controls:SegmentedItem x:Uid="Controls_RightPanel_RightPanelView__SegmentedItem_3"
                                                        x:Name="FriendsTabItem"
                                                        Content="Friends"
                                                        Tag="Friends"/>
                                <controls:SegmentedItem x:Uid="Controls_RightPanel_RightPanelView__SegmentedItem_4"
                                                        x:Name="DetailsTabItem"
                                                        Content="Details"
                                                        Tag="Details"/>
                                <!--
                                    Temporary "Track details" tab — invoked from TrackDataGrid's
                                    details toggle. Collapsed by default; code-behind shows it
                                    when ShellViewModel.SelectedTrackForDetails is set.
                                -->
                                <controls:SegmentedItem x:Name="TrackDetailsTabItem"
                                                        Content="Track"
                                                        Tag="TrackDetails"
                                                        Visibility="Collapsed"/>
                            </controls:Segmented>
                        </ScrollViewer>

                    </Grid>

                    <!-- Right pager — visible when there's content cut off on the right. -->
                    <Button x:Name="TabPagerRightButton"
                            Grid.Column="2"
                            Visibility="Collapsed"
                            Click="TabPagerRight_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="2"
                            Width="22" Height="28"
                            MinWidth="0" MinHeight="0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Scroll tabs right">
                        <FontIcon Glyph="&#xE76C;" FontSize="11"/>
                    </Button>

                    <!-- Pop-out: tear the right panel into its own window. The header strip
                         carries DragToDetachBehavior too, so dragging it outside the main
                         window achieves the same. -->
                    <Button x:Name="PopOutButton"
                            Grid.Column="3"
                            Click="PopOutButton_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="2"
                            Margin="2,0,0,0"
                            Width="22" Height="28"
                            MinWidth="0" MinHeight="0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Pop out to window">
                        <FontIcon Glyph="&#xE8A7;" FontSize="11"/>
                    </Button>
                </Grid>

                <!-- Content area -->
                <Grid Grid.Row="1" Padding="12,0,12,14">

                <!-- Shared bottom content fade: composition SpriteVisual injected in code-behind.
                     Placed as a sibling inside the padded content Grid so it overlays every tab,
                     pinned to the bottom, full width (negative margins cancel the parent padding). -->
                <Grid x:Name="TabContentFadeHost"
                      VerticalAlignment="Bottom"
                      Height="140"
                      Margin="-12,0,-12,-14"
                      IsHitTestVisible="False"
                      Canvas.ZIndex="50"/>

                <!-- Queue tab (its own UserControl) -->
                <local:QueueTabView x:Name="QueueContent"/>

                <!-- Lyrics panel — deferred from visual tree until first selection -->
                <Grid x:Name="LyricsContent"
                      x:Load="False"
                      Visibility="Collapsed"
                      SizeChanged="LyricsContent_SizeChanged">

                    <!-- Transparent overlay for mouse interaction (seek, scroll) -->
                    <Border
                        x:Name="LyricsInteractionOverlay"
                        Background="Transparent"
                        PointerEntered="LyricsOverlay_PointerEntered"
                        PointerExited="LyricsOverlay_PointerExited"
                        PointerMoved="LyricsOverlay_PointerMoved"
                        PointerPressed="LyricsOverlay_PointerPressed"
                        PointerReleased="LyricsOverlay_PointerReleased"
                        PointerWheelChanged="LyricsOverlay_PointerWheelChanged"/>

                    <!-- Sync button (visible when user scrolls away) -->
                    <Button
                        x:Name="LyricsSyncButton"
                        Content="&#xE72C;"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Click="LyricsSyncButton_Click"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,12"
                        Padding="12,6"
                        CornerRadius="16"
                        Visibility="Collapsed"/>

                    <Button
                        x:Name="LyricsHoverExplainButton"
                        Click="LyricsHoverExplainButton_Click"
                        PointerEntered="LyricsHoverExplainButton_PointerEntered"
                        PointerExited="LyricsHoverExplainButton_PointerExited"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Width="34"
                        Height="34"
                        Padding="0"
                        MinWidth="0"
                        MinHeight="0"
                        CornerRadius="17"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed"
                        Canvas.ZIndex="6"
                        ToolTipService.ToolTip="Explain this line">
                        <ic:SymbolIcon Symbol="LightbulbFilament"
                                       IconVariant="Filled"
                                       FontSize="14"
                                       Foreground="{ThemeResource AiAccentSolidBrush}"/>
                    </Button>

                    <!-- Loading indicator -->
                    <ProgressRing
                        x:Name="LyricsLoadingRing"
                        IsActive="False"
                        Width="24" Height="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed"/>

                    <!-- Loading shimmer placeholder -->
                    <StackPanel
                        x:Name="LyricsLoadingShimmer"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Margin="14,0,14,0"
                        Spacing="10">
                        <controls:Shimmer Height="14" Width="210" CornerRadius="7" HorizontalAlignment="Left"/>
                        <controls:Shimmer Height="14" Width="248" CornerRadius="7" HorizontalAlignment="Left"/>
                        <controls:Shimmer Height="14" Width="186" CornerRadius="7" HorizontalAlignment="Left"/>
                        <controls:Shimmer Height="14" Width="230" CornerRadius="7" HorizontalAlignment="Left"/>
                        <controls:Shimmer Height="14" Width="170" CornerRadius="7" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- No lyrics fallback -->
                    <TextBlock x:Uid="Controls_RightPanel_RightPanelView__TextBlock_5"
                        x:Name="NoLyricsText"
                        Text="No lyrics available for this track"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        FontSize="13"
                        Visibility="Collapsed"/>

                    <!-- Debug info button (DEBUG builds only) -->
                    <Button
                        x:Name="LyricsDebugButton"
                        Content="&#xEBE8;"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Click="LyricsDebugButton_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,4,4,0"
                        Padding="6"
                        MinWidth="0" MinHeight="0"
                        CornerRadius="4"
                        FontSize="12"
                        Opacity="0.5"
                        Background="Transparent"
                        Visibility="Collapsed"/>

                    <sidebarplayer:LyricsAiPanel
                        x:Name="RightPanelLyricsAi"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Margin="0,4,0,0"
                        Canvas.ZIndex="4" />
                </Grid>

                <!-- Friends tab (its own UserControl) -->
                <local:FriendsTabView x:Name="FriendsContent" Visibility="Collapsed"/>

                <!--
                    Track details tab (temporary, invoked from TrackDataGrid).
                    Bound to ShellViewModel.SelectedTrackForDetails via code-behind.
                    x:Load="False" keeps the subtree out of the visual tree until
                    the first time this tab is activated.
                -->
                <ScrollViewer x:Name="TrackDetailsContent"
                              x:Load="False"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Hidden"
                              Padding="0,4,0,12">
                    <StackPanel x:Name="TrackDetailsPanel" Spacing="14">
                        <Border Width="180" Height="180"
                                HorizontalAlignment="Center"
                                CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Image x:Name="TrackDetailsArtwork" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock x:Name="TrackDetailsTitle"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="2"/>
                            <TextBlock x:Name="TrackDetailsArtist"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextAlignment="Center"/>
                        </StackPanel>
                        <Grid ColumnSpacing="12" RowSpacing="6"
                              HorizontalAlignment="Stretch"
                              Margin="8,8,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Album"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TrackDetailsAlbum" Grid.Row="0" Grid.Column="1"
                                       TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Duration"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TrackDetailsDuration" Grid.Row="1" Grid.Column="1"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Added"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TrackDetailsAdded" Grid.Row="2" Grid.Column="1"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Plays"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TrackDetailsPlays" Grid.Row="3" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Details panel — deferred from visual tree until first selection -->
                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              Margin="-8,0,-8,-12"
                              x:Name="DetailsContent"
                              x:Load="False"
                              Visibility="Collapsed"
                              SizeChanged="DetailsContent_SizeChanged">
                    <animations:Implicit.ShowAnimations>
                        <animations:OpacityAnimation Duration="0:0:0.25" From="0" To="1"/>
                        <animations:TranslationAnimation Duration="0:0:0.25" From="0,12,0" To="0"/>
                    </animations:Implicit.ShowAnimations>
                    <animations:Implicit.HideAnimations>
                        <animations:OpacityAnimation Duration="0:0:0.15" From="1" To="0"/>
                    </animations:Implicit.HideAnimations>
                    <StackPanel Spacing="16" Padding="0,4,0,8">

                        <!-- Canvas mode spacer — pushes cards to bottom so video is visible -->
                        <Border x:Name="DetailsCanvasSpacer" Height="0"/>

                        <!-- Loading shimmer skeleton -->
                        <StackPanel x:Name="DetailsLoadingShimmer" Spacing="16" Visibility="Collapsed">
                            <!-- Artist header skeleton -->
                            <Border Background="{ThemeResource DetailsCardBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:Shimmer Width="56" Height="56" CornerRadius="28"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                        <controls:Shimmer Width="120" Height="16"/>
                                        <controls:Shimmer Width="180" Height="12"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <!-- Lyrics snippet skeleton -->
                            <Border Background="{ThemeResource DetailsCardBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12">
                                <StackPanel Spacing="8">
                                    <controls:Shimmer Width="60" Height="12"/>
                                    <controls:Shimmer Height="14" HorizontalAlignment="Stretch"/>
                                    <controls:Shimmer Width="180" Height="18"/>
                                    <controls:Shimmer Height="14" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                            <!-- Bio skeleton -->
                            <Border Background="{ThemeResource DetailsCardBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12">
                                <StackPanel Spacing="6">
                                    <controls:Shimmer Width="60" Height="14"/>
                                    <controls:Shimmer Height="12" HorizontalAlignment="Stretch"/>
                                    <controls:Shimmer Height="12" HorizontalAlignment="Stretch"/>
                                    <controls:Shimmer Width="200" Height="12"/>
                                </StackPanel>
                            </Border>
                            <!-- Credits skeleton -->
                            <Border Background="{ThemeResource DetailsCardBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12">
                                <StackPanel Spacing="8">
                                    <controls:Shimmer Width="60" Height="14"/>
                                    <controls:Shimmer Width="40" Height="10"/>
                                    <controls:Shimmer Height="32" HorizontalAlignment="Stretch" CornerRadius="6"/>
                                    <controls:Shimmer Height="32" HorizontalAlignment="Stretch" CornerRadius="6"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Error -->
                        <TextBlock
                            x:Name="DetailsErrorText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="WrapWholeWords"
                            FontSize="13"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed"/>

                        <!-- Artist header -->
                        <Border x:Name="DetailsArtistHeaderCard"
                                Background="{ThemeResource DetailsCardBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12"
                                Visibility="Collapsed">
                        <Grid x:Name="DetailsArtistHeader" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <PersonPicture
                                x:Name="DetailsArtistAvatar"
                                Width="56" Height="56"
                                Grid.Column="0"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock
                                        x:Name="DetailsArtistName"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        TextTrimming="CharacterEllipsis"
                                        MaxLines="1"/>
                                    <FontIcon
                                        x:Name="DetailsVerifiedIcon"
                                        Glyph="&#xE73E;"
                                        FontSize="14"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"/>
                                </StackPanel>
                                <TextBlock
                                    x:Name="DetailsArtistStats"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"
                                    TextWrapping="WrapWholeWords"/>
                            </StackPanel>

                            <!-- More options button -->
                            <Button x:Uid="Controls_RightPanel_RightPanelView__Button_6"
                                x:Name="DetailsMoreButton"
                                Grid.Column="2"
                                Click="DetailsMoreButton_Click"
                                Style="{StaticResource SubtleButtonStyle}"
                                Width="32" Height="32"
                                VerticalAlignment="Top"
                                ToolTipService.ToolTip="More options">
                                <FontIcon Glyph="&#xE712;" FontSize="14"/>
                            </Button>
                        </Grid>
                        </Border>

                        <!-- Podcast episode header -->
                        <Border x:Name="DetailsPodcastHeaderCard"
                                Background="{ThemeResource DetailsCardBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12"
                                Visibility="Collapsed">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="72" Height="72" CornerRadius="8"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <Grid>
                                            <FontIcon Glyph="&#xE189;"
                                                      FontSize="26"
                                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            <Image x:Name="DetailsPodcastArtwork"
                                                   Stretch="UniformToFill"
                                                   behaviors:ImageFallbackBehavior.HideOnError="True"
                                                   behaviors:ImageFallbackBehavior.FadeInOnLoad="True"
                                                   behaviors:ImageFallbackBehavior.DecodePixelWidth="168"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock x:Name="DetailsPodcastTitle"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   TextWrapping="WrapWholeWords"
                                                   MaxLines="3"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="DetailsPodcastShowLine"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="WrapWholeWords"
                                                   MaxLines="2"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="DetailsPodcastMetaLine"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="WrapWholeWords"
                                                   MaxLines="2"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Command="{Binding OpenPodcastEpisodeDetailCommand}"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE8A7;" FontSize="13"/>
                                            <TextBlock Text="Episode"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Command="{Binding OpenPodcastShowCommand}"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE93C;" FontSize="13"/>
                                            <TextBlock Text="Show"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ================================ -->
                        <!-- Output Device card                -->
                        <!-- ================================ -->
                        <playback:AudioOutputPicker
                            x:Name="DetailsOutputDeviceCard"
                            DisplayMode="Card"
                            HideWhenNoTrack="True" />

                        <!-- Lyrics snippet (tap to open Lyrics tab) -->
                        <Border x:Name="DetailsLyricsSnippet"
                                Background="{ThemeResource DetailsCardBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                PointerEntered="DetailsLyricsSnippet_PointerEntered"
                                PointerExited="DetailsLyricsSnippet_PointerExited"
                                Tapped="DetailsLyricsSnippet_Tapped"
                                BorderThickness="1" CornerRadius="8" Padding="12"
                                Visibility="Collapsed">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xED1E;" FontSize="12"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Uid="Controls_RightPanel_RightPanelView__TextBlock_7" Text="Lyrics" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <!-- Previous line (faded) -->
                                <TextBlock x:Name="DetailsLyricsPrev"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextWrapping="WrapWholeWords" MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- Current line (highlighted) -->
                                <TextBlock x:Name="DetailsLyricsCurrent"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           TextWrapping="WrapWholeWords" MaxLines="2"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- Next line (faded) -->
                                <TextBlock x:Name="DetailsLyricsNext"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextWrapping="WrapWholeWords" MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <!-- On-device AI lyrics meaning -->
                        <Border x:Name="DetailsAiMeaningSection"
                                Background="{ThemeResource DetailsCardBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12"
                                Visibility="Collapsed">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xECAD;"
                                                  FontSize="12"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Lyrics meaning"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <Button x:Name="DetailsAiMeaningButton"
                                            Grid.Column="1"
                                            Content="Generate"
                                            Click="DetailsAiMeaningButton_Click"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="8,4"
                                            MinHeight="0"/>
                                </Grid>
                                <ProgressBar x:Name="DetailsAiMeaningProgress"
                                             IsIndeterminate="True"
                                             Visibility="Collapsed"/>
                                <TextBlock x:Name="DetailsAiMeaningText"
                                           TextWrapping="WrapWholeWords"
                                           LineHeight="19"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- Biography -->
                        <Border x:Name="DetailsBio"
                                Background="{ThemeResource DetailsCardBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12"
                                Visibility="Collapsed">
                            <StackPanel Spacing="4">
                                <TextBlock x:Uid="Controls_RightPanel_RightPanelView__TextBlock_8"
                                    Text="About"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Margin="0,0,0,4"/>
                                <TextBlock
                                    x:Name="DetailsBioText"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"
                                    TextWrapping="WrapWholeWords"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="3"
                                    IsTextTrimmedChanged="DetailsBioText_IsTextTrimmedChanged"/>
                                <HyperlinkButton x:Uid="Controls_RightPanel_RightPanelView__HyperlinkButton_9"
                                    x:Name="DetailsBioToggle"
                                    Content="Show more"
                                    Click="DetailsBioToggle_Click"
                                    Padding="0"
                                    FontSize="12"
                                    Visibility="Collapsed"/>
                                <!-- Record label -->
                                <TextBlock
                                    x:Name="DetailsRecordLabel"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    FontSize="11"
                                    Margin="0,4,0,0"
                                    Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- Podcast description -->
                        <Border x:Name="DetailsPodcastDescriptionSection"
                                Background="{ThemeResource DetailsCardBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12"
                                Visibility="Collapsed">
                            <StackPanel Spacing="8">
                                <TextBlock Text="About this episode"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock x:Name="DetailsPodcastDescriptionText"
                                           FontSize="12"
                                           LineHeight="18"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="WrapWholeWords"
                                           MaxLines="8"
                                           TextTrimming="CharacterEllipsis"/>
                                <Border x:Name="DetailsPodcastTranscriptChip"
                                        HorizontalAlignment="Left"
                                        Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                        CornerRadius="6"
                                        Padding="8,4"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE8D2;"
                                                  FontSize="11"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock x:Name="DetailsPodcastTranscriptText"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Podcast chapters -->
                        <Border x:Name="DetailsPodcastChaptersSection"
                                Background="{ThemeResource DetailsCardBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="10"
                                Visibility="Collapsed">
                            <StackPanel Spacing="8">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Chapters"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="DetailsPodcastChaptersToggleButton"
                                            Grid.Column="1"
                                            Click="DetailsPodcastChaptersToggle_Click"
                                            Padding="8,4"
                                            MinHeight="0"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Visibility="Collapsed"/>
                                </Grid>
                                <ItemsRepeater x:Name="DetailsPodcastChaptersList">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="0"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Button Tag="{Binding}"
                                                    Click="DetailsPodcastChapter_Click"
                                                    PointerEntered="DetailsPodcastChapter_PointerEntered"
                                                    PointerExited="DetailsPodcastChapter_PointerExited"
                                                    PointerPressed="DetailsPodcastChapter_PointerPressed"
                                                    PointerReleased="DetailsPodcastChapter_PointerReleased"
                                                    PointerCanceled="DetailsPodcastChapter_PointerCanceled"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    MinHeight="0"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    ToolTipService.ToolTip="Seek to chapter"
                                                    AutomationProperties.Name="{Binding Title}">
                                                <Grid ColumnSpacing="8" Padding="0,1,0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="42"/>
                                                        <ColumnDefinition Width="18"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding StartTime}"
                                                               FontSize="10"
                                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                               Opacity="{Binding ChromeOpacity}"
                                                               TextAlignment="Right"
                                                               TextWrapping="NoWrap"
                                                               VerticalAlignment="Center"/>

                                                    <local:PodcastChapterTimelineRail Grid.Column="1"
                                                                                      Progress="{Binding TimelineCellProgress}"
                                                                                      IsActive="{Binding IsActive}"
                                                                                      IsCompleted="{Binding IsCompleted}"
                                                                                      IsFirst="{Binding IsFirst}"
                                                                                      IsLast="{Binding IsLast}"/>

                                                    <Border Grid.Column="2"
                                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="8,6"
                                                            Opacity="{Binding ContentOpacity}">
                                                        <Grid ColumnSpacing="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Spacing="3">
                                                                <TextBlock Text="{Binding ChapterLabel}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                                           Opacity="{Binding ChromeOpacity}"/>
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontSize="11.5"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="WrapWholeWords"
                                                                           MaxLines="1"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Subtitle}"
                                                                           FontSize="10.5"
                                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                           TextWrapping="WrapWholeWords"
                                                                           MaxLines="1"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>

                                                            <Border Grid.Column="1"
                                                                    Width="24"
                                                                    Height="24"
                                                                    CornerRadius="12"
                                                                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                                                    VerticalAlignment="Center">
                                                                <FontIcon Glyph="&#xE768;"
                                                                          FontSize="10"
                                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>

                        <!-- Podcast comments — uses the shared CommentsList control
                             in CompactMode so styling + behavior match the library
                             episode detail. Code-behind sets HeaderText, Comments,
                             HasNoComments, HasMoreComments, StatusText imperatively
                             (the right panel resolves its VM lazily). -->
                        <Border x:Name="DetailsPodcastCommentsSection"
                                Background="{ThemeResource DetailsCardBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12"
                                Visibility="Collapsed">
                            <comments:CommentsList x:Name="DetailsPodcastComments"
                                                   CompactMode="True"
                                                   PlaceholderText="Add a comment..."
                                                   ShowStatusAsInfoBar="False"
                                                   Draft="{Binding PodcastCommentDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   CharacterCount="{Binding PodcastCommentCharacterCount}"
                                                   SubmitCommand="{Binding SubmitPodcastCommentCommand}"
                                                   LoadMoreCommand="{Binding LoadMorePodcastCommentsCommand}"
                                                   ShowReactionsRequested="DetailsPodcastComments_ShowReactionsRequested"
                                                   ShowReplyReactionsRequested="DetailsPodcastComments_ShowReplyReactionsRequested"/>
                        </Border>

                        <!-- Credits -->
                        <Border x:Name="DetailsCreditsSection"
                                Background="{ThemeResource DetailsCardBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12"
                                Visibility="Collapsed">
                            <StackPanel Spacing="14">
                                <TextBlock x:Uid="Controls_RightPanel_RightPanelView__TextBlock_10"
                                    Text="Credits"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <ItemsRepeater x:Name="DetailsCreditGroups">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="14"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="6">
                                                <TextBlock
                                                    Text="{Binding RoleName}"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                    CharacterSpacing="60"/>
                                                <ItemsRepeater ItemsSource="{Binding Contributors}">
                                                    <ItemsRepeater.Layout>
                                                        <StackLayout Spacing="4"/>
                                                    </ItemsRepeater.Layout>
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid ColumnSpacing="10" Padding="2,4"
                                                                  Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                  CornerRadius="6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Artist avatar -->
                                                                <PersonPicture Width="24" Height="24"
                                                                               ProfilePicture="{Binding ImageUrl, Converter={StaticResource SpotifyImageConverter}, ConverterParameter=48}"
                                                                               Margin="2,0,0,0"/>
                                                                <TextBlock
                                                                    Grid.Column="1"
                                                                    Text="{Binding Name}"
                                                                    FontSize="12"
                                                                    VerticalAlignment="Center"
                                                                    TextTrimming="CharacterEllipsis"/>
                                                                <!-- Role tag -->
                                                                <Border Grid.Column="2"
                                                                        Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                                                        CornerRadius="4"
                                                                        Padding="6,2"
                                                                        Margin="0,0,2,0"
                                                                        MaxWidth="150"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock
                                                                        Text="{Binding RolesText}"
                                                                        FontSize="10"
                                                                        TextTrimming="CharacterEllipsis"
                                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                                <HyperlinkButton x:Uid="Controls_RightPanel_RightPanelView__HyperlinkButton_11"
                                    x:Name="DetailsCreditsToggle"
                                    Content="View all credits"
                                    Click="DetailsCreditsToggle_Click"
                                    Padding="0"
                                    FontSize="12"
                                    HorizontalAlignment="Left"
                                    Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- Concerts -->
                        <Border x:Name="DetailsConcertsSection"
                                Background="{ThemeResource DetailsCardBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12"
                                Visibility="Collapsed">
                            <StackPanel Spacing="8">
                                <TextBlock x:Uid="Controls_RightPanel_RightPanelView__TextBlock_12"
                                    Text="Concerts"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <ItemsRepeater x:Name="DetailsConcertsList">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="6"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,4" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Text="{Binding DateFormatted}"
                                                    FontSize="11"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    VerticalAlignment="Top"
                                                    MinWidth="70"/>
                                                <StackPanel Grid.Column="1" Spacing="1">
                                                    <TextBlock
                                                        Text="{Binding Title}"
                                                        FontSize="13"
                                                        TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                        TextTrimming="CharacterEllipsis">
                                                        <Run Text="{Binding Venue}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding City}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>

                        <!-- Related Videos -->
                        <Border x:Name="DetailsRelatedVideosSection"
                                Visibility="Collapsed">
                            <StackPanel Spacing="10">
                                <TextBlock x:Uid="Controls_RightPanel_RightPanelView__TextBlock_13"
                                    Text="Related Videos"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <ItemsRepeater x:Name="DetailsRelatedVideosList">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="140" MinItemHeight="110"
                                                           MinColumnSpacing="6" MinRowSpacing="6"
                                                           ItemsStretch="Fill"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Thumbnail card with gradient overlay text -->
                                            <Border CornerRadius="8">
                                                <Grid>
                                                    <Image
                                                        Source="{Binding ThumbnailUrl}"
                                                        Stretch="UniformToFill"/>
                                                    <!-- Gradient scrim for text readability -->
                                                    <Border>
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#00000000" Offset="0.3"/>
                                                                <GradientStop Color="#CC000000" Offset="1.0"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <!-- Play icon -->
                                                    <FontIcon Glyph="&#xE768;"
                                                              FontSize="20"
                                                              Foreground="White"
                                                              Opacity="0.7"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                    <!-- Title + artist at bottom -->
                                                    <StackPanel VerticalAlignment="Bottom"
                                                                Padding="10,0,10,8"
                                                                Spacing="1">
                                                        <TextBlock
                                                            Text="{Binding Title}"
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            Foreground="White"
                                                            MaxLines="1"
                                                            TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock
                                                            Text="{Binding ArtistName}"
                                                            FontSize="11"
                                                            Foreground="#CCFFFFFF"
                                                            MaxLines="1"
                                                            TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="ResizerStates">
                <VisualState x:Name="ResizerNormal" />
                <VisualState x:Name="ResizerPointerOver">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PanelResizer" Storyboard.TargetProperty="Background">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource CardStrokeColorDefaultSolidBrush}" />
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="ResizerPressed">
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PanelResizer" Storyboard.TargetProperty="Background">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SolidBackgroundFillColorSecondaryBrush}" />
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>
