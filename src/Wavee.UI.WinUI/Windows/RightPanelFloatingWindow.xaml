<?xml version="1.0" encoding="utf-8"?>
<winuiex:WindowEx
    x:Class="Wavee.UI.WinUI.Floating.RightPanelFloatingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winuiex="using:WinUIEx"
    xmlns:rightpanel="using:Wavee.UI.WinUI.Controls.RightPanel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Wavee — Now playing"
    MinWidth="280"
    MinHeight="420"
    PersistenceId="WaveeRightPanelFloating">

    <winuiex:WindowEx.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </winuiex:WindowEx.SystemBackdrop>

    <!-- See PlayerFloatingWindow.xaml for the bleed pattern. RightPanelView's
         IsOpen / PanelWidth are driven from code-behind so it actually renders
         (defaults are IsOpen=false / Width=300) and tracks window resizing. -->
    <Grid x:Name="RootGrid">
        <rightpanel:RightPanelView
            x:Name="PanelHost"
            Margin="0,32,0,0" />

        <Border x:Name="DragRegion"
                Height="32"
                VerticalAlignment="Top"
                Background="Transparent" />
    </Grid>
</winuiex:WindowEx>
