<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Wavee.Controls.HeroCarousel.HeroCarouselView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="#1D1D24"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="HeroCarouselPipButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Border
                                Width="6"
                                Height="6"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#73FFFFFF"
                                CornerRadius="3" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Padding="0">
        <Grid
            MaxWidth="1100"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid
                x:Name="StageWrap"
                Grid.Row="0"
                HorizontalAlignment="Stretch"
                SizeChanged="OnStageWrapSizeChanged">

                <Grid
                    x:Name="GlowHost"
                    Margin="-110"
                    IsHitTestVisible="False">
                    <canvas:CanvasControl
                        x:Name="GlowCanvasA"
                        ClearColor="Transparent"
                        HorizontalAlignment="Center"
                        IsHitTestVisible="False"
                        Opacity="0"
                        VerticalAlignment="Center" />
                    <canvas:CanvasControl
                        x:Name="GlowCanvasB"
                        ClearColor="Transparent"
                        HorizontalAlignment="Center"
                        IsHitTestVisible="False"
                        Opacity="0"
                        VerticalAlignment="Center" />
                </Grid>

                <Grid
                    x:Name="StageShadowHost"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Transparent">
                    <Border
                        x:Name="StageBorder"
                        Background="#111111"
                        BorderBrush="#0AFFFFFF"
                        BorderThickness="1"
                        CornerRadius="18">
                        <Grid
                            x:Name="StageRoot"
                        Background="Transparent"
                        KeyDown="OnStageRootKeyDown"
                        PointerEntered="OnStagePointerEntered"
                        PointerExited="OnStagePointerExited"
                        PointerPressed="OnStagePointerPressed"
                        PointerReleased="OnStagePointerReleased"
                        PointerCanceled="OnStagePointerCanceled"
                        PointerCaptureLost="OnStagePointerCaptureLost"
                        PointerMoved="OnStagePointerMoved"
                        PointerWheelChanged="OnStagePointerWheelChanged">

                        <Grid
                            x:Name="BgTrack"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch" />

                        <Grid
                            x:Name="ContentTrack"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch" />

                        <canvas:CanvasControl
                            x:Name="SpotlightCanvas"
                            ClearColor="Transparent"
                            IsHitTestVisible="False"
                            Opacity="0" />

                        <!-- Loading state. Shown when SlideCount == 0, hidden otherwise.
                             Uses the CommunityToolkit Shimmer for a clean Fluent loading look. -->
                        <controls:Shimmer
                            x:Name="LoadingShimmer"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            IsHitTestVisible="False"
                            Visibility="Collapsed" />
                    </Grid>
                </Border>
                </Grid>

                <Button
                    x:Name="PrevButton"
                    Width="36"
                    Height="36"
                    Margin="12,0,0,0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    AutomationProperties.AutomationId="HeroCarouselPreviousButton"
                    Background="#8C141419"
                    BorderBrush="#14FFFFFF"
                    BorderThickness="1"
                    Click="OnPreviousClicked"
                    CornerRadius="18"
                    Opacity="0">
                    <FontIcon
                        FontSize="12"
                        Foreground="White"
                        Glyph="&#xE76B;" />
                </Button>

                <Button
                    x:Name="NextButton"
                    Width="36"
                    Height="36"
                    Margin="0,0,12,0"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    AutomationProperties.AutomationId="HeroCarouselNextButton"
                    Background="#8C141419"
                    BorderBrush="#14FFFFFF"
                    BorderThickness="1"
                    Click="OnNextClicked"
                    CornerRadius="18"
                    Opacity="0">
                    <FontIcon
                        FontSize="12"
                        Foreground="White"
                        Glyph="&#xE76C;" />
                </Button>
            </Grid>

            <Grid
                x:Name="PipsPresenter"
                Grid.Row="1"
                Height="18"
                Margin="0,14,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">
                <PipsPager
                    x:Name="SlidePips"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    MaxVisiblePips="12"
                    NormalPipStyle="{StaticResource HeroCarouselPipButtonStyle}"
                    NumberOfPages="1"
                    Orientation="Horizontal"
                    PreviousButtonVisibility="Collapsed"
                    NextButtonVisibility="Collapsed"
                    SelectedIndexChanged="OnPipsPagerSelectedIndexChanged"
                    SelectedPageIndex="0"
                    SelectedPipStyle="{StaticResource HeroCarouselPipButtonStyle}" />

                <Border
                    x:Name="AnimatedSelectedPip"
                    Width="18"
                    Height="6"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="3"
                    IsHitTestVisible="False"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <CompositeTransform />
                    </Border.RenderTransform>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
